{
  "ci": {
    "collect": {
      "url": [
        "https://freshwax.co.uk/",
        "https://freshwax.co.uk/releases/",
        "https://freshwax.co.uk/merch/",
        "https://freshwax.co.uk/dj-mixes/"
      ],
      "numberOfRuns": 3,
      "settings": {}
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.7,
            "aggregationMethod": "median-run"
          }
        ],
        "categories:accessibility": [
          "warn",
          {
            "minScore": 0.9,
            "aggregationMethod": "median-run"
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.85,
            "aggregationMethod": "median-run"
          }
        ],
        "categories:seo": [
          "warn",
          {
            "minScore": 0.9,
            "aggregationMethod": "median-run"
          }
        ],
        "largest-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 4500,
            "aggregationMethod": "median-run"
          }
        ],
        "cumulative-layout-shift": [
          "warn",
          {
            "maxNumericValue": 0.15,
            "aggregationMethod": "median-run"
          }
        ],
        "interactive": [
          "warn",
          {
            "maxNumericValue": 5000,
            "aggregationMethod": "median-run"
          }
        ],
        "interaction-to-next-paint": [
          "warn",
          {
            "maxNumericValue": 200,
            "aggregationMethod": "median-run"
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
