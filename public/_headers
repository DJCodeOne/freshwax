# Cloudflare Pages Security Headers
# https://freshwax.co.uk

# Security headers are managed by src/middleware.ts for HTML and API responses.
# Only static asset headers are defined here to avoid dual CSP policies.
/*
  X-Content-Type-Options: nosniff

# Cache static assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Hashed Astro bundles are safe to cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=86400

/*.css
  Cache-Control: public, max-age=86400

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

# Don't cache HTML or API responses
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/api/*
  Cache-Control: no-cache, no-store, must-revalidate
  X-Robots-Tag: noindex

# Don't cache dynamic pages (prices, ratings change)
/item/*
  Cache-Control: no-cache, no-store, must-revalidate

/releases/*
  Cache-Control: no-cache, no-store, must-revalidate
