# Cloudflare Pages Security Headers
# https://freshwax.co.uk

# Security headers are managed by src/middleware.ts for HTML and API responses.
# Only static asset headers are defined here to avoid dual CSP policies.
/*
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Generic fallbacks (MUST come before specific rules — last match wins in CF Pages)
/*.js
  Cache-Control: public, max-age=86400

/*.css
  Cache-Control: public, max-age=86400

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

# Cache static assets (overrides generic rules above)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Hashed Astro bundles — safe to cache forever (overrides /*.js and /*.css)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: no-cache, must-revalidate, max-age=0

# Versioned public JS (7-day cache, filename-based busting)
/freshwax-cart.js
  Cache-Control: public, max-age=604800
/newsletter-form.js
  Cache-Control: public, max-age=604800
/item-page.js
  Cache-Control: public, max-age=604800
/audio-player-init.js
  Cache-Control: public, max-age=604800

# Don't cache HTML or API responses
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/api/*
  Cache-Control: no-cache, no-store, must-revalidate
  X-Robots-Tag: noindex

# Don't cache dynamic pages (prices, ratings change)
/item/*
  Cache-Control: no-cache, no-store, must-revalidate

/releases/*
  Cache-Control: no-cache, no-store, must-revalidate
