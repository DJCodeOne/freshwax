{
  "name": "freshwax",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:lighthouse": "lhci autorun --config=.github/lighthouse-ci.json",
    "test:lighthouse:prod": "lhci autorun --config=.github/lighthouse-ci-production.json",
    "typecheck": "astro check",
    "validate": "npm run typecheck && npm run build && npm run test",
    "test:ci": "vitest run",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.5",
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@cf-wasm/photon": "^0.3.4",
    "@jsquash/webp": "^1.5.0",
    "@tailwindcss/vite": "^4.1.14",
    "@xmldom/xmldom": "^0.8.11",
    "adm-zip": "^0.5.16",
    "astro": "^5.17.2",
    "resend": "^6.5.2",
    "stripe": "^20.3.1",
    "tailwindcss": "^4.1.18",
    "zod": "^4.0.0"
  },
  "overrides": {
    "fast-xml-parser": ">=5.3.8",
    "undici": ">=7.19.0",
    "wrangler": ">=4.59.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@types/adm-zip": "^0.5.7",
