{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@styles/*": ["src/styles/*"]
    }
  }
  // NOTE: Path aliases (@lib/, @components/, @layouts/, @styles/) are resolved at BUILD TIME
  // by Vite/Rollup. The Cloudflare Workers runtime never sees these aliases — only
  // the final bundled JS. Aliases are safe to use and are preferred for deeply nested
  // files (4+ levels of ../). Shallow files (1-2 levels) may continue using relative
  // imports — both styles coexist without issues.
}
