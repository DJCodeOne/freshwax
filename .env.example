# ===========================================================================
# Fresh Wax - Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
#
# DEPLOYMENT NOTES:
#   - Variables marked [wrangler.toml] go in wrangler.toml [vars] section
#     (non-secret, safe to commit)
#   - Variables marked [CF Secret] must be set via the Cloudflare dashboard
#     (Settings > Environment Variables > Secrets) or `wrangler secret put`
#   - Variables marked [.env only] are used at build time or local dev only
#   - (required) = must be set for the app to function
#   - (optional) = has a sensible default or only needed for specific features
# ===========================================================================


# ===========================================================================
# FIREBASE - Server Side (service account auth via REST API)
# [CF Secret] - These contain credentials and must never be in wrangler.toml
# ===========================================================================

# (required) Firebase project identifier
FIREBASE_PROJECT_ID=your-firebase-project-id

# (required) Firebase Web API key (used for REST API calls)
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# (required) Service account email for server-side JWT auth
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# (required) Service account private key (RS256, PEM format, keep the quotes)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADA...\n-----END PRIVATE KEY-----\n"

# (optional) Full service account JSON (alternative to CLIENT_EMAIL + PRIVATE_KEY)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# (optional) Alias for FIREBASE_SERVICE_ACCOUNT
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}


# ===========================================================================
# FIREBASE - Client Side (PUBLIC_ prefix exposes to browser via Vite)
# [wrangler.toml] - These are public values, safe to commit
# ===========================================================================

# (required) Same as FIREBASE_PROJECT_ID, exposed to client
PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id

# (required) Web API key for client-side Firebase Auth calls
PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# (required) Firebase Auth domain
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# (required) Firebase Storage bucket
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# (required) Firebase Cloud Messaging sender ID
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012

# (required) Firebase web app ID
PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890


# ===========================================================================
# CLOUDFLARE R2 STORAGE (S3-compatible API credentials)
# [CF Secret] for credentials, [wrangler.toml] for bucket names/domains
# ===========================================================================

# (required) [CF Secret] Cloudflare account ID
R2_ACCOUNT_ID=your-cloudflare-account-id

# (required) [CF Secret] R2 API token access key
R2_ACCESS_KEY_ID=your-r2-access-key-id

# (required) [CF Secret] R2 API token secret key
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# (required) [wrangler.toml] Public CDN domain for R2 assets
R2_PUBLIC_DOMAIN=https://cdn.yourdomain.com

# (optional) [wrangler.toml] Alias for R2_PUBLIC_DOMAIN
R2_PUBLIC_URL=https://cdn.yourdomain.com

# (optional) [wrangler.toml] General uploads bucket name
R2_BUCKET=freshwax-uploads

# (required) [wrangler.toml] Bucket name used in S3 API calls
R2_BUCKET_NAME=freshwax-releases

# (optional) [wrangler.toml] Uploads bucket name
R2_UPLOADS_BUCKET=freshwax-uploads

# (required) [wrangler.toml] Releases bucket name (artwork, audio, etc.)
R2_RELEASES_BUCKET=freshwax-releases


# ===========================================================================
# CLOUDFLARE
# [.env only] - Used for local dev / scripts
# ===========================================================================

# (optional) Cloudflare account ID (same as R2_ACCOUNT_ID)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id


# ===========================================================================
# STRIPE PAYMENTS
# [CF Secret] for secret keys, [wrangler.toml] for publishable/price IDs
# ===========================================================================

# (required) [CF Secret] Stripe secret API key
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# (required) [wrangler.toml] Stripe publishable key (exposed to browser)
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX

# (required) [CF Secret] Stripe webhook signing secret (checkout events)
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# (optional) [CF Secret] Stripe Connect webhook signing secret (platform payouts)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# (required) [wrangler.toml] Stripe price ID for Plus annual subscription
STRIPE_PLUS_ANNUAL_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXX

# (optional) [wrangler.toml] Stripe price ID for promo-priced Plus annual subscription
STRIPE_PLUS_ANNUAL_PROMO_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXX


# ===========================================================================
# PAYPAL PAYMENTS
# [CF Secret] for secret, [wrangler.toml] for client ID / mode
# ===========================================================================

# (required) [CF Secret] PayPal app client ID (also used server-side for API calls)
PAYPAL_CLIENT_ID=your-paypal-client-id

# (required) [CF Secret] PayPal app secret
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# (optional) [CF Secret] Alias for PAYPAL_CLIENT_SECRET
PAYPAL_SECRET=your-paypal-secret

# (required) [wrangler.toml] PayPal environment: "sandbox" or "live"
PAYPAL_MODE=sandbox

# (optional) [wrangler.toml] "true" to use sandbox endpoints
PAYPAL_SANDBOX=true

# (required) [wrangler.toml] PayPal client ID exposed to browser for JS SDK
PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id


# ===========================================================================
# PUSHER (Real-time chat, DJ lobby, live notifications)
# [CF Secret] for secret, [wrangler.toml] for public keys
# ===========================================================================

# (required) [CF Secret] Pusher application ID
PUSHER_APP_ID=123456

# (required) [CF Secret] Pusher secret key (server-side event triggers)
PUSHER_SECRET=your-pusher-secret

# (required) [wrangler.toml] Pusher key (also used server-side, aliased from PUBLIC_)
PUSHER_KEY=your-pusher-key

# (required) [wrangler.toml] Pusher cluster region
PUSHER_CLUSTER=eu

# (required) [wrangler.toml] Pusher key exposed to browser
PUBLIC_PUSHER_KEY=your-pusher-key

# (required) [wrangler.toml] Pusher cluster exposed to browser (default: eu)
PUBLIC_PUSHER_CLUSTER=eu


# ===========================================================================
# EMAIL (Resend)
# [CF Secret] for API key, [wrangler.toml] for addresses
# ===========================================================================

# (required) [CF Secret] Resend API key for transactional emails
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# (required) [wrangler.toml] Admin notification email address
ADMIN_EMAIL=admin@yourdomain.com

# (optional) [wrangler.toml] Vinyl stockist notification email
VINYL_STOCKIST_EMAIL=vinyl@yourdomain.com


# ===========================================================================
# GIF / MEDIA APIs
# [wrangler.toml] - These are public API keys
# ===========================================================================

# (required) [wrangler.toml] Giphy API key (server-side, also used as fallback)
GIPHY_API_KEY=your-giphy-api-key

# (required) [wrangler.toml] Giphy API key exposed to browser (chat GIF picker)
PUBLIC_GIPHY_API_KEY=your-giphy-api-key

# (optional) [wrangler.toml] Tenor API key exposed to browser (alternative GIF source)
PUBLIC_TENOR_API_KEY=your-tenor-api-key

# (optional) [CF Secret] YouTube Data API key (for live stream ID lookup, video durations)
YOUTUBE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ===========================================================================
# reCAPTCHA v3
# [wrangler.toml] for site key (public)
# ===========================================================================

# (required) [wrangler.toml] reCAPTCHA v3 site key (exposed to browser)
PUBLIC_RECAPTCHA_SITE_KEY=6LeXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ===========================================================================
# ADMIN & SECURITY
# [CF Secret] - All of these are sensitive
# ===========================================================================

# (required) [CF Secret] Secret key for admin API auth (generate 32+ char random string)
ADMIN_KEY=your-secure-admin-key-min-32-chars

# (required) [CF Secret] Comma-separated Firebase UIDs with admin access
ADMIN_UIDS=uid1,uid2

# (required) [CF Secret] Comma-separated email addresses with admin access
ADMIN_EMAILS=admin@yourdomain.com,dev@yourdomain.com

# (required) [CF Secret] Secret for authenticating cron job requests
CRON_SECRET=your-cron-secret-min-32-chars

# (required) [CF Secret] System key for gift card generation endpoint
GIFTCARD_SYSTEM_KEY=your-giftcard-system-key


# ===========================================================================
# LIVESTREAM (Red5 Pro / Streaming Server)
# [CF Secret] for secrets, [wrangler.toml] for URLs
# ===========================================================================

# (optional) [wrangler.toml] Red5 RTMP ingest URL
RED5_RTMP_URL=rtmp://rtmp.yourdomain.com/live

# (optional) [wrangler.toml] Red5 HLS playback base URL
RED5_HLS_URL=https://stream.yourdomain.com/live

# (optional) [CF Secret] Secret for signing stream keys
RED5_SIGNING_SECRET=your-red5-signing-secret

# (optional) [CF Secret] Secret for Red5 webhook verification
RED5_WEBHOOK_SECRET=your-red5-webhook-secret

# (optional) [wrangler.toml] WHIP ingest base URL for browser streaming
WHIP_BASE_URL=https://stream.yourdomain.com


# ===========================================================================
# PLAYLIST SERVER
# [CF Secret]
# ===========================================================================

# (optional) [CF Secret] Access token for external playlist server API
PLAYLIST_ACCESS_TOKEN=your-playlist-access-token


# ===========================================================================
# AUDIO PROCESSING
# [wrangler.toml] or [.env only]
# ===========================================================================

# (optional) [wrangler.toml] URL of the audio processor service (track waveforms, etc.)
AUDIO_PROCESSOR_URL=http://localhost:8089


# ===========================================================================
# VINYL API
# [wrangler.toml]
# ===========================================================================

# (optional) [wrangler.toml] External vinyl pressing API URL
PUBLIC_VINYL_API_URL=https://vinyl-api.example.workers.dev


# ===========================================================================
# CLOUDFLARE BINDINGS (configured in wrangler.toml, not in .env)
# ===========================================================================
# These are NOT environment variables - they are Cloudflare resource bindings
# defined in wrangler.toml. Listed here for reference only.
#
#   DB        = D1 database binding (binding name in wrangler.toml)
#   CACHE     = KV namespace binding (general cache)
#   SESSION   = KV namespace binding (Astro session driver)
#   R2        = R2 bucket binding (used in API routes)
#
# See wrangler.toml for database_id, KV namespace IDs, and bucket names.
# Cron triggers are configured via Cloudflare Pages dashboard (wrangler.toml [triggers] is not supported for Pages projects).
