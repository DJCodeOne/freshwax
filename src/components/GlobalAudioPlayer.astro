---
interface Props {
  nonce?: string;
}
const { nonce = '' } = Astro.props;
---
<!-- src/components/GlobalAudioPlayer.astro -->
<!-- Persistent audio player for DJ MIXES and SHUFFLE mode -->
<!-- Features: Spectrum analyser LEDs, shuffle mode, DJ mix mode -->

<div id="global-audio-container" transition:persist="global-audio">
  <audio id="global-audio" preload="auto" crossorigin="anonymous"></audio>
</div>

<!-- Mini Player (sticky bottom) -->
<div
  id="mini-player"
  class="fixed bottom-0 left-0 right-0 z-[99999] translate-y-full transition-[translate] duration-300 ease-out"
  transition:persist="mini-player"
  role="region"
  aria-label="Audio player"
>
  <div class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 border-t-2 border-red-600 shadow-2xl backdrop-blur-sm">
    <!-- Progress bar (clickable + draggable) -->
    <div id="mini-progress-container" class="h-2 bg-gray-700 cursor-pointer group relative overflow-visible hover:h-3 transition-[height] duration-150" role="slider" aria-label="Seek position" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
      <div class="absolute inset-0 bg-gradient-to-r from-red-600/20 to-red-500/20 animate-pulse"></div>
      <div id="mini-progress-bar" class="h-full bg-gradient-to-r from-red-600 via-red-500 to-red-600 relative z-10 shadow-lg shadow-red-500/50 pointer-events-none" style="width: 0%">
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent animate-shimmer"></div>
        <!-- Draggable seek handle -->
        <div id="mini-progress-handle" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 w-4 h-4 bg-red-500 rounded-full shadow-lg shadow-red-500/70 cursor-grab active:cursor-grabbing opacity-0 group-hover:opacity-100 transition-opacity duration-150 pointer-events-auto hover:scale-125 hover:bg-red-400">
          <div class="absolute inset-1 bg-white rounded-full opacity-30"></div>
        </div>
      </div>
    </div>
    
    <div class="mini-player-inner">
      <div class="mini-player-row">

        <!-- LEFT: Info section -->
        <div class="mini-player-left">
          <!-- Spectrum Analyser (desktop only) -->
          <div id="spectrum-left" class="hidden lg:flex items-end gap-[2px] h-8 flex-shrink-0">
            <div class="spectrum-bar" style="--bar-index: 0;"></div>
            <div class="spectrum-bar" style="--bar-index: 1;"></div>
            <div class="spectrum-bar" style="--bar-index: 2;"></div>
            <div class="spectrum-bar" style="--bar-index: 3;"></div>
            <div class="spectrum-bar" style="--bar-index: 4;"></div>
            <div class="spectrum-bar" style="--bar-index: 5;"></div>
            <div class="spectrum-bar" style="--bar-index: 6;"></div>
            <div class="spectrum-bar" style="--bar-index: 7;"></div>
          </div>

          <!-- Artwork (desktop only) -->
          <a id="mini-artwork-link" href="javascript:void(0)" class="mini-artwork-wrap" role="link" aria-label="View release details">
            <div class="absolute inset-0 bg-red-600 blur-xl opacity-0 group-hover:opacity-50 transition-opacity duration-300"></div>
            <img
              id="mini-artwork"
              src="/place-holder.webp"
              alt="Now Playing"
              width="48"
              height="48"
              loading="lazy"
              decoding="async"
              class="w-12 h-12 border-2 border-white shadow-lg object-cover relative z-10"
            />
          </a>

          <!-- Track Info -->
          <a id="mini-info-link" href="javascript:void(0)" class="mini-track-info" role="link">
            <p id="mini-title" class="text-white font-black text-xs uppercase truncate">No track loaded</p>
            <p id="mini-dj" class="text-gray-300 font-bold text-[10px] uppercase truncate">--</p>
          </a>
        </div>
        <!-- ARIA live region -->
        <div id="mini-player-live" aria-live="polite" aria-atomic="true" class="sr-only" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;"></div>

        <!-- CENTER: Volume, transport, shuffle, duration -->
        <div class="mini-player-center">
          <!-- Volume (desktop only) -->
          <div class="mini-btn-desktop flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M9.383 3.076A1 1 0 0110 4v12a1 1 0 01-1.707.707L4.586 13H2a1 1 0 01-1-1V8a1 1 0 011-1h2.586l3.707-3.707a1 1 0 011.09-.217zM12.293 7.293a1 1 0 011.414 0 3 3 0 010 4.242 1 1 0 11-1.414-1.414 1 1 0 000-1.414 1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
            <input type="range" id="mini-volume" min="0" max="100" value="70" class="w-16 h-1 bg-gray-600 rounded-full appearance-none cursor-pointer mini-volume-slider" aria-label="Volume" />
          </div>

          <!-- Skip Back -->
          <button id="mini-skip-back" class="mini-ctrl-btn" title="Back 10s / Previous" aria-label="Skip back 10 seconds">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12.066 11.2a1 1 0 000 1.6l5.334 4A1 1 0 0019 16V8a1 1 0 00-1.6-.8l-5.333 4zM4.066 11.2a1 1 0 000 1.6l5.334 4A1 1 0 0011 16V8a1 1 0 00-1.6-.8l-5.334 4z"/>
            </svg>
          </button>

          <!-- Play Button -->
          <button id="mini-play-btn" class="mini-play-btn" aria-label="Play or pause" aria-pressed="false">
            <div class="absolute inset-0 rounded-full bg-gradient-to-br from-white/20 to-transparent"></div>
            <svg id="mini-play-icon" class="relative z-10" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <svg id="mini-pause-icon" class="relative z-10 hidden" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
            </svg>
          </button>

          <!-- Skip Forward -->
          <button id="mini-skip-forward" class="mini-ctrl-btn" title="Forward 10s / Next" aria-label="Skip forward 10 seconds">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.933 12.8a1 1 0 000-1.6L6.6 7.2A1 1 0 005 8v8a1 1 0 001.6.8l5.333-4zM19.933 12.8a1 1 0 000-1.6l-5.333-4A1 1 0 0013 8v8a1 1 0 001.6.8l5.333-4z"/>
            </svg>
          </button>

          <!-- Shuffle (desktop only) -->
          <button id="mini-shuffle-btn" class="mini-shuffle-btn mini-btn-desktop" title="Shuffle Play" aria-label="Shuffle play">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41l-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"/>
            </svg>
          </button>

          <!-- Mode indicator (desktop only) -->
          <span id="mini-mode-indicator" class="mini-btn-desktop text-[10px] uppercase tracking-wider text-gray-300 bg-black/30 px-2 py-1 rounded"></span>

          <!-- Duration (desktop only) -->
          <div class="mini-btn-desktop flex items-center gap-1 text-xs text-gray-300 font-mono bg-black/30 px-2 py-1 rounded">
            <span id="mini-current-time" class="text-red-500 font-bold">0:00</span>
            <span class="text-gray-400">/</span>
            <span id="mini-duration">0:00</span>
          </div>
        </div>

        <!-- RIGHT: Spectrum, close -->
        <div class="mini-player-right">
          <!-- Spectrum Analyser (desktop only) -->
          <div id="spectrum-right" class="hidden lg:flex items-end gap-[2px] h-8 flex-shrink-0">
            <div class="spectrum-bar" style="--bar-index: 7;"></div>
            <div class="spectrum-bar" style="--bar-index: 6;"></div>
            <div class="spectrum-bar" style="--bar-index: 5;"></div>
            <div class="spectrum-bar" style="--bar-index: 4;"></div>
            <div class="spectrum-bar" style="--bar-index: 3;"></div>
            <div class="spectrum-bar" style="--bar-index: 2;"></div>
            <div class="spectrum-bar" style="--bar-index: 1;"></div>
            <div class="spectrum-bar" style="--bar-index: 0;"></div>
          </div>

          <!-- Close button -->
          <button id="mini-close" class="mini-close-btn" title="Close player" aria-label="Close player">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Spectrum analyser bars */
  .spectrum-bar {
    width: 4px;
    min-height: 4px;
    height: 4px;
    background: linear-gradient(to top, #22c55e 0%, #22c55e 40%, #eab308 40%, #eab308 70%, #dc2626 70%, #dc2626 100%);
    border-radius: 1px;
    transition: height 0.05s ease-out;
    box-shadow: 0 0 4px rgba(34, 197, 94, 0.3);
  }
  
  .spectrum-bar.active {
    box-shadow: 0 0 8px rgba(34, 197, 94, 0.5), 0 0 12px rgba(234, 179, 8, 0.3);
  }
  
  /* Idle animation when not playing */
  #mini-player:not(.playing) .spectrum-bar {
    animation: idle-pulse 2s ease-in-out infinite;
    animation-delay: calc(var(--bar-index) * 0.1s);
  }
  
  @keyframes idle-pulse {
    0%, 100% { height: 4px; opacity: 0.3; }
    50% { height: 8px; opacity: 0.5; }
  }
  
  /* When playing, bars are controlled by JS */
  #mini-player.playing .spectrum-bar {
    animation: none;
    opacity: 1;
  }

  .mini-volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #dc2626;
    cursor: pointer;
    box-shadow: 0 0 10px rgba(220, 38, 38, 0.5);
  }
  
  .mini-volume-slider::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #dc2626;
    cursor: pointer;
    border: none;
  }
  
  /* Shuffle button styles */
  .mini-shuffle-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid transparent;
    transition: background-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }
  
  .mini-shuffle-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }
  
  .mini-shuffle-btn.active {
    color: #dc2626 !important;
    background: rgba(220, 38, 38, 0.15);
    border-color: rgba(220, 38, 38, 0.4);
    box-shadow: 0 0 15px rgba(220, 38, 38, 0.3);
  }
  
  .mini-shuffle-btn.loading {
    opacity: 0.5;
    pointer-events: none;
    animation: pulse 1s infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 0.8; }
  }
  
  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  
  .animate-shimmer {
    animation: shimmer 2s infinite;
  }
  
  #mini-player.visible {
    translate: 0;
  }

  /* Mini player layout — 3-column grid for centered play button */
  .mini-player-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0.375rem 0.5rem;
  }

  .mini-player-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 6px;
  }

  .mini-player-left {
    display: flex;
    align-items: center;
    gap: 4px;
    min-width: 0;
    justify-content: flex-start;
  }

  .mini-player-center {
    display: flex;
    align-items: center;
    gap: 2px;
    justify-content: center;
  }

  .mini-player-right {
    display: flex;
    align-items: center;
    gap: 4px;
    justify-content: flex-end;
    min-width: 0;
  }

  .mini-track-info {
    flex: 1 1 0%;
    min-width: 0;
    overflow: hidden;
  }

  .mini-artwork-wrap {
    display: none;
    flex-shrink: 0;
    position: relative;
  }

  .mini-ctrl-btn {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #d1d5db;
    background: none;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    padding: 0;
  }

  .mini-ctrl-btn svg {
    width: 16px;
    height: 16px;
  }

  .mini-ctrl-btn:hover {
    color: white;
  }

  .mini-play-btn {
    position: relative;
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to bottom right, #dc2626, #b91c1c);
    border: none;
    border-radius: 50%;
    color: white;
    cursor: pointer;
    box-shadow: 0 4px 6px -1px rgba(220, 38, 38, 0.5);
    padding: 0;
  }

  .mini-play-btn svg {
    width: 20px;
    height: 20px;
  }

  .mini-play-btn:active {
    transform: scale(0.95);
  }

  .mini-close-btn {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    border-radius: 50%;
    color: white;
    cursor: pointer;
    padding: 0;
  }

  .mini-close-btn svg {
    width: 14px;
    height: 14px;
  }

  .mini-close-btn:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  .mini-btn-desktop {
    display: none !important;
  }

  @media (min-width: 640px) {
    .mini-player-inner {
      padding: 0.5rem 0.75rem;
    }

    .mini-player-row {
      gap: 8px;
    }

    .mini-player-left {
      gap: 8px;
    }

    .mini-player-center {
      gap: 4px;
    }

    .mini-player-right {
      gap: 8px;
    }

    .mini-artwork-wrap {
      display: block;
    }

    .mini-track-info {
      flex: 0 0 160px;
    }

    .mini-ctrl-btn {
      width: 38px;
      height: 38px;
      padding: 8px;
    }

    .mini-ctrl-btn svg {
      width: 20px;
      height: 20px;
    }

    .mini-play-btn {
      width: 48px;
      height: 48px;
      padding: 12px;
    }

    .mini-play-btn svg {
      width: 22px;
      height: 22px;
    }

    .mini-close-btn {
      width: 36px;
      height: 36px;
    }

    .mini-close-btn svg {
      width: 18px;
      height: 18px;
    }

    .mini-btn-desktop {
      display: none !important;
    }

    .mini-btn-desktop.has-mode {
      display: inline-block !important;
    }

    .mini-btn-desktop.flex {
      display: flex !important;
    }
  }

  /* Desktop: mini-player at absolute bottom */
  #mini-player {
    bottom: 0 !important;
    margin-bottom: 0 !important;
    padding-bottom: env(safe-area-inset-bottom, 0);
  }

  /* Mobile: mini-player sits above the bottom nav bar when visible */
  @media (max-width: 1023px) {
    #mini-player {
      bottom: 56px !important;
      padding-bottom: 0;
      /* Override translate-y-full so hidden state pushes fully off-screen
         (translate-y-full only moves by its own height, but bottom:56px
         means it still peeks above the nav) */
      translate: 0 calc(100% + 56px);
    }
    #mini-player.visible {
      translate: 0 0;
    }
  }

  /* Progress bar handle - always visible when playing */
  #mini-player.playing #mini-progress-handle {
    opacity: 0.7;
  }

  #mini-player.playing #mini-progress-container:hover #mini-progress-handle,
  #mini-progress-container:active #mini-progress-handle {
    opacity: 1;
    transform: translate(50%, -50%) scale(1.2);
  }

  /* Smoother progress bar transition when not dragging */
  #mini-progress-bar {
    transition: width 0.1s linear;
  }

  /* Disable transition during drag for instant feedback */
  #mini-progress-bar.dragging {
    transition: none;
  }
</style>

<script is:inline src="/audio-player-init.js" defer nonce={nonce}></script>