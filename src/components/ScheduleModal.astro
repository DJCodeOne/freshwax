---
// src/components/ScheduleModal.astro
// Modal wrapper for public and booking schedule views
// Opens as overlay modal on the live page

import DailySchedule from './DailySchedule.astro';
---

<!-- Public Schedule Modal (Read-only) -->
<div id="publicScheduleModal" class="schedule-modal-wrapper hidden" role="dialog" aria-modal="true" aria-labelledby="publicScheduleTitle" data-has-focus-trap="true">
  <div class="schedule-modal-overlay"></div>
  <div class="schedule-modal-container">
    <div class="schedule-modal-header">
      <h2 id="publicScheduleTitle">📅 Full Schedule</h2>
      <p class="modal-subtitle">Fresh Wax Live - DJ Streaming Schedule</p>
      <button type="button" class="schedule-modal-close" id="closePublicSchedule" aria-label="Close">×</button>
    </div>
    <div class="schedule-modal-body">
      <DailySchedule mode="public" id="publicSchedule" />
    </div>
  </div>
</div>

<!-- Booking Schedule Modal (DJ Selection) -->
<div id="bookingScheduleModal" class="schedule-modal-wrapper hidden" role="dialog" aria-modal="true" aria-labelledby="bookingScheduleTitle" data-has-focus-trap="true">
  <div class="schedule-modal-overlay"></div>
  <div class="schedule-modal-container booking-mode">
    <div class="schedule-modal-header">
      <h2 id="bookingScheduleTitle">Book Your Live Stream Slot</h2>
      <p class="modal-subtitle">Click on available slots to select your time. You can book up to 2 hours per day.</p>
      <button type="button" class="schedule-modal-close" id="closeBookingSchedule" aria-label="Close">×</button>
    </div>
    <div class="schedule-modal-body">
      <DailySchedule mode="booking" id="bookingSchedule" />
    </div>
  </div>
</div>

<style>
  .schedule-modal-wrapper {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .schedule-modal-wrapper.hidden {
    display: none;
  }

  .schedule-modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
  }

  .schedule-modal-container {
    position: relative;
    background: var(--bg-secondary, #fff);
    border-radius: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: none;
    overflow: hidden;
  }

  .schedule-modal-header {
    position: relative;
    padding: 1.5rem 1.5rem 1.25rem;
    background: linear-gradient(135deg, #000 0%, #1a1a1a 100%);
    color: #fff;
    text-align: center;
  }

  .schedule-modal-header h2 {
    margin: 0 0 0.5rem;
    font-family: 'Inter', sans-serif; font-weight: 700;
    font-size: 2rem;
    letter-spacing: 0.05em;
  }

  .modal-subtitle {
    margin: 0;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.4;
  }

  .schedule-modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    color: #fff;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    font-size: 1.5rem;
    cursor: pointer;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .schedule-modal-close:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .schedule-modal-body {
    flex: 1;
    overflow: auto;
    /* Keep the scroll inside the modal — don't chain to the page behind it. */
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  /* Remove duplicate border/radius since modal provides it */
  .schedule-modal-body :global(.daily-schedule) {
    border: none;
    border-radius: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* Booking mode styling */
  .booking-mode .schedule-modal-header {
    background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
  }

  @media (max-width: 768px) {
    .schedule-modal-wrapper {
      padding: 0;
    }

    .schedule-modal-container {
      max-width: none;
      max-height: none;
      height: 100%;
      border-radius: 0;
    }

    .schedule-modal-header h2 {
      font-size: 1.5rem;
    }

    /* On mobile the inner grid-wrapper stops being its own scroll area
       (overflow-y:visible, columns stacked), so the modal body must scroll. But
       the :global(.daily-schedule) flex:1 stretches it to exactly the body
       height, leaving nothing to overflow. Let it take its natural (tall)
       content height so .schedule-modal-body actually scrolls it. */
    .schedule-modal-body :global(.daily-schedule) {
      flex: 0 0 auto;
      height: auto;
    }
  }

  /* ---- Darkside theme: match the /live page styling ---- */
  .schedule-modal-container {
    background: linear-gradient(180deg, #331515 0%, #221010 50%, #180a0a 100%);
  }

  /* Subtle red vignette like the live page */
  .schedule-modal-container::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse at 50% 0%, rgba(220, 38, 38, 0.12) 0%, transparent 60%);
    z-index: 0;
  }
  .schedule-modal-header,
  .schedule-modal-body { position: relative; z-index: 1; }

  .schedule-modal-header {
    background: linear-gradient(135deg, #1a0808 0%, #2a0f0f 100%);
    border-bottom: 2px solid #dc2626;
  }

  .schedule-modal-body :global(.daily-schedule) {
    background: transparent;
  }

  .schedule-modal-body :global(.schedule-header) {
    background: linear-gradient(135deg, #1a0808 0%, #2a0f0f 100%);
    border: 1px solid #dc2626;
    border-radius: 8px;
  }

  .schedule-modal-body :global(.schedule-legend) {
    background: rgba(30, 14, 14, 0.55);
    border-bottom: 1px solid #dc2626;
  }
  .schedule-modal-body :global(.legend-item) { color: #e7c9c9; }

  .schedule-modal-body :global(.schedule-grid-wrapper) {
    background: transparent;
  }

  .schedule-modal-body :global(.schedule-column) {
    background: linear-gradient(180deg, #1f0f0f 0%, #190b0b 100%);
    border: 1px solid #dc2626;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.45);
  }

  .schedule-modal-body :global(.column-header) {
    background: linear-gradient(135deg, #2a1010 0%, #3a1414 100%);
    border-bottom: 2px solid #dc2626;
  }

  .schedule-modal-body :global(.schedule-grid .time-label) {
    background: rgba(40, 18, 18, 0.7);
    color: #e7c9c9;
    border-bottom: 1px solid rgba(220, 38, 38, 0.25);
  }
  .schedule-modal-body :global(.schedule-grid .time-label.past) {
    background: rgba(25, 12, 12, 0.6);
    color: #7a5b5b;
  }
  .schedule-modal-body :global(.schedule-grid .time-label.current) { color: #34d399; }

  .schedule-modal-body :global(.schedule-grid .slot-cell) {
    border-bottom: 1px solid rgba(220, 38, 38, 0.2);
  }
  .schedule-modal-body :global(.schedule-grid .slot-cell.past) {
    background: rgba(20, 10, 10, 0.5);
  }
  .schedule-modal-body :global(.schedule-grid .slot-cell.current-hour) {
    background: rgba(16, 185, 129, 0.12);
  }

  .schedule-modal-body :global(.slot-block.past-slot) {
    background: rgba(30, 15, 15, 0.4);
  }
  .schedule-modal-body :global(.slot-block.past-slot .past-text) { color: #6b4f4f; }

  /* Available cells in booking mode: red-dashed to fit the theme */
  .schedule-modal-body :global(.mode-booking .slot-cell.available::after) {
    color: #f87171;
    border-color: rgba(248, 113, 113, 0.35);
    background: rgba(220, 38, 38, 0.06);
  }
</style>

<script>
  // Schedule Modal Controllers
  (function() {
    const publicModal = document.getElementById('publicScheduleModal');
    const bookingModal = document.getElementById('bookingScheduleModal');
    if (!publicModal && !bookingModal) return;

    // Abort previous listeners to prevent leak on View Transition re-runs
    if (window._scheduleModalAC) window._scheduleModalAC.abort();
    const ac = new AbortController();
    const sig = { signal: ac.signal };
    window._scheduleModalAC = ac;

    // Track trigger elements for focus restoration
    let publicTrigger: HTMLElement | null = null;
    let bookingTrigger: HTMLElement | null = null;

    // Focus trap helper: cycle Tab/Shift+Tab within a modal
    function trapFocus(modal: HTMLElement, e: KeyboardEvent) {
      if (e.key !== 'Tab') return;
      const focusableEls = modal.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
      );
      if (focusableEls.length === 0) return;
      const firstEl = focusableEls[0];
      const lastEl = focusableEls[focusableEls.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === firstEl) {
          e.preventDefault();
          lastEl.focus();
        }
      } else {
        if (document.activeElement === lastEl) {
          e.preventDefault();
          firstEl.focus();
        }
      }
    }

    // Body scroll lock — the modals are position:fixed, but on mobile the live
    // page body scrolls (so the user can reach tab content), which means a
    // touch-scroll inside the modal chains through to the page behind it. Pin
    // the body while a modal is open (the position:fixed technique works on iOS,
    // where overflow:hidden alone does not) and restore the scroll on close.
    let savedScrollY = 0;
    let scrollLocked = false;
    function lockBodyScroll() {
      if (scrollLocked) return;
      scrollLocked = true;
      savedScrollY = window.scrollY || window.pageYOffset || 0;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${savedScrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.width = '100%';
    }
    function unlockBodyScroll() {
      if (!scrollLocked) return;
      scrollLocked = false;
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.width = '';
      window.scrollTo(0, savedScrollY);
    }

    // Close a modal and restore focus to its trigger
    function closePublic() {
      publicModal?.classList.add('hidden');
      unlockBodyScroll();
      if (publicTrigger && typeof publicTrigger.focus === 'function') {
        publicTrigger.focus();
        publicTrigger = null;
      }
    }

    function closeBooking() {
      bookingModal?.classList.add('hidden');
      unlockBodyScroll();
      if (bookingTrigger && typeof bookingTrigger.focus === 'function') {
        bookingTrigger.focus();
        bookingTrigger = null;
      }
    }

    // Open Public Schedule
    window.openPublicSchedule = function() {
      publicTrigger = document.activeElement as HTMLElement;
      publicModal?.classList.remove('hidden');
      lockBodyScroll();
      window.schedule_publicSchedule?.refresh();
      // Move focus into the modal
      const closeBtn = document.getElementById('closePublicSchedule');
      if (closeBtn) closeBtn.focus();
    };

    // Open Booking Schedule
    window.openBookingSchedule = function(userId: string, displayName: string, avatar?: string | null) {
      if (!userId) {
        console.error('[ScheduleModal] No userId provided!');
        alert('You must be logged in to book a slot.');
        return;
      }

      // Set user info on the schedule component
      if (window.schedule_bookingSchedule) {
        window.schedule_bookingSchedule.setUser(userId, displayName, avatar || null);
      } else {
        console.error('[ScheduleModal] schedule_bookingSchedule not found!');
      }

      bookingTrigger = document.activeElement as HTMLElement;
      bookingModal?.classList.remove('hidden');
      lockBodyScroll();
      window.schedule_bookingSchedule?.refresh();
      // Move focus into the modal
      const closeBtn = document.getElementById('closeBookingSchedule');
      if (closeBtn) closeBtn.focus();
    };

    // Close function for booking schedule (called from DailySchedule)
    window.closeScheduleModal = function() {
      closePublic();
      closeBooking();
    };

    // Close handlers
    document.getElementById('closePublicSchedule')?.addEventListener('click', closePublic, sig);

    document.getElementById('closeBookingSchedule')?.addEventListener('click', closeBooking, sig);

    publicModal?.querySelector('.schedule-modal-overlay')?.addEventListener('click', closePublic, sig);

    bookingModal?.querySelector('.schedule-modal-overlay')?.addEventListener('click', closeBooking, sig);

    // Focus trap for public schedule modal
    publicModal?.addEventListener('keydown', (e: KeyboardEvent) => {
      trapFocus(publicModal!, e);
    }, sig);

    // Focus trap for booking schedule modal
    bookingModal?.addEventListener('keydown', (e: KeyboardEvent) => {
      trapFocus(bookingModal!, e);
    }, sig);

    // Keyboard close (Escape)
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        if (publicModal && !publicModal.classList.contains('hidden')) closePublic();
        if (bookingModal && !bookingModal.classList.contains('hidden')) closeBooking();
      }
    }, sig);
  })();
</script>
