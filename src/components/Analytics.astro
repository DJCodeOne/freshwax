---
// src/components/Analytics.astro
// Google Analytics 4 + additional tracking for Fresh Wax
// Consent-gated: GA4 only loads after user accepts cookies (UK GDPR/PECR)

interface Props {
  // Your Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
  ga4Id?: string;
  // Optional Google Tag Manager ID (format: GTM-XXXXXXX)
  gtmId?: string;
  // Enable enhanced e-commerce tracking
  ecommerce?: boolean;
  // Enable debug mode (for development)
  debug?: boolean;
  // CSP nonce
  nonce?: string;
}

const {
  ga4Id = '',
  gtmId = '',
  ecommerce = true,
  debug = import.meta.env.DEV,
  nonce = ''
} = Astro.props;

const shouldRender = !!ga4Id && (import.meta.env.PROD || debug);
---

{shouldRender && (
  <>
    <!-- GA4 consent-gated loader -->
    <script define:vars={{ ga4Id, ecommerce, debug, gtmId }} nonce={nonce}>
      // Module-scope handler refs so we can remove listeners on View Transitions
      var _clickHandler = null;
      var _scrollHandler = null;
      var _timeOnPageInterval = null;
      var _beforeSwapHandler = null;
      var _pageLoadHandler = null;

      // Only initialize analytics if user has consented
      function initAnalytics() {
        if (window._analyticsInitialized) return;
        window._analyticsInitialized = true;

        // Load gtag.js
        const script = document.createElement('script');
        script.async = true;
        script.crossOrigin = 'anonymous';
        script.src = `https://www.googletagmanager.com/gtag/js?id=${ga4Id}`;
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());

        // Base configuration with privacy settings
        gtag('config', ga4Id, {
          'anonymize_ip': true,
          'cookie_flags': 'SameSite=Lax;Secure',
          'send_page_view': true,
          'enhanced_measurement': true,
          'debug_mode': debug
        });

        // Enhanced E-commerce setup
        if (ecommerce) {
          gtag('set', 'linker', {
            'domains': ['freshwax.co.uk']
          });
        }

        // Load GTM if configured
        if (gtmId) {
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer',gtmId);
        }

        // Setup tracking helpers
        setupTrackingHelpers();

      }

      function setupTrackingHelpers() {
        window.trackEvent = function(eventName, parameters = {}) {
          if (typeof window.gtag === 'function') {
            window.gtag('event', eventName, parameters);
          }
        };

        window.trackAudioPlay = function(mixId, mixTitle, djName, duration) {
          window.trackEvent('audio_play', {
            'event_category': 'DJ Mix',
            'event_label': mixTitle,
            'mix_id': mixId,
            'dj_name': djName,
            'duration': duration,
            'content_type': 'dj_mix'
          });
        };

        window.trackAudioComplete = function(mixId, mixTitle, djName) {
          window.trackEvent('audio_complete', {
            'event_category': 'DJ Mix',
            'event_label': mixTitle,
            'mix_id': mixId,
            'dj_name': djName
          });
        };

        window.trackPreviewPlay = function(releaseId, releaseTitle, artist, trackName) {
          window.trackEvent('preview_play', {
            'event_category': 'Release Preview',
            'event_label': releaseTitle,
            'release_id': releaseId,
            'artist': artist,
            'track_name': trackName
          });
        };

        window.trackAddToCart = function(itemId, itemName, price, itemType, quantity = 1) {
          window.trackEvent('add_to_cart', {
            'currency': 'GBP',
            'value': price * quantity,
            'items': [{
              'item_id': itemId,
              'item_name': itemName,
              'price': price,
              'quantity': quantity,
              'item_category': itemType
            }]
          });
        };

        window.trackRemoveFromCart = function(itemId, itemName, price, quantity = 1) {
          window.trackEvent('remove_from_cart', {
            'currency': 'GBP',
            'value': price * quantity,
            'items': [{
              'item_id': itemId,
              'item_name': itemName,
              'price': price,
              'quantity': quantity
            }]
          });
        };

        window.trackViewItem = function(itemId, itemName, price, itemType, artist = null) {
          window.trackEvent('view_item', {
            'currency': 'GBP',
            'value': price,
            'items': [{
              'item_id': itemId,
              'item_name': itemName,
              'price': price,
              'item_category': itemType,
              'item_brand': artist || 'Fresh Wax'
            }]
          });
        };

        window.trackBeginCheckout = function(cartItems, totalValue) {
          window.trackEvent('begin_checkout', {
            'currency': 'GBP',
            'value': totalValue,
            'items': cartItems.map(item => ({
              'item_id': item.id,
              'item_name': item.name,
              'price': item.price,
              'quantity': item.quantity
            }))
          });
        };

        window.trackPurchase = function(orderId, totalValue, items, shipping = 0) {
          window.trackEvent('purchase', {
            'transaction_id': orderId,
            'currency': 'GBP',
            'value': totalValue,
            'shipping': shipping,
            'items': items.map(item => ({
              'item_id': item.id,
              'item_name': item.name,
              'price': item.price,
              'quantity': item.quantity
            }))
          });
        };

        window.trackLiveStreamJoin = function(streamId, djName) {
          window.trackEvent('live_stream_join', {
            'event_category': 'Live Stream',
            'event_label': djName,
            'stream_id': streamId
          });
        };

        window.trackLiveStreamChat = function(streamId) {
          window.trackEvent('live_stream_chat', {
            'event_category': 'Live Stream',
            'stream_id': streamId
          });
        };

        window.trackNewsletterSignup = function(location) {
          window.trackEvent('newsletter_signup', {
            'event_category': 'Engagement',
            'event_label': location
          });
        };

        window.trackSearch = function(searchTerm, resultsCount) {
          window.trackEvent('search', {
            'search_term': searchTerm,
            'results_count': resultsCount
          });
        };

        window.trackFilter = function(filterType, filterValue) {
          window.trackEvent('filter_use', {
            'event_category': 'Navigation',
            'filter_type': filterType,
            'filter_value': filterValue
          });
        };

        window.trackDownload = function(releaseId, releaseTitle, format) {
          window.trackEvent('download', {
            'event_category': 'Downloads',
            'event_label': releaseTitle,
            'release_id': releaseId,
            'format': format
          });
        };

        // Track external link clicks (remove old handler first to prevent leaks on View Transitions)
        if (_clickHandler) document.removeEventListener('click', _clickHandler);
        _clickHandler = function(e) {
          const link = e.target.closest('a');
          if (link && link.href && !link.href.includes('freshwax.co.uk')) {
            window.trackEvent('outbound_click', {
              'event_category': 'Outbound Links',
              'event_label': link.href
            });
          }
        };
        document.addEventListener('click', _clickHandler);

        // Track scroll depth (throttled with requestAnimationFrame)
        var scrollDepthTracked = {};
        var scrollTicking = false;
        if (_scrollHandler) window.removeEventListener('scroll', _scrollHandler);
        _scrollHandler = function() {
          if (!scrollTicking) {
            scrollTicking = true;
            requestAnimationFrame(function() {
              var scrollPercent = Math.round((window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100);
              var milestones = [25, 50, 75, 90, 100];

              milestones.forEach(function(milestone) {
                if (scrollPercent >= milestone && !scrollDepthTracked[milestone]) {
                  scrollDepthTracked[milestone] = true;
                  window.trackEvent('scroll_depth', {
                    'event_category': 'Engagement',
                    'event_label': milestone + '%',
                    'value': milestone
                  });
                }
              });
              scrollTicking = false;
            });
          }
        };
        window.addEventListener('scroll', _scrollHandler);

        // Track time on page
        var timeOnPage = 0;
        if (_timeOnPageInterval) clearInterval(_timeOnPageInterval);
        _timeOnPageInterval = setInterval(function() {
          timeOnPage += 30;
          if (timeOnPage === 30 || timeOnPage === 60 || timeOnPage === 180 || timeOnPage === 300) {
            window.trackEvent('time_on_page', {
              'event_category': 'Engagement',
              'event_label': timeOnPage + ' seconds',
              'value': timeOnPage
            });
          }
        }, 30000);

        // Reset scroll depth + time-on-page tracking on Astro View Transitions
        // Remove old handler first to prevent accumulation
        if (_beforeSwapHandler) document.removeEventListener('astro:before-swap', _beforeSwapHandler);
        _beforeSwapHandler = function() {
          // Remove listeners — setupTrackingHelpers() will re-add them on astro:page-load
          if (_clickHandler) { document.removeEventListener('click', _clickHandler); _clickHandler = null; }
          if (_scrollHandler) { window.removeEventListener('scroll', _scrollHandler); _scrollHandler = null; }
          if (_timeOnPageInterval) { clearInterval(_timeOnPageInterval); _timeOnPageInterval = null; }
        };
        document.addEventListener('astro:before-swap', _beforeSwapHandler);

        // Re-setup tracking helpers after View Transition page load
        if (_pageLoadHandler) document.removeEventListener('astro:page-load', _pageLoadHandler);
        _pageLoadHandler = function() {
          if (window._analyticsInitialized) {
            setupTrackingHelpers();
          }
        };
        document.addEventListener('astro:page-load', _pageLoadHandler);
      }

      // No-op tracking helpers when analytics not consented
      // These prevent errors in code that calls trackEvent before consent
      if (!window.trackEvent) {
        window.trackEvent = function() {};
        window.trackAudioPlay = function() {};
        window.trackAudioComplete = function() {};
        window.trackPreviewPlay = function() {};
        window.trackAddToCart = function() {};
        window.trackRemoveFromCart = function() {};
        window.trackViewItem = function() {};
        window.trackBeginCheckout = function() {};
        window.trackPurchase = function() {};
        window.trackLiveStreamJoin = function() {};
        window.trackLiveStreamChat = function() {};
        window.trackNewsletterSignup = function() {};
        window.trackSearch = function() {};
        window.trackFilter = function() {};
        window.trackDownload = function() {};
      }

      // Check consent (supports both old string and new granular JSON format)
      // In-memory cache so localStorage is only read once per page load
      var _consentCache = null;
      function hasAnalyticsConsent() {
        if (_consentCache !== null) return _consentCache;
        try {
          var raw = localStorage.getItem('cookie-consent');
          if (!raw) { _consentCache = false; return false; }
          if (raw === 'accepted') { _consentCache = true; return true; }
          if (raw === 'rejected') { _consentCache = false; return false; }
          _consentCache = JSON.parse(raw).analytics === true;
        } catch (e) {
          _consentCache = false;
        }
        return _consentCache;
      }

      if (hasAnalyticsConsent()) {
        initAnalytics();
      }

      // Listen for consent events from cookie banner (guard prevents duplicate listeners on View Transitions)
      if (!window._cookieConsentSetup) {
        window._cookieConsentSetup = true;
        window.addEventListener('cookie-consent-granted', function() {
          _consentCache = true; // Reset cache on consent
          initAnalytics();
        });
      }
    </script>

    <!-- Core Web Vitals: LCP, CLS, INP (consent-gated via gtag check) -->
    <script is:inline nonce={nonce}>
      (function(){
        if(typeof PerformanceObserver==='undefined')return;
        function send(name,val){
          if(typeof window.gtag==='function'){
            window.gtag('event','web_vitals',{
              event_category:'Web Vitals',
              metric_name:name,
              value:Math.round(val),
              non_interaction:true
            });
          }
        }
        var sent={};
        function sendOnce(name,val){if(!sent[name]){sent[name]=1;send(name,val);}}
        try{
          // LCP - report the last entry (largest) on page hide
          var lcpVal=0;
          new PerformanceObserver(function(l){
            var entries=l.getEntries();
            var last=entries[entries.length-1];
            if(last) lcpVal=last.renderTime||last.startTime;
          }).observe({type:'largest-contentful-paint',buffered:true});

          // CLS - session window approach per web.dev spec
          var clsVal=0,clsSession=0,clsStart=0,clsPrev=0;
          new PerformanceObserver(function(l){
            for(var e,i=0;i<l.getEntries().length;i++){
              e=l.getEntries()[i];
              if(e.hadRecentInput)continue;
              if(e.startTime-clsPrev<1000&&e.startTime-clsStart<5000){
                clsSession+=e.value;
              }else{
                clsSession=e.value;
                clsStart=e.startTime;
              }
              clsPrev=e.startTime;
              if(clsSession>clsVal)clsVal=clsSession;
            }
          }).observe({type:'layout-shift',buffered:true});

          // INP - track worst interaction (replaces deprecated FID)
          var inpVal=0,inpEntries=[];
          new PerformanceObserver(function(l){
            for(var e,i=0;i<l.getEntries().length;i++){
              e=l.getEntries()[i];
              // interactionId groups multi-event interactions
              if(!e.interactionId)continue;
              var dur=e.duration;
              inpEntries.push(dur);
            }
          }).observe({type:'event',buffered:true,durationThreshold:16});

          // Send all metrics when page is being unloaded
          function reportAll(){
            sendOnce('LCP',lcpVal);
            sendOnce('CLS',clsVal*1000);
            // INP = p98 of interactions (approximation: highest minus outlier)
            if(inpEntries.length){
              inpEntries.sort(function(a,b){return a-b;});
              var idx=Math.min(inpEntries.length-1,Math.floor(inpEntries.length*0.98));
              sendOnce('INP',inpEntries[idx]);
            }
          }
          document.addEventListener('visibilitychange',function(){
            if(document.visibilityState==='hidden')reportAll();
          });
          // Safari fallback
          window.addEventListener('pagehide',reportAll);
        }catch (e){/* Web Vitals observers are best-effort — silently degrade if PerformanceObserver throws */}
      })();
    </script>
  </>
)}

<!-- GTM noscript fallback -->
{gtmId && shouldRender && (
  <noscript>
    <iframe
      src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
      height="0"
      width="0"
      style="display:none;visibility:hidden"
      title="Google Tag Manager">
    </iframe>
  </noscript>
)}
