---
// src/components/ReleasePlate.astro
// OPTIMIZED VERSION - API-friendly with reduced calls
// - Server-side ratings eliminate batch API calls
// - Lazy audio element creation reduces DOM size
// - Extended cache duration (30 min ratings, 10 min comments)
// - Debounced interactions prevent duplicate calls
// - Optimistic UI updates reduce perceived latency

interface Track {
  trackNumber?: number;
  displayTrackNumber?: number;
  trackName?: string;
  featured?: string;
  remixer?: string;
  previewUrl?: string | null;
  wavUrl?: string;
  mp3Url?: string;
  duration?: string | number;
  ratings?: {
    average: number;
    count: number;
    total: number;
  };
  comments?: Record<string, unknown>[];
}

interface Comment {
  id: string;
  userName?: string;
  username?: string;
  comment?: string;
  text?: string;
  timestamp: string;
  createdAt?: string;
}

interface Props {
  id: string;
  artistName?: string;
  releaseName?: string;
  labelName?: string;
  recordLabel?: string;
  copyrightHolder?: string;
  labelCode?: string;
  catalogNumber?: string;
  genre?: string;
  coverArtUrl?: string;
  thumbUrl?: string;
  additionalArtwork?: string[];
  tracks?: Track[];
  releaseDate?: string;
  processedAt?: string;
  uploadedAt?: string;
  publishedAt?: string;
  pricePerSale?: number;
  trackPrice?: number;
  vinylRelease?: boolean;
  vinylRecordCount?: string;
  vinylPrice?: number;
  hasLimitedEdition?: boolean;
  limitedEditionType?: string;
  limitedEditionDetails?: string;
  releaseDescription?: string;
  pricing?: {
    digital?: number;
    track?: number;
    vinyl?: number;
  };
  vinyl?: {
    price?: number;
    recordCount?: number | string;
    available?: boolean;
  };
  ratings?: {
    average?: number;
    count?: number;
    total?: number;
  };
  overallRating?: {
    average: number;
    count: number;
    total: number;
  };
  comments?: Comment[];
  socialLinks?: unknown;
  notes?: string;
  submittedBy?: string;
  status?: string;
  approved?: boolean;
  published?: boolean;
  stats?: {
    totalTracks: number;
    totalPreviews: number;
    totalArtwork: number;
    plays: number;
    downloads: number;
    views: number;
  };
  saleDiscount?: number;
  // Name Your Own Price (NYOP)
  nyopEnabled?: boolean;
  nyopMinPrice?: number;
  nyopSuggestedPrice?: number;
  priority?: boolean;
}

const { 
  id = '', 
  artistName = 'Unknown Artist',
  releaseName = 'Untitled Release',
  labelName = '',
  recordLabel = '',
  copyrightHolder = '',
  labelCode = '',
  catalogNumber = '',
  genre = '',
  coverArtUrl = '/place-holder.webp',
  thumbUrl,
  additionalArtwork = [],
  tracks = [],
  releaseDate = new Date().toISOString(),
  pricePerSale = 0,
  trackPrice = 1.00,
  vinylRelease = false,
  vinylRecordCount = '',
  vinylPrice = 0,
  hasLimitedEdition = false,
  limitedEditionType = '',
  limitedEditionDetails = '',
  releaseDescription = '',
  pricing = {},
  vinyl = {},
  ratings = {},
  overallRating = { average: 0, count: 0, total: 0 },
  comments = [],
  notes = '',
  status = 'live',
  saleDiscount = 0,
  // NYOP
  nyopEnabled = false,
  nyopMinPrice = 0,
  nyopSuggestedPrice = 0,
  priority = false
} = Astro.props;

// Derive thumb URL for srcset (400w thumbnail + 800w cover)
// Encode spaces in URLs for valid srcset parsing
const encUrl = (u: string) => u.replace(/ /g, '%20');
const thumbSrc = thumbUrl || (coverArtUrl?.includes('/cover.webp') ? coverArtUrl.replace('/cover.webp', '/thumb.webp') : undefined);
const hasSrcset = thumbSrc && coverArtUrl !== '/place-holder.webp';
const srcsetThumb = thumbSrc ? encUrl(thumbSrc) : '';
const srcsetCover = coverArtUrl ? encUrl(coverArtUrl) : '';

// Use whichever label field is available
const displayLabel = labelName || recordLabel || copyrightHolder || '';

// Use catalogNumber if available, fallback to labelCode
const displayCatalogNumber = catalogNumber || labelCode || '';

// Handle nested pricing structure - use explicit checks for 0 values
const finalDigitalPrice = pricing?.digital !== undefined && pricing?.digital !== null
  ? pricing.digital
  : (pricePerSale !== undefined && pricePerSale !== null ? pricePerSale : (trackPrice * tracks.length));
const finalTrackPrice = pricing?.track !== undefined && pricing?.track !== null
  ? pricing.track
  : (trackPrice !== undefined && trackPrice !== null ? trackPrice : 1.00);
const finalVinylPrice = vinyl?.price ?? pricing?.vinyl ?? vinylPrice ?? 0;

// Handle nested vinyl structure
const finalVinylRecordCount = vinyl?.recordCount?.toString() || vinylRecordCount || '0';
const finalVinylAvailable = vinyl?.available !== undefined ? vinyl.available : vinylRelease;

// Handle ratings - prefer ratings over overallRating (server-side normalized)
const finalRating = {
  average: ratings?.average || overallRating?.average || 0,
  count: ratings?.count || overallRating?.count || 0,
  total: ratings?.total || overallRating?.total || 0
};

// Flag to indicate if ratings came from server (non-zero means server-provided)
const hasServerRatings = finalRating.count > 0 || finalRating.average > 0;

// Parse artist from wavUrl filename (format: ArtistName_-_AlbumName_-_...)
function parseArtistFromWavUrl(wavUrl: string): string {
  if (!wavUrl) return '';
  const filename = wavUrl.split('/').pop() || '';
  const match = filename.match(/^(.+?)_-_[^_]/);
  if (match) {
    return match[1].replace(/_/g, ' ').replace(/  +/g, ' & ').trim();
  }
  return '';
}

// Check if this is a release with "Artist - Title" format that needs swapping
const needsSwap = releaseName.toLowerCase().includes('vol.2') || releaseName.toLowerCase().includes('vol 2');

// Process tracks with IDs and sort by track number
const tracksWithIds = tracks.map((track, index) => {
  const displayNum = track.displayTrackNumber || track.trackNumber || (index + 1);
  const rawTitle = track.trackName || track.title || `Track ${displayNum}`;

  // Check if trackName already contains " - " (embedded artist info)
  const hasEmbeddedArtist = rawTitle.includes(' - ');
  let title = rawTitle;
  let trackArtist = '';

  if (hasEmbeddedArtist) {
    if (needsSwap) {
      // Vol 2 format: "Artist - Title" → swap to show Title - Artist
      const parts = rawTitle.split(' - ');
      trackArtist = parts[0].trim();
      title = parts.slice(1).join(' - ').trim();
    } else {
      // Vol 1 format: "Title - Artist" → keep as-is in white
      title = rawTitle;
      trackArtist = '';
    }
  } else {
    // Try explicit artist field, then parse from wavUrl
    trackArtist = track.artist || track.trackArtist || parseArtistFromWavUrl(track.wavUrl);
  }

  return {
    id: `${id}-track-${displayNum}`,
    title: title,
    artist: trackArtist,
    featured: track.featured || '',
    remixer: track.remixer || '',
    preview_url: track.previewUrl || track.preview_url || track.mp3Url || null,
    track_number: displayNum,
    mp3Url: track.mp3Url,
    wavUrl: track.wavUrl,
    duration: track.duration
  };
}).sort((a, b) => a.track_number - b.track_number);

const formattedDate = new Date(releaseDate).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric'
});

// Check if this is a pre-order (release date is in the future)
const releaseDateTime = new Date(releaseDate);
const now = new Date();
const isPreOrder = releaseDateTime > now;
const daysUntilRelease = isPreOrder ? Math.ceil((releaseDateTime.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)) : 0;

const vinylAvailable = finalVinylAvailable && parseInt(finalVinylRecordCount) > 0;

// Sale calculations
const hasSale = saleDiscount > 0;
const originalDigitalPrice = finalDigitalPrice;
const digitalPrice = hasSale ? originalDigitalPrice * (1 - saleDiscount / 100) : originalDigitalPrice;
const originalTrackPrice = finalTrackPrice;
const saleTrackPrice = hasSale ? originalTrackPrice * (1 - saleDiscount / 100) : originalTrackPrice;
const originalVinylPrice = finalVinylPrice;
const saleVinylPrice = hasSale ? finalVinylPrice * (1 - saleDiscount / 100) : finalVinylPrice;

// Calculate total duration
const totalDurationSeconds = tracksWithIds.reduce((acc, track) => {
  if (track.duration) {
    // Handle both "mm:ss" string format and seconds number
    if (typeof track.duration === 'string' && track.duration.includes(':')) {
      const [mins, secs] = track.duration.split(':').map(Number);
      return acc + (mins * 60) + (secs || 0);
    } else if (typeof track.duration === 'number') {
      return acc + track.duration;
    }
  }
  return acc;
}, 0);
const totalMinutes = Math.floor(totalDurationSeconds / 60);
const totalSeconds = totalDurationSeconds % 60;
const totalDurationFormatted = totalDurationSeconds > 0 
  ? `${totalMinutes}:${totalSeconds.toString().padStart(2, '0')}` 
  : null;
---

<article 
  class="release-plate-container bg-gradient-to-b from-black via-gray-800 to-white rounded-lg shadow-sm border border-gray-200 p-6 mb-4 w-full" 
  data-release={id}
  data-has-server-ratings={hasServerRatings ? 'true' : 'false'}
>
  <div class="content-wrapper flex flex-col md:flex-row gap-6">
    <!-- LEFT: ARTWORK + BUY BUTTONS -->
    <div class="artwork-column relative flex-shrink-0 flex flex-col">
      <div class="artwork-image">
        {isPreOrder && (
          <div class="pre-order-badge absolute top-2 left-2 z-10 bg-gradient-to-r from-orange-500 to-red-500 text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-lg uppercase tracking-wide">
            <span class="flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
              Pre-order • {daysUntilRelease} day{daysUntilRelease !== 1 ? 's' : ''}
            </span>
          </div>
        )}
        {hasSale && (
          <div class="sale-badge absolute top-2 right-2 z-10 bg-gradient-to-r from-red-600 to-red-700 text-white text-xs font-black px-3 py-1.5 rounded-lg shadow-lg uppercase tracking-wide">
            <span class="flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              {saleDiscount}% OFF
            </span>
          </div>
        )}
        <div class="cover-glow w-64 h-64 bg-white rounded-md shadow-md mb-4 overflow-hidden border-2 border-gray-400">
          <img
            src={coverArtUrl}
            srcset={hasSrcset ? `${srcsetThumb} 400w, ${srcsetCover} 800w` : undefined}
            sizes={hasSrcset ? "256px" : undefined}
            alt={`${releaseName} by ${artistName}`}
            class="w-full h-full object-cover"
            width="256"
            height="256"
            loading={priority ? "eager" : "lazy"}
            fetchpriority={priority ? "high" : undefined}
            decoding={priority ? "auto" : "async"}
          />
        </div>
      </div>

      <div class="buy-actions-mobile flex flex-col">
      <div class="buy-container">
      {/* NYOP Purchase UI - Simplified with Modal */}
      {nyopEnabled ? (
        <div class="w-64 nyop-container" data-release-id={id}>
          <div class="text-xs text-white uppercase tracking-wide font-bold mb-2 text-center">Name Your Price</div>
          <button
            type="button"
            data-release-id={id}
            data-title={releaseName}
            data-artist={artistName}
            data-label-name={labelName}
            data-artwork={coverArtUrl}
            data-nyop-min={nyopMinPrice}
            data-nyop-suggested={nyopSuggestedPrice}
            data-is-preorder={isPreOrder ? 'true' : 'false'}
            class="nyop-open-modal w-full px-4 py-3 rounded-lg flex items-center justify-center gap-2 transition-colors font-bold text-sm shadow-sm font-body bg-green-700 hover:bg-green-800 text-white"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
            </svg>
            <span>Buy Digital</span>
          </button>
        </div>
      ) : (
        <div class="flex gap-2 w-64">
          <button
            data-release-id={id}
            data-product-type="digital"
            data-price={digitalPrice}
            data-title={releaseName}
            data-artist={artistName}
            data-label-name={labelName}
            data-artwork={coverArtUrl}
            data-is-preorder={isPreOrder ? 'true' : 'false'}
            class={`add-to-cart px-4 py-3 rounded-lg flex items-center justify-center gap-2 transition-colors font-bold text-sm flex-1 font-body ${isPreOrder ? 'bg-gradient-to-r from-orange-600 to-red-600 hover:from-orange-700 hover:to-red-700 text-white shadow-sm' : 'bg-green-700 hover:bg-green-800 text-white'}`}
            style={isPreOrder ? undefined : 'animation: buy-glow-pulse 2s ease-in-out infinite; box-shadow: 0 0 12px rgba(21, 128, 61, 0.7), 0 0 24px rgba(21, 128, 61, 0.5), 0 0 48px rgba(21, 128, 61, 0.3);'}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              {isPreOrder ? (
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              ) : (
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
              )}
            </svg>
            <span>
              {isPreOrder ? 'Pre-order' : 'Digital EP'}
              {hasSale ? (
                <Fragment>
                  <span class="line-through opacity-60 mx-1">£{originalDigitalPrice.toFixed(2)}</span>
                  <span class="text-green-300 font-black">£{digitalPrice.toFixed(2)}</span>
                </Fragment>
              ) : (
                <Fragment> £{digitalPrice.toFixed(2)}</Fragment>
              )}
            </span>
          </button>

        <button
          data-release-id={id}
          data-product-type="vinyl"
          data-price={finalVinylPrice}
          data-digital-price={digitalPrice}
          data-title={releaseName}
          data-artist={artistName}
          data-label-name={labelName}
          data-artwork={coverArtUrl}
          data-includes-digital="true"
          data-is-preorder={isPreOrder ? 'true' : 'false'}
          disabled={!vinylAvailable}
          class={`vinyl-btn add-to-cart px-4 py-3 rounded-lg flex items-center justify-center gap-2 transition-colors font-bold text-sm flex-1 shadow-sm font-body ${
            vinylAvailable
              ? (isPreOrder ? 'bg-gradient-to-r from-orange-600 to-red-600 hover:from-orange-700 hover:to-red-700 text-white' : 'bg-red-600 hover:bg-red-700 text-white')
              : 'bg-sky-600/40 text-sky-200/70 cursor-not-allowed'
          }`}
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/>
            <circle cx="12" cy="12" r="3" fill="currentColor"/>
          </svg>
          <span>
            {!finalVinylAvailable ? 'No Vinyl' : vinylAvailable ? (
              <Fragment>
                {isPreOrder ? 'Pre-order' : 'Vinyl EP'}
                {hasSale ? (
                  <Fragment>
                    <span class="line-through opacity-60 mx-1">£{originalVinylPrice?.toFixed(2)}</span>
                    <span class="text-green-300 font-black">£{saleVinylPrice?.toFixed(2)}</span>
                  </Fragment>
                ) : (
                  <Fragment> £{finalVinylPrice?.toFixed(2)}</Fragment>
                )}
              </Fragment>
            ) : 'Vinyl Sold Out'}
          </span>
        </button>
        </div>
      )}

      {/* Vinyl button for NYOP mode - shown separately below the NYOP box */}
      {nyopEnabled && vinylAvailable && (
        <div class="w-64 mt-2">
          <button
            data-release-id={id}
            data-product-type="vinyl"
            data-price={finalVinylPrice}
            data-digital-price={digitalPrice}
            data-title={releaseName}
            data-artist={artistName}
            data-label-name={labelName}
            data-artwork={coverArtUrl}
            data-includes-digital="true"
            data-is-preorder={isPreOrder ? 'true' : 'false'}
            class="add-to-cart w-full px-4 py-3 rounded-lg flex items-center justify-center gap-2 transition-colors font-bold text-sm shadow-sm font-body bg-red-600 hover:bg-red-700 text-white"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/>
              <circle cx="12" cy="12" r="3" fill="currentColor"/>
            </svg>
            <span>Vinyl + Digital £{finalVinylPrice?.toFixed(2)}</span>
          </button>
        </div>
      )}
      </div>

      <!-- Compact Info Row -->
      <div class="flex items-center justify-between w-64 mt-auto pt-3 px-1 relative z-10">
        <!-- Wishlist Button (always visible) -->
        <button
          type="button"
          class="wishlist-btn flex items-center gap-1 text-sm hover:opacity-70 transition-opacity font-body font-semibold cursor-pointer"
          data-release-id={id}
          data-title={releaseName}
          data-artist={artistName}
          data-artwork={coverArtUrl}
          data-genre={genre}
          data-label={displayLabel}
          title="Add to wishlist"
          aria-label={`Add ${releaseName} to wishlist`}
        >
          <svg class="w-4 h-4 wishlist-icon-empty text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
          <svg class="w-4 h-4 wishlist-icon-filled text-red-500 hidden" fill="currentColor" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
          <span class="wishlist-text text-gray-800 text-xs">Wishlist</span>
        </button>

        {isPreOrder && (
          <!-- Pre-order Link (only for upcoming releases) -->
          <a
            href={`/item/${id}/`}
            class="preorder-link flex items-center gap-1 text-xs font-body font-semibold text-orange-500 hover:text-orange-400 transition-colors"
            title={`Pre-order - Available ${formattedDate}`}
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Pre-order</span>
          </a>
        )}

        <span class="text-xs font-body font-semibold text-gray-800">{tracksWithIds.length} tracks</span>
      </div>
      </div>
    </div>

    <!-- RIGHT: INFO SECTION -->
    <div class="flex-1 min-w-0 flex flex-col">
      <div class="flex flex-col h-full">
        <h3 class="release-title text-4xl text-red-600 leading-tight truncate mb-4" title={releaseName}>
          {releaseName.length > 30 ? releaseName.substring(0, 27) + '...' : releaseName}
        </h3>

        <div class="space-y-2 mb-4">
          <p class="artist-name-font text-xl font-semibold text-white truncate" title={artistName}>
            {artistName.length > 30 ? artistName.substring(0, 27) + '...' : artistName}
          </p>
          <p class="label-name-font text-base font-medium text-white truncate" title={displayLabel || 'Unknown Label'}>
            {displayLabel ? `© ${displayLabel.length > 35 ? displayLabel.substring(0, 32) + '...' : displayLabel}` : '© Unknown Label'}
          </p>
        </div>

        <div class="genre-section flex items-center gap-2 text-base text-gray-300 mb-5 flex-wrap">
          {genre && (
            <span class="text-sm px-2 py-1 bg-gray-700 text-white rounded font-medium">{genre}</span>
          )}
          {displayCatalogNumber && (
            <span class="text-sm px-2 py-1 bg-gray-700 text-white rounded font-medium font-body tracking-wide">{displayCatalogNumber}</span>
          )}
        </div>

        <!-- Release Details Box -->
        <div class="details-section mt-auto">
          <a href={`/item/${id}/`} class="details-preview block bg-gradient-to-r from-gray-800 via-gray-900 to-black border-2 border-gray-600 hover:border-red-500 rounded-lg overflow-hidden cursor-pointer transition-colors group">
            <div class="flex items-stretch">
              <div class="flex-1 p-4">
                <div class="text-xs text-white uppercase tracking-widest mb-2 font-heading font-bold flex items-center gap-2">
                  <span>📋</span> Release Details
                </div>
                <div class="space-y-1.5 text-sm text-gray-300 font-body font-semibold">
                  <div class="flex items-center gap-2">
                    <span class="text-gray-300">📅</span>
                    <span class="truncate">{formattedDate}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="text-gray-300">💿</span>
                    <span class="truncate">{finalVinylAvailable ? 'Vinyl + Digital' : 'Digital Only'}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="text-gray-300">🔗</span>
                    <span class="truncate">Social Links</span>
                  </div>
                </div>
              </div>
              <div class="flex items-center justify-center px-5 bg-gradient-to-r from-red-600 to-red-700 group-hover:from-red-500 group-hover:to-red-600 transition-colors">
                <div class="flex flex-col items-center gap-1">
                  <span class="text-xs text-white uppercase font-heading font-bold tracking-wide whitespace-nowrap">View</span>
                  <svg class="w-5 h-5 text-white group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>

    <!-- RIGHT: TRACKS SECTION (hidden on mobile, accessible from item/[id]) -->
    <div class="tracks-section flex-1 flex flex-col bg-gradient-to-b from-gray-900 via-gray-800 to-black rounded-lg p-4 min-w-0 max-w-full overflow-hidden border border-gray-700">
      <div class="mb-3 flex items-center justify-between pb-2 border-b border-gray-700">
        <h4 class="text-sm text-white uppercase tracking-wider font-heading">
          TRACKS ({tracksWithIds.length})
        </h4>
        {finalTrackPrice > 0 && !nyopEnabled && (
          <div class="text-sm text-white font-body">
            {hasSale ? (
              <Fragment>
                <span class="line-through opacity-60">£{originalTrackPrice.toFixed(2)}</span>
                <span class="text-green-400 font-bold ml-1">£{saleTrackPrice.toFixed(2)}</span> per track
              </Fragment>
            ) : (
              <Fragment>£{finalTrackPrice.toFixed(2)} per track</Fragment>
            )}
          </div>
        )}
      </div>

      {tracksWithIds.length > 0 ? (
        <div class="flex flex-col flex-1">
          <div class="track-list-container relative" style="max-height: 160px; overflow-y: auto; overflow-x: hidden;">
            {tracksWithIds.map((track) => (
              <div class="track-row flex items-center gap-2 py-2 px-2 hover:bg-white/10 rounded transition-colors border-b border-gray-700/50 last:border-b-0">
                <button
                  class="play-button flex-shrink-0 w-7 h-7 flex items-center justify-center rounded-full bg-white text-black transition-colors"
                  data-track-id={track.id}
                  data-release-id={id}
                  data-preview-url={track.preview_url || ''}
                  data-track-title={track.title}
                  title="Play"
                  aria-label={`Play ${track.title}`}
                >
                  <svg class="w-3.5 h-3.5 play-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                  <svg class="w-3.5 h-3.5 pause-icon hidden" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
                  </svg>
                </button>
                <span class="text-sm text-gray-300 w-6 text-center flex-shrink-0 font-body">
                  {track.track_number}
                </span>
                <p class="text-sm text-white truncate flex-1 min-w-0 font-body" title={track.artist ? `${track.title} - ${track.artist}` : track.title} data-track-title={track.title}>
                  {track.title}
                  {track.remixer && <span class="text-gray-300 font-normal"> ({track.remixer} Remix)</span>}
                  {track.artist && <span class="text-gray-300 font-normal"> - {track.artist}</span>}
                  {track.featured && <span class="text-gray-300 font-normal text-xs"> ft. {track.featured.replace(/^(ft\.?|feat\.?)\s*/i, '')}</span>}
                </p>
                {finalTrackPrice > 0 && !nyopEnabled && (
                  <button
                    class="buy-track flex-shrink-0 text-sm font-bold text-white bg-green-700 hover:bg-green-800 transition-colors px-3 py-1 rounded font-body"
                    data-track-id={track.id}
                    data-track-title={track.title}
                    data-track-price={finalTrackPrice}
                    data-release-id={id}
                    data-artist={artistName}
                    data-artwork={coverArtUrl}
                    title="Buy this track"
                  >
                    BUY
                  </button>
                )}
              </div>
            ))}
            
            {tracksWithIds.length > 3 && (
              <div class="scroll-indicator absolute bottom-0 left-0 right-0 h-8 bg-gradient-to-t from-black/60 to-transparent pointer-events-none flex items-end justify-center pb-1">
                <svg class="w-4 h-4 text-white animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </div>
            )}
          </div>

          <div class="player-section pt-4 border-t border-gray-700 mt-auto">
            <div class="flex items-center justify-between mb-2 gap-2">
              <div class="flex-1 min-w-0">
                <p class="text-sm text-white uppercase tracking-wide font-heading">NOW PLAYING</p>
                <p class="text-sm text-red-500 truncate font-body" data-now-playing-text={id}>
                  No track selected
                </p>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0 min-w-fit">
                <svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M9.383 3.076A1 1 0 0110 4v12a1 1 0 01-1.707.707L4.586 13H2a1 1 0 01-1-1V8a1 1 0 011-1h2.586l3.707-3.707a1 1 0 011.09-.217zM12.293 7.293a1 1 0 011.414 0 3 3 0 010 4.242 1 1 0 11-1.414-1.414 1 1 0 000-1.414 1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="70"
                  class="shared-volume-slider flex-shrink-0"
                  style="width: 72px;"
                  data-release-id={id}
                  title="Volume"
                />
                <svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M9.383 3.076A1 1 0 0110 4v12a1 1 0 01-1.707.707L4.586 13H2a1 1 0 01-1-1V8a1 1 0 011-1h2.586l3.707-3.707a1 1 0 011.09-.217zM14.657 2.929a1 1 0 011.414 0A9.972 9.972 0 0119 10a9.972 9.972 0 01-2.929 7.071 1 1 0 01-1.414-1.414A7.971 7.971 0 0017 10c0-2.21-.894-4.208-2.343-5.657a1 1 0 010-1.414zm-2.829 2.828a1 1 0 011.415 0A5.983 5.983 0 0115 10a5.984 5.984 0 01-1.757 4.243 1 1 0 01-1.415-1.415A3.984 3.984 0 0013 10a3.983 3.983 0 00-1.172-2.828 1 1 0 010-1.415z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
            <div class="waveform-wrapper" style="width: 100%; max-width: 100%; overflow: hidden;">
              <canvas 
                class="shared-waveform cursor-pointer rounded border-2 border-gray-700"
                width="400"
                height="50"
                style="width: 100%; height: 50px; display: block; max-width: 100%; background: linear-gradient(to bottom, #1a1a1a, #0a0a0a);"
                data-release-id={id}
              ></canvas>
            </div>
          </div>
        </div>
      ) : (
        <div class="flex-1 flex items-center justify-center text-white">
          <p class="text-base">No tracks available</p>
        </div>
      )}
    </div>
  </div>
</article>

<!-- Share Modal (Enhanced) -->
<div id="share-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-labelledby="share-modal-heading" data-has-focus-trap="true">
  <div class="fixed inset-0 bg-black/90 backdrop-blur-sm transition-opacity" id="share-modal-backdrop"></div>
  <div class="fixed inset-0 flex items-center justify-center p-3 sm:p-4 overflow-y-auto">
