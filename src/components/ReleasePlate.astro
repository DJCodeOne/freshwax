          </svg>
          Share via Device
        </button>
      </div>

      <!-- Footer -->
      <div class="px-4 py-3 border-t border-white/10 bg-white/5 rounded-b-2xl">
        <p class="text-center text-xs text-gray-300">
          Share the <span class="text-red-500 font-bold">music</span> - Support independent artists
        </p>
      </div>
    </div>
  </div>
</div>

<!-- NYOP Price Selection Modal -->
<div id="nyop-modal" class="nyop-modal hidden fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-label="Name your own price" data-has-focus-trap="true">
  <div class="nyop-modal-backdrop absolute inset-0 bg-black/80" data-close-modal></div>
  <div class="nyop-modal-content relative bg-gray-900 rounded-xl p-6 max-w-sm w-full border border-gray-700 shadow-2xl">
    <button type="button" class="nyop-modal-close absolute top-3 right-3 text-gray-300 hover:text-white transition-colors" data-close-modal aria-label="Close">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="text-center mb-6">
      <img id="nyop-modal-artwork" src="/place-holder.webp" alt="Release artwork" class="w-24 h-24 mx-auto rounded-lg mb-3 object-cover" width="96" height="96" loading="lazy" decoding="async" />
      <h3 id="nyop-modal-title" class="text-lg font-bold text-white"></h3>
      <p id="nyop-modal-artist" class="text-sm text-gray-300"></p>
    </div>

    <div class="mb-6">
      <label class="block text-sm text-gray-300 uppercase tracking-wide font-bold mb-3 text-center">Name Your Price</label>

      <!-- Quick price buttons -->
      <div class="grid grid-cols-4 gap-2 mb-4">
        <button type="button" class="nyop-quick-price py-2 px-3 rounded-lg bg-gray-800 hover:bg-gray-700 text-white font-bold text-sm transition-colors" data-price="0">Free</button>
        <button type="button" class="nyop-quick-price py-2 px-3 rounded-lg bg-gray-800 hover:bg-gray-700 text-white font-bold text-sm transition-colors" data-price="3">£3</button>
        <button type="button" class="nyop-quick-price py-2 px-3 rounded-lg bg-gray-800 hover:bg-gray-700 text-white font-bold text-sm transition-colors" data-price="5">£5</button>
        <button type="button" class="nyop-quick-price py-2 px-3 rounded-lg bg-gray-800 hover:bg-gray-700 text-white font-bold text-sm transition-colors" data-price="10">£10</button>
      </div>

      <!-- Custom price input -->
      <div class="flex items-center gap-3 justify-center">
        <span class="text-white font-bold text-xl">£</span>
        <input
          type="text"
          inputmode="decimal"
          id="nyop-modal-price"
          aria-label="Your price"
          class="w-28 bg-gray-800 border-2 border-gray-600 rounded-lg px-4 py-3 text-white text-2xl font-bold text-center focus:outline-none focus:border-red-500 transition-colors"
          value="5.00"
          placeholder="0.00"
        />
      </div>

      <p id="nyop-modal-min-text" class="text-xs text-gray-300 text-center mt-2">Pay what you want (including £0)</p>
      <p id="nyop-modal-error" class="text-sm text-red-400 text-center mt-2 hidden"></p>
    </div>

    <button
      type="button"
      id="nyop-modal-add-cart"
      class="w-full py-4 rounded-lg bg-red-600 hover:bg-red-700 text-white font-bold text-lg transition-colors flex items-center justify-center gap-2"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
      <span>Add to Cart</span>
    </button>
  </div>
</div>

<style>
  /* Cover Art Glow */
  .cover-glow {
    box-shadow: 0 0 16px rgba(220, 38, 38, 0.6), 0 0 32px rgba(220, 38, 38, 0.3), 0 0 48px rgba(220, 38, 38, 0.15);
