---
// src/components/live/LiveChat.astro
// Live stream chat with emoji picker, GIF support, and online users
---

<div class="chat-section">
    <div class="chat-header">
      <h3>LIVE CHAT</h3>
      <span class="chat-viewers" id="chatViewers">0 watching</span>
    </div>

    <div class="chat-messages" id="chatMessages">
    </div>

    <div id="chatInputSection" class="chat-input-section" style="position: relative;">
    <div id="loginPrompt" class="login-prompt">
      <p><a href="/login/">Sign in</a> to chat</p>
    </div>

    <div id="chatForm" class="chat-form hidden">
      <div id="replyIndicator" class="reply-indicator" style="display: none;"></div>

      <!-- Emoji Picker Panel -->
      <div id="emojiPanel" class="emoji-panel" style="display: none;">
        <div class="emoji-panel-header">
          <span>Emojis</span>
          <button type="button" class="emoji-panel-close" id="closeEmojiPanel" aria-label="Close">×</button>
        </div>
        <div class="emoji-panel-cats">
          <button class="emoji-panel-cat active" data-category="music" aria-label="Music emojis">🎵</button>
          <button class="emoji-panel-cat" data-category="fire" aria-label="Fire emojis">🔥</button>
          <button class="emoji-panel-cat" data-category="faces" aria-label="Face emojis">😎</button>
          <button class="emoji-panel-cat" data-category="vibes" aria-label="Vibe emojis">🌴</button>
        </div>
        <div class="emoji-panel-grid" id="emojiPanelGrid"></div>
      </div>

      <div class="chat-input-wrapper">
        <input type="text" id="chatInput" placeholder="Message..." maxlength="500" autocomplete="off" aria-label="Chat message" />
        <button type="button" id="openEmojiPanel" class="chat-tool-btn" title="Emojis" aria-label="Open emoji picker">😀</button>
        <button type="button" id="openGifModal" class="chat-tool-btn" title="GIFs">GIF</button>
        <button type="submit" id="sendBtn" aria-label="Send message">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- DM Modal -->
<div id="dmModal" class="dm-modal-bg" style="display: none;" role="dialog" aria-modal="true" aria-label="Direct message">
  <div class="dm-modal-box">
    <div class="dm-modal-header">
      <span>Message <strong id="dmRecipientName"></strong></span>
      <button type="button" id="closeDmModal" class="dm-modal-close" aria-label="Close">×</button>
    </div>
    <div class="dm-modal-body">
      <textarea id="dmMessageInput" placeholder="Type your message..." maxlength="500" aria-label="Direct message"></textarea>
    </div>
    <div class="dm-modal-footer">
      <button type="button" id="sendDmBtn" class="dm-send-btn">Send Message</button>
    </div>
  </div>
</div>

<!-- GIF Modal -->
<div id="gifModal" class="gif-modal-bg" style="display: none;" role="dialog" aria-modal="true" aria-label="Choose a GIF">
  <div class="gif-modal-box">
    <div class="gif-modal-top">
      <h2>Choose a GIF</h2>
      <button type="button" id="closeGifModal" class="gif-modal-x" aria-label="Close">×</button>
    </div>
    <div class="gif-modal-search-box">
      <input type="text" id="gifSearchInput" placeholder="Search GIFs..." aria-label="Search GIFs" />
    </div>
    <div class="gif-modal-cats">
      <button class="gif-modal-cat active" data-category="trending">Trending</button>
      <button class="gif-modal-cat" data-category="reactions">Reactions</button>
      <button class="gif-modal-cat" data-category="music">Music</button>
      <button class="gif-modal-cat" data-category="dance">Dance</button>
      <button class="gif-modal-cat" data-category="party">Party</button>
    </div>
    <div class="gif-modal-results" id="gifResults">
      <p class="gif-modal-loading">Loading GIFs...</p>
    </div>
    <div class="gif-modal-bottom">
      <span>Powered by GIPHY</span>
    </div>
  </div>
</div>

<script>
function escapeHtml(s: string){if(typeof s!=='string')return '';return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,"&#39;");}

// WeakMaps to store per-element state without `as any` casts
const focusTrapHandlers = new WeakMap<HTMLElement, (e: KeyboardEvent) => void>();
const previousFocusMap = new WeakMap<HTMLElement, HTMLElement | null>();

// Focus trap helper for modal dialogs
function trapFocusOnModal(modalEl: HTMLElement) {
  const focusableSelector = 'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';
  const focusableElements = modalEl.querySelectorAll<HTMLElement>(focusableSelector);
  if (focusableElements.length === 0) return;
  const firstFocusable = focusableElements[0];
  const lastFocusable = focusableElements[focusableElements.length - 1];

  const handler = (e: KeyboardEvent) => {
    if (e.key !== 'Tab') return;
    if (e.shiftKey) {
      if (document.activeElement === firstFocusable) {
        e.preventDefault();
        lastFocusable.focus();
      }
    } else {
      if (document.activeElement === lastFocusable) {
        e.preventDefault();
        firstFocusable.focus();
      }
    }
  };
  focusTrapHandlers.set(modalEl, handler);
  modalEl.addEventListener('keydown', handler);
  firstFocusable.focus();
}

function removeFocusTrapFromModal(modalEl: HTMLElement) {
  const handler = focusTrapHandlers.get(modalEl);
  if (handler) {
    modalEl.removeEventListener('keydown', handler);
    focusTrapHandlers.delete(modalEl);
  }
}

function restoreFocusFromModal(modalEl: HTMLElement) {
  removeFocusTrapFromModal(modalEl);
  const prev = previousFocusMap.get(modalEl);
  if (prev && typeof prev.focus === 'function') {
    prev.focus();
    previousFocusMap.delete(modalEl);
  }
}

// Simple self-contained emoji/GIF picker
(function() {
  const EMOJIS = {
    music: ['🎵', '🎶', '🎤', '🎧', '🎹', '🎸', '🥁', '🎺', '🎷', '🪘', '💿', '📀', '🔊', '🔉', '🎼', '🎻', '🪗', '📻', '🎚️', '🎛️', '🎙️', '📯', '🪕', '🎭'],
    fire: ['🔥', '💥', '⚡', '✨', '💫', '🌟', '⭐', '💯', '🚀', '💪', '👊', '👏', '🙌', '🤘', '✌️', '👍', '🎯', '💎', '🏆', '👑', '🥇', '⚔️', '🛡️', '💣'],
    faces: ['😀', '😎', '🤩', '😍', '🥳', '🤯', '😱', '🥵', '🤤', '😏', '😈', '👀', '💀', '🤖', '👽', '🎃', '🙃', '😜', '🤪', '😂', '🥹', '😭', '🫠', '🤑'],
    vibes: ['🌴', '🌊', '🌅', '🌙', '🌈', '☀️', '🍹', '🍻', '🥂', '💜', '💙', '💚', '💛', '🧡', '❤️', '🖤', '🌺', '🍀', '🌸', '🦋', '🌠', '🎪', '🎡', '🎢']
  };

  let currentCategory = 'music';
  let gifSearchTimeout = null;
  let documentClickListenerSet = false;
  let onlineUsersIntervalId = null;

  // AbortController for cleaning up event listeners on View Transitions
  const liveChatCleanupController = new AbortController();

  // Send GIF using existing globals from live-stream.js or dj-lobby
  async function sendGifToChat(giphyUrl, giphyId) {
    const streamId = window.currentStreamId;
    const auth = window.firebaseAuth;
    const user = auth?.currentUser;

    if (!user) {
      console.error('[GIF] No current user');
      alert('Please log in to send GIFs');
      return;
    }

    // Check email verification for new users
    if (window.FreshWax?.checkEmailVerified) {
      const verified = await window.FreshWax.checkEmailVerified('send GIFs');
      if (!verified) return;
    }
    if (!streamId) {
      console.error('[GIF] No current stream');
      alert('No active stream');
      return;
    }

    const userName = window.currentUserInfo?.name || user.displayName || user.email?.split('@')[0] || 'User';
    const userAvatar = window.currentUserInfo?.avatar || user.photoURL || null;

    async function doSendGif(targetStreamId) {
      const chatHeaders = { 'Content-Type': 'application/json' };
      try { const t = await user.getIdToken(); if (t) chatHeaders['Authorization'] = `Bearer ${t}`; } catch (e) {/* Auth token refresh failed — request proceeds without token; server allows unauthenticated chat */}
      return fetch('/api/livestream/chat/', {
        method: 'POST',
        headers: chatHeaders,
        body: JSON.stringify({
          streamId: targetStreamId,
          userId: user.uid,
          userName,
          userAvatar,
          isPro: window.currentUserInfo?.isPro || false,
          badge: window.currentUserInfo?.badge || 'crown',
          message: '[GIF]',
          type: 'giphy',
          giphyUrl,
          giphyId
        })
      });
    }

    try {
      const response = await doSendGif(streamId);
      if (!response.ok) {
        const err = await response.json().catch(() => ({}));
        console.error('[GIF] Server error:', response.status, err);
        // Auto-fallback to playlist-global if stream is not live
        if (err.error === 'Stream is not live' && streamId !== 'playlist-global') {
          window.currentStreamId = 'playlist-global';
          const retryResponse = await doSendGif('playlist-global');
          if (!retryResponse.ok) {
            console.error('[GIF] Retry also failed:', retryResponse.status);
          }
        }
      }
    } catch (error) {
      console.error('[GIF] Error sending:', error);
    }
  }

  // Wait for DOM
  function init() {
    const emojiBtn = document.getElementById('openEmojiPanel');
    const emojiPanel = document.getElementById('emojiPanel');
    const closeEmoji = document.getElementById('closeEmojiPanel');
    const emojiGrid = document.getElementById('emojiPanelGrid');
    const chatInput = document.getElementById('chatInput');

    const gifBtn = document.getElementById('openGifModal');
    const gifModal = document.getElementById('gifModal');
    const closeGif = document.getElementById('closeGifModal');
    const gifResults = document.getElementById('gifResults');
    const gifSearch = document.getElementById('gifSearchInput');

    if (!emojiBtn || !emojiPanel) {
      setTimeout(init, 500);
      return;
    }

    // Prevent double-binding (init can fire from both DOMContentLoaded and astro:page-load)
    if (emojiBtn.dataset.bound) return;
    emojiBtn.dataset.bound = 'true';

    // Render emojis
    function renderEmojis(cat) {
      const emojis = EMOJIS[cat] || EMOJIS.music;
      emojiGrid.innerHTML = emojis.map(e =>
        `<button type="button" class="emoji-grid-btn">${e}</button>`
      ).join('');

      emojiGrid.querySelectorAll('.emoji-grid-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          if (chatInput) chatInput.value += btn.textContent;
          chatInput?.focus();
        });
      });
    }

    // Expose toggle functions globally and bind via addEventListener (CSP-safe)
    window.toggleEmojiPanel = function() {
      const isVisible = emojiPanel.style.display !== 'none';
      emojiPanel.style.display = isVisible ? 'none' : 'block';
      if (!isVisible) renderEmojis(currentCategory);
    };

    window.toggleGifModal = function() {
      if (!gifModal) {
        console.error('[Picker] GIF modal element not found!');
        return;
      }
      previousFocusMap.set(gifModal, document.activeElement as HTMLElement);
      gifModal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      loadGifs('trending');
      trapFocusOnModal(gifModal);
    };

    // Bind toggle buttons via addEventListener (CSP-safe, replaces inline onclick)
    emojiBtn?.addEventListener('click', () => window.toggleEmojiPanel && window.toggleEmojiPanel());
    gifBtn?.addEventListener('click', () => window.toggleGifModal && window.toggleGifModal());

    // Close emoji panel
    closeEmoji?.addEventListener('click', () => {
      emojiPanel.style.display = 'none';
    });

    // Emoji category buttons
    document.querySelectorAll('.emoji-panel-cat').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.emoji-panel-cat').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentCategory = btn.dataset.category;
        renderEmojis(currentCategory);
      });
    });

    // Close GIF modal
    closeGif?.addEventListener('click', () => {
      gifModal.style.display = 'none';
      document.body.style.overflow = '';
      restoreFocusFromModal(gifModal);
    });

    // Click outside to close GIF modal
    gifModal?.addEventListener('click', (e) => {
      if (e.target === gifModal) {
        gifModal.style.display = 'none';
        document.body.style.overflow = '';
        restoreFocusFromModal(gifModal);
      }
    });

    // GIF category buttons
    document.querySelectorAll('.gif-modal-cat').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.gif-modal-cat').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        loadGifs(btn.dataset.category);
      });
    });

    // GIF search
    gifSearch?.addEventListener('input', (e) => {
      clearTimeout(gifSearchTimeout);
      gifSearchTimeout = setTimeout(() => {
        const query = e.target.value.trim();
        if (query) {
          loadGifs(null, query);
        } else {
          loadGifs('trending');
        }
      }, 400);
    });

    // Load GIFs via server-side proxy (API key stays on server)
    async function loadGifs(category, searchQuery = null) {
      if (!gifResults) {
        console.error('[GIF] gifResults element not found!');
        return;
      }

      gifResults.innerHTML = '<p class="gif-modal-loading">Loading GIFs...</p>';

      try {
        let proxyUrl;
        if (searchQuery) {
          proxyUrl = `/api/giphy/search/?q=${encodeURIComponent(searchQuery)}&limit=24`;
        } else if (category === 'trending') {
          proxyUrl = `/api/giphy/search/?endpoint=trending&limit=24`;
        } else {
          proxyUrl = `/api/giphy/search/?q=${encodeURIComponent(category)}&limit=24`;
        }

        const res = await fetch(proxyUrl);

        if (!res.ok) {
          console.error('[GIF] Proxy error:', res.status);
          gifResults.innerHTML = `<p class="gif-modal-loading">Error loading GIFs (${res.status})</p>`;
          return;
        }

        const data = await res.json();

        if (data.gifs?.length > 0) {
          gifResults.innerHTML = data.gifs.map(gif => `
            <div class="gif-result-item" data-url="${escapeHtml(gif.url)}" data-id="${escapeHtml(gif.id)}">
              <img src="${escapeHtml(gif.preview)}" alt="${escapeHtml(gif.title)}" loading="lazy" />
            </div>
          `).join('');

          gifResults.querySelectorAll('.gif-result-item').forEach(item => {
            item.addEventListener('click', () => {
              // Send GIF using local function
              sendGifToChat(item.dataset.url, item.dataset.id);
              gifModal.style.display = 'none';
              document.body.style.overflow = '';
              restoreFocusFromModal(gifModal);
            });
          });
        } else {
          gifResults.innerHTML = '<p class="gif-modal-loading">No GIFs found</p>';
        }
      } catch (err) {
        console.error('[GIF] Error:', err);
        gifResults.innerHTML = '<p class="gif-modal-loading">Error loading GIFs</p>';
      }
    }

    // Click outside emoji panel to close (with cleanup on navigation)
    if (!documentClickListenerSet) {
      document.addEventListener('click', (e) => {
        const panel = document.getElementById('emojiPanel');
        const btn = document.getElementById('openEmojiPanel');
        if (panel && panel.style.display !== 'none' &&
            !panel.contains(e.target) &&
            e.target !== btn) {
          panel.style.display = 'none';
        }
      }, { signal: liveChatCleanupController.signal });
      documentClickListenerSet = true;
    }

    // Initialize with music emojis
    renderEmojis('music');

    // Setup DM modal
    const dmModal = document.getElementById('dmModal');
    const closeDmBtn = document.getElementById('closeDmModal');
    const sendDmBtn = document.getElementById('sendDmBtn');
    const dmInput = document.getElementById('dmMessageInput');
    const dmRecipientName = document.getElementById('dmRecipientName');
    let currentDmRecipient = null;

    closeDmBtn?.addEventListener('click', () => {
      dmModal.style.display = 'none';
      dmInput.value = '';
      currentDmRecipient = null;
      restoreFocusFromModal(dmModal);
    });

    dmModal?.addEventListener('click', (e) => {
      if (e.target === dmModal) {
        dmModal.style.display = 'none';
        dmInput.value = '';
        currentDmRecipient = null;
        restoreFocusFromModal(dmModal);
      }
    });

    sendDmBtn?.addEventListener('click', async () => {
      const message = dmInput.value.trim();
      if (!message || !currentDmRecipient) return;

      const auth = window.firebaseAuth;
      const user = auth?.currentUser;
      if (!user) {
        alert('Please log in to send messages');
        return;
      }

      try {
        const dmHeaders = { 'Content-Type': 'application/json' };
        try { const t = await user.getIdToken(); if (t) dmHeaders['Authorization'] = `Bearer ${t}`; } catch (e) {/* Auth token refresh failed — DM proceeds without token; server allows unauthenticated chat */}
        const response = await fetch('/api/livestream/chat/', {
          method: 'POST',
          headers: dmHeaders,
          body: JSON.stringify({
            streamId: window.currentStreamId,
            userId: user.uid,
            userName: window.currentUserInfo?.name || user.displayName || user.email?.split('@')[0] || 'User',
            message: `@${currentDmRecipient.name}: ${message}`,
            type: 'dm',
            recipientId: currentDmRecipient.id
          })
        });
        if (response.ok) {
          dmModal.style.display = 'none';
          dmInput.value = '';
          currentDmRecipient = null;
          restoreFocusFromModal(dmModal);
        }
      } catch (err) {
        console.error('[DM] Error sending:', err);
      }
    });

    // Expose openDM function globally
    window.openDmModal = function(userId, userName) {
      currentDmRecipient = { id: userId, name: userName };
      dmRecipientName.textContent = userName;
      previousFocusMap.set(dmModal, document.activeElement as HTMLElement);
      dmModal.style.display = 'flex';
      trapFocusOnModal(dmModal);
    };
  }

  // Online users tracking
  function initOnlineUsers() {
    const usersList = document.getElementById('onlineUsersList');
    const userCount = document.getElementById('onlineUserCount');
    if (!usersList) return;

    // Update online users from Pusher presence or viewer data
    window.updateOnlineUsers = function(users) {
      if (!users || users.length === 0) {
        usersList.innerHTML = '<p class="no-users-msg">No users online</p>';
        userCount.textContent = '0';
        return;
      }

      userCount.textContent = users.length.toString();
      usersList.innerHTML = users.map(user => {
        const initial = (user.name || 'U').charAt(0).toUpperCase();
        const avatarContent = user.avatar
          ? `<img src="${escapeHtml(user.avatar)}" alt="${escapeHtml(user.name)}" />`
          : escapeHtml(initial);
        return `
          <div class="online-user-item" data-action="openDm" data-user-id="${escapeHtml(user.id)}" data-user-name="${escapeHtml(user.name)}">
            <div class="online-user-avatar">${avatarContent}</div>
            <span class="online-user-name">${escapeHtml(user.name)}</span>
          </div>
        `;
      }).join('');
    };

    // Event delegation for online user items (CSP-safe, replaces inline onclick)
    usersList.addEventListener('click', (e) => {
      const item = e.target.closest('[data-action="openDm"]');
      if (!item) return;
      if (window.openDmModal) {
        window.openDmModal(item.dataset.userId, item.dataset.userName);
      }
    });

    // Poll for online users (connected to existing viewer system)
    // Clear any existing interval to prevent duplicates on View Transitions
    if (onlineUsersIntervalId) {
      clearInterval(onlineUsersIntervalId);
    }
    onlineUsersIntervalId = setInterval(() => {
      if (window.getOnlineViewers) {
        const viewers = window.getOnlineViewers();
        window.updateOnlineUsers(viewers);
      }
    }, 5000);
  }

  // Clean up intervals and event listeners before View Transitions swap
  document.addEventListener('astro:before-swap', () => {
    if (onlineUsersIntervalId) {
      clearInterval(onlineUsersIntervalId);
      onlineUsersIntervalId = null;
    }
    liveChatCleanupController.abort();
    documentClickListenerSet = false;
  }, { once: true });

  // astro:page-load fires on pages with ViewTransitions (Layout-based pages)
  document.addEventListener('astro:page-load', () => { init(); initOnlineUsers(); });
  // DOMContentLoaded fires on standalone pages without ViewTransitions (e.g. dj-lobby)
  // The double-init guard (emojiBtn.dataset.bound) prevents duplicate binding
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => { init(); initOnlineUsers(); });
  } else {
    init();
    initOnlineUsers();
  }
})();
</script>

<style is:global>
  /* DM Modal */
  .dm-modal-bg {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .dm-modal-box {
    background: #1a1a1a;
    border-radius: 12px;
    width: 100%;
    max-width: 400px;
    border: 1px solid #333;
  }

  .dm-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    border-bottom: 1px solid #333;
    color: #fff;
    font-size: 0.9375rem;
  }

  .dm-modal-header strong {
    color: #6366f1;
  }

  .dm-modal-close {
    background: none;
    border: none;
    color: #888;
    font-size: 1.5rem;
    cursor: pointer;
    line-height: 1;
  }

  .dm-modal-close:hover { color: #fff; }

  .dm-modal-body {
    padding: 1rem;
  }

  .dm-modal-body textarea {
    width: 100%;
    height: 100px;
    background: #111;
    border: 1px solid #333;
    border-radius: 8px;
    color: #fff;
    padding: 0.75rem;
    font-size: 0.9375rem;
    resize: none;
  }

  .dm-modal-body textarea:focus {
    outline: none;
    border-color: #6366f1;
  }

  .dm-modal-body textarea:focus-visible {
    outline: 2px solid #60a5fa;
    outline-offset: 2px;
  }

  .dm-modal-footer {
    padding: 1rem;
    border-top: 1px solid #333;
    text-align: right;
  }

  .dm-send-btn {
    background: #6366f1;
    color: #fff;
    border: none;
    padding: 0.625rem 1.25rem;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    font-size: 0.875rem;
  }

  .dm-send-btn:hover {
    background: #5558e3;
  }

  /* Hide sidebar on mobile */
  @media (max-width: 768px) {
    .online-users-sidebar {
      display: none;
    }
  }

  /* Emoji Panel - Fixed position like GIF modal */
  .emoji-panel {
    position: fixed;
    bottom: 100px;
    left: 50%;
    transform: translateX(-50%);
    width: 400px;
    max-width: calc(100vw - 2rem);
    background: #1a1a1a;
    border: 2px solid #444;
    border-radius: 12px;
    z-index: 9999;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.6);
    overflow: hidden;
  }

  .emoji-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
