<script>
  // Lazy-load the playlist modal module to reduce initial JS payload (~20KB gzipped).
  // The heavy playlist-manager + modal logic loads on idle or first interaction.
  let _playlistModuleLoaded = false;

  async function loadPlaylistModule() {
    if (_playlistModuleLoaded) return;
    _playlistModuleLoaded = true;
    const { initPlaylistModal } = await import('../../lib/playlist-modal-init');
    initPlaylistModal();
  }

  // Load on idle (well before the 10-second playlist fallback timer in live.astro)
  if ('requestIdleCallback' in window) {
    (window as any).requestIdleCallback(() => loadPlaylistModule(), { timeout: 3000 });
  } else {
    // Fallback for Safari: load after a short delay
    setTimeout(loadPlaylistModule, 1000);
  }

  // Also load immediately if playlist button is clicked before idle fires
  const _playlistBtn = document.getElementById('playlistBtn');
  if (_playlistBtn) {
    _playlistBtn.addEventListener('click', loadPlaylistModule, { once: true });
  }

  // Also load on View Transitions navigation
  document.addEventListener('astro:page-load', () => {
    // Reset on navigation so it re-initializes for the new page
    _playlistModuleLoaded = false;
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(() => loadPlaylistModule(), { timeout: 3000 });
    } else {
      setTimeout(loadPlaylistModule, 1000);
    }
    const btn = document.getElementById('playlistBtn');
    if (btn) {
      btn.addEventListener('click', loadPlaylistModule, { once: true });
    }
  });
</script>

