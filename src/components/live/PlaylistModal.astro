---
// src/components/live/PlaylistModal.astro
// Playlist modal — HTML is lazy-injected by playlist-modal-init.ts on first open.
// Only a lightweight placeholder is rendered server-side to avoid ~8KB of DOM on every load.
---

<div id="playlistModal" class="playlist-modal hidden" role="dialog" aria-modal="true" aria-label="Playlist">
  <!-- Loading spinner shown while the modal JS + HTML loads on first click -->
  <div id="playlistModalLoader" class="playlist-modal-loader">
    <div class="playlist-modal-loader-spinner"></div>
    <span>Loading playlist...</span>
  </div>
  <!-- Full modal content will be injected here by playlist-modal-init.ts -->
</div>

<style is:global>
  /* Loading spinner shown while modal content loads on first open */
  .playlist-modal-loader {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
    width: 100%;
    gap: 1rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    background: rgba(10, 10, 21, 0.95);
  }

  .playlist-modal-loader-spinner {
    width: 36px;
    height: 36px;
    border: 3px solid rgba(255, 255, 255, 0.15);
    border-top-color: #dc2626;
    border-radius: 50%;
    animation: playlistLoaderSpin 0.8s linear infinite;
  }

  @keyframes playlistLoaderSpin {
    to { transform: rotate(360deg); }
  }

  /* Full page modal */
  .playlist-modal-large {
    width: 100%;
    max-width: 100%;
    height: 100vh;
    max-height: 100vh;
    border-radius: 0;
    overflow: hidden;
  }

  /* Header with back button */
  .playlist-modal-large .playlist-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .playlist-modal-large .playlist-modal-header h2 {
    flex: 1;
    text-align: center;
    margin: 0;
  }

  /* Back button */
  .back-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    color: #fff;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .back-btn:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* Now Playing Strip */
  .now-playing-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.75rem 1.5rem;
    background: linear-gradient(90deg, rgba(220, 38, 38, 0.15), rgba(220, 38, 38, 0.1));
    border-bottom: 1px solid rgba(220, 38, 38, 0.3);
    margin-bottom: 1rem;
  }

  .now-playing-strip.hidden {
    display: none;
  }

  .now-playing-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 1px;
    color: #dc2626;
    text-transform: uppercase;
  }

  .now-playing-pulse {
    width: 8px;
    height: 8px;
    background: #dc2626;
    border-radius: 50%;
    animation: pulse 1.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .now-playing-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: #fff;
  }

  .now-playing-dj {
    font-weight: 600;
    color: #60a5fa;
  }

  .now-playing-separator {
    color: rgba(255, 255, 255, 0.3);
  }

  .now-playing-title {
    color: rgba(255, 255, 255, 0.8);
    max-width: 300px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Two Column Layout */
  .playlist-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    flex: 1;
    overflow: hidden;
  }

  .playlist-column {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .queue-column {
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    padding-right: 1.5rem;
  }

  .my-playlist-column {
    padding-left: 0.5rem;
  }

  /* Split container for queue list + video preview */
  .queue-split-container {
    display: flex;
    gap: 1rem;
    flex: 1;
    min-height: 0;
    max-height: 65vh;
    overflow: hidden;
  }

  .queue-list-side {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
  }

  .queue-preview-side {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    max-height: 100%;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 12px;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .preview-header {
    margin-bottom: 0.75rem;
  }

  .preview-header h3 {
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
    margin: 0;
  }

  .queue-video-preview {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 8px;
    overflow: hidden;
    width: 100%;
    flex: 1;
    min-height: 0;
  }

  .preview-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
    padding: 1rem;
  }

  .preview-empty svg {
    opacity: 0.4;
  }

  .preview-empty p {
    font-size: 0.85rem;
    margin: 0;
  }

  .preview-player-container {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .preview-player-container iframe,
  .preview-player-container video {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border: none;
    aspect-ratio: 16/9;
  }

  .preview-thumbnail-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    border-radius: 8px;
    overflow: hidden;
  }

  .preview-thumbnail-wrapper img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .preview-playing-indicator {
    position: absolute;
    bottom: 12px;
    left: 12px;
    display: flex;
    gap: 3px;
    align-items: flex-end;
    height: 20px;
    padding: 6px 10px;
    background: rgba(0, 0, 0, 0.7);
    border-radius: 4px;
  }

  .playing-bar {
    width: 4px;
    background: #22c55e;
    border-radius: 2px;
    animation: playingBars 0.8s ease-in-out infinite;
  }

  .playing-bar:nth-child(1) {
    height: 8px;
    animation-delay: 0s;
  }

  .playing-bar:nth-child(2) {
    height: 14px;
    animation-delay: 0.2s;
  }

  .playing-bar:nth-child(3) {
    height: 10px;
    animation-delay: 0.4s;
  }

  @keyframes playingBars {
    0%, 100% {
      transform: scaleY(0.5);
    }
    50% {
      transform: scaleY(1);
    }
  }

  .preview-no-thumb {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 8px;
    color: rgba(255, 255, 255, 0.3);
  }

  .preview-track-info {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Recently Played Section */
  .recently-played-section {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .recently-played-header h4 {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.5rem 0;
  }

  .recently-played-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .recently-played-empty {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
    padding: 1rem;
  }

  .recently-played-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .recently-played-item:hover {
    background: rgba(255, 255, 255, 0.06);
  }

  .recently-played-number {
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.3);
    min-width: 18px;
    text-align: center;
  }

  .recently-played-info {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .recently-played-title {
    font-size: 0.75rem;
    font-weight: 500;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .recently-played-dj {
    font-size: 0.65rem;
    color: #60a5fa;
  }

  .recently-played-time {
    font-size: 0.65rem;
    color: rgba(156, 163, 175, 0.8);
    flex-shrink: 0;
    text-align: right;
  }

  .preview-track-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: #dc2626;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 0.25rem;
  }

  .preview-track-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .preview-track-dj {
    font-size: 0.75rem;
    color: #60a5fa;
    flex: 1;
    min-width: 0;
  }

  .preview-duration-box {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid #333;
    border-radius: 6px;
    padding: 0.25rem 0.5rem;
    flex-shrink: 0;
  }

  .preview-duration-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #666;
  }

  .preview-duration-value {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: #dc2626;
    font-variant-numeric: tabular-nums;
    min-width: 35px;
    text-align: left;
  }

  /* Add section styling */
  .playlist-modal-large .playlist-add-section {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    padding: 1rem 0;
    margin-bottom: 1rem;
  }

  /* Input group */
  .playlist-modal-large .playlist-input-group {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    width: 100%;
    position: relative;
  }

  .playlist-modal-large .playlist-url-input {
    flex: 1;
    padding: 1rem 3rem 1rem 1rem;
    font-size: 1rem;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.1);
    border: 2px solid rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  .playlist-modal-large .playlist-url-input:focus {
    outline: none;
    border-color: #3b82f6;
  }

  .playlist-modal-large .playlist-url-input:focus-visible {
    outline: 2px solid #60a5fa;
    outline-offset: 2px;
  }

  .playlist-modal-large .playlist-url-input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  /* Clear input button */
  .clear-input-btn {
    position: absolute;
    right: 90px;
    padding: 0.5rem;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .clear-input-btn:hover {
    background: rgba(220, 38, 38, 0.3);
    color: #dc2626;
  }

  .clear-input-btn.hidden {
    display: none;
  }

  /* Button group for input */
  .input-button-group {
    display: flex;
    gap: 0.5rem;
  }

  /* Add to Queue button */
  .playlist-modal-large .add-to-playlist-btn {
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    border-radius: 10px;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    border: none;
    color: #fff;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .playlist-modal-large .add-to-playlist-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(34, 197, 94, 0.4);
  }

  /* Save for Later button */
  .save-for-later-btn {
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    border-radius: 10px;
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    border: none;
    color: #fff;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .save-for-later-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(37, 99, 235, 0.4);
  }

  /* Queue header styling */
  .playlist-modal-large .playlist-queue-header {
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
  }

  .playlist-modal-large .playlist-queue-header h3 {
    margin: 0;
    font-size: 1.25rem;
    color: #fff;
  }

  /* Compact list for queue items - all 10 visible */
  .playlist-queue-grid {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.5rem 0;
    flex: 1;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(59, 130, 246, 0.5) transparent;
  }

  .playlist-queue-grid::-webkit-scrollbar {
    width: 4px;
  }

  .playlist-queue-grid::-webkit-scrollbar-track {
    background: transparent;
  }

  .playlist-queue-grid::-webkit-scrollbar-thumb {
    background: rgba(59, 130, 246, 0.5);
    border-radius: 2px;
  }

  /* Modal body fills available space */
  .playlist-modal-large .playlist-modal-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 1.5rem 2rem;
    overflow: hidden;
  }

  /* Freshwax branded footer */
  .playlist-modal-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: #0a0a12;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
    min-height: 44px;
  }

  .playlist-modal-footer .footer-logo {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .playlist-modal-footer .footer-fresh {
    color: #ffffff;
  }

  .playlist-modal-footer .footer-wax {
    color: #ef4444;
  }

  .playlist-modal-footer .footer-tagline {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 400;
  }

  /* Queue item card style - compact rows for all items */
  .playlist-grid-item {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    background: rgba(20, 20, 35, 0.9) !important;
    border: 1px solid rgba(255, 255, 255, 0.15) !important;
    border-radius: 6px !important;
    overflow: hidden !important;
    transition: all 0.2s ease;
    height: 50px !important;
    padding: 0 !important;
  }

  .playlist-grid-item::before {
    display: none !important;
    content: none !important;
  }

  .playlist-grid-item:hover {
    border-color: rgba(255, 255, 255, 0.3) !important;
    background: rgba(30, 30, 50, 0.95) !important;
  }

  /* Compact thumbnail for all items */
  .playlist-grid-item .playlist-grid-thumb {
    width: 70px !important;
    min-width: 70px !important;
    max-width: 70px !important;
    height: 50px !important;
    aspect-ratio: auto !important;
  }

  /* Active/now playing item - highlight but keep compact */
  .playlist-grid-item.active {
    border-color: #dc2626 !important;
    border-width: 2px !important;
    background: rgba(220, 38, 38, 0.15) !important;
    height: 50px !important;
    flex-direction: row !important;
  }

  .playlist-grid-item.active::before {
    display: none !important;
    content: none !important;
  }

  .playlist-grid-thumb {
    position: relative;
    background: #0a0a15;
    overflow: hidden;
  }

  .playlist-grid-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .playlist-grid-thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0a0a15 0%, #1f2937 100%);
    color: rgba(59, 130, 246, 0.4);
  }

  .playlist-grid-thumb-placeholder svg {
    width: 24px;
    height: 24px;
  }

  .playlist-grid-info {
    padding: 0.25rem 0.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
    flex: 1;
    overflow: hidden;
    min-width: 0;
  }

  .playlist-grid-title {
    font-size: 0.7rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .playlist-grid-platform {
    font-size: 0.55rem;
    color: #dc2626;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 700;
  }

  .playlist-grid-addedby {
    font-size: 0.55rem;
    color: #22c55e;
  }

  .playlist-grid-addedby strong {
    font-weight: 700;
    color: #4ade80;
  }

  /* Actions - shown inline at end of row */
  .playlist-grid-actions {
    display: flex;
    gap: 0.25rem;
    padding-right: 0.5rem;
    flex-shrink: 0;
  }

  .playlist-action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
    padding: 0.4rem 0.5rem;
    border: none;
    border-radius: 4px;
    font-size: 0.55rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    min-width: 32px;
    min-height: 32px;
  }

  .playlist-action-btn svg {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }

  .playlist-copy-btn {
    background: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.2);
  }

  .playlist-copy-btn:hover {
    background: rgba(59, 130, 246, 0.3);
    border-color: rgba(59, 130, 246, 0.4);
  }

  .playlist-remove-btn {
    background: rgba(239, 68, 68, 0.15);
    color: #f87171;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  .playlist-remove-btn:hover {
    background: rgba(239, 68, 68, 0.3);
    border-color: rgba(239, 68, 68, 0.4);
  }

  .playlist-save-btn {
    background: rgba(139, 92, 246, 0.15);
    color: #a78bfa;
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .playlist-save-btn:hover {
    background: rgba(139, 92, 246, 0.3);
    border-color: rgba(139, 92, 246, 0.4);
  }

  .playlist-save-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .playlist-save-btn .spinning {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Controls section */
  .playlist-controls {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: 0.5rem;
    padding-top: 0.75rem;
  }

  .playlist-controls-simple {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 0.5rem 0;
  }

  .control-btn-large {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    box-shadow: 0 4px 15px rgba(220, 38, 38, 0.3);
  }

  .control-btn-large:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(220, 38, 38, 0.4);
  }

  .volume-control {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: #888;
  }

  .volume-control svg {
    opacity: 0.7;
  }

  .volume-slider {
    width: 100px;
    height: 5px;
    -webkit-appearance: none;
    appearance: none;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    outline: none;
    cursor: pointer;
  }

  .volume-slider:focus-visible {
    outline: 2px solid #60a5fa;
    outline-offset: 2px;
  }

  .volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 14px;
    background: #3b82f6;
    border-radius: 50%;
    cursor: pointer;
    transition: transform 0.2s ease;
    box-shadow: 0 2px 6px rgba(59, 130, 246, 0.4);
  }

  .volume-slider::-webkit-slider-thumb:hover {
    transform: scale(1.15);
  }

  .volume-slider::-moz-range-thumb {
    width: 14px;
    height: 14px;
    background: #3b82f6;
    border: none;
    border-radius: 50%;
    cursor: pointer;
  }

  .playlist-status {
    text-align: center;
    padding: 0.25rem 0;
  }

  .playlist-status span {
    font-size: 0.75rem;
    color: rgba(156, 163, 175, 0.8);
    font-weight: 500;
  }

  /* Empty state */
  .playlist-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 2rem;
    color: #666;
  }

  .playlist-empty svg {
    opacity: 0.3;
    margin-bottom: 0.75rem;
  }

  .playlist-empty p {
    margin: 0.25rem 0;
  }

  .playlist-empty-hint {
    font-size: 0.8rem;
    opacity: 0.6;
  }

  /* Auth notice for non-logged in users */
  .playlist-auth-notice {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: rgba(251, 191, 36, 0.1);
    border: 1px solid rgba(251, 191, 36, 0.3);
    border-radius: 8px;
    color: #fbbf24;
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .playlist-auth-notice svg {
    flex-shrink: 0;
  }

  /* Position indicator for DJ waitlist */
  .position-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1rem;
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.15), rgba(59, 130, 246, 0.15));
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 10px;
    margin: 0 auto 1rem;
    max-width: 400px;
  }

  .position-indicator span {
    font-size: 1rem;
    font-weight: 600;
    color: #60a5fa;
  }

  .position-indicator.hidden {
    display: none;
  }

  .position-indicator.your-turn {
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.2), rgba(22, 163, 74, 0.2));
    border-color: rgba(34, 197, 94, 0.4);
  }

  .position-indicator.your-turn span {
    color: #4ade80;
  }

  /* DJ name display - inline */
  .dj-name-display {
    font-size: 0.6rem;
    font-weight: 600;
    color: #60a5fa;
    white-space: nowrap;
  }

  /* Position badge for items */
  .dj-position-badge {
    position: absolute;
    top: 2px;
    left: 2px;
    background: rgba(0, 0, 0, 0.85);
    color: #60a5fa;
    font-size: 0.5rem;
    font-weight: 700;
    padding: 1px 4px;
    border-radius: 3px;
    z-index: 2;
  }

  /* Make grid items relative for badge positioning */
  .playlist-grid-item {
    position: relative;
  }

  /* Highlight user's track in queue - subtle indicator only */
  .playlist-grid-item.your-track:not(.active) {
    border-color: rgba(59, 130, 246, 0.3);
  }

  .playlist-grid-item.your-track .dj-name-display {
    color: #93c5fd;
  }

  /* Your Track Playing indicator - above Now Playing preview */
  .your-track-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1rem;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.25), rgba(22, 163, 74, 0.25));
    border: 2px solid rgba(34, 197, 94, 0.5);
    border-radius: 10px;
    margin-bottom: 0.75rem;
    animation: pulseGreen 2s ease-in-out infinite;
  }

  .your-track-indicator.hidden {
    display: none;
  }

  .your-track-indicator span {
    font-size: 0.9rem;
    font-weight: 700;
    color: #4ade80;
    letter-spacing: 0.5px;
  }

  @keyframes pulseGreen {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
    50% { box-shadow: 0 0 0 8px rgba(34, 197, 94, 0); }
  }

  /* My Playlist Section - Full height in right column */
  .my-playlist-section {
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
    text-align: left;
  }

  .my-playlist-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    width: 100%;
  }

  .my-playlist-title-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .my-playlist-header h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
    text-align: left;
  }

  .my-playlist-count-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid #333;
    border-radius: 6px;
    padding: 0.25rem 0.6rem;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: #dc2626;
    min-width: 28px;
  }

  .playlist-sort-select {
    background: #1f1f1f !important;
    border: 1px solid #666 !important;
    border-radius: 6px;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    color: #bbb !important;
    cursor: pointer;
    outline: none;
  }

  .playlist-sort-select:hover {
    border-color: #777 !important;
    color: #ddd !important;
  }

  .playlist-sort-select:focus {
    border-color: #888 !important;
  }

  .playlist-sort-select:focus-visible {
    outline: 2px solid #60a5fa;
    outline-offset: 2px;
  }

  .playlist-sort-select option {
    background: #1f1f1f !important;
    color: #bbb !important;
  }

  .playlist-layout-toggle {
    display: flex;
    gap: 0.25rem;
  }

  .layout-btn {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid #333;
    border-radius: 4px;
    padding: 0.25rem;
    cursor: pointer;
    color: #666;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .layout-btn:hover {
    border-color: #444;
    color: #999;
  }

  .layout-btn.active {
    background: rgba(220, 38, 38, 0.2);
    border-color: #dc2626;
    color: #dc2626;
  }

  .my-playlist-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .clear-playlist-btn {
    padding: 0.4rem 0.8rem;
    font-size: 0.75rem;
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 6px;
    color: #f87171;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .clear-playlist-btn:hover {
    background: rgba(239, 68, 68, 0.25);
  }

  .export-playlist-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.8rem;
    font-size: 0.75rem;
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 6px;
    color: #4ade80;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .export-playlist-btn:hover {
    background: rgba(34, 197, 94, 0.25);
  }

  .export-playlist-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Export Modal */
  .export-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .export-modal.hidden {
    display: none;
  }

  .export-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
  }

  .export-modal-content {
    position: relative;
    background: #1a1a2e;
    border: 2px solid #333;
    border-radius: 16px;
    padding: 0;
    max-width: 400px;
    width: 90%;
    animation: modalSlideIn 0.2s ease;
  }

  @keyframes modalSlideIn {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

  .export-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #333;
  }

  .export-modal-header h3 {
    margin: 0;
    font-size: 1.1rem;
    color: #fff;
  }

  .export-modal-close {
    background: none;
    border: none;
    color: #666;
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }

  .export-modal-close:hover {
    color: #fff;
  }

  .export-modal-body {
    padding: 1.25rem;
  }

  .export-field {
    margin-bottom: 1rem;
  }

  .export-field label {
    display: block;
    font-size: 0.8rem;
    color: #d1d5db;
    margin-bottom: 0.5rem;
  }

  .export-field input[type="text"] {
    width: 100%;
    padding: 0.6rem 0.75rem;
    background: #0a0a15;
    border: 1px solid #333;
    border-radius: 6px;
    color: #fff;
    font-size: 0.85rem;
  }

  .export-field input[type="text"]:focus {
    outline: none;
    border-color: #4ade80;
  }

  .export-field input[type="text"]:focus-visible {
    outline: 2px solid #60a5fa;
    outline-offset: 2px;
  }

  .export-formats {
    display: flex;
    gap: 0.5rem;
  }

  .format-option {
    flex: 1;
    cursor: pointer;
  }

  .format-option input {
    display: none;
  }

  .format-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.6rem 0.5rem;
    background: #0a0a15;
    border: 1px solid #333;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .format-option input:checked + .format-label {
    border-color: #4ade80;
    background: rgba(34, 197, 94, 0.1);
  }

  .format-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
  }

  .format-desc {
    font-size: 0.65rem;
    color: #666;
    margin-top: 0.15rem;
  }

  .export-info {
    text-align: center;
    font-size: 0.8rem;
    color: #d1d5db;
    margin-bottom: 1rem;
  }

  .export-info span {
    color: #4ade80;
    font-weight: 600;
  }

  .confirm-export-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    border: none;
    border-radius: 8px;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .confirm-export-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
  }

  .export-modal-divider {
    height: 1px;
    background: #333;
    margin: 0;
  }

  .export-modal-danger {
    padding: 1rem 1.25rem;
    background: rgba(239, 68, 68, 0.05);
  }

  .export-modal-danger h4 {
    margin: 0 0 0.25rem 0;
    font-size: 0.8rem;
    color: #f87171;
  }

  .export-modal-danger p {
    margin: 0 0 0.75rem 0;
    font-size: 0.75rem;
    color: #d1d5db;
  }

  .clear-playlist-danger-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.75rem;
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 6px;
    color: #f87171;
    cursor: pointer;
    transition: all 0.2s;
  }

  .clear-playlist-danger-btn:hover {
    background: rgba(239, 68, 68, 0.25);
  }

  .clear-confirmation {
    padding: 1rem 1.25rem;
    background: rgba(239, 68, 68, 0.1);
    border-top: 1px solid rgba(239, 68, 68, 0.2);
  }

  .clear-confirmation.hidden {
    display: none;
  }

  .clear-confirmation p {
    margin: 0 0 0.75rem 0;
    font-size: 0.85rem;
    color: #f87171;
    text-align: center;
  }

  .clear-confirmation span {
    font-weight: 600;
  }

  .clear-confirm-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }

  .cancel-clear-btn {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    background: rgba(75, 85, 99, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 6px;
    color: #e5e7eb;
    cursor: pointer;
    transition: all 0.2s;
  }

  .cancel-clear-btn:hover {
    background: rgba(75, 85, 99, 0.7);
  }

  .confirm-clear-btn {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    background: #dc2626;
    border: none;
    border-radius: 6px;
    color: #fff;
    cursor: pointer;
    transition: all 0.2s;
  }

  .confirm-clear-btn:hover {
    background: #b91c1c;
  }

  .back-to-stream-btn {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.4rem 0.8rem;
    font-size: 0.75rem;
    background: rgba(59, 130, 246, 0.15);
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 6px;
    color: #60a5fa;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .back-to-stream-btn:hover {
    background: rgba(59, 130, 246, 0.25);
  }

  .back-to-stream-btn svg {
    flex-shrink: 0;
  }

  /* Playlist pagination tabs */
  .my-playlist-pagination {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .my-playlist-pagination.hidden {
    display: none;
  }

  .playlist-page-btn {
    padding: 0.35rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 600;
    background: transparent;
    border: 1px solid #1e3a5a;
    border-radius: 6px;
    color: #d1d5db;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .playlist-page-btn:hover {
    background: rgba(30, 58, 90, 0.3);
    border-color: #2563eb;
    color: #e5e7eb;
  }

  .playlist-page-btn.active {
    background: rgba(30, 58, 90, 0.4);
    border-color: #3b82f6;
    color: #93c5fd;
  }

  .my-playlist-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    overflow-y: auto;
    width: 100%;
    scrollbar-width: thin;
    scrollbar-color: rgba(59, 130, 246, 0.5) transparent;
  }

  .my-playlist-grid.grid-mode {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.3rem;
  }

  .my-playlist-grid.grid-mode .personal-playlist-item {
    padding: 0.3rem;
    gap: 0.3rem;
  }

  .my-playlist-grid.grid-mode .personal-item-thumb {
    width: 36px;
    height: 27px;
    flex-shrink: 0;
  }

  .my-playlist-grid.grid-mode .personal-item-info {
    flex: 1;
    min-width: 0;
    gap: 0.1rem;
  }

  .my-playlist-grid.grid-mode .personal-item-title {
    font-size: 0.65rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .my-playlist-grid.grid-mode .personal-item-meta {
    font-size: 0.55rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .my-playlist-grid.grid-mode .personal-item-actions {
    gap: 0.15rem;
    flex-shrink: 0;
  }

  .my-playlist-grid.grid-mode .personal-item-actions button {
    padding: 0.15rem 0.35rem;
    font-size: 0.6rem;
  }

  .my-playlist-grid::-webkit-scrollbar {
    width: 6px;
  }

  .my-playlist-grid::-webkit-scrollbar-track {
    background: transparent;
  }

  .my-playlist-grid::-webkit-scrollbar-thumb {
    background: rgba(59, 130, 246, 0.5);
    border-radius: 3px;
  }

  .my-playlist-grid .playlist-empty {
    grid-column: unset;
    text-align: center;
    padding: 1.5rem;
    color: #666;
  }

  .my-playlist-grid .playlist-empty p {
    margin: 0.25rem 0;
  }

  /* Personal playlist item - horizontal compact style */
  .personal-playlist-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem;
    background: rgba(31, 41, 55, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    transition: all 0.2s ease;
    width: 85%;
    margin: 0 auto;
  }

  .personal-playlist-item:hover {
    background: rgba(55, 65, 81, 0.5);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .personal-item-thumb {
    width: 60px;
    height: 40px;
    border-radius: 4px;
    overflow: hidden;
    flex-shrink: 0;
    background: #0a0a15;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .personal-item-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .personal-item-thumb svg {
    width: 24px;
    height: 24px;
  }

  .personal-item-info {
    flex: 1;
    min-width: 0;
    text-align: left;
  }

  .personal-item-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: left;
  }

  .personal-item-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
  }

  .personal-item-platform {
    color: rgba(156, 163, 175, 0.8);
    text-transform: uppercase;
    text-align: left;
  }

  .personal-item-date {
    color: rgba(156, 163, 175, 0.6);
  }

  .personal-item-date::before {
    content: '•';
    margin-right: 0.5rem;
    color: rgba(156, 163, 175, 0.4);
  }

  .personal-item-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .personal-add-btn {
    padding: 0.4rem 0.7rem;
    font-size: 0.7rem;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    border: none;
    border-radius: 5px;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: all 0.2s ease;
  }

  .personal-add-btn:hover {
    transform: scale(1.05);
  }

  .personal-add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .personal-delete-btn {
    padding: 0.4rem 0.5rem;
    font-size: 0.7rem;
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 5px;
    color: #f87171;
    cursor: pointer;
    display: flex;
    align-items: center;
    transition: all 0.2s ease;
  }

  .personal-delete-btn:hover {
    background: rgba(239, 68, 68, 0.25);
  }

  /* Added by name */
  .playlist-grid-addedby {
    font-size: 0.6rem;
    color: rgba(156, 163, 175, 0.6);
    margin-top: 0.2rem;
  }

  .playlist-grid-addedby strong {
    color: rgba(156, 163, 175, 0.9);
  }

  /* Tablet: stack columns */
  @media (max-width: 900px) {
    .playlist-columns {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .queue-column {
      border-right: none;
      padding-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      padding-bottom: 1.5rem;
    }

    .my-playlist-column {
      padding-left: 0;
    }

    .playlist-queue-grid {
      max-height: 40vh;
    }

    .my-playlist-grid {
      max-height: 30vh;
    }

    /* Stack queue list and preview vertically on tablet */
    .queue-split-container {
      flex-direction: column;
    }

    .queue-preview-side {
      min-height: 250px;
      max-height: 300px;
    }
  }

  /* Mobile: single column */
  @media (max-width: 640px) {
    .playlist-queue-grid {
      grid-template-columns: 1fr;
      max-height: 35vh;
    }

    .playlist-modal-large {
      width: 100%;
      max-width: 100%;
      height: 100vh;
      max-height: 100vh;
      border-radius: 0;
    }

    .playlist-modal-large .playlist-modal-body {
      padding: 1rem;
    }

    .playlist-controls-simple {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .volume-slider {
      width: 120px;
    }

    .playlist-grid-title {
      font-size: 0.85rem;
    }

    .now-playing-strip {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }

    .now-playing-info {
      flex-wrap: wrap;
      justify-content: center;
    }

    .now-playing-title {
      max-width: 200px;
    }

    .input-button-group {
      width: 100%;
      justify-content: stretch;
    }

    .input-button-group button {
      flex: 1;
    }
  }
</style>

<script>
  // Fully lazy-loaded: the playlist modal JS (~78KB) and HTML are only loaded
  // when the user clicks the playlist button. No idle preloading.
  let _playlistModuleLoaded = false;
  let _playlistModuleLoading = false;

  async function loadPlaylistModule(options?: { silent?: boolean } | Event) {
    if (_playlistModuleLoaded) return;
    if (_playlistModuleLoading) return; // Prevent double-loading from rapid clicks
    _playlistModuleLoading = true;

    // silent mode: init the manager without showing the modal UI (used by playlist fallback)
    const silent = options && !(options instanceof Event) && options.silent;

    if (!silent) {
      // Show the modal container with loading spinner
      const modal = document.getElementById('playlistModal');
      if (modal) {
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
    }

    try {
      const { initPlaylistModal } = await import('../../lib/playlist-modal-init');
      initPlaylistModal();
      _playlistModuleLoaded = true;
    } catch (err) {
      console.error('[PlaylistModal] Failed to load module:', err);
      if (!silent) {
        const loader = document.getElementById('playlistModalLoader');
        if (loader) {
          loader.innerHTML = '<span style="color: #f87171;">Failed to load playlist. Please try again.</span>';
        }
      }
      _playlistModuleLoading = false;
      return;
    }
    _playlistModuleLoading = false;
  }

  // Expose globally so playlist fallback can trigger init without button click
  window.loadPlaylistModule = loadPlaylistModule;

  // Only load when playlist button is clicked — no idle preloading
  function attachPlaylistListener() {
    const btn = document.getElementById('playlistBtn');
    if (btn && !btn.dataset.playlistListenerAttached) {
      btn.dataset.playlistListenerAttached = 'true';
      btn.addEventListener('click', loadPlaylistModule);
    }
  }

  // Attach listener on initial load
  attachPlaylistListener();

  // Re-attach on View Transitions navigation
  document.addEventListener('astro:page-load', () => {
    _playlistModuleLoaded = false;
    _playlistModuleLoading = false;
    attachPlaylistListener();
  });
</script>
