---
// src/components/live/PlaylistModal.astro
// Playlist modal for adding and managing media queue
---

<div id="playlistModal" class="playlist-modal hidden">
  <div class="playlist-modal-backdrop"></div>
  <div class="playlist-modal-content playlist-modal-large">
    <div class="playlist-modal-header">
      <button id="backFromPlaylist" class="back-btn" aria-label="Back to stream">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        <span>Back</span>
      </button>
      <h2>Playlist</h2>
      <button id="closePlaylistModal" class="close-btn" aria-label="Close playlist">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="playlist-modal-body">
      <!-- Now Playing Strip - shows when a track is active -->
      <div id="nowPlayingStrip" class="now-playing-strip hidden">
        <div class="now-playing-label">
          <span class="now-playing-pulse"></span>
          NOW PLAYING
        </div>
        <div class="now-playing-info">
          <span id="nowPlayingTitle" class="now-playing-title">--</span>
        </div>
      </div>

      <!-- Two Column Layout for Queue and My Playlist -->
      <div class="playlist-columns">
        <!-- Left Column: Queue Section (split into queue list + video preview) -->
        <div class="playlist-column queue-column">
          <!-- URL Input - Only for logged in users -->
          <div class="playlist-add-section">
            <div id="playlistAuthNotice" class="playlist-auth-notice hidden">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
              </svg>
              <span>Sign in to add videos to the playlist</span>
            </div>
            <div id="playlistInputGroup" class="playlist-input-group">
              <input
                type="url"
                id="playlistUrlInput"
                class="playlist-url-input"
                placeholder="Paste a YouTube Or SoundCloud Link Here..."
                autocomplete="off"
              />
              <button id="clearPlaylistInput" class="clear-input-btn hidden" title="Clear input">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </button>
              <div class="input-button-group">
                <button id="addToPlaylistBtn" class="add-to-playlist-btn" title="Add to Playlist Queue">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="5 3 19 12 5 21 5 3"></polygon>
                  </svg>
                  Queue
                </button>
                <button id="saveForLaterBtn" class="save-for-later-btn" title="Save to My Playlist for later">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                  </svg>
                  Save
                </button>
              </div>
            </div>
            <div id="playlistError" class="playlist-error hidden"></div>
            <div id="playlistSuccess" class="playlist-success hidden"></div>
          </div>

          <!-- Split container: Queue List + Video Preview -->
          <div class="queue-split-container">
            <!-- Queue List Side -->
            <div class="queue-list-side">
              <div class="playlist-queue-header">
                <h3>Playlist Queue <span id="queueCount" class="queue-count">0/10</span></h3>
              </div>

              <!-- Position Indicator - centered above the queue -->
              <div id="positionIndicator" class="position-indicator hidden">
                <span id="positionText"></span>
              </div>

              <div id="playlistQueue" class="playlist-queue-grid">
                <div class="playlist-empty">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <polygon points="5 3 19 12 5 21 5 3"></polygon>
                  </svg>
                  <p>Playlist is empty</p>
                  <p class="playlist-empty-hint">Add a track to join</p>
                </div>
              </div>
            </div>

            <!-- Now Playing Info Side -->
            <div class="queue-preview-side">
              <!-- Position Indicator (Your Track Playing) - shown above Now Playing when it's your turn -->
              <div id="yourTrackIndicator" class="your-track-indicator hidden">
                <span id="yourTrackText">🎧 YOUR TRACK IS PLAYING</span>
              </div>
              <div class="preview-header">
                <h3>Now Playing</h3>
              </div>
              <div id="previewTrackInfo" class="preview-track-info">
                <div class="preview-track-title" id="previewTrackTitle">--</div>
                <div class="preview-track-bottom">
                  <div class="preview-track-dj" id="previewTrackDj">Selector: --</div>
                  <div class="preview-duration-box" id="previewDurationBox">
                    <span class="preview-duration-value" id="previewDuration">--:--</span>
                    <span class="preview-duration-label">LEFT</span>
                  </div>
                </div>
              </div>

              <!-- Recently Played -->
              <div class="recently-played-section">
                <div class="recently-played-header">
                  <h4>Recently Played</h4>
                </div>
                <div id="recentlyPlayedList" class="recently-played-list">
                  <div class="recently-played-empty">No tracks played yet</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: My Playlist Section -->
        <div class="playlist-column my-playlist-column">
          <div id="myPlaylistSection" class="my-playlist-section" style="display: flex;">
            <div class="my-playlist-header">
              <div class="my-playlist-title-group">
                <h3>My Playlist</h3>
                <span id="myPlaylistCount" class="my-playlist-count-box">0</span>
              </div>
              <div class="my-playlist-actions">
                <select id="playlistSortSelect" class="playlist-sort-select">
                  <option value="recent">Recently Added</option>
                  <option value="oldest">Oldest First</option>
                  <option value="alpha-az">A-Z</option>
                  <option value="alpha-za">Z-A</option>
                </select>
                <div class="playlist-layout-toggle">
                  <button id="layoutSingleBtn" class="layout-btn active" title="Single column">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="3" width="18" height="4" rx="1"></rect>
                      <rect x="3" y="10" width="18" height="4" rx="1"></rect>
                      <rect x="3" y="17" width="18" height="4" rx="1"></rect>
                    </svg>
                  </button>
                  <button id="layoutGridBtn" class="layout-btn" title="Two columns">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="3" width="7" height="7" rx="1"></rect>
                      <rect x="14" y="3" width="7" height="7" rx="1"></rect>
                      <rect x="3" y="14" width="7" height="7" rx="1"></rect>
                      <rect x="14" y="14" width="7" height="7" rx="1"></rect>
                    </svg>
                  </button>
                </div>
                <button id="exportPlaylistBtn" class="export-playlist-btn" title="Export playlist">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                  </svg>
                  Export
                </button>
                <button id="backToStreamBtn" class="back-to-stream-btn" title="Back to stream">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="15 18 9 12 15 6"></polyline>
                  </svg>
                  Back
                </button>
              </div>
            </div>

            <!-- Export Playlist Modal -->
            <div id="exportModal" class="export-modal hidden">
              <div class="export-modal-backdrop"></div>
              <div class="export-modal-content">
                <div class="export-modal-header">
                  <h3>Export Playlist</h3>
                  <button id="closeExportModal" class="export-modal-close">&times;</button>
                </div>

                <div class="export-modal-body">
                  <div class="export-field">
                    <label for="exportTitle">Playlist Title</label>
                    <input type="text" id="exportTitle" placeholder="My Fresh Wax Playlist" />
                  </div>

                  <div class="export-field">
                    <label>Export Format</label>
                    <div class="export-formats">
                      <label class="format-option">
                        <input type="radio" name="exportFormat" value="txt" checked />
                        <span class="format-label">
                          <span class="format-name">TXT</span>
                          <span class="format-desc">Plain text file</span>
                        </span>
                      </label>
                      <label class="format-option">
                        <input type="radio" name="exportFormat" value="csv" />
                        <span class="format-label">
                          <span class="format-name">CSV</span>
                          <span class="format-desc">Spreadsheet</span>
                        </span>
                      </label>
                      <label class="format-option">
                        <input type="radio" name="exportFormat" value="pdf" />
                        <span class="format-label">
                          <span class="format-name">PDF</span>
                          <span class="format-desc">Printable</span>
                        </span>
                      </label>
                    </div>
                  </div>

                  <div class="export-info">
                    <span id="exportTrackCount">0</span> tracks will be exported
                  </div>

                  <button id="confirmExportBtn" class="confirm-export-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="7 10 12 15 17 10"></polyline>
                      <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                    Download Playlist
                  </button>
                </div>

                <div class="export-modal-divider"></div>

                <div class="export-modal-danger">
                  <h4>Danger Zone</h4>
                  <p>Clear all tracks from your playlist. This cannot be undone.</p>
                  <button id="clearPlaylistBtn" class="clear-playlist-danger-btn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M3 6h18"></path>
                      <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    </svg>
                    Clear Playlist
                  </button>
                </div>

                <!-- Clear Confirmation (hidden by default) -->
                <div id="clearConfirmation" class="clear-confirmation hidden">
                  <p>Are you sure? This will remove all <span id="clearItemCount">0</span> tracks.</p>
                  <div class="clear-confirm-actions">
                    <button id="cancelClearBtn" class="cancel-clear-btn">Cancel</button>
                    <button id="confirmClearBtn" class="confirm-clear-btn">Yes, Clear All</button>
                  </div>
                </div>
              </div>
            </div>
            <!-- Pagination tabs for large playlists (20+ items) -->
            <div id="myPlaylistPagination" class="my-playlist-pagination hidden"></div>
            <div id="myPlaylistGrid" class="my-playlist-grid">
              <div class="playlist-empty">
                <p>Your playlist is empty</p>
                <p class="playlist-empty-hint">Save tracks for later</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Freshwax Footer -->
    <div class="playlist-modal-footer">
      <span class="footer-logo"><span class="footer-fresh">Fresh</span><span class="footer-wax">Wax</span></span>
      <span class="footer-tagline">community playlist</span>
    </div>

  </div>
</div>

<style is:global>
  /* Full page modal */
  .playlist-modal-large {
    width: 100%;
    max-width: 100%;
    height: 100vh;
    max-height: 100vh;
    border-radius: 0;
    overflow: hidden;
  }

  /* Header with back button */
  .playlist-modal-large .playlist-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .playlist-modal-large .playlist-modal-header h2 {
    flex: 1;
    text-align: center;
    margin: 0;
  }

  /* Back button */
  .back-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    color: #fff;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .back-btn:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* Now Playing Strip */
  .now-playing-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.75rem 1.5rem;
    background: linear-gradient(90deg, rgba(220, 38, 38, 0.15), rgba(220, 38, 38, 0.1));
    border-bottom: 1px solid rgba(220, 38, 38, 0.3);
    margin-bottom: 1rem;
  }

  .now-playing-strip.hidden {
    display: none;
  }

  .now-playing-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 1px;
    color: #dc2626;
    text-transform: uppercase;
  }

  .now-playing-pulse {
    width: 8px;
    height: 8px;
    background: #dc2626;
    border-radius: 50%;
    animation: pulse 1.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .now-playing-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: #fff;
  }

  .now-playing-dj {
    font-weight: 600;
    color: #60a5fa;
  }

  .now-playing-separator {
    color: rgba(255, 255, 255, 0.3);
  }

  .now-playing-title {
    color: rgba(255, 255, 255, 0.8);
    max-width: 300px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Two Column Layout */
  .playlist-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    flex: 1;
    overflow: hidden;
  }

  .playlist-column {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .queue-column {
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    padding-right: 1.5rem;
  }

  .my-playlist-column {
    padding-left: 0.5rem;
  }

  /* Split container for queue list + video preview */
  .queue-split-container {
    display: flex;
    gap: 1rem;
    flex: 1;
    min-height: 0;
    max-height: 65vh;
    overflow: hidden;
  }

  .queue-list-side {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
  }

  .queue-preview-side {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    max-height: 100%;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 12px;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .preview-header {
    margin-bottom: 0.75rem;
  }

  .preview-header h3 {
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
    margin: 0;
  }

  .queue-video-preview {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 8px;
    overflow: hidden;
    width: 100%;
    flex: 1;
    min-height: 0;
  }

  .preview-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
    padding: 1rem;
  }

  .preview-empty svg {
    opacity: 0.4;
  }

  .preview-empty p {
    font-size: 0.85rem;
    margin: 0;
  }

  .preview-player-container {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .preview-player-container iframe,
  .preview-player-container video {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border: none;
    aspect-ratio: 16/9;
  }

  .preview-thumbnail-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    border-radius: 8px;
    overflow: hidden;
  }

  .preview-thumbnail-wrapper img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .preview-playing-indicator {
    position: absolute;
    bottom: 12px;
    left: 12px;
    display: flex;
    gap: 3px;
    align-items: flex-end;
    height: 20px;
    padding: 6px 10px;
    background: rgba(0, 0, 0, 0.7);
    border-radius: 4px;
  }

  .playing-bar {
    width: 4px;
    background: #22c55e;
    border-radius: 2px;
    animation: playingBars 0.8s ease-in-out infinite;
  }

  .playing-bar:nth-child(1) {
    height: 8px;
    animation-delay: 0s;
  }

  .playing-bar:nth-child(2) {
    height: 14px;
    animation-delay: 0.2s;
  }

  .playing-bar:nth-child(3) {
    height: 10px;
    animation-delay: 0.4s;
  }

  @keyframes playingBars {
    0%, 100% {
      transform: scaleY(0.5);
    }
    50% {
      transform: scaleY(1);
    }
  }

  .preview-no-thumb {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 8px;
    color: rgba(255, 255, 255, 0.3);
  }

  .preview-track-info {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Recently Played Section */
  .recently-played-section {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .recently-played-header h4 {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.5rem 0;
  }

  .recently-played-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .recently-played-empty {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
    padding: 1rem;
  }

  .recently-played-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .recently-played-item:hover {
    background: rgba(255, 255, 255, 0.06);
  }

  .recently-played-number {
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.3);
    min-width: 18px;
    text-align: center;
  }

  .recently-played-info {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .recently-played-title {
    font-size: 0.75rem;
    font-weight: 500;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .recently-played-dj {
    font-size: 0.65rem;
    color: #60a5fa;
  }

  .recently-played-time {
    font-size: 0.65rem;
    color: rgba(156, 163, 175, 0.8);
    flex-shrink: 0;
    text-align: right;
  }

  .preview-track-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: #dc2626;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 0.25rem;
  }

  .preview-track-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .preview-track-dj {
    font-size: 0.75rem;
    color: #60a5fa;
    flex: 1;
    min-width: 0;
  }

  .preview-duration-box {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid #333;
    border-radius: 6px;
    padding: 0.25rem 0.5rem;
    flex-shrink: 0;
  }

  .preview-duration-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #666;
  }

  .preview-duration-value {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: #dc2626;
    font-variant-numeric: tabular-nums;
    min-width: 35px;
    text-align: left;
  }

  /* Add section styling */
  .playlist-modal-large .playlist-add-section {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    padding: 1rem 0;
    margin-bottom: 1rem;
  }

  /* Input group */
  .playlist-modal-large .playlist-input-group {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    width: 100%;
    position: relative;
  }

  .playlist-modal-large .playlist-url-input {
    flex: 1;
    padding: 1rem 3rem 1rem 1rem;
    font-size: 1rem;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.1);
    border: 2px solid rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  .playlist-modal-large .playlist-url-input:focus {
    outline: none;
    border-color: #3b82f6;
  }

  .playlist-modal-large .playlist-url-input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  /* Clear input button */
  .clear-input-btn {
    position: absolute;
    right: 90px;
    padding: 0.5rem;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .clear-input-btn:hover {
    background: rgba(220, 38, 38, 0.3);
    color: #dc2626;
  }

  .clear-input-btn.hidden {
    display: none;
  }

  /* Button group for input */
  .input-button-group {
    display: flex;
    gap: 0.5rem;
  }

  /* Add to Queue button */
  .playlist-modal-large .add-to-playlist-btn {
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    border-radius: 10px;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    border: none;
    color: #fff;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .playlist-modal-large .add-to-playlist-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(34, 197, 94, 0.4);
  }

  /* Save for Later button */
  .save-for-later-btn {
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    border-radius: 10px;
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    border: none;
    color: #fff;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .save-for-later-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(37, 99, 235, 0.4);
  }

  /* Queue header styling */
  .playlist-modal-large .playlist-queue-header {
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
  }

  .playlist-modal-large .playlist-queue-header h3 {
    margin: 0;
    font-size: 1.25rem;
    color: #fff;
  }

  /* Compact list for queue items - all 10 visible */
  .playlist-queue-grid {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.5rem 0;
    flex: 1;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(59, 130, 246, 0.5) transparent;
  }

  .playlist-queue-grid::-webkit-scrollbar {
    width: 4px;
  }

  .playlist-queue-grid::-webkit-scrollbar-track {
    background: transparent;
  }

  .playlist-queue-grid::-webkit-scrollbar-thumb {
    background: rgba(59, 130, 246, 0.5);
    border-radius: 2px;
  }

  /* Modal body fills available space */
  .playlist-modal-large .playlist-modal-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 1.5rem 2rem;
    overflow: hidden;
  }

  /* Freshwax branded footer */
  .playlist-modal-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: #0a0a12;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
    min-height: 44px;
  }

  .playlist-modal-footer .footer-logo {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .playlist-modal-footer .footer-fresh {
    color: #ffffff;
  }

  .playlist-modal-footer .footer-wax {
    color: #ef4444;
  }

  .playlist-modal-footer .footer-tagline {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 400;
  }

  /* Queue item card style - compact rows for all items */
  .playlist-grid-item {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    background: rgba(20, 20, 35, 0.9) !important;
    border: 1px solid rgba(255, 255, 255, 0.15) !important;
    border-radius: 6px !important;
    overflow: hidden !important;
    transition: all 0.2s ease;
    height: 50px !important;
    padding: 0 !important;
  }

  .playlist-grid-item::before {
    display: none !important;
    content: none !important;
  }

  .playlist-grid-item:hover {
    border-color: rgba(255, 255, 255, 0.3) !important;
    background: rgba(30, 30, 50, 0.95) !important;
  }

  /* Compact thumbnail for all items */
  .playlist-grid-item .playlist-grid-thumb {
    width: 70px !important;
    min-width: 70px !important;
    max-width: 70px !important;
    height: 50px !important;
    aspect-ratio: auto !important;
  }

  /* Active/now playing item - highlight but keep compact */
  .playlist-grid-item.active {
    border-color: #dc2626 !important;
    border-width: 2px !important;
    background: rgba(220, 38, 38, 0.15) !important;
    height: 50px !important;
    flex-direction: row !important;
  }

  .playlist-grid-item.active::before {
    display: none !important;
    content: none !important;
  }

  .playlist-grid-thumb {
    position: relative;
    background: #0a0a15;
    overflow: hidden;
  }

  .playlist-grid-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .playlist-grid-thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0a0a15 0%, #1f2937 100%);
    color: rgba(59, 130, 246, 0.4);
  }

  .playlist-grid-thumb-placeholder svg {
    width: 24px;
    height: 24px;
  }

  .playlist-grid-info {
    padding: 0.25rem 0.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
    flex: 1;
    overflow: hidden;
    min-width: 0;
  }

  .playlist-grid-title {
    font-size: 0.7rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .playlist-grid-platform {
    font-size: 0.55rem;
    color: #dc2626;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 700;
  }

  .playlist-grid-addedby {
    font-size: 0.55rem;
    color: #22c55e;
  }

  .playlist-grid-addedby strong {
    font-weight: 700;
    color: #4ade80;
  }

  /* Actions - shown inline at end of row */
  .playlist-grid-actions {
    display: flex;
    gap: 0.25rem;
    padding-right: 0.5rem;
    flex-shrink: 0;
  }

  .playlist-action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
    padding: 0.4rem 0.5rem;
    border: none;
    border-radius: 4px;
    font-size: 0.55rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    min-width: 32px;
    min-height: 32px;
  }

  .playlist-action-btn svg {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }

  .playlist-copy-btn {
    background: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.2);
  }

  .playlist-copy-btn:hover {
    background: rgba(59, 130, 246, 0.3);
    border-color: rgba(59, 130, 246, 0.4);
  }

  .playlist-remove-btn {
    background: rgba(239, 68, 68, 0.15);
    color: #f87171;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  .playlist-remove-btn:hover {
    background: rgba(239, 68, 68, 0.3);
    border-color: rgba(239, 68, 68, 0.4);
  }

  .playlist-save-btn {
    background: rgba(139, 92, 246, 0.15);
    color: #a78bfa;
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .playlist-save-btn:hover {
    background: rgba(139, 92, 246, 0.3);
    border-color: rgba(139, 92, 246, 0.4);
  }

  .playlist-save-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .playlist-save-btn .spinning {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Controls section */
  .playlist-controls {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: 0.5rem;
    padding-top: 0.75rem;
  }

  .playlist-controls-simple {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 0.5rem 0;
  }

  .control-btn-large {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    box-shadow: 0 4px 15px rgba(220, 38, 38, 0.3);
  }

  .control-btn-large:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(220, 38, 38, 0.4);
  }

  .volume-control {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: #888;
  }

  .volume-control svg {
    opacity: 0.7;
  }

  .volume-slider {
    width: 100px;
    height: 5px;
    -webkit-appearance: none;
    appearance: none;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    outline: none;
    cursor: pointer;
  }

  .volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 14px;
    background: #3b82f6;
    border-radius: 50%;
    cursor: pointer;
    transition: transform 0.2s ease;
    box-shadow: 0 2px 6px rgba(59, 130, 246, 0.4);
  }

  .volume-slider::-webkit-slider-thumb:hover {
    transform: scale(1.15);
  }

  .volume-slider::-moz-range-thumb {
    width: 14px;
    height: 14px;
    background: #3b82f6;
    border: none;
    border-radius: 50%;
    cursor: pointer;
  }

  .playlist-status {
    text-align: center;
    padding: 0.25rem 0;
  }

  .playlist-status span {
    font-size: 0.75rem;
    color: rgba(156, 163, 175, 0.8);
    font-weight: 500;
  }

  /* Empty state */
  .playlist-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 2rem;
    color: #666;
  }

  .playlist-empty svg {
    opacity: 0.3;
    margin-bottom: 0.75rem;
  }

  .playlist-empty p {
    margin: 0.25rem 0;
  }

  .playlist-empty-hint {
    font-size: 0.8rem;
    opacity: 0.6;
  }

  /* Auth notice for non-logged in users */
  .playlist-auth-notice {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: rgba(251, 191, 36, 0.1);
    border: 1px solid rgba(251, 191, 36, 0.3);
    border-radius: 8px;
    color: #fbbf24;
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .playlist-auth-notice svg {
    flex-shrink: 0;
  }

  /* Position indicator for DJ waitlist */
  .position-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1rem;
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.15), rgba(59, 130, 246, 0.15));
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 10px;
    margin: 0 auto 1rem;
    max-width: 400px;
  }

  .position-indicator span {
    font-size: 1rem;
    font-weight: 600;
    color: #60a5fa;
  }

  .position-indicator.hidden {
    display: none;
  }

  .position-indicator.your-turn {
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.2), rgba(22, 163, 74, 0.2));
    border-color: rgba(34, 197, 94, 0.4);
  }

  .position-indicator.your-turn span {
    color: #4ade80;
  }

  /* DJ name display - inline */
  .dj-name-display {
    font-size: 0.6rem;
    font-weight: 600;
    color: #60a5fa;
    white-space: nowrap;
  }

  /* Position badge for items */
  .dj-position-badge {
    position: absolute;
    top: 2px;
    left: 2px;
    background: rgba(0, 0, 0, 0.85);
    color: #60a5fa;
    font-size: 0.5rem;
    font-weight: 700;
    padding: 1px 4px;
    border-radius: 3px;
    z-index: 2;
  }

  /* Make grid items relative for badge positioning */
  .playlist-grid-item {
    position: relative;
  }

  /* Highlight user's track in queue - subtle indicator only */
  .playlist-grid-item.your-track:not(.active) {
    border-color: rgba(59, 130, 246, 0.3);
  }

  .playlist-grid-item.your-track .dj-name-display {
    color: #93c5fd;
  }

  /* Your Track Playing indicator - above Now Playing preview */
  .your-track-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1rem;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.25), rgba(22, 163, 74, 0.25));
    border: 2px solid rgba(34, 197, 94, 0.5);
    border-radius: 10px;
    margin-bottom: 0.75rem;
    animation: pulseGreen 2s ease-in-out infinite;
  }

  .your-track-indicator.hidden {
    display: none;
  }

  .your-track-indicator span {
    font-size: 0.9rem;
    font-weight: 700;
    color: #4ade80;
    letter-spacing: 0.5px;
  }

  @keyframes pulseGreen {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
    50% { box-shadow: 0 0 0 8px rgba(34, 197, 94, 0); }
  }

  /* My Playlist Section - Full height in right column */
  .my-playlist-section {
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
    text-align: left;
  }

  .my-playlist-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    width: 100%;
  }

  .my-playlist-title-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .my-playlist-header h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
    text-align: left;
  }

  .my-playlist-count-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid #333;
    border-radius: 6px;
    padding: 0.25rem 0.6rem;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: #dc2626;
    min-width: 28px;
  }

  .playlist-sort-select {
    background: #1f1f1f !important;
    border: 1px solid #666 !important;
    border-radius: 6px;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    color: #bbb !important;
    cursor: pointer;
    outline: none;
  }

  .playlist-sort-select:hover {
    border-color: #777 !important;
    color: #ddd !important;
  }

  .playlist-sort-select:focus {
    border-color: #888 !important;
  }

  .playlist-sort-select option {
    background: #1f1f1f !important;
    color: #bbb !important;
  }

  .playlist-layout-toggle {
    display: flex;
    gap: 0.25rem;
  }

  .layout-btn {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid #333;
    border-radius: 4px;
    padding: 0.25rem;
    cursor: pointer;
    color: #666;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .layout-btn:hover {
    border-color: #444;
    color: #999;
  }

  .layout-btn.active {
    background: rgba(220, 38, 38, 0.2);
    border-color: #dc2626;
    color: #dc2626;
  }

  .my-playlist-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .clear-playlist-btn {
    padding: 0.4rem 0.8rem;
    font-size: 0.75rem;
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 6px;
    color: #f87171;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .clear-playlist-btn:hover {
    background: rgba(239, 68, 68, 0.25);
  }

  .export-playlist-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.8rem;
    font-size: 0.75rem;
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 6px;
    color: #4ade80;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .export-playlist-btn:hover {
    background: rgba(34, 197, 94, 0.25);
  }

  .export-playlist-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Export Modal */
  .export-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .export-modal.hidden {
    display: none;
  }

  .export-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
  }

  .export-modal-content {
    position: relative;
    background: #1a1a2e;
    border: 2px solid #333;
    border-radius: 16px;
    padding: 0;
    max-width: 400px;
    width: 90%;
    animation: modalSlideIn 0.2s ease;
  }

  @keyframes modalSlideIn {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

  .export-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #333;
  }

  .export-modal-header h3 {
    margin: 0;
    font-size: 1.1rem;
    color: #fff;
  }

  .export-modal-close {
    background: none;
    border: none;
    color: #666;
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }

  .export-modal-close:hover {
    color: #fff;
  }

  .export-modal-body {
    padding: 1.25rem;
  }

  .export-field {
    margin-bottom: 1rem;
  }

  .export-field label {
    display: block;
    font-size: 0.8rem;
    color: #9ca3af;
    margin-bottom: 0.5rem;
  }

  .export-field input[type="text"] {
    width: 100%;
    padding: 0.6rem 0.75rem;
    background: #0a0a15;
    border: 1px solid #333;
    border-radius: 6px;
    color: #fff;
    font-size: 0.85rem;
  }

  .export-field input[type="text"]:focus {
    outline: none;
    border-color: #4ade80;
  }

  .export-formats {
    display: flex;
    gap: 0.5rem;
  }

  .format-option {
    flex: 1;
    cursor: pointer;
  }

  .format-option input {
    display: none;
  }

  .format-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.6rem 0.5rem;
    background: #0a0a15;
    border: 1px solid #333;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .format-option input:checked + .format-label {
    border-color: #4ade80;
    background: rgba(34, 197, 94, 0.1);
  }

  .format-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
  }

  .format-desc {
    font-size: 0.65rem;
    color: #666;
    margin-top: 0.15rem;
  }

  .export-info {
    text-align: center;
    font-size: 0.8rem;
    color: #9ca3af;
    margin-bottom: 1rem;
  }

  .export-info span {
    color: #4ade80;
    font-weight: 600;
  }

  .confirm-export-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    border: none;
    border-radius: 8px;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .confirm-export-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
  }

  .export-modal-divider {
    height: 1px;
    background: #333;
    margin: 0;
  }

  .export-modal-danger {
    padding: 1rem 1.25rem;
    background: rgba(239, 68, 68, 0.05);
  }

  .export-modal-danger h4 {
    margin: 0 0 0.25rem 0;
    font-size: 0.8rem;
    color: #f87171;
  }

  .export-modal-danger p {
    margin: 0 0 0.75rem 0;
    font-size: 0.75rem;
    color: #9ca3af;
  }

  .clear-playlist-danger-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.75rem;
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 6px;
    color: #f87171;
    cursor: pointer;
    transition: all 0.2s;
  }

  .clear-playlist-danger-btn:hover {
    background: rgba(239, 68, 68, 0.25);
  }

  .clear-confirmation {
    padding: 1rem 1.25rem;
    background: rgba(239, 68, 68, 0.1);
    border-top: 1px solid rgba(239, 68, 68, 0.2);
  }

  .clear-confirmation.hidden {
    display: none;
