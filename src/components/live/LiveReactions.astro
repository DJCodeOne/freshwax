---
// src/components/live/LiveReactions.astro
// Reaction buttons, record control, and volume for live stream
---

<!-- Play/Pause - standalone so it sits left of reactions on desktop -->
<button id="playBtn" class="play-btn" disabled aria-label="Play or pause stream">
  <svg id="playIcon" class="play-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
  <svg id="pauseIcon" class="pause-icon hidden" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
</button>

<!-- Emoji Reactions - disabled by default until stream is live -->
<div class="inline-reactions">
  <button id="likeBtn" class="inline-btn reaction-btn like-btn reactions-disabled" title="Love" aria-label="React with love (join stream to react)" data-emoji="❤️,💖,💗,💓,💕" disabled>
    <span class="reaction-emoji">❤️</span>
  </button>
  <button id="fireBtn" class="inline-btn reaction-btn fire-btn reactions-disabled" title="Fire" aria-label="React with fire (join stream to react)" data-emoji="🔥,🔥,🔥,🔥,🔥" disabled>
    <span class="reaction-emoji">🔥</span>
  </button>
  <button id="explosionBtn" class="inline-btn reaction-btn explosion-btn reactions-disabled" title="Explosion" aria-label="React with explosion (join stream to react)" data-emoji="💥,💥,💥,💥,💥" disabled>
    <span class="reaction-emoji">💥</span>
  </button>
  <button id="fistBtn" class="inline-btn reaction-btn fist-btn reactions-disabled" title="Fist" aria-label="React with fist bump (join stream to react)" data-emoji="👊,👊,👊,👊,👊" disabled>
    <span class="reaction-emoji">👊</span>
  </button>
  <button id="clapBtn" class="inline-btn reaction-btn clap-btn reactions-disabled" title="Clap" aria-label="React with clap (join stream to react)" data-emoji="👏,👏,👏,👏,👏" disabled>
    <span class="reaction-emoji">👏</span>
  </button>
  <button id="rocketBtn" class="inline-btn reaction-btn rocket-btn reactions-disabled" title="Rocket" aria-label="React with rocket (join stream to react)" data-emoji="🚀,🚀,🚀,🚀,🚀" disabled>
    <span class="reaction-emoji">🚀</span>
  </button>
</div>

<!-- Player Controls - share, toggle, volume -->
<div class="inline-controls">
  <button id="shareBtn" class="inline-btn share-btn" title="Share" aria-label="Share stream">
    <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg>
  </button>
  <button id="animToggleBtn" class="inline-btn anim-toggle-btn reactions-disabled" title="Turn off emoji animations" aria-label="Toggle emoji animations (join stream to react)" disabled>
    <svg class="anim-on-icon" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
    <svg class="anim-off-icon" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/></svg>
  </button>
  <button id="nowPlayingSaveBtn" class="inline-btn save-btn" title="Save to My Playlist" aria-label="Save to my playlist">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
    </svg>
  </button>
  <div class="record-control">
    <button id="recordBtn" class="record-btn pro-locked" disabled title="Upgrade to Pro to record livestreams">
      <span class="record-dot"></span>
      <span class="record-text">REC</span>
    </button>
    <span id="recordDuration" class="record-duration hidden">00:00</span>
  </div>
  <div class="volume-control">
    <svg class="volume-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/></svg>
    <input type="range" id="volumeSlider" min="0" max="100" value="80" aria-label="Stream volume" />
  </div>
</div>

<script>
  // Volume slider handler - runs when component is rendered
  const volumeSlider = document.getElementById('volumeSlider');
  if (volumeSlider) {
    volumeSlider.addEventListener('input', (e) => {
      const volume = parseInt(e.target.value);

      // Update HLS video if exists
      const hlsVideo = document.getElementById('hlsVideoElement');
      if (hlsVideo) hlsVideo.volume = volume / 100;

      // Update audio element if exists
      const audio = document.getElementById('audioElement');
      if (audio) audio.volume = volume / 100;

      // Update playlist volume if active
      if (window.playlistManager) {
        window.playlistManager.setVolume(volume);
      }
    });
  }
</script>
