---
// src/components/Header.astro
// OPTIMIZED: Minimal API calls with aggressive caching + debounced search

interface Props {
  nonce?: string;
}
const nonce = Astro.locals.nonce || Astro.props.nonce || '';

// Firebase config for client-side auth
const firebaseConfig = {
  apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY || '',
  authDomain: "freshwax-store.firebaseapp.com",
  projectId: "freshwax-store",
  storageBucket: "freshwax-store.firebasestorage.app",
  messagingSenderId: "675435782973",
  appId: "1:675435782973:web:e8459c2ec4a5f6d683db54"
};
---

<header id="freshwax-header" role="banner">
  <div class="fwx-header-inner">
    
    <!-- Mobile Layout -->
    <div class="fwx-mobile">
      <div class="fwx-mobile-top">
        <div class="fwx-mobile-left">
          <a href="/" class="fwx-logo-link" id="logoMobile">
            <img src="/logo.webp?v=2" alt="Fresh Wax" class="fwx-logo-mobile" width="63" height="50" translate="no" fetchpriority="high" decoding="async" />
          </a>
        </div>

        <div class="fwx-mobile-right">
          <!-- Mobile LIVE Button -->
          <a href="/live/" id="liveButtonMobile" class="live-button fwx-live-btn" data-astro-reload aria-label="Live stream">
            <span class="live-dot"></span>
            <span class="live-text">LIVE</span>
          </a>

          <!-- Mobile Charts Button -->
          <button id="chartsBtnMobile" class="fwx-charts-btn fwx-charts-btn-mobile" aria-expanded="false" aria-controls="chartsPanelMobile" aria-label="Charts menu">
            <svg class="fwx-charts-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M18 20V10M12 20V4M6 20v-6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <a href="/cart/" class="fwx-cart-btn" aria-label="Shopping bag">
            <svg class="fwx-cart-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            <span class="fwx-cart-text">Bag</span>
            <span id="cart-count-mobile" class="fwx-cart-count fwx-hidden" aria-live="polite" aria-label="items in bag">0</span>
          </a>

          <!-- Burger Menu Button -->
          <button id="burgerMenuBtn" class="fwx-burger-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu">
            <svg class="fwx-burger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <div class="fwx-search-mobile">
        <div class="fwx-search-icon-wrap">
          <svg class="fwx-search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input
          type="text"
          id="search-input-mobile"
          placeholder="Search releases, artists, merch..."
          class="fwx-search-input"
          autocomplete="off"
          aria-label="Search releases, artists, and merchandise"
          role="combobox"
          aria-autocomplete="list"
          aria-expanded="false"
          aria-controls="search-results-mobile"
          aria-owns="search-results-mobile"
          aria-haspopup="listbox"
        />
        <!-- Mobile Search Results Dropdown -->
        <div id="search-results-mobile" class="fwx-search-results fwx-hidden" role="listbox" aria-label="Search results" aria-live="polite">
          <div id="search-results-content-mobile" class="fwx-search-content"></div>
        </div>
      </div>

      <!-- Mobile Charts Panel (slides down below search) -->
      <div id="chartsPanelMobile" class="fwx-charts-panel-mobile fwx-hidden" role="menu" aria-label="Charts navigation">
        <a href="/weekly-chart/" class="fwx-charts-link" role="menuitem">
          <span class="fwx-charts-link-icon" style="background: linear-gradient(135deg, #dc2626, #991b1b);">📅</span>
          <span class="fwx-charts-link-text">Weekly Chart</span>
        </a>
        <a href="/pre-orders/" class="fwx-charts-link" role="menuitem">
          <span class="fwx-charts-link-icon" style="background: linear-gradient(135deg, #f97316, #dc2626);">⏰</span>
          <span class="fwx-charts-link-text">Pre-Orders</span>
        </a>
        <a href="/dj-mix-chart/" class="fwx-charts-link" role="menuitem">
          <span class="fwx-charts-link-icon" style="background: linear-gradient(135deg, #fbbf24, #f59e0b);">🏆</span>
          <span class="fwx-charts-link-text">Mix Chart</span>
        </a>
        <a href="/samples/" class="fwx-charts-link" role="menuitem">
          <span class="fwx-charts-link-icon" style="background: linear-gradient(135deg, #8b5cf6, #6d28d9);">🎛</span>
          <span class="fwx-charts-link-text">Sample Packs</span>
        </a>
        <a href="/schedule/" class="fwx-charts-link" role="menuitem">
          <span class="fwx-charts-link-icon" style="background: linear-gradient(135deg, #10b981, #059669);">📅</span>
          <span class="fwx-charts-link-text">Schedule</span>
        </a>
      </div>
    </div>

    <!-- Mobile Slide-out Menu -->
    <div id="mobileMenu" class="fwx-mobile-menu fwx-hidden" role="dialog" aria-modal="true" aria-label="Navigation menu" data-has-focus-trap="true">
      <div class="fwx-mobile-menu-header">
        <span class="fwx-menu-title">Menu</span>
        <button id="closeMenuBtn" class="fwx-close-btn" aria-label="Close menu">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="fwx-mobile-menu-content">
        <!-- Account Section -->
        <div class="fwx-menu-account">
          <div class="fwx-menu-avatar">
            <svg class="account-avatar-icon fwx-avatar-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span class="account-avatar-initial fwx-hidden"></span>
            <img class="account-avatar-img fwx-hidden" src="" alt="Account avatar" width="40" height="40" loading="lazy" decoding="async" />
          </div>
          <span class="fwx-menu-account-name account-name">Login</span>
        </div>

        <!-- Auth Links -->
        <div class="fwx-menu-auth logged-out">
          <a href="/login/" class="fwx-menu-link">Login</a>
          <a href="/register/" class="fwx-menu-link">Register</a>
        </div>
        <div class="fwx-menu-auth logged-in fwx-hidden">
          <a href="/account/dashboard/" class="fwx-menu-link">My Account</a>
        </div>

        <div class="fwx-menu-divider"></div>

        <!-- Navigation Links -->
        <nav class="fwx-menu-nav" aria-label="Mobile menu navigation">
          <a href="/releases/" class="fwx-menu-link">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
            </svg>
            All Releases
          </a>
          <a href="/dj-mixes/" class="fwx-menu-link">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
            </svg>
            DJ Mixes
          </a>
          <a href="/merch/" class="fwx-menu-link">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.5 2L2 6l3 2v12a1 1 0 001 1h12a1 1 0 001-1V8l3-2-4.5-4h-3L12 5l-2.5-3h-3z" />
            </svg>
            Merch
          </a>
          <a href="/crates/" class="fwx-menu-link">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4m-6-1v6m8-6v6" />
            </svg>
            Crates
          </a>
          <a href="/blog/" class="fwx-menu-link">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
            Blog
          </a>
          <a href="/samples/" class="fwx-menu-link">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z" />
            </svg>
            Sample Packs
          </a>
          <a href="/schedule/" class="fwx-menu-link">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Schedule
          </a>
        </nav>

        <div class="fwx-menu-divider"></div>

        <!-- Logout (only when logged in) -->
        <div class="fwx-menu-footer logged-in fwx-hidden">
          <button class="logout-btn fwx-menu-logout">Logout</button>
        </div>
      </div>
    </div>

    <!-- Menu Overlay -->
    <div id="menuOverlay" class="fwx-menu-overlay fwx-hidden"></div>

    <!-- Desktop Layout -->
    <div class="fwx-desktop">
      <!-- Logo -->
      <a href="/" class="fwx-logo-link" id="logoDesktop">
        <img src="/logo.webp?v=2" alt="Fresh Wax" class="fwx-logo-desktop" width="89" height="70" translate="no" fetchpriority="high" decoding="async" />
      </a>
      
      <!-- Search Bar (centered between logo and nav) -->
      <div class="fwx-search-desktop">
        <div class="fwx-search-icon-wrap">
          <svg class="fwx-search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input
          type="text"
          id="search-input"
          placeholder="Search releases, artists, merch..."
          class="fwx-search-input"
          autocomplete="off"
          aria-label="Search releases, artists, and merchandise"
          role="combobox"
          aria-autocomplete="list"
          aria-expanded="false"
          aria-controls="search-results"
          aria-owns="search-results"
          aria-haspopup="listbox"
        />
        <!-- Search Results Dropdown -->
        <div id="search-results" class="fwx-search-results fwx-hidden" role="listbox" aria-label="Search results" aria-live="polite">
          <div id="search-results-content" class="fwx-search-content"></div>
        </div>
      </div>
      
      <!-- Center section: Navigation tabs -->
      <nav class="fwx-nav" aria-label="Main navigation">
        <a href="/releases/" class="fwx-nav-btn">
          <svg class="fwx-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
          </svg>
          All Releases
        </a>

        <a href="/dj-mixes/" class="fwx-nav-btn">
          <svg class="fwx-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
          </svg>
          DJ Mixes
        </a>

        <a href="/merch/" class="fwx-nav-btn">
          <svg class="fwx-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.5 2L2 6l3 2v12a1 1 0 001 1h12a1 1 0 001-1V8l3-2-4.5-4h-3L12 5l-2.5-3h-3z" />
          </svg>
          Merch
        </a>


        <a href="/crates/" class="fwx-nav-btn">
          <svg class="fwx-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4m-6-1v6m8-6v6" />
          </svg>
          Crates
        </a>

        <a href="/blog/" class="fwx-nav-btn">
          <svg class="fwx-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
          Blog
        </a>
      </nav>

      <!-- Account Dropdown (centered between nav and bag) -->
      <div class="account-dropdown fwx-account">
        <button class="account-button fwx-account-btn" aria-label="Account menu" aria-expanded="false" aria-haspopup="true">
          <div class="account-avatar fwx-avatar">
            <svg class="account-avatar-icon fwx-avatar-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span class="account-avatar-initial fwx-hidden"></span>
            <img class="account-avatar-img fwx-hidden" src="" alt="Account avatar" width="40" height="40" loading="lazy" decoding="async" />
          </div>
          <span class="account-name">Login</span>
          <svg class="fwx-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="account-menu fwx-dropdown fwx-hidden">
          <div class="logged-out">
            <a href="/login/" class="fwx-dropdown-link">Login</a>
            <a href="/register/" class="fwx-dropdown-link">Register</a>
          </div>
          <div class="logged-in fwx-hidden">
            <a href="/account/dashboard/" class="fwx-dropdown-link">My Account</a>
            <button class="logout-btn fwx-logout-btn">Logout</button>
          </div>
        </div>
      </div>

      <!-- Bag -->
      <a href="/cart/" class="fwx-cart-btn fwx-cart-black" aria-label="Shopping bag">
        <svg class="fwx-cart-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        Bag
        <span id="cart-count" class="fwx-cart-count fwx-hidden" aria-live="polite" aria-label="items in bag">0</span>
      </a>

      <!-- LIVE Button -->
      <a href="/live/" id="liveButton" class="live-button fwx-live-btn" data-astro-reload aria-label="Live stream">
        <span class="live-dot"></span>
        <span class="live-text">LIVE</span>
      </a>

      <!-- Charts Button -->
      <div class="fwx-charts-wrap">
        <button id="chartsBtn" class="fwx-charts-btn" aria-expanded="false" aria-controls="chartsPanel" aria-label="Charts menu">
          <svg class="fwx-charts-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M18 20V10M12 20V4M6 20v-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <svg class="fwx-charts-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="chartsPanel" class="fwx-charts-panel fwx-hidden" role="menu" aria-label="Charts navigation">
          <a href="/weekly-chart/" class="fwx-charts-link" role="menuitem">
            <span class="fwx-charts-link-icon" style="background: linear-gradient(135deg, #dc2626, #991b1b);">📅</span>
            <span class="fwx-charts-link-text">Weekly Chart</span>
          </a>
          <a href="/pre-orders/" class="fwx-charts-link" role="menuitem">
            <span class="fwx-charts-link-icon" style="background: linear-gradient(135deg, #f97316, #dc2626);">⏰</span>
            <span class="fwx-charts-link-text">Pre-Orders</span>
          </a>
          <a href="/dj-mix-chart/" class="fwx-charts-link" role="menuitem">
            <span class="fwx-charts-link-icon" style="background: linear-gradient(135deg, #fbbf24, #f59e0b);">🏆</span>
            <span class="fwx-charts-link-text">Mix Chart</span>
          </a>
          <a href="/samples/" class="fwx-charts-link" role="menuitem">
            <span class="fwx-charts-link-icon" style="background: linear-gradient(135deg, #8b5cf6, #6d28d9);">🎛</span>
            <span class="fwx-charts-link-text">Sample Packs</span>
          </a>
          <a href="/schedule/" class="fwx-charts-link" role="menuitem">
            <span class="fwx-charts-link-icon" style="background: linear-gradient(135deg, #10b981, #059669);">📅</span>
            <span class="fwx-charts-link-text">Schedule</span>
          </a>
        </div>
      </div>

      <!-- Language Selector -->
      <div class="fwx-lang-wrap">
        <button id="langBtn" class="fwx-lang-btn" aria-label="Change language" aria-expanded="false" aria-controls="langPanel">
          <svg class="fwx-lang-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10A15.3 15.3 0 0112 2z" />
          </svg>
        </button>
        <div id="langPanel" class="fwx-lang-panel" role="dialog" aria-modal="true" aria-label="Select language" hidden>
          <div class="fwx-lang-grid">
            <button class="fwx-lang-opt" data-lang="en" aria-pressed="true" aria-label="Switch to English">English</button>
            <button class="fwx-lang-opt" data-lang="fr" aria-label="Switch to French">Français</button>
            <button class="fwx-lang-opt" data-lang="de" aria-label="Switch to German">Deutsch</button>
            <button class="fwx-lang-opt" data-lang="es" aria-label="Switch to Spanish">Español</button>
            <button class="fwx-lang-opt" data-lang="it" aria-label="Switch to Italian">Italiano</button>
            <button class="fwx-lang-opt" data-lang="pt" aria-label="Switch to Portuguese">Português</button>
            <button class="fwx-lang-opt" data-lang="nl" aria-label="Switch to Dutch">Nederlands</button>
            <button class="fwx-lang-opt" data-lang="ja" aria-label="Switch to Japanese">日本語</button>
            <button class="fwx-lang-opt" data-lang="zh-CN" aria-label="Switch to Chinese">中文</button>
            <button class="fwx-lang-opt" data-lang="ko" aria-label="Switch to Korean">한국어</button>
            <button class="fwx-lang-opt" data-lang="ru" aria-label="Switch to Russian">Русский</button>
            <button class="fwx-lang-opt" data-lang="pl" aria-label="Switch to Polish">Polski</button>
            <button class="fwx-lang-opt" data-lang="sv" aria-label="Switch to Swedish">Svenska</button>
            <button class="fwx-lang-opt" data-lang="da" aria-label="Switch to Danish">Dansk</button>
            <button class="fwx-lang-opt" data-lang="no" aria-label="Switch to Norwegian">Norsk</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Google Translate (offscreen, never shown to user) -->
<div id="google_translate_element" style="position:fixed;top:-9999px;left:-9999px;opacity:0;pointer-events:none;"></div>

<!-- Mobile Bottom Navigation -->
<nav id="fwx-mobile-nav" class="fwx-bottom-nav" aria-label="Mobile bottom navigation">
  <a href="/releases/" class="fwx-bnav-item">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="fwx-bnav-icon" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
    </svg>
    <span>Releases</span>
  </a>
  <a href="/dj-mixes/" class="fwx-bnav-item">
