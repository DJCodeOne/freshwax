  const _hasSession = document.cookie.includes('userId=');

  if (_hasSession) {
    const { initializeApp } = await import('https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js');
    const _fb = await import('https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js');
    signOutFn = _fb.signOut;
    onAuthStateChangedFn = _fb.onAuthStateChanged;

    let app;
    try {
      app = initializeApp(firebaseConfig);
      auth = _fb.getAuth(app);
    } catch (e) {
      const { getApps, getApp } = await import('https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js');
      app = getApps().length ? getApp() : initializeApp(firebaseConfig);
      auth = _fb.getAuth(app);
    }
    window.firebaseAuth = auth;

    const unsubscribeInitial = _fb.onAuthStateChanged(auth, (user) => {
      window.authUser = user;
      authReadyResolve(user);
      unsubscribeInitial();
    });
  } else {
    // Anonymous visitor — skip Firebase Auth import entirely (saves 118KB)
    authReadyResolve(null);
  }

  // Cache helpers
  const USER_CACHE_KEY = 'freshwax_user_type_cache';
  const CACHE_DURATION = 5 * 60 * 1000; // 5 minutes (reduced from 30)

  function getCachedUserType() {
    try {
      const cached = sessionStorage.getItem(USER_CACHE_KEY);
      if (!cached) return null;
      const data = JSON.parse(cached);
      if (Date.now() - data.timestamp > CACHE_DURATION) {
        sessionStorage.removeItem(USER_CACHE_KEY);
        return null;
      }
      if (data.isAdmin === undefined) {
        sessionStorage.removeItem(USER_CACHE_KEY);
        return null;
      }
      return data;
    } catch (e) {
      /* intentional: sessionStorage parse failure returns null — cache miss fallback */
      return null;
    }
  }

  function setCachedUserType(userType, isAdmin, avatarUrl = null, displayName = null) {
    try {
      sessionStorage.setItem(USER_CACHE_KEY, JSON.stringify({
        userType,
        isAdmin,
        avatarUrl,
        displayName,
        timestamp: Date.now()
      }));
    } catch (e) {
      /* intentional: sessionStorage write failure is non-critical */
    }
  }

  // Debounced search with request cancellation
  let searchTimeout;
  let searchAbortController = null;
  const SEARCH_DEBOUNCE = 300;
  const MIN_QUERY_LENGTH = 2;
  const searchCache = new Map();

  async function performSearch(query, resultsContainer, contentContainer, searchInputEl) {
    if (searchCache.has(query)) {
      displayResults(searchCache.get(query), contentContainer);
      resultsContainer.classList.remove('fwx-hidden');
      resultsContainer.style.display = 'block';
      if (searchInputEl) searchInputEl.setAttribute('aria-expanded', 'true');
      return;
    }

    // Cancel any in-flight search request
    if (searchAbortController) searchAbortController.abort();
    searchAbortController = new AbortController();

    try {
      const response = await fetch(`/api/search-releases/?q=${encodeURIComponent(query)}&limit=10`, { signal: searchAbortController.signal });
      if (!response.ok) throw new Error('Search failed');
      const data = await response.json();
      searchCache.set(query, data);
      displayResults(data, contentContainer);
      resultsContainer.classList.remove('fwx-hidden');
      resultsContainer.style.display = 'block';
      if (searchInputEl) searchInputEl.setAttribute('aria-expanded', 'true');
      window.trackSearch?.(query, (data.results || []).length);
    } catch (error) {
      if (error instanceof DOMException && error.name === 'AbortError') return; // Cancelled by newer search
      console.error('Search error:', error);
      contentContainer.innerHTML = '<p style="padding: 1rem; color: #595959; text-align: center;">Search unavailable</p>';
      resultsContainer.classList.remove('fwx-hidden');
      resultsContainer.style.display = 'block';
      if (searchInputEl) searchInputEl.setAttribute('aria-expanded', 'true');
    }
  }

  function displayResults(data, container) {
    const results = data.results || [];

    if (results.length === 0) {
      container.innerHTML = '<p style="padding: 1rem; color: #595959; text-align: center;">No results found</p>';
      return;
    }

    // Group results by type
    const releases = results.filter(r => r.type === 'release');
    const mixes = results.filter(r => r.type === 'mix');
    const merch = results.filter(r => r.type === 'merch');

    let html = '';
    let resultIndex = 0;

    if (releases.length > 0) {
      html += '<div role="presentation" style="padding: 0.5rem 1rem; font-size: 0.75rem; font-weight: 600; color: #595959; text-transform: uppercase; border-bottom: 1px solid #eee;">Releases</div>';
      releases.forEach(r => {
        html += `<a href="/item/${encodeURIComponent(r.id)}/" id="search-result-${resultIndex}" role="option" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; color: black; text-decoration: none; transition: background 0.15s;" class="search-result-hover">
          <img src="${escapeHtml(r.artwork_url) || '/place-holder.webp'}" alt="${escapeHtml(r.title)} by ${escapeHtml(r.artist_name)}" loading="lazy" width="40" height="40" style="width: 40px; height: 40px; border-radius: 4px; object-fit: cover;" />
          <div>
            <div style="font-weight: 500; font-size: 0.875rem;">${escapeHtml(r.title)}</div>
            <div style="font-size: 0.75rem; color: #595959;">${escapeHtml(r.artist_name)}</div>
          </div>
        </a>`;
        resultIndex++;
      });
    }

    if (mixes.length > 0) {
      html += '<div role="presentation" style="padding: 0.5rem 1rem; font-size: 0.75rem; font-weight: 600; color: #595959; text-transform: uppercase; border-top: 1px solid #eee; border-bottom: 1px solid #eee;">DJ Mixes</div>';
      mixes.forEach(m => {
        html += `<a href="/dj-mix/${encodeURIComponent(m.id)}/" id="search-result-${resultIndex}" role="option" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; color: black; text-decoration: none; transition: background 0.15s;" class="search-result-hover">
          <img src="${escapeHtml(m.artwork_url) || '/place-holder.webp'}" alt="${escapeHtml(m.title)}" loading="lazy" width="40" height="40" style="width: 40px; height: 40px; border-radius: 4px; object-fit: cover;" />
          <div>
            <div style="font-weight: 500; font-size: 0.875rem;">${escapeHtml(m.title)}</div>
            <div style="font-size: 0.75rem; color: #595959;">${escapeHtml(m.artist_name)}</div>
          </div>
        </a>`;
        resultIndex++;
      });
    }

    if (merch.length > 0) {
      const hasPreviousSections = releases.length > 0 || mixes.length > 0;
      html += `<div role="presentation" style="padding: 0.5rem 1rem; font-size: 0.75rem; font-weight: 600; color: #595959; text-transform: uppercase; ${hasPreviousSections ? 'border-top: 1px solid #eee;' : ''} border-bottom: 1px solid #eee;">Merch</div>`;
      merch.forEach(item => {
        const priceStr = item.price ? `£${item.price.toFixed(2)}` : '';
        const stockStr = item.stock === 0 ? '<span style="color: #dc2626;">Out of Stock</span>' : (item.stock <= 5 ? `<span style="color: #f59e0b;">Low Stock</span>` : '');
        html += `<a href="/merch/#quick-view-${encodeURIComponent(item.id)}" id="search-result-${resultIndex}" role="option" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; color: black; text-decoration: none; transition: background 0.15s;" class="search-result-hover">
          <img src="${escapeHtml(item.artwork_url) || '/place-holder.webp'}" alt="${escapeHtml(item.title)}" loading="lazy" width="40" height="40" style="width: 40px; height: 40px; border-radius: 4px; object-fit: cover;" />
          <div style="flex: 1; min-width: 0;">
            <div style="font-weight: 500; font-size: 0.875rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${escapeHtml(item.title)}</div>
            <div style="font-size: 0.75rem; color: #595959; display: flex; gap: 0.5rem; align-items: center;">
              ${priceStr ? `<span style="color: #16a34a; font-weight: 600;">${priceStr}</span>` : ''}
              ${stockStr}
            </div>
          </div>
        </a>`;
        resultIndex++;
      });
    }

    container.innerHTML = html;
  }

  // Check live status
  async function checkLiveStatus() {
    try {
      const response = await fetch('/api/livestream/status/');
      if (!response.ok) return;
      const data = await response.json();
      
      document.querySelectorAll('.live-button').forEach(btn => {
        if (data.isLive) {
          btn.classList.add('is-live');
        } else {
          btn.classList.remove('is-live');
        }
      });
    } catch (e){
      // Ignore errors
    }
  }

  // Track if we've set up global listeners
  let globalListenersSet = false;
  // Use window-scoped interval ID to prevent accumulation across View Transitions
  // (local let would create a new variable each time the inline script re-executes)
  if (!window._headerLiveInterval) window._headerLiveInterval = null;

  // AbortController for cleaning up event listeners on View Transitions navigation
  const headerCleanupController = new AbortController();

  // Initialize header functionality - called on every page load
  function initHeader() {
    // Setup search functionality
    function setupSearch(inputId, resultsId, contentId) {
      const input = document.getElementById(inputId);
      const results = document.getElementById(resultsId);
      const content = document.getElementById(contentId);

      if (!input || !results || !content) return;

      // Ensure initial hidden state
      results.style.display = 'none';

      // Remove old listeners by cloning
      const newInput = input.cloneNode(true);
      input.parentNode.replaceChild(newInput, input);

      newInput.addEventListener('input', (e) => {
        const query = e.target.value.trim();
        clearTimeout(searchTimeout);

        if (query.length < MIN_QUERY_LENGTH) {
          results.classList.add('fwx-hidden');
          results.style.display = 'none';
          newInput.setAttribute('aria-expanded', 'false');
          newInput.removeAttribute('aria-activedescendant');
          return;
        }

        searchTimeout = setTimeout(() => performSearch(query, results, content, newInput), SEARCH_DEBOUNCE);
      });

      // Arrow key navigation for search results
      newInput.addEventListener('keydown', function(e) {
        var options = results.querySelectorAll('[role="option"]');
        if (!options.length) return;

        var activeIndex = -1;
        options.forEach(function(r, i) {
          if (r.classList.contains('active')) activeIndex = i;
        });

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          activeIndex = Math.min(activeIndex + 1, options.length - 1);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          activeIndex = Math.max(activeIndex - 1, 0);
        } else if (e.key === 'Enter' && activeIndex >= 0) {
          e.preventDefault();
          var link = options[activeIndex].querySelector('a') || options[activeIndex];
          if (link.href) window.location.href = link.href;
          return;
        } else if (e.key === 'Escape') {
          results.classList.add('fwx-hidden');
          results.style.display = 'none';
          newInput.setAttribute('aria-expanded', 'false');
          newInput.removeAttribute('aria-activedescendant');
          return;
        } else {
          return;
        }

        options.forEach(function(r) { r.classList.remove('active'); r.style.background = ''; });
        if (activeIndex >= 0) {
          options[activeIndex].classList.add('active');
          options[activeIndex].style.background = 'rgba(0,0,0,0.05)';
          options[activeIndex].scrollIntoView({ block: 'nearest' });
          newInput.setAttribute('aria-activedescendant', options[activeIndex].id);
        }
      });
    }

    setupSearch('search-input', 'search-results', 'search-results-content');
    setupSearch('search-input-mobile', 'search-results-mobile', 'search-results-content-mobile');

    // Account dropdown functionality - re-attach listeners
    document.querySelectorAll('.account-dropdown').forEach(dropdown => {
      const button = dropdown.querySelector('.account-button');
      const menu = dropdown.querySelector('.account-menu');
      
      if (button && menu) {
        // Clone to remove old listeners
        const newButton = button.cloneNode(true);
        button.parentNode.replaceChild(newButton, button);
        
        newButton.addEventListener('click', (e) => {
          e.stopPropagation();
          menu.classList.toggle('fwx-hidden');
          var isOpen = !menu.classList.contains('fwx-hidden');
          menu.style.display = isOpen ? 'block' : 'none';
          newButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });
      }
    });

    // Close dropdowns on click outside (only set once)
    if (!globalListenersSet) {
      document.addEventListener('click', () => {
        document.querySelectorAll('.account-menu').forEach(menu => {
          menu.classList.add('fwx-hidden');
          menu.style.display = 'none';
        });
        document.querySelectorAll('.fwx-search-results').forEach(results => {
          results.classList.add('fwx-hidden');
          results.style.display = 'none';
        });
        document.querySelectorAll('[role="combobox"]').forEach(input => {
          input.setAttribute('aria-expanded', 'false');
          input.removeAttribute('aria-activedescendant');
        });
      });
      globalListenersSet = true;
    }

    // Check live status (reduced frequency to minimize Firebase reads)
    // Stop polling when tab is hidden to save API calls
    checkLiveStatus();
    if (window._headerLiveInterval) clearInterval(window._headerLiveInterval);
    window._headerLiveInterval = setInterval(checkLiveStatus, 60000); // 60s instead of 30s
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) {
        if (window._headerLiveInterval) { clearInterval(window._headerLiveInterval); window._headerLiveInterval = null; }
      } else {
        checkLiveStatus();
        if (!window._headerLiveInterval) window._headerLiveInterval = setInterval(checkLiveStatus, 60000);
      }
    }, { signal: headerCleanupController.signal });

    // Language globe button
    setupLangButton();

    // Mobile burger menu functionality
    setupBurgerMenu();

    // Charts dropdown functionality
    setupChartsButtons();

    // Set aria-current="page" on matching nav links
    var currentPath = window.location.pathname;
    document.querySelectorAll('.fwx-nav-btn, .fwx-menu-link, .fwx-bnav-item').forEach(function(link) {
      var href = link.getAttribute('href');
      if (href && (currentPath === href || (href !== '/' && currentPath.startsWith(href)))) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });

    // Update UI based on current auth state
    updateAuthUI();
  }

  // Setup burger menu
  function setupBurgerMenu() {
    const burgerBtn = document.getElementById('burgerMenuBtn');
    const closeBtn = document.getElementById('closeMenuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    const overlay = document.getElementById('menuOverlay');

    if (!burgerBtn || !mobileMenu || !overlay) return;

    // Focus trap handler reference (needed for cleanup)
    var trapFocus = null;

    function openMenu() {
      mobileMenu.classList.add('open');
      mobileMenu.classList.remove('fwx-hidden');
      overlay.classList.add('open');
      overlay.classList.remove('fwx-hidden');
      document.body.style.overflow = 'hidden';
      var burgerEl = document.getElementById('burgerMenuBtn');
      if (burgerEl) burgerEl.setAttribute('aria-expanded', 'true');

      // Focus trap: find all focusable elements inside the menu
      var focusableEls = mobileMenu.querySelectorAll('a[href], button, input, [tabindex]:not([tabindex="-1"])');
      var firstFocusable = focusableEls[0];
      var lastFocusable = focusableEls[focusableEls.length - 1];

      // Focus the first element
      if (firstFocusable) firstFocusable.focus();

      // Trap focus within the menu
      trapFocus = function(e) {
        if (e.key !== 'Tab') return;
        if (e.shiftKey) {
          if (document.activeElement === firstFocusable) {
            e.preventDefault();
            lastFocusable.focus();
          }
        } else {
          if (document.activeElement === lastFocusable) {
            e.preventDefault();
            firstFocusable.focus();
          }
        }
      };
      mobileMenu.addEventListener('keydown', trapFocus);
    }

    function closeMenu() {
      // Remove focus trap
      if (trapFocus) {
        mobileMenu.removeEventListener('keydown', trapFocus);
        trapFocus = null;
      }
      mobileMenu.classList.remove('open');
      overlay.classList.remove('open');
      document.body.style.overflow = '';
      var burgerEl = document.getElementById('burgerMenuBtn');
      if (burgerEl) {
        burgerEl.setAttribute('aria-expanded', 'false');
        // Return focus to the burger button
        burgerEl.focus();
      }
      // Hide after animation
      setTimeout(() => {
        if (!mobileMenu.classList.contains('open')) {
          mobileMenu.classList.add('fwx-hidden');
          overlay.classList.add('fwx-hidden');
        }
      }, 300);
    }

    // Clone buttons to remove old listeners
    const newBurgerBtn = burgerBtn.cloneNode(true);
    burgerBtn.parentNode.replaceChild(newBurgerBtn, burgerBtn);
    newBurgerBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      openMenu();
    });

    if (closeBtn) {
      const newCloseBtn = closeBtn.cloneNode(true);
      closeBtn.parentNode.replaceChild(newCloseBtn, closeBtn);
      newCloseBtn.addEventListener('click', closeMenu);
    }

    // Clone overlay to remove old listeners
    const newOverlay = overlay.cloneNode(true);
    overlay.parentNode.replaceChild(newOverlay, overlay);
    newOverlay.addEventListener('click', closeMenu);

    // Close menu when clicking a nav link
    mobileMenu.querySelectorAll('.fwx-menu-link').forEach(link => {
      link.addEventListener('click', () => {
        closeMenu();
      });
    });

    // Re-get overlay reference after cloning
    const currentOverlay = document.getElementById('menuOverlay');

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobileMenu.classList.contains('open')) {
        closeMenu();
      }
    });
  }

  // Setup Charts dropdown buttons (desktop + mobile)
  function setupChartsButtons() {
    // Desktop - clone to remove stale listeners
    var dBtn = document.getElementById('chartsBtn');
    var dPanel = document.getElementById('chartsPanel');
    if (dBtn && dPanel) {
      var freshBtn = dBtn.cloneNode(true);
      dBtn.parentNode.replaceChild(freshBtn, dBtn);
      freshBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var open = freshBtn.getAttribute('aria-expanded') === 'true';
        freshBtn.setAttribute('aria-expanded', String(!open));
        dPanel.classList.toggle('fwx-hidden');
      });
      // Close desktop panel when clicking outside
      document.addEventListener('click', function(e) {
        if (!freshBtn.contains(e.target) && !dPanel.contains(e.target)) {
          freshBtn.setAttribute('aria-expanded', 'false');
          if (!dPanel.classList.contains('fwx-hidden')) dPanel.classList.add('fwx-hidden');
        }
      });
    }

    // Mobile - clone to remove stale listeners
    var mBtn = document.getElementById('chartsBtnMobile');
    var mPanel = document.getElementById('chartsPanelMobile');
    if (mBtn && mPanel) {
      var freshMBtn = mBtn.cloneNode(true);
      mBtn.parentNode.replaceChild(freshMBtn, mBtn);
      freshMBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var open = freshMBtn.getAttribute('aria-expanded') === 'true';
        freshMBtn.setAttribute('aria-expanded', String(!open));
        mPanel.classList.toggle('fwx-hidden');
      });
    }
  }

  // Update auth UI without re-subscribing to onAuthStateChanged
  let _authUIUpdating = false;
  function updateAuthUI() {
    if (_authUIUpdating) return;
    if (!auth) {
      // Firebase Auth not loaded (anonymous) — show logged-out UI
      document.querySelectorAll('.logged-out').forEach(el => { el.classList.remove('fwx-hidden'); el.style.display = 'block'; });
      document.querySelectorAll('.logged-in').forEach(el => { el.classList.add('fwx-hidden'); el.style.display = 'none'; });
      document.querySelectorAll('.account-name').forEach(el => { el.textContent = 'Login'; });
      document.querySelectorAll('.fwx-logo-link').forEach(logo => { logo.classList.remove('admin-mode'); logo.href = '/'; });
      return;
    }
    _authUIUpdating = true;
    setTimeout(() => { _authUIUpdating = false; }, 100);
    const user = auth.currentUser;
    const accountNames = document.querySelectorAll('.account-name');
    const loggedOutSections = document.querySelectorAll('.logged-out');
    const loggedInSections = document.querySelectorAll('.logged-in');
    const logoutBtns = document.querySelectorAll('.logout-btn');
    const avatars = document.querySelectorAll('.account-avatar');
    const logoLinks = document.querySelectorAll('.fwx-logo-link');
    
    if (user) {
      const cachedData = getCachedUserType() || { userType: 'customer', isAdmin: false };
      const displayName = cachedData.displayName || user.displayName || user.email?.split('@')[0] || 'Account';
      
      accountNames.forEach(el => el.textContent = displayName);
      loggedOutSections.forEach(el => { el.classList.add('fwx-hidden'); el.style.display = 'none'; });
      loggedInSections.forEach(el => { el.classList.remove('fwx-hidden'); el.style.display = 'block'; });
      
      // Toggle admin-mode class on logo (red background indicates admin)
      // Admin logo links to /admin dashboard, regular users link to /
      if (cachedData.isAdmin) {
        logoLinks.forEach(logo => {
          logo.classList.add('admin-mode');
          logo.href = '/admin';
        });
      } else {
        logoLinks.forEach(logo => {
          logo.classList.remove('admin-mode');
          logo.href = '/';
        });
      }
      
      // Update all avatar elements (header + mobile menu)
      const allAvatars = [...document.querySelectorAll('.account-avatar'), ...document.querySelectorAll('.fwx-menu-avatar')];
      allAvatars.forEach(avatar => {
        const icon = avatar.querySelector('.account-avatar-icon, .fwx-avatar-icon');
        const initial = avatar.querySelector('.account-avatar-initial');
        const img = avatar.querySelector('.account-avatar-img');

        // Use cached avatarUrl first, then fall back to Firebase photoURL
        const avatarUrl = cachedData.avatarUrl || user.photoURL;

        if (avatarUrl && img) {
          icon?.classList.add('fwx-hidden');
          initial?.classList.add('fwx-hidden');
          img.src = avatarUrl;
          img.classList.remove('fwx-hidden');
        } else if (initial) {
          icon?.classList.add('fwx-hidden');
          initial.textContent = displayName.charAt(0).toUpperCase();
          initial.classList.remove('fwx-hidden');
          img?.classList.add('fwx-hidden');
        }
      });
      
      // Re-attach logout listeners
      logoutBtns.forEach(btn => {
        const newBtn = btn.cloneNode(true);
        btn.parentNode.replaceChild(newBtn, btn);
        newBtn.addEventListener('click', async () => {
          try {
            sessionStorage.removeItem(USER_CACHE_KEY);
            // Clear auth cookies (HttpOnly — must go via server API)
            if (window.__setAuthCookies) await window.__setAuthCookies({ action: 'logout' });
            // Clear auth cache for live page
            sessionStorage.removeItem('fw_auth_cache');
            if (signOutFn && auth) await signOutFn(auth);
            window.location.href = '/';
          } catch (e){
            console.error('Logout error:', e);
          }
        });
      });
    } else {
      accountNames.forEach(el => el.textContent = 'Login');
      loggedOutSections.forEach(el => { el.classList.remove('fwx-hidden'); el.style.display = 'block'; });
      loggedInSections.forEach(el => { el.classList.add('fwx-hidden'); el.style.display = 'none'; });
      logoLinks.forEach(logo => {
        logo.classList.remove('admin-mode');
        logo.href = '/';
      });
    }
  }

  // Auth state change listener (only set once, skip if Firebase not loaded)
  if (auth && onAuthStateChangedFn) onAuthStateChangedFn(auth, async (user) => {
    if (user) {
      // userId/customerId cookies are set by __setAuthCookies during login
      // (HttpOnly — cannot be set via document.cookie)

      let cachedData = getCachedUserType();
      // Force refresh if no cache OR cache has no avatarUrl (might have been uploaded since)
      const needsFresh = !cachedData || !cachedData.avatarUrl;
      if (needsFresh) {
        try {
          const idToken = await user.getIdToken();
          const response = await fetch(`/api/get-user-type/?uid=${encodeURIComponent(user.uid)}`, {
            headers: { 'Authorization': `Bearer ${idToken}` }
          });
          if (!response.ok) throw new Error('Failed to fetch user type');
          const data = await response.json();
          if (data.success) {
            setCachedUserType(data.isArtist ? 'artist' : 'customer', data.isAdmin, data.avatarUrl || null, data.displayName || data.name || null);
            // Set __session cookie with ID token for SSR admin page auth (HttpOnly)
            if (data.isAdmin && window.__setAuthCookies) {
              window.__setAuthCookies({ token: idToken, action: 'login', isPartner: data.isArtist || false });
            }
            // Also set fw_auth_cache for instant auth on other pages (comments, ratings, etc.)
            try {
              sessionStorage.setItem('fw_auth_cache', JSON.stringify({
                loggedIn: true,
                id: user.uid,
                name: data.displayName || data.name || user.displayName || user.email?.split('@')[0] || 'User',
                displayName: data.displayName || data.name || user.displayName || user.email?.split('@')[0] || 'User',
                avatar: data.avatarUrl || user.photoURL || '',
                avatarUrl: data.avatarUrl || user.photoURL || '',
                timestamp: Date.now(),
                cachedAt: Date.now()
              }));
            } catch (e){ /* Ignore storage errors */ }
          } else {
            setCachedUserType('customer', false, null);
          }
        } catch (e){
          setCachedUserType('customer', false, null);
        }
      } else {
        // Refresh __session cookie for admin users (tokens expire hourly, HttpOnly)
        if (cachedData?.isAdmin && window.__setAuthCookies) {
          try {
            const freshToken = await user.getIdToken();
            window.__setAuthCookies({ token: freshToken, action: 'refresh' });
          } catch (e){ /* Token refresh failed, cookie will expire naturally */ }
        }
        // Even with cached data, ensure fw_auth_cache is set
        try {
          const existing = sessionStorage.getItem('fw_auth_cache');
          if (!existing || JSON.parse(existing).id !== user.uid) {
            sessionStorage.setItem('fw_auth_cache', JSON.stringify({
              loggedIn: true,
              id: user.uid,
              name: user.displayName || user.email?.split('@')[0] || 'User',
              displayName: user.displayName || user.email?.split('@')[0] || 'User',
              avatar: cachedData?.avatarUrl || user.photoURL || '',
              avatarUrl: cachedData?.avatarUrl || user.photoURL || '',
              timestamp: Date.now(),
              cachedAt: Date.now()
            }));
          }
        } catch (e){ /* Ignore storage errors */ }
      }
    } else {
      // User logged out - clear the auth cache and admin session cookie (HttpOnly)
      try { sessionStorage.removeItem('fw_auth_cache'); } catch (e){ /* Non-critical: best-effort cleanup on logout */ }
      if (window.__setAuthCookies) window.__setAuthCookies({ action: 'logout' });
    }
    // Update UI AFTER any fetch is complete
    updateAuthUI();
  });

  // ========== CART BADGE FUNCTIONALITY ==========
  function updateHeaderCartBadge() {
    // Get cart count from FreshWaxCart if available, otherwise check localStorage
    let count = 0;
    
    if (window.FreshWaxCart && typeof window.FreshWaxCart.count === 'function') {
      count = window.FreshWaxCart.count();
    } else {
      // Fallback: read directly from localStorage
      try {
        const customerId = document.cookie.split(';')
          .find(c => c.trim().startsWith('customerId='))
          ?.split('=')[1];

        if (customerId) {
          const cartKey = 'freshwax_cart_' + customerId;
          const stored = localStorage.getItem(cartKey);
          if (stored) {
            const data = JSON.parse(stored);
            const items = Array.isArray(data) ? data : (Array.isArray(data?.items) ? data.items : []);
            count = items.reduce((sum, item) => sum + (item.quantity || 1), 0);
          }
        }
      } catch (e){
        /* Non-critical: storage or JSON parse may fail in private browsing */
      }
    }
    
    // Update both desktop and mobile cart counts
    const desktopCount = document.getElementById('cart-count');
    const mobileCount = document.getElementById('cart-count-mobile');
    
    [desktopCount, mobileCount].forEach(el => {
      if (el) {
        el.textContent = count.toString();
        if (count > 0) {
          el.classList.remove('fwx-hidden');
          el.style.display = '';
        } else {
          el.classList.add('fwx-hidden');
          el.style.display = 'none';
        }
      }
    });
  }
  
  // Listen for cart updates (cleaned up on View Transitions navigation)
  window.addEventListener('cart-updated', updateHeaderCartBadge, { signal: headerCleanupController.signal });
  window.addEventListener('cartUpdated', updateHeaderCartBadge, { signal: headerCleanupController.signal });
  window.addEventListener('storage', (e) => {
    if (e.key && e.key.startsWith('freshwax_cart_')) {
      updateHeaderCartBadge();
    }
  }, { signal: headerCleanupController.signal });

  // Clean up intervals and event listeners before View Transitions swaps the DOM
  document.addEventListener('astro:before-swap', () => {
    if (window._headerLiveInterval) { clearInterval(window._headerLiveInterval); window._headerLiveInterval = null; }
    if (searchTimeout) { clearTimeout(searchTimeout); searchTimeout = undefined; }
    headerCleanupController.abort();
  }, { once: true });

  // Initialize on first load
  initHeader();
  updateHeaderCartBadge();

  // Re-initialize on View Transitions page load
  document.addEventListener('astro:page-load', async () => {
    initHeader();
    updateHeaderCartBadge();
    if (typeof initGoPlusModal === 'function') initGoPlusModal();

    // Ensure auth state is available for new page components
    // Re-create authReady promise for components that might be waiting
    if (auth && auth.currentUser !== undefined) {
      // Auth is already initialized, update window.authUser and re-apply UI
      window.authUser = auth.currentUser;

      // Create a new resolved promise for any new components
      window.authReady = Promise.resolve(auth.currentUser);

      // Re-apply auth UI state (avatar, name, etc.) since DOM was swapped
      updateAuthUI();

      // Dispatch custom event for components that listen for auth state
      window.dispatchEvent(new CustomEvent('auth-state-ready', { detail: { user: auth.currentUser } }));
    }
  });
</script>

