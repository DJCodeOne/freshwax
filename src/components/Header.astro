<script is:inline nonce={nonce}>
  // Immediate UI initialization — runs before Firebase module loads
  // Ensures header interactions (dropdown, burger menu) work even if Firebase CDN is slow/blocked
  (function() {
    // Account dropdown toggle (desktop)
    document.querySelectorAll('.account-dropdown').forEach(function(dropdown) {
      var button = dropdown.querySelector('.account-button');
      var menu = dropdown.querySelector('.account-menu');
      if (button && menu) {
        button.addEventListener('click', function(e) {
          e.stopPropagation();
          var isHidden = menu.style.display === 'none' || menu.classList.contains('fwx-hidden');
          if (isHidden) {
            menu.classList.remove('fwx-hidden');
            menu.style.display = 'block';
            button.setAttribute('aria-expanded', 'true');
          } else {
            menu.classList.add('fwx-hidden');
            menu.style.display = 'none';
            button.setAttribute('aria-expanded', 'false');
          }
        });
      }
    });

    // Close dropdowns on click outside
    document.addEventListener('click', function() {
      document.querySelectorAll('.account-menu').forEach(function(menu) {
        menu.classList.add('fwx-hidden');
        menu.style.display = 'none';
      });
      document.querySelectorAll('.account-button').forEach(function(btn) {
        btn.setAttribute('aria-expanded', 'false');
      });
    });

    // Burger menu (mobile)
    var burgerBtn = document.getElementById('burgerMenuBtn');
    var mobileMenu = document.getElementById('mobileMenu');
    var menuOverlay = document.getElementById('menuOverlay');
    var closeMenuBtn = document.getElementById('closeMenuBtn');

    function openMobileMenu() {
      if (mobileMenu) { mobileMenu.classList.add('open'); mobileMenu.classList.remove('fwx-hidden'); }
      if (menuOverlay) { menuOverlay.classList.add('open'); menuOverlay.classList.remove('fwx-hidden'); }
      document.body.style.overflow = 'hidden';
      if (burgerBtn) burgerBtn.setAttribute('aria-expanded', 'true');
    }

    function closeMobileMenu() {
      if (mobileMenu) mobileMenu.classList.remove('open');
      if (menuOverlay) menuOverlay.classList.remove('open');
      document.body.style.overflow = '';
      if (burgerBtn) { burgerBtn.setAttribute('aria-expanded', 'false'); burgerBtn.focus(); }
      setTimeout(function() {
        if (mobileMenu && !mobileMenu.classList.contains('open')) mobileMenu.classList.add('fwx-hidden');
        if (menuOverlay && !menuOverlay.classList.contains('open')) menuOverlay.classList.add('fwx-hidden');
      }, 300);
    }

    if (burgerBtn) burgerBtn.addEventListener('click', function(e) { e.stopPropagation(); openMobileMenu(); });
    if (closeMenuBtn) closeMenuBtn.addEventListener('click', closeMobileMenu);
    if (menuOverlay) menuOverlay.addEventListener('click', closeMobileMenu);

    // Close mobile menu on nav link click
    if (mobileMenu) {
      mobileMenu.querySelectorAll('.fwx-menu-link').forEach(function(link) {
        link.addEventListener('click', closeMobileMenu);
      });
    }

    // Close on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && mobileMenu && mobileMenu.classList.contains('open')) {
        closeMobileMenu();
      }
    });
  })();
</script>

<script is:inline nonce={nonce}>
  // Google Translate — lazy-loaded on first button click
  // When translation is active, navigations use full page reload so GT
  // can read the googtrans cookie and translate automatically.
  var _gtConfig = {
    pageLanguage: 'en',
    includedLanguages: 'en,fr,de,es,it,pt,nl,ja,zh-CN,ko,ru,pl,sv,da,no',
    autoDisplay: false
  };

  if (!window._gtState) {
    window._gtState = { loading: false, ready: false, waiting: false };
  }

  function googleTranslateElementInit() {
    // Prevent duplicate widget — check if select already exists
    var existing = document.querySelector('select.goog-te-combo');
    if (existing) {
      window._gtState.ready = true;
      return;
    }
    new google.translate.TranslateElement(_gtConfig, 'google_translate_element');
    window._gtState.ready = true;

    // After widget is created, apply saved language by selecting it in the dropdown.
    var lang = null;
    try { lang = localStorage.getItem('fw_translate_lang'); } catch (e){ /* Non-critical: storage may be unavailable in private browsing */ }
    if (lang) {
      waitForSelect(function(sel) {
        if (sel.value !== lang) {
          sel.value = lang;
          sel.dispatchEvent(new Event('change'));
        }
      });
    }
  }

  function loadGoogleTranslate() {
    if (window._gtState.loading || window._gtState.ready) return;
    window._gtState.loading = true;
    var s = document.createElement('script');
    s.src = 'https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit';
    s.async = true;
    s.onerror = function() { window._gtState.loading = false; };
    document.head.appendChild(s);
    // Safety timeout: reset loading flag after 10s so button can be retried
    setTimeout(function() {
      if (!window._gtState.ready) { window._gtState.loading = false; }
    }, 10000);
  }

  function waitForSelect(callback) {
    // Prevent multiple concurrent polling loops
    if (window._gtState.waiting) return;
    window._gtState.waiting = true;
    var attempts = 0;
    var poll = setInterval(function() {
      attempts++;
      var sel = document.querySelector('select.goog-te-combo');
      if (sel) {
        clearInterval(poll);
        window._gtState.waiting = false;
        callback(sel);
      } else if (attempts > 50) {
        clearInterval(poll);
        window._gtState.waiting = false;
      }
    }, 150);
  }

  function applyLanguage(langCode) {
    var sel = document.querySelector('select.goog-te-combo');
    var domainCookie = location.hostname.indexOf('.') !== -1 ? ';domain=.' + location.hostname : '';

    // Update the document lang attribute for a11y / screen readers
    document.documentElement.lang = (langCode && langCode !== 'en') ? langCode : 'en-GB';

    if (langCode && langCode !== 'en') {
      try { localStorage.setItem('fw_translate_lang', langCode); } catch (e){ /* Non-critical: storage may be unavailable in private browsing */ }
      document.cookie = 'googtrans=/en/' + langCode + ';path=/;Secure;SameSite=Lax';
      if (domainCookie) document.cookie = 'googtrans=/en/' + langCode + ';path=/' + domainCookie + ';Secure;SameSite=Lax';
    } else {
      try { localStorage.removeItem('fw_translate_lang'); } catch (e){ /* Non-critical: storage may be unavailable in private browsing */ }
      document.cookie = 'googtrans=;path=/;expires=Thu, 01 Jan 1970 00:00:00 GMT;Secure;SameSite=Lax';
      if (domainCookie) document.cookie = 'googtrans=;path=/;expires=Thu, 01 Jan 1970 00:00:00 GMT' + domainCookie + ';Secure;SameSite=Lax';
    }

    // Drive the hidden Google Translate select
    if (sel) {
      sel.value = langCode;
      sel.dispatchEvent(new Event('change'));
    } else {
      // GT not loaded yet — reload to let GT read the cookie
      window.location.reload();
    }
  }

  function updatePanelSelection(langCode) {
    var panel = document.getElementById('langPanel');
    if (!panel) return;
    var opts = panel.querySelectorAll('.fwx-lang-opt');
    for (var i = 0; i < opts.length; i++) {
      opts[i].setAttribute('aria-pressed', opts[i].getAttribute('data-lang') === langCode ? 'true' : 'false');
    }
  }

  function toggleLangPanel() {
    var panel = document.getElementById('langPanel');
    var btn = document.getElementById('langBtn');
    if (!panel || !btn) return;

    var isOpen = !panel.hidden;
    if (isOpen) {
      // Remove focus trap when closing
      if (panel._focusTrapHandler) {
        panel.removeEventListener('keydown', panel._focusTrapHandler);
        panel._focusTrapHandler = null;
      }
      panel.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
      btn.focus();
      return;
    }

    // Highlight current language
    var current = 'en';
    try { current = localStorage.getItem('fw_translate_lang') || 'en'; } catch (e){ /* Non-critical: storage may be unavailable in private browsing */ }
    updatePanelSelection(current);

    panel.hidden = false;
    btn.setAttribute('aria-expanded', 'true');

    // Focus first option for keyboard users
    var firstOpt = panel.querySelector('.fwx-lang-opt[aria-pressed="true"]') || panel.querySelector('.fwx-lang-opt');
    if (firstOpt) firstOpt.focus();

    // Focus trap: Tab/Shift+Tab cycles within the language panel
    var focusTrapHandler = function(e) {
      if (e.key !== 'Tab') return;
      var focusableEls = panel.querySelectorAll('button:not([disabled]), [tabindex]:not([tabindex="-1"])');
      if (focusableEls.length === 0) return;
      var firstEl = focusableEls[0];
      var lastEl = focusableEls[focusableEls.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === firstEl) {
          e.preventDefault();
          lastEl.focus();
        }
      } else {
        if (document.activeElement === lastEl) {
          e.preventDefault();
          firstEl.focus();
        }
      }
    };
    // Remove old handler if present
    if (panel._focusTrapHandler) {
      panel.removeEventListener('keydown', panel._focusTrapHandler);
    }
    panel._focusTrapHandler = focusTrapHandler;
    panel.addEventListener('keydown', focusTrapHandler);

    // Close on outside click
    function closeOnOutside(e) {
      if (!panel.contains(e.target) && e.target !== btn && !btn.contains(e.target)) {
        if (panel._focusTrapHandler) {
          panel.removeEventListener('keydown', panel._focusTrapHandler);
          panel._focusTrapHandler = null;
        }
        panel.hidden = true;
        btn.setAttribute('aria-expanded', 'false');
        document.removeEventListener('click', closeOnOutside, true);
        document.removeEventListener('keydown', closeOnEsc);
      }
    }
    function closeOnEsc(e) {
      if (e.key === 'Escape') {
        if (panel._focusTrapHandler) {
          panel.removeEventListener('keydown', panel._focusTrapHandler);
          panel._focusTrapHandler = null;
        }
        panel.hidden = true;
        btn.setAttribute('aria-expanded', 'false');
        btn.focus();
        document.removeEventListener('click', closeOnOutside, true);
        document.removeEventListener('keydown', closeOnEsc);
      }
    }
    // Delay to avoid immediate close from the click that opened it
    setTimeout(function() {
      document.addEventListener('click', closeOnOutside, true);
      document.addEventListener('keydown', closeOnEsc);
    }, 0);
  }

  // Globe button + panel handlers
  function setupLangButton() {
    var langBtn = document.getElementById('langBtn');
    var panel = document.getElementById('langPanel');
    if (!langBtn) return;

    // Clone to remove old listeners on re-init (View Transitions)
    var newBtn = langBtn.cloneNode(true);
    langBtn.parentNode.replaceChild(newBtn, langBtn);

    newBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      // Load GT on first interaction instead of proactively (saves ~119KB)
      if (!window._gtState.ready && !window._gtState.loading) {
        loadGoogleTranslate();
      }
      toggleLangPanel();
    });

    if (panel) {
      // Clone panel too to avoid duplicate listeners
      var newPanel = panel.cloneNode(true);
      panel.parentNode.replaceChild(newPanel, panel);

      newPanel.addEventListener('click', function(e) {
        var opt = e.target.closest('.fwx-lang-opt');
        if (!opt) return;
        var lang = opt.getAttribute('data-lang');
        updatePanelSelection(lang);
        if (newPanel._focusTrapHandler) {
          newPanel.removeEventListener('keydown', newPanel._focusTrapHandler);
          newPanel._focusTrapHandler = null;
        }
        newPanel.hidden = true;
        newBtn.setAttribute('aria-expanded', 'false');
        newBtn.focus();
        applyLanguage(lang);
      });

      // Keyboard navigation within the grid
      newPanel.addEventListener('keydown', function(e) {
        var opts = Array.prototype.slice.call(newPanel.querySelectorAll('.fwx-lang-opt'));
        var idx = opts.indexOf(document.activeElement);
        if (idx === -1) return;
        var cols = 3;
        var next = -1;
        if (e.key === 'ArrowRight') next = Math.min(idx + 1, opts.length - 1);
        else if (e.key === 'ArrowLeft') next = Math.max(idx - 1, 0);
        else if (e.key === 'ArrowDown') next = Math.min(idx + cols, opts.length - 1);
        else if (e.key === 'ArrowUp') next = Math.max(idx - cols, 0);
        if (next !== -1 && next !== idx) {
          e.preventDefault();
          opts[next].focus();
        }
      });
    }
  }
  setupLangButton();

  // When translation is active, force full page reload on all internal
  // navigation so Google Translate reads the googtrans cookie and translates.
  // Uses capture phase to fire BEFORE Astro's View Transition router.
  if (!window._gtNavHooked) {
    window._gtNavHooked = true;

    document.addEventListener('click', function(e) {
      try { if (!localStorage.getItem('fw_translate_lang')) return; } catch (ex) { /* intentional: localStorage unavailable in private browsing — skip translation nav */ return; }
      var a = e.target.closest('a[href]');
      if (!a) return;
      var href = a.getAttribute('href');
      if (!href || href.charAt(0) === '#' || href.startsWith('javascript:')) return;
      // Only intercept same-origin navigation
      if (a.origin !== window.location.origin) return;
      // Force full page reload instead of View Transition
      e.preventDefault();
      e.stopPropagation();
      window.location.href = a.href;
    }, true);
  }

  // On page load, if there's a saved language, set cookie and defer GT load
  var savedLang = null;
  try { savedLang = localStorage.getItem('fw_translate_lang'); } catch (e){ /* Non-critical: storage may be unavailable in private browsing */ }
  if (savedLang) {
    // Set cookie on both path and domain for maximum compatibility
    document.cookie = 'googtrans=/en/' + savedLang + ';path=/;Secure;SameSite=Lax';
    if (location.hostname.indexOf('.') !== -1) {
      document.cookie = 'googtrans=/en/' + savedLang + ';path=/;domain=.' + location.hostname + ';Secure;SameSite=Lax';
    }
    // Defer GT loading so it doesn't block initial performance metrics
    if (typeof requestIdleCallback === 'function') {
      requestIdleCallback(function() { loadGoogleTranslate(); }, { timeout: 4000 });
    } else {
      setTimeout(function() { loadGoogleTranslate(); }, 3000);
    }
  }
</script>

