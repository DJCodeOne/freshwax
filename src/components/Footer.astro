---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 relative z-50" role="contentinfo">
  <div class="container mx-auto px-4 py-6 sm:py-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      
      <!-- About Section -->
      <div class="lg:col-span-2">
        <a href="/" class="inline-block mb-3 bg-white rounded-lg p-2">
          <img src="/logo.webp" alt="Fresh Wax" class="h-10 w-auto" translate="no" />
        </a>
        <p class="text-sm text-gray-400 mb-3 max-w-md leading-relaxed">
          Independent UK online music store specialising in jungle and drum & bass. Digital downloads, vinyl records, DJ mixes, and exclusive merchandise.
        </p>
        <div class="flex gap-4">
          <a href="https://www.facebook.com/people/Fresh-Wax/61585403216797/" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Fresh Wax on Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/freshwaxuk" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Fresh Wax on Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="https://www.youtube.com/@freshwaxuk" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Fresh Wax on YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links - SEO Important -->
      <div>
        <h3 class="text-white font-bold text-base mb-3">Shop</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/releases/" class="hover:text-white transition-colors">All Releases</a></li>
          <li><a href="/weekly-chart/" class="hover:text-white transition-colors">Weekly Chart</a></li>
          <li><a href="/pre-orders/" class="hover:text-white transition-colors">Pre-Orders</a></li>
          <li><a href="/dj-mixes/" class="hover:text-white transition-colors">DJ Mixes</a></li>
          <li><a href="/dj-mix-chart/" class="hover:text-white transition-colors">Mix Chart</a></li>
          <li><a href="/merch/" class="hover:text-white transition-colors">Merchandise</a></li>
          <li><a href="/giftcards/" class="hover:text-white transition-colors">Gift Cards</a></li>
          <li><a href="/live/" class="hover:text-white transition-colors">Live Stream</a></li>
        </ul>
      </div>

      <!-- Info Links - SEO & Legal -->
      <div>
        <h3 class="text-white font-bold text-base mb-3">Information</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/about/" class="hover:text-white transition-colors">About Us</a></li>
          <li><a href="/contact/" class="hover:text-white transition-colors">Contact</a></li>
          <li><a href="/shipping/" class="hover:text-white transition-colors">Shipping & Returns</a></li>
          <li><a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/cookies/" class="hover:text-white transition-colors">Cookie Policy</a></li>
          <li><a href="/terms/" class="hover:text-white transition-colors">Terms & Conditions</a></li>
        </ul>
      </div>
    </div>

    <!-- Newsletter Signup -->
    <div class="border-t border-gray-800 mt-6 pt-6">
      <div class="max-w-xl mx-auto text-center">
        <h3 class="text-white font-bold text-base mb-2">Stay Fresh</h3>
        <p class="text-gray-400 text-sm mb-3">Subscribe for new releases, exclusive offers, and store updates.</p>
        <form id="newsletter-form" class="max-w-md mx-auto">
          <div class="flex flex-col sm:flex-row gap-2">
            <input
              type="email"
              id="newsletter-email"
              placeholder="Enter your email"
              required
              aria-label="Email address for newsletter"
              class="flex-1 px-4 py-2 bg-gray-800 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:border-white transition-colors text-sm rounded-lg"
            />
            <button
              type="submit"
              id="newsletter-btn"
              class="px-6 py-2 bg-white text-black font-bold hover:bg-red-600 hover:text-white transition-colors rounded-lg text-sm"
            >
              Subscribe
            </button>
          </div>
          <label class="flex items-start gap-2 mt-2 cursor-pointer">
            <input type="checkbox" id="newsletter-consent" required class="mt-0.5 w-3.5 h-3.5 accent-red-600" />
            <span class="text-xs text-gray-500">I agree to receive marketing emails. <a href="/privacy/" class="text-gray-400 hover:text-white underline">Privacy Policy</a></span>
          </label>
        </form>
        <p id="newsletter-message" class="mt-2 text-xs hidden" role="alert"></p>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-800 mt-6 pt-4 flex flex-col md:flex-row justify-between items-center gap-3">
      <p class="text-sm text-gray-400">
        © {currentYear} <span class="text-white">Fresh</span><span class="text-red-500">Wax</span>
      </p>
      <div class="flex items-center gap-4 text-sm text-gray-400">
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
          </svg>
          Jungle & D&B
        </span>
        <a href="/sitemap.xml" class="hover:text-white transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('newsletter-form');
    const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
    const btn = document.getElementById('newsletter-btn') as HTMLButtonElement;
    const message = document.getElementById('newsletter-message') as HTMLParagraphElement;
    
    const consentInput = document.getElementById('newsletter-consent') as HTMLInputElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = emailInput?.value?.trim();
      if (!email) return;

      if (!consentInput?.checked) {
        if (message) {
          message.textContent = 'Please agree to receive marketing emails.';
          message.className = 'mt-2 text-xs text-red-500';
          message.classList.remove('hidden');
        }
        return;
      }

      // Update button state
      btn.disabled = true;
      btn.textContent = 'Subscribing...';
      message.classList.add('hidden');

      try {
        const response = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'footer', consent: true })
        });
        
        const data = await response.json();
        
        if (data.success) {
          message.textContent = data.message || 'Successfully subscribed!';
          message.className = 'mt-3 text-sm text-green-500';
          message.classList.remove('hidden');
          form.reset();
        } else {
          message.textContent = data.error || 'Failed to subscribe. Please try again.';
          message.className = 'mt-3 text-sm text-red-500';
          message.classList.remove('hidden');
        }
      } catch (err) {
        message.textContent = 'An error occurred. Please try again.';
        message.className = 'mt-3 text-sm text-red-500';
        message.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Subscribe';
      }
    });
  });
</script>
