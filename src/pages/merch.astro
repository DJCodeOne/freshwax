---
// src/pages/merch.astro
// Public Merch Store - Cloudflare Pages compatible (uses REST API)

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageLoader from '../components/PageLoader.astro';
import { getLiveMerch } from '../lib/firebase-rest';
import '../styles/merch.css';

export const prerender = false;

// Get D1 binding for optimized reads
const db = Astro.locals.runtime.env?.DB;

// Fetch merch using D1 first, Firebase fallback
let products: Record<string, unknown>[] = [];
// Hierarchical categories: { categorySlug: { label: string, names: string[] } }
let categoryGroups: Record<string, { label: string; names: Set<string> }> = {};
let productTypes: Record<string, string> = {};

// Category type display names
const categoryLabels: Record<string, string> = {
  freshwax: 'Fresh Wax',
  label: 'Labels',
  soundsystem: 'Sound Systems',
  dj: 'DJs',
  crew: 'Crews'
};

try {
  const merchData = await getLiveMerch(undefined, db);

  products = merchData.map(doc => {
    // Build hierarchical category filter
    const catSlug = doc.category || 'freshwax';
    const catName = doc.categoryName || 'Fresh Wax';
    if (!categoryGroups[catSlug]) {
      categoryGroups[catSlug] = {
        label: categoryLabels[catSlug] || catSlug,
        names: new Set()
      };
    }
    categoryGroups[catSlug].names.add(catName);

    if (doc.productType && doc.productTypeName) {
      productTypes[doc.productType] = doc.productTypeName;
    }
    
    // Calculate stock status
    const stock = doc.totalStock || 0;
    const threshold = doc.lowStockThreshold || 5;
    let stockStatus = 'in-stock';
    let stockLabel = 'In Stock';
    
    if (stock === 0) {
      stockStatus = 'out-of-stock';
      stockLabel = 'Out of Stock';
    } else if (stock <= threshold) {
      stockStatus = 'low-stock';
      stockLabel = 'Low Stock';
    }
    
    // Get images - keep full objects for color association
    let imageObjects: Record<string, unknown>[] = [];
    let allImages: string[] = [];
    if (doc.images && Array.isArray(doc.images)) {
      imageObjects = doc.images.filter((img) => {
        if (typeof img === 'string') return true;
        if (img && typeof img === 'object' && img.url) return true;
        return false;
      });
      allImages = imageObjects.map((img) => {
        if (typeof img === 'string') return img;
        return img.url;
      });
    }

    if (allImages.length === 0) {
      if (doc.primaryImage) {
        allImages = [doc.primaryImage];
        imageObjects = [{ url: doc.primaryImage }];
      } else if (doc.imageUrl) {
        allImages = [doc.imageUrl];
        imageObjects = [{ url: doc.imageUrl }];
      }
    }

    const imageUrl = doc.primaryImage || allImages[0] || '';
    
    // Process colors - array of {hex, name} objects
    let colorList: string[] = [];
    let colorNames: string[] = [];
    if (doc.colors && Array.isArray(doc.colors)) {
      colorList = doc.colors.map((c) => c.hex || c).filter(Boolean);
      colorNames = doc.colors.map((c) => c.name || c.hex || c).filter(Boolean);
    }
    
    return {
      ...doc,
      stockStatus,
      stockLabel,
      images: allImages,
      imageObjects,
      imageUrl,
      colorList,
      colorNames,
      retailPrice: parseFloat(doc.retailPrice) || 0,
      salePrice: doc.salePrice ? parseFloat(doc.salePrice) : null,
    };
  });
  
  // Sort: featured first, then by date
  products.sort((a, b) => {
    if (a.featured && !b.featured) return -1;
    if (!a.featured && b.featured) return 1;
    return new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime();
  });
  
} catch (e: unknown) {
  console.error('[Merch] Error fetching:', e);
}

const onSaleCount = products.filter(p => p.onSale).length;
const productsJson = JSON.stringify(products);

// Convert Sets to arrays for template use
const categoryGroupsArray = Object.entries(categoryGroups).map(([slug, group]) => ({
  slug,
  label: group.label,
  names: Array.from(group.names).sort()
})).sort((a, b) => a.label.localeCompare(b.label));
const nonce = Astro.locals.nonce || '';

// Preload first product image for faster LCP
const firstProductImage = products[0]?.imageUrl;

Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=300, stale-while-revalidate=600');

// Build ItemList structured data for SEO
const merchItemList = {
  name: 'Official Merchandise',
  items: products.map((p, i) => ({
    name: p.name || p.title || 'Product',
    url: `/merch/${p.id}/`,
    image: p.imageUrl || undefined,
    position: i + 1,
  }))
};
---

<Layout title="Merchandise - Jungle & Drum and Bass Apparel" description="Official jungle and drum & bass merchandise from Fresh Wax. T-shirts, hoodies, hats and more from sound systems, labels and DJs." itemList={merchItemList}>
  {firstProductImage && <link rel="preload" href={firstProductImage} as="image" slot="head" />}
  <PageLoader nonce={nonce} />
  <Header />

  <div class="merch-page">
    <!-- Hero Section -->
    <section class="merch-hero">
      <div class="hero-container">
        <h1 class="hero-title">MERCH <span class="red">STORE</span></h1>
        <p class="hero-subtitle">Sound Systems, Crews, Labels, DJs & More</p>
      </div>
    </section>

    <!-- Filters Bar -->
    <section class="filters-bar">
      <div class="filters-row">
        <div class="filter-item category-filter">
          <label>Category</label>
          <div class="category-dropdown" id="categoryDropdown">
            <button type="button" class="category-dropdown-btn" id="categoryBtn" aria-haspopup="true" aria-expanded="false" aria-controls="dropdown-category-menu">
              <span id="categoryLabel">All</span>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M2 4l4 4 4-4"/></svg>
            </button>
            <div class="category-menu" id="dropdown-category-menu" role="menu" aria-label="Category filter">
              <div class="category-menu-item" data-category="" data-name="" role="menuitem">
                <span>All</span>
              </div>
              {categoryGroupsArray.map(group => {
                // If only one supplier and it matches the category label, show as direct link
                const singleSupplier = group.names.length === 1 && group.names[0] === group.label;

                return singleSupplier ? (
                  <div class="category-menu-item" data-category={group.slug} data-name={group.names[0]} role="menuitem">
                    <span>{group.label}</span>
                  </div>
                ) : (
                  <div class="category-menu-item has-submenu" data-category={group.slug} role="menuitem">
                    <span>{group.label}</span>
                    <svg width="8" height="8" viewBox="0 0 8 8" fill="currentColor"><path d="M2 0l4 4-4 4"/></svg>
                    <div class="category-submenu">
                      <div class="category-submenu-item" data-category={group.slug} data-name="" role="menuitem">
                        <span>All {group.label}</span>
                      </div>
                      {group.names.map(name => (
                        <div class="category-submenu-item" data-category={group.slug} data-name={name} role="menuitem">
                          <span>{name}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
          <input type="hidden" id="categoryFilter" value="" />
          <input type="hidden" id="categoryNameFilter" value="" />
        </div>

        <div class="filter-item">
          <label>Type</label>
          <div class="custom-dropdown" id="typeDropdown">
            <button type="button" class="dropdown-btn" aria-haspopup="listbox" aria-expanded="false" aria-controls="dropdown-type-menu">
              <span id="typeLabel">All</span>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M2 4l4 4 4-4"/></svg>
            </button>
            <div class="dropdown-menu" role="listbox" id="dropdown-type-menu" aria-label="Type filter">
              <div class="dropdown-item" data-value="" role="option" aria-selected="true">All</div>
              {Object.entries(productTypes).map(([key, name]) => (
                <div class="dropdown-item" data-value={key} role="option" aria-selected="false">{name}</div>
              ))}
            </div>
          </div>
          <input type="hidden" id="typeFilter" value="" />
        </div>

        <div class="filter-item">
          <label>Availability</label>
          <div class="custom-dropdown" id="stockDropdown">
            <button type="button" class="dropdown-btn" aria-haspopup="listbox" aria-expanded="false" aria-controls="dropdown-stock-menu">
              <span id="stockLabel">All</span>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M2 4l4 4 4-4"/></svg>
            </button>
            <div class="dropdown-menu" role="listbox" id="dropdown-stock-menu" aria-label="Availability filter">
              <div class="dropdown-item" data-value="" role="option" aria-selected="true">All</div>
              <div class="dropdown-item" data-value="in-stock" role="option" aria-selected="false">In Stock</div>
              {onSaleCount > 0 && <div class="dropdown-item" data-value="on-sale" role="option" aria-selected="false">On Sale</div>}
            </div>
          </div>
          <input type="hidden" id="stockFilter" value="" />
        </div>

        <div class="filter-item">
          <label>Sort By</label>
          <div class="custom-dropdown" id="sortDropdown">
            <button type="button" class="dropdown-btn" aria-haspopup="listbox" aria-expanded="false" aria-controls="dropdown-sort-menu">
              <span id="sortLabel">Featured</span>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M2 4l4 4 4-4"/></svg>
            </button>
            <div class="dropdown-menu" role="listbox" id="dropdown-sort-menu" aria-label="Sort filter">
              <div class="dropdown-item" data-value="featured" role="option" aria-selected="true">Featured</div>
              <div class="dropdown-item" data-value="newest" role="option" aria-selected="false">Newest</div>
              <div class="dropdown-item" data-value="price-low" role="option" aria-selected="false">Price ↑</div>
              <div class="dropdown-item" data-value="price-high" role="option" aria-selected="false">Price ↓</div>
              <div class="dropdown-item" data-value="name" role="option" aria-selected="false">A-Z</div>
            </div>
          </div>
          <input type="hidden" id="sortSelect" value="featured" />
        </div>

        <button id="clearFilters" class="clear-btn">Clear</button>

        <div class="products-count">
          <span id="visibleCount">{products.length}</span> / {products.length}
        </div>

        <a href="/giftcards/" class="gift-card-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
            <path d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
          </svg>
          Gift Cards
        </a>
      </div>
    </section>

    <!-- Content Section -->
    <div class="merch-content">
      <!-- Products Grid - 2x2 -->
      <section class="products-section">
        {products.length === 0 ? (
          <div class="empty-state">
            <span>👕</span>
            <h2>No merch available</h2>
            <p>Check back soon!</p>
          </div>
        ) : (
          <div id="productsGrid" class="products-grid">
            {products.map((product, pIdx) => (
              <div
                class="product-card"
                data-id={product.id}
                data-category={product.category || 'freshwax'}
                data-category-name={product.categoryName || ''}
                data-type={product.productType || ''}
                data-stock={product.stockStatus}
                data-sale={product.onSale ? 'true' : 'false'}
                data-featured={product.featured ? 'true' : 'false'}
                data-price={product.salePrice || product.retailPrice}
                data-name={product.name}
                data-created={product.createdAt || ''}
                data-product={JSON.stringify(product)}
              >
                <!-- Image -->
                <div class="card-image card-clickable">
                  {product.imageUrl ? (
                    <img
                      src={product.imageUrl}
                      alt={product.name}
                      width="400"
                      height="400"
                      loading={pIdx < 4 ? "eager" : "lazy"}
                      decoding={pIdx < 4 ? "auto" : "async"}
                      fetchpriority={pIdx === 0 ? "high" : undefined}
                    />
                  ) : (
                    <div class="placeholder">👕</div>
                  )}
                  
                  <div class="badges">
                    {product.onSale && <span class="badge sale">SALE</span>}
                    {product.featured && <span class="badge featured">★</span>}
                    {product.stockStatus === 'out-of-stock' && <span class="badge sold-out">SOLD OUT</span>}
                  </div>
                </div>
                
                <!-- Info -->
                <div class="card-info card-clickable">
                  <span class="product-name">{product.name}</span>
                  <p class="product-meta">{product.categoryName}</p>
                  
                  {product.sizes && product.sizes.length > 0 && (
                    <p class="product-sizes">{product.sizes.join(' • ')}</p>
                  )}
                  
                  {product.colorList && product.colorList.length > 0 && (
                    <div class="color-dots" role="group" aria-label="Available colours">
                      {product.colorList.map((color: string, idx: number) => (
                        <span
                          class="dot"
                          style={`background:${color}`}
                          data-color={product.colorNames?.[idx] || color}
                          role="button"
                          tabindex="0"
                          aria-label={`Preview colour ${product.colorNames?.[idx] || color}`}
                        ></span>
                      ))}
                    </div>
                  )}
                </div>
                
                <!-- Buy Button -->
                <button 
                  class="buy-btn" 
                  disabled={product.stockStatus === 'out-of-stock'}
                >
                  {product.stockStatus === 'out-of-stock' ? (
                    <span>Sold Out</span>
                  ) : (
                    <>
                      <span class="buy-text">BUY</span>
                      <span class="buy-price">
                        {product.onSale && product.salePrice ? (
                          <>£{product.salePrice.toFixed(2)}</>
                        ) : (
                          <>£{product.retailPrice.toFixed(2)}</>
                        )}
                      </span>
                    </>
                  )}
                </button>
              </div>
            ))}
          </div>
        )}
      </section>
    </div>
  </div>

  <!-- Quick View / Buy Modal -->
  <div id="buyModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modalName">
    <div class="modal-box">
      <button class="modal-close" aria-label="Close">&times;</button>
      
      <div class="modal-grid">
        <!-- Image -->
        <div class="modal-image">
          <img id="modalImg" src="" alt="Product image" width="500" height="500" loading="lazy" decoding="async" />
          <div id="modalThumbs" class="modal-thumbs"></div>
        </div>
        
        <!-- Details -->
        <div class="modal-info">
          <h2 id="modalName"></h2>
          <p id="modalCategory" class="modal-cat"></p>
          <p id="modalDesc" class="modal-desc"></p>
          
          <div id="modalPriceBox" class="modal-price"></div>
          
          <!-- Size Selection -->
          <fieldset id="sizeSection" class="option-section">
            <div class="size-label-row">
              <legend>Select Size <span class="required">*</span></legend>
              <button type="button" id="sizeGuideBtn" class="size-guide-btn">Size Guide</button>
            </div>
            <div id="sizeOptions" class="option-grid"></div>
            <!-- Size Guide Popup -->
            <div id="sizeGuidePopup" class="size-guide-popup">
              <div class="size-guide-content">
                <div class="size-guide-header">
                  <h3>Size Guide (Chest in inches)</h3>
                  <button type="button" class="size-guide-close" aria-label="Close size guide">&times;</button>
                </div>
                <table class="size-guide-table" aria-label="Size guide - chest measurements in inches">
                  <tr><th scope="col">Size</th><th scope="col">Chest</th></tr>
                  <tr><td>S</td><td>34-36"</td></tr>
                  <tr><td>M</td><td>38-40"</td></tr>
                  <tr><td>L</td><td>42-44"</td></tr>
                  <tr><td>XL</td><td>46-48"</td></tr>
                  <tr><td>XXL</td><td>50-52"</td></tr>
                  <tr><td>3XL</td><td>54-56"</td></tr>
                </table>
              </div>
            </div>
          </fieldset>

          <!-- Color Selection -->
          <fieldset id="colorSection" class="option-section">
            <legend>Select Colour <span class="required">*</span></legend>
            <div id="colorOptions" class="option-grid"></div>
          </fieldset>
          
          <!-- Stock Status -->
          <div id="modalStockStatus" class="stock-info"></div>
          
          <!-- Add to Cart -->
          <button id="addToCartBtn" class="add-to-cart-btn" disabled>
            <span class="btn-text">Select Options</span>
            <span class="btn-price"></span>
          </button>
          
          <a id="viewDetailsLink" href="" class="view-details-link">View Larger with Zoom →</a>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script define:vars={{ productsJson }} nonce={nonce}>
  window.PRODUCTS_DATA = JSON.parse(productsJson);
</script>

<script is:inline nonce={nonce}>

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }

  function init() {
    // Filters
    const categoryFilter = document.getElementById('categoryFilter');
    const categoryNameFilter = document.getElementById('categoryNameFilter');
    const categoryDropdown = document.getElementById('categoryDropdown');
    const categoryBtn = document.getElementById('categoryBtn');
    const categoryLabel = document.getElementById('categoryLabel');
    const typeFilter = document.getElementById('typeFilter');
    const stockFilter = document.getElementById('stockFilter');
    const sortSelect = document.getElementById('sortSelect');
    const clearBtn = document.getElementById('clearFilters');
    const grid = document.getElementById('productsGrid');
    const countEl = document.getElementById('visibleCount');

    // Custom dropdown elements
    const typeDropdown = document.getElementById('typeDropdown');
    const stockDropdown = document.getElementById('stockDropdown');
    const sortDropdown = document.getElementById('sortDropdown');
    const typeLabel = document.getElementById('typeLabel');
    const stockLabel = document.getElementById('stockLabel');
    const sortLabel = document.getElementById('sortLabel');
    const allDropdowns = [categoryDropdown, typeDropdown, stockDropdown, sortDropdown];

    // Nested category dropdown logic
    if (categoryBtn && categoryDropdown) {
      categoryBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        closeAllDropdownsExcept(categoryDropdown);
        categoryDropdown.classList.toggle('open');
        var isOpen = categoryDropdown.classList.contains('open');
        categoryBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    }

    // Generic dropdown toggle
    function setupDropdown(dropdown) {
      if (!dropdown) return;
      var btn = dropdown.querySelector('.dropdown-btn');
      if (btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          closeAllDropdownsExcept(dropdown);
          dropdown.classList.toggle('open');
          var isOpen = dropdown.classList.contains('open');
          btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });
      }
    }

    setupDropdown(typeDropdown);
    setupDropdown(stockDropdown);
    setupDropdown(sortDropdown);

    function closeAllDropdownsExcept(except) {
      allDropdowns.forEach(function(dd) {
        if (dd && dd !== except) {
          dd.classList.remove('open');
          var ddBtn = dd.querySelector('.dropdown-btn, .category-dropdown-btn');
          if (ddBtn) ddBtn.setAttribute('aria-expanded', 'false');
        }
      });
    }

    // Close dropdown when clicking outside
    document.addEventListener('click', function(e) {
      allDropdowns.forEach(function(dd) {
        if (dd && !dd.contains(e.target)) {
          dd.classList.remove('open');
          var ddBtn = dd.querySelector('.dropdown-btn, .category-dropdown-btn');
          if (ddBtn) ddBtn.setAttribute('aria-expanded', 'false');
        }
      });
    });

    // Handle Type dropdown selection
    if (typeDropdown) {
      typeDropdown.querySelectorAll('.dropdown-item').forEach(function(item) {
        item.addEventListener('click', function(e) {
          e.stopPropagation();
          var value = this.dataset.value || '';
          if (typeFilter) typeFilter.value = value;
          if (typeLabel) typeLabel.textContent = this.textContent;
          typeDropdown.querySelectorAll('[role="option"]').forEach(function(o) { o.setAttribute('aria-selected', 'false'); });
          this.setAttribute('aria-selected', 'true');
          typeDropdown.classList.remove('open');
          var ddBtn = typeDropdown.querySelector('.dropdown-btn');
          if (ddBtn) ddBtn.setAttribute('aria-expanded', 'false');
          applyFilters();
        });
      });
    }

    // Handle Availability dropdown selection
    if (stockDropdown) {
      stockDropdown.querySelectorAll('.dropdown-item').forEach(function(item) {
        item.addEventListener('click', function(e) {
          e.stopPropagation();
          var value = this.dataset.value || '';
          if (stockFilter) stockFilter.value = value;
          if (stockLabel) stockLabel.textContent = this.textContent;
          stockDropdown.querySelectorAll('[role="option"]').forEach(function(o) { o.setAttribute('aria-selected', 'false'); });
          this.setAttribute('aria-selected', 'true');
          stockDropdown.classList.remove('open');
          var ddBtn = stockDropdown.querySelector('.dropdown-btn');
          if (ddBtn) ddBtn.setAttribute('aria-expanded', 'false');
          applyFilters();
        });
      });
    }

    // Handle Sort dropdown selection
    if (sortDropdown) {
      sortDropdown.querySelectorAll('.dropdown-item').forEach(function(item) {
        item.addEventListener('click', function(e) {
          e.stopPropagation();
          var value = this.dataset.value || 'featured';
          if (sortSelect) sortSelect.value = value;
          if (sortLabel) sortLabel.textContent = this.textContent;
          sortDropdown.querySelectorAll('[role="option"]').forEach(function(o) { o.setAttribute('aria-selected', 'false'); });
          this.setAttribute('aria-selected', 'true');
          sortDropdown.classList.remove('open');
          var ddBtn = sortDropdown.querySelector('.dropdown-btn');
          if (ddBtn) ddBtn.setAttribute('aria-expanded', 'false');
          applyFilters();
        });
      });
    }

    // Handle category selection
    if (categoryDropdown) {
      categoryDropdown.querySelectorAll('.category-menu-item:not(.has-submenu), .category-submenu-item').forEach(function(item) {
        item.addEventListener('click', function(e) {
          e.stopPropagation();
          var cat = this.dataset.category || '';
          var name = this.dataset.name || '';

          if (categoryFilter) categoryFilter.value = cat;
          if (categoryNameFilter) categoryNameFilter.value = name;

          // Update button label
          if (categoryLabel) {
            if (!cat && !name) {
              categoryLabel.textContent = 'All';
            } else if (name) {
              categoryLabel.textContent = name;
            } else {
              var parentItem = categoryDropdown.querySelector('.category-menu-item[data-category="' + cat + '"]');
              var label = parentItem ? parentItem.querySelector('span').textContent : cat;
              categoryLabel.textContent = 'All ' + label;
            }
          }

          categoryDropdown.classList.remove('open');
          if (categoryBtn) categoryBtn.setAttribute('aria-expanded', 'false');
          applyFilters();
        });
      });
    }

    // Keyboard navigation for dropdowns
    function addDropdownKeyboard(dropdown, itemSelector) {
      if (!dropdown) return;
      var btn = dropdown.querySelector('.dropdown-btn, .category-dropdown-btn');
      if (!btn) return;

      btn.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowDown' || e.key === 'Down') {
          e.preventDefault();
          if (!dropdown.classList.contains('open')) {
            btn.click();
          }
          var items = dropdown.querySelectorAll(itemSelector);
          if (items.length > 0) items[0].focus();
        } else if (e.key === 'Escape' || e.key === 'Esc') {
          dropdown.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
          btn.focus();
        }
      });

      dropdown.addEventListener('keydown', function(e) {
        var items = Array.from(dropdown.querySelectorAll(itemSelector));
        var current = document.activeElement;
        var idx = items.indexOf(current);

        if (e.key === 'ArrowDown' || e.key === 'Down') {
          e.preventDefault();
          var next = idx < items.length - 1 ? idx + 1 : 0;
          items[next].focus();
        } else if (e.key === 'ArrowUp' || e.key === 'Up') {
          e.preventDefault();
          var prev = idx > 0 ? idx - 1 : items.length - 1;
          items[prev].focus();
        } else if (e.key === 'Home') {
          e.preventDefault();
          items[0].focus();
        } else if (e.key === 'End') {
          e.preventDefault();
          items[items.length - 1].focus();
        } else if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          if (current && items.indexOf(current) !== -1) current.click();
        } else if (e.key === 'Escape' || e.key === 'Esc') {
          e.preventDefault();
          dropdown.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
          btn.focus();
        } else if (e.key.length === 1) {
          // Type-ahead: jump to first item starting with typed letter
          var letter = e.key.toLowerCase();
          for (var i = 0; i < items.length; i++) {
            if ((items[i].textContent || '').trim().toLowerCase().startsWith(letter)) {
              items[i].focus();
              break;
            }
          }
        }
      });
    }

    // Add tabindex to items for focus
    function makeItemsFocusable(dropdown, itemSelector) {
      if (!dropdown) return;
      dropdown.querySelectorAll(itemSelector).forEach(function(item) {
        item.setAttribute('tabindex', '-1');
      });
    }

    makeItemsFocusable(typeDropdown, '.dropdown-item');
    makeItemsFocusable(stockDropdown, '.dropdown-item');
    makeItemsFocusable(sortDropdown, '.dropdown-item');
    makeItemsFocusable(categoryDropdown, '.category-menu-item:not(.has-submenu), .category-submenu-item');

    addDropdownKeyboard(typeDropdown, '.dropdown-item');
    addDropdownKeyboard(stockDropdown, '.dropdown-item');
    addDropdownKeyboard(sortDropdown, '.dropdown-item');
    addDropdownKeyboard(categoryDropdown, '.category-menu-item:not(.has-submenu), .category-submenu-item');

    function applyFilters() {
      var category = categoryFilter?.value || '';
      var categoryName = categoryNameFilter?.value || '';
      var type = typeFilter?.value || '';
      var stock = stockFilter?.value || '';
      var sort = sortSelect?.value || 'featured';

      var cards = Array.from(grid?.querySelectorAll('.product-card') || []);
      var visible = 0;

      cards.forEach(function(card) {
        var show = true;
        // Category filter: match category type and optionally name
        if (category) {
          if (card.dataset.category !== category) show = false;
          if (show && categoryName && card.dataset.categoryName !== categoryName) show = false;
        }
        if (type && card.dataset.type !== type) show = false;
        if (stock === 'in-stock' && card.dataset.stock === 'out-of-stock') show = false;
        if (stock === 'on-sale' && card.dataset.sale !== 'true') show = false;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      var visibleCards = cards.filter(function(c) { return c.style.display !== 'none'; });
      visibleCards.sort(function(a, b) {
        switch (sort) {
          case 'featured':
            if (a.dataset.featured === 'true' && b.dataset.featured !== 'true') return -1;
            if (a.dataset.featured !== 'true' && b.dataset.featured === 'true') return 1;
            return 0;
          case 'newest':
            return new Date(b.dataset.created || 0).getTime() - new Date(a.dataset.created || 0).getTime();
          case 'price-low':
            return parseFloat(a.dataset.price || '0') - parseFloat(b.dataset.price || '0');
          case 'price-high':
            return parseFloat(b.dataset.price || '0') - parseFloat(a.dataset.price || '0');
          case 'name':
            return (a.dataset.name || '').localeCompare(b.dataset.name || '');
          default:
            return 0;
        }
      });
      visibleCards.forEach(function(card) { if (grid) grid.appendChild(card); });
      if (countEl) countEl.textContent = String(visible);
    }

    // Hidden inputs are updated by dropdown handlers, no need for change listeners
    if (clearBtn) {
      clearBtn.addEventListener('click', function() {
        if (categoryFilter) categoryFilter.value = '';
        if (categoryNameFilter) categoryNameFilter.value = '';
        if (categoryLabel) categoryLabel.textContent = 'All';
        if (typeFilter) typeFilter.value = '';
        if (typeLabel) typeLabel.textContent = 'All';
        if (stockFilter) stockFilter.value = '';
        if (stockLabel) stockLabel.textContent = 'All';
        if (sortSelect) sortSelect.value = 'featured';
        if (sortLabel) sortLabel.textContent = 'Featured';
        // Reset aria-selected on all dropdowns
        [typeDropdown, stockDropdown, sortDropdown].forEach(function(dd) {
          if (!dd) return;
          dd.querySelectorAll('[role="option"]').forEach(function(o, i) {
            o.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
          });
        });
        applyFilters();
      });
    }

    // Color dot hover - show corresponding image (using event delegation)
    if (grid) {
      // Store original images on initial load
      grid.querySelectorAll('.product-card').forEach(function(card) {
        var cardImg = card.querySelector('.card-image img');
        if (cardImg && cardImg.src) {
          cardImg.dataset.originalSrc = cardImg.src;
        }
      });

      // Use event delegation for hover events
      grid.addEventListener('mouseenter', function(e) {
        var dot = e.target;
        if (!dot.classList || !dot.classList.contains('dot')) return;

        var card = dot.closest('.product-card');
        if (!card) return;

        var product = JSON.parse(card.dataset.product || '{}');
        var cardImg = card.querySelector('.card-image img');
        var colorName = dot.dataset.color;

        if (!colorName || !cardImg || !product.imageObjects) return;

        // Find image matching this color
        var matchingImage = product.imageObjects.find(function(img) {
          if (typeof img === 'object' && img.color) {
            return img.color.toLowerCase() === colorName.toLowerCase();
          }
          return false;
        });

        if (matchingImage && matchingImage.url) {
          cardImg.src = matchingImage.url;
        }
      }, true);

      grid.addEventListener('mouseleave', function(e) {
        var dot = e.target;
        if (!dot.classList || !dot.classList.contains('dot')) return;

        var card = dot.closest('.product-card');
        if (!card) return;

        var cardImg = card.querySelector('.card-image img');
        if (cardImg && cardImg.dataset.originalSrc) {
          cardImg.src = cardImg.dataset.originalSrc;
        }
      }, true);

      // Keyboard support for color dot swatches (Enter/Space triggers same as hover preview)
      grid.addEventListener('keydown', function(e) {
        var dot = e.target;
        if (!dot.classList || !dot.classList.contains('dot')) return;
        if (e.key !== 'Enter' && e.key !== ' ') return;

        e.preventDefault();
        var card = dot.closest('.product-card');
        if (!card) return;

        var product = JSON.parse(card.dataset.product || '{}');
        var cardImg = card.querySelector('.card-image img');
        var colorName = dot.dataset.color;

        if (!colorName || !cardImg || !product.imageObjects) return;

        var matchingImage = product.imageObjects.find(function(img) {
          if (typeof img === 'object' && img.color) {
            return img.color.toLowerCase() === colorName.toLowerCase();
          }
          return false;
        });

        if (matchingImage && matchingImage.url) {
          cardImg.src = matchingImage.url;
        }
      });
    }

    // Modal
    var modal = document.getElementById('buyModal');
    var modalClose = document.querySelector('.modal-close');
    var currentProduct = null;
    var selectedSize = null;
    var selectedColor = null;
    var modalTrigger = null;
    var modalFocusTrap = null;

    // Size Guide popup - use event delegation for reliability
    document.addEventListener('click', function(e) {
      var sizeGuidePopup = document.getElementById('sizeGuidePopup');

      // Open size guide when clicking the button
      if (e.target && (e.target.id === 'sizeGuideBtn' || e.target.closest('#sizeGuideBtn'))) {
        e.preventDefault();
        e.stopPropagation();
        if (sizeGuidePopup) {
          sizeGuidePopup.classList.add('active');
        }
        return;
      }

      // Close size guide when clicking the close button
      if (e.target && e.target.classList.contains('size-guide-close')) {
        e.preventDefault();
        if (sizeGuidePopup) {
          sizeGuidePopup.classList.remove('active');
        }
        return;
      }

      // Close size guide when clicking the overlay background
      if (e.target && e.target.id === 'sizeGuidePopup') {
        sizeGuidePopup.classList.remove('active');
      }
    });

    // Open modal when clicking on card image, info, or buy button (using event delegation)
    if (grid) {
      grid.addEventListener('click', function(e) {
        var target = e.target;

        // Find if click was on a clickable element or buy button
        var clickableEl = target.closest('.card-clickable');
        var buyBtn = target.closest('.buy-btn');

        if (!clickableEl && !buyBtn) return;

        // Find the card
        var card = target.closest('.product-card');
        if (!card) return;

        var product = JSON.parse(card.dataset.product || '{}');
        e.preventDefault();
        openModal(product);
      });
    }

    if (modalClose) {
      modalClose.addEventListener('click', closeModal);
    }
    if (modal) {
      modal.addEventListener('click', function(e) {
        if (e.target === modal) closeModal();
      });
    }
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
    });

    function openModal(product, skipPushState) {
      skipPushState = skipPushState || false;
      if (!modal) return;

      // Store trigger element for focus restoration on close
      modalTrigger = document.activeElement;

      currentProduct = product;
      selectedSize = null;
      selectedColor = null;
      
      // Add hash to URL for back navigation (unless coming from popstate)
      if (!skipPushState) {
        history.pushState({ productId: product.id }, '', `#quick-view-${product.id}`);
      }

      // Image
      var mainImg = document.getElementById('modalImg');
      if (mainImg) {
        mainImg.src = product.imageUrl || '';
        mainImg.alt = product.name;
      }

      // Thumbnails
      var thumbs = document.getElementById('modalThumbs');
      if (thumbs && product.images?.length > 1) {
        thumbs.innerHTML = product.images.map(function(img, i) {
          return '<button class="thumb ' + (i === 0 ? 'active' : '') + '" data-src="' + escapeHtml(img) + '"><img src="' + escapeHtml(img) + '" alt="' + escapeHtml(product.name) + ' thumbnail ' + (i + 1) + '" width="80" height="80" loading="lazy" decoding="async" /></button>';
        }).join('');
        thumbs.querySelectorAll('.thumb').forEach(function(t) {
          t.addEventListener('click', function() {
            mainImg.src = t.dataset.src || '';
            thumbs.querySelectorAll('.thumb').forEach(function(x) { x.classList.remove('active'); });
            t.classList.add('active');

            // Sync colour circle when thumbnail has a color association
            var thumbUrl = t.dataset.src || '';
            if (thumbUrl && currentProduct && currentProduct.imageObjects) {
              var matchObj = currentProduct.imageObjects.find(function(img) {
                return typeof img === 'object' && img.url === thumbUrl && img.color;
              });
              if (matchObj && matchObj.color) {
                var colorOptions = document.getElementById('colorOptions');
                if (colorOptions) {
                  var matchBtn = null;
                  colorOptions.querySelectorAll('.color-opt').forEach(function(b) {
                    if (b.dataset.color && b.dataset.color.toLowerCase() === matchObj.color.toLowerCase()) {
                      matchBtn = b;
                    }
                    b.classList.remove('selected');
                  });
                  if (matchBtn) {
                    matchBtn.classList.add('selected');
                    selectedColor = matchBtn.dataset.color || null;
                    updateCartButton();
                  }
                }
              }
            }
          });
        });
      } else if (thumbs) {
        thumbs.innerHTML = '';
      }

      // Details
      var nameEl = document.getElementById('modalName');
      var catEl = document.getElementById('modalCategory');
      var descEl = document.getElementById('modalDesc');
      var priceBox = document.getElementById('modalPriceBox');
      var viewLink = document.getElementById('viewDetailsLink');

      if (nameEl) nameEl.textContent = product.name || '';
      if (catEl) catEl.textContent = product.categoryName || '';
      if (descEl) descEl.textContent = product.description || '';
      if (viewLink) viewLink.href = `/merch/${product.id}`;

      if (priceBox) {
        var price = product.onSale && product.salePrice ? product.salePrice : product.retailPrice;
        if (product.onSale && product.salePrice) {
          priceBox.innerHTML = '<span class="current-price">£' + product.salePrice.toFixed(2) + '</span>' +
            '<span class="old-price">£' + product.retailPrice.toFixed(2) + '</span>' +
            '<span class="save-badge">SAVE £' + (product.retailPrice - product.salePrice).toFixed(2) + '</span>';
        } else {
          priceBox.innerHTML = '<span class="current-price">£' + product.retailPrice.toFixed(2) + '</span>';
        }
      }

      // Sizes
      var sizeSection = document.getElementById('sizeSection');
      var sizeOptions = document.getElementById('sizeOptions');
      if (sizeSection && sizeOptions) {
        // Ensure sizes is an array (might be string from some data sources)
        var sizesArray = product.sizes;
        if (typeof sizesArray === 'string') {
          sizesArray = sizesArray.split(',').map(function(s) { return s.trim(); }).filter(Boolean);
        }
        if (sizesArray && Array.isArray(sizesArray) && sizesArray.length > 0) {
          sizeSection.style.display = 'block';
          sizeOptions.innerHTML = sizesArray.map(function(s, i) {
            return '<button class="opt-btn size-btn ' + (sizesArray.length === 1 ? 'selected' : '') + '" data-size="' + s + '" aria-label="Select size ' + escapeHtml(s) + '">' + s + '</button>';
          }).join('');

          // Auto-select if only one size
          if (sizesArray.length === 1) {
            selectedSize = sizesArray[0];
          }

          sizeOptions.querySelectorAll('.size-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
              sizeOptions.querySelectorAll('.size-btn').forEach(function(b) { b.classList.remove('selected'); });
              btn.classList.add('selected');
              selectedSize = btn.dataset.size || null;
              updateCartButton();
            });
          });
        } else {
          sizeSection.style.display = 'none';
          selectedSize = 'none';
        }
      }

      // Colors
      var colorSection = document.getElementById('colorSection');
      var colorOptions = document.getElementById('colorOptions');
      if (colorSection && colorOptions) {
        if (product.colorList?.length > 0) {
          colorSection.style.display = 'block';
          colorOptions.innerHTML = product.colorList.map(function(hex, i) {
            var name = product.colorNames?.[i] || hex;
            var isSelected = product.colorList.length === 1 ? 'selected' : '';
            return '<button class="opt-btn color-opt ' + isSelected + '" data-color="' + name + '" data-hex="' + hex + '" style="background:' + hex + '" title="' + escapeHtml(name) + '" aria-label="Select colour ' + escapeHtml(name) + '"></button>';
          }).join('');

          // Auto-select if only one color
          if (product.colorList.length === 1) {
            selectedColor = product.colorNames?.[0] || product.colorList[0];
          }

          colorOptions.querySelectorAll('.color-opt').forEach(function(btn) {
            btn.addEventListener('click', function() {
              colorOptions.querySelectorAll('.color-opt').forEach(function(b) { b.classList.remove('selected'); });
              btn.classList.add('selected');
              selectedColor = btn.dataset.color || null;

              // Find and show image for this color
              var colorName = selectedColor;
              if (colorName && currentProduct?.imageObjects) {
                // Look for an image associated with this color
                var matchingImage = currentProduct.imageObjects.find(function(img) {
                  if (typeof img === 'object' && img.color) {
                    return img.color.toLowerCase() === colorName.toLowerCase();
                  }
                  return false;
                });

                var mainImg = document.getElementById('modalImg');
                var thumbs = document.getElementById('modalThumbs');

                if (matchingImage && mainImg) {
                  var imgUrl = matchingImage.url;
                  if (imgUrl) {
                    mainImg.src = imgUrl;
                    // Update thumbnail active state
                    if (thumbs) {
                      thumbs.querySelectorAll('.thumb').forEach(function(t) {
                        t.classList.toggle('active', t.dataset.src === imgUrl);
                      });
                    }
                  }
                }
              }

              updateCartButton();
            });
          });
        } else {
          colorSection.style.display = 'none';
          selectedColor = 'none';
        }
      }

      // Stock status
      var stockStatus = document.getElementById('modalStockStatus');
      if (stockStatus) {
        stockStatus.className = 'stock-info ' + product.stockStatus;
        stockStatus.textContent = product.stockLabel;
      }

      updateCartButton();
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';

      // Focus trap: cycle Tab/Shift+Tab within the modal
      if (modalFocusTrap) {
        modal.removeEventListener('keydown', modalFocusTrap);
      }
      modalFocusTrap = function(e) {
        if (e.key !== 'Tab') return;
        var focusableEls = modal.querySelectorAll('a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])');
        if (focusableEls.length === 0) return;
        var firstEl = focusableEls[0];
        var lastEl = focusableEls[focusableEls.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === firstEl) {
            e.preventDefault();
            lastEl.focus();
          }
        } else {
          if (document.activeElement === lastEl) {
            e.preventDefault();
            firstEl.focus();
          }
        }
      };
      modal.addEventListener('keydown', modalFocusTrap);

      // Move focus into the modal (close button)
      var closeBtn = modal.querySelector('.modal-close');
      if (closeBtn) closeBtn.focus();
    }

    function updateCartButton() {
      var btn = document.getElementById('addToCartBtn');
      var btnText = btn?.querySelector('.btn-text');
      var btnPrice = btn?.querySelector('.btn-price');

      if (!btn || !currentProduct) return;

      var needsSize = currentProduct.sizes?.length > 0;
      var needsColor = currentProduct.colorList?.length > 0;
      var sizeOk = !needsSize || selectedSize;
      var colorOk = !needsColor || selectedColor;

      if (currentProduct.stockStatus === 'out-of-stock') {
        btn.disabled = true;
        if (btnText) btnText.textContent = 'Sold Out';
        if (btnPrice) btnPrice.textContent = '';
      } else if (!sizeOk || !colorOk) {
        btn.disabled = true;
        var missing = [];
        if (!sizeOk) missing.push('size');
        if (!colorOk) missing.push('colour');
        if (btnText) btnText.textContent = 'Select ' + missing.join(' & ');
        if (btnPrice) btnPrice.textContent = '';
      } else {
        btn.disabled = false;
        if (btnText) btnText.textContent = 'Add to Cart';
        var price = currentProduct.onSale && currentProduct.salePrice
          ? currentProduct.salePrice
          : currentProduct.retailPrice;
        if (btnPrice) btnPrice.textContent = '£' + price.toFixed(2);
      }
    }

    // Add to Cart - prevent duplicate listeners
    var addToCartBtn = document.getElementById('addToCartBtn');
    if (addToCartBtn && !addToCartBtn.hasAttribute('data-listener-added')) {
      addToCartBtn.setAttribute('data-listener-added', 'true');
      addToCartBtn.addEventListener('click', function() {
        if (!currentProduct) return;

        // Find image matching selected color, fallback to primary image
        var cartImage = currentProduct.imageUrl;
        if (selectedColor && selectedColor !== 'none' && currentProduct.imageObjects) {
          var matchingImage = currentProduct.imageObjects.find(function(img) {
            if (typeof img === 'object' && img.color) {
              return img.color.toLowerCase() === selectedColor.toLowerCase();
            }
            return false;
          });
          if (matchingImage?.url) {
            cartImage = matchingImage.url;
          }
        }

        var sizeVal = selectedSize && selectedSize !== 'none' ? selectedSize : null;
        var colorVal = selectedColor && selectedColor !== 'none' ? selectedColor : null;

        // Build display name with size/colour suffix
        var displayName = currentProduct.name;
        var details = [];
        if (sizeVal) details.push(sizeVal);
        if (colorVal) details.push(colorVal);
        if (details.length > 0) displayName += ' (' + details.join(' / ') + ')';

        var item = {
          id: currentProduct.id,
          name: displayName,
          type: 'merch',
          price: currentProduct.onSale && currentProduct.salePrice
            ? currentProduct.salePrice
            : currentProduct.retailPrice,
          image: cartImage,
          size: sizeVal,
          color: colorVal,
          quantity: 1
        };

        // Use global cart if available
        if (typeof window.FreshWaxCart !== 'undefined') {
          window.FreshWaxCart.add(item);
        } else {
          alert('Added ' + item.name + ' to cart!');
        }

        closeModal();
      });
    }

    function closeModal() {
      // Remove focus trap
      if (modalFocusTrap && modal) {
        modal.removeEventListener('keydown', modalFocusTrap);
        modalFocusTrap = null;
      }

      if (modal) modal.classList.remove('active');
      document.body.style.overflow = '';
      currentProduct = null;
      selectedSize = null;
      selectedColor = null;

      // Return focus to the element that triggered the modal
      if (modalTrigger && typeof modalTrigger.focus === 'function') {
        modalTrigger.focus();
        modalTrigger = null;
      }

      // Remove hash from URL
      if (window.location.hash.startsWith('#quick-view-')) {
        history.pushState(null, '', window.location.pathname + window.location.search);
      }
    }

    // Handle browser back/forward navigation
    window.addEventListener('popstate', function() {
      var hash = window.location.hash;
      if (hash.startsWith('#quick-view-')) {
        var productId = hash.replace('#quick-view-', '');
        var products = window.PRODUCTS_DATA || [];
        var product = products.find(function(p) { return p.id === productId; });
        if (product) {
          openModal(product, true); // skipPushState = true
        }
      } else {
        // Close modal if hash is gone
        if (modal) modal.classList.remove('active');
        document.body.style.overflow = '';
      }
    });

    // Check for hash on page load
    var initialHash = window.location.hash;
    if (initialHash.startsWith('#quick-view-')) {
      var productId = initialHash.replace('#quick-view-', '');
      var products = window.PRODUCTS_DATA || [];
      var product = products.find(function(p) { return p.id === productId; });
      if (product) {
        // Small delay to ensure DOM is ready
        setTimeout(function() { openModal(product, true); }, 100);
      }
    }
  }

  // astro:page-load fires on both initial load and View Transitions
  document.addEventListener('astro:page-load', init);
</script>


