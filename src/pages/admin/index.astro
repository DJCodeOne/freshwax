<script>
  // Refresh dashboard button
  document.getElementById('refreshDashboardBtn')?.addEventListener('click', () => {
    window.location.reload();
  });

  // Feature toggle handling
  document.addEventListener('astro:page-load', async function() {
    // Wait for Firebase auth before making admin API calls
    if (window.getAdminToken) {
      try { await window.getAdminToken(); } catch (e) { /* intentional: auth failed — abort page init */ return; }
    }

    const toggleMixCharts = document.getElementById('toggleMixCharts');

    // Load current settings
    try {
      const response = await fetch('/api/admin/get-settings/');
      const data = await response.json();
      if (data.success && data.settings) {
        toggleMixCharts.checked = data.settings.showMixCharts || false;
      }
    } catch (error) {
      console.error('Failed to load settings:', error);
    }

    // Save toggle changes
    toggleMixCharts?.addEventListener('change', async function() {
      try {
        await fetch('/api/admin/update-settings/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ showMixCharts: this.checked })
        });
      } catch (error) {
        console.error('Failed to save setting:', error);
      }
    });

    // Playlist History handling
    const HISTORY_KEY = 'freshwax_playlist_history';
    const viewHistoryBtn = document.getElementById('viewHistoryBtn');
    const downloadHistoryBtn = document.getElementById('downloadHistoryBtn');
    const clearHistoryBtn = document.getElementById('clearHistoryBtn');
    const historyPreview = document.getElementById('historyPreview');
    const historyList = document.getElementById('historyList');
    const historyTotal = document.getElementById('historyTotal');
    const historyCount = document.getElementById('historyCount');

    function getHistory() {
      try {
        const data = localStorage.getItem(HISTORY_KEY);
        return data ? JSON.parse(data) : [];
      } catch (e){
        return [];
      }
    }

    function updateHistoryCount() {
      const history = getHistory();
      historyCount.textContent = `${history.length} tracks in history`;
    }

    function escapeHistoryHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    updateHistoryCount();

    viewHistoryBtn?.addEventListener('click', () => {
      const history = getHistory();
      historyTotal.textContent = history.length.toString();

      if (history.length === 0) {
        historyList.innerHTML = '<p class="text-muted">No history entries yet</p>';
      } else {
        historyList.innerHTML = history.map((item, i) => `
          <div class="history-item">
            <img src="${escapeHistoryHtml(item.thumbnail || '/place-holder.webp')}" alt="${escapeHistoryHtml(item.title || 'History item')}" width="48" height="48" loading="lazy" />
            <div class="history-item-info">
              <div class="history-item-title">${escapeHistoryHtml(item.title || item.url)}</div>
              <div class="history-item-meta">
                ${escapeHistoryHtml(item.platform)} • ${item.playedAt ? new Date(item.playedAt).toLocaleString() : 'Unknown date'}
              </div>
            </div>
          </div>
        `).join('');
      }

      historyPreview.classList.toggle('hidden');
    });

    downloadHistoryBtn?.addEventListener('click', () => {
      const history = getHistory();
      const blob = new Blob([JSON.stringify(history, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `playlist-history-${new Date().toISOString().split('T')[0]}.json`;
      a.click();
      URL.revokeObjectURL(url);
    });

    clearHistoryBtn?.addEventListener('click', () => {
      if (confirm('Are you sure you want to clear the playlist history? This cannot be undone.')) {
        localStorage.removeItem(HISTORY_KEY);
        updateHistoryCount();
        historyList.innerHTML = '<p class="text-muted">No history entries yet</p>';
        historyTotal.textContent = '0';
        alert('History cleared');
      }
    });
  });
</script>


<script>
  // Bypass Request Management
  const EXPIRY_TIME = 15 * 60 * 1000; // 15 minutes
  
  // Update time displays and check for expired requests
  function updateRequestTimes() {
    document.querySelectorAll('.bypass-request-item').forEach(item => {
      const createdAt = item.dataset.createdAt;
      if (!createdAt) return;
      
      const createdDate = new Date(createdAt);
      const now = Date.now();
      const elapsed = now - createdDate.getTime();
      const remaining = EXPIRY_TIME - elapsed;
      
      const timeEl = item.querySelector('.request-time');
      const statusEl = item.querySelector('.request-status');
      
      if (remaining <= 0) {
        // Request expired
        item.classList.add('expired');
        if (statusEl) {
          statusEl.textContent = 'Expired';
          statusEl.className = 'request-status expired';
        }
        if (timeEl) timeEl.textContent = 'Expired';
        
        // Disable buttons
        item.querySelectorAll('button').forEach(btn => btn.disabled = true);
        
        // Auto-expire on server
        autoExpireRequest(item.dataset.requestId);
      } else {
        // Show countdown
        const mins = Math.floor(remaining / 60000);
        const secs = Math.floor((remaining % 60000) / 1000);
        if (timeEl) timeEl.textContent = `${mins}:${secs.toString().padStart(2, '0')} left`;
      }
    });
  }
  
  // Auto-expire request on server
  async function autoExpireRequest(requestId) {
    try {
      await fetch('/api/admin/bypass-requests/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'expire', requestId })
      });
    } catch (e){
      console.error('Failed to expire request:', e);
    }
  }
  
  // Handle approve button click
  document.querySelectorAll('.btn-approve').forEach(btn => {
    btn.addEventListener('click', async () => {
      const requestId = btn.dataset.id;
      const userId = btn.dataset.user;
      const item = btn.closest('.bypass-request-item');
      
      btn.disabled = true;
      btn.textContent = 'Approving...';
      
      try {
        const response = await fetch('/api/admin/bypass-requests/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'approve', requestId })
        });
        
        const result = await response.json();
        
        if (result.success) {
          item.classList.remove('expired');
          item.classList.add('approved');
          const statusEl = item.querySelector('.request-status');
          if (statusEl) {
            statusEl.textContent = 'Approved';
            statusEl.className = 'request-status approved';
          }
          item.querySelectorAll('button').forEach(b => b.style.display = 'none');
          
          // Show success message
          const timeEl = item.querySelector('.request-time');
          if (timeEl) timeEl.textContent = '✓ User can now go live';
        } else {
          btn.disabled = false;
          btn.textContent = '✓ Approve';
          alert('Failed to approve: ' + result.error);
        }
      } catch (e){
        btn.disabled = false;
        btn.textContent = '✓ Approve';
        alert('Error approving request');
      }
    });
  });
  
  // Handle reject button click
  document.querySelectorAll('.btn-reject').forEach(btn => {
    btn.addEventListener('click', async () => {
      const requestId = btn.dataset.id;
      const item = btn.closest('.bypass-request-item');
      
      if (!confirm('Reject this bypass request?')) return;
      
      btn.disabled = true;
      btn.textContent = 'Rejecting...';
      
      try {
        const response = await fetch('/api/admin/bypass-requests/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'deny', requestId })
        });
        
        const result = await response.json();
        
        if (result.success) {
          item.classList.remove('expired');
          item.classList.add('rejected');
          const statusEl = item.querySelector('.request-status');
          if (statusEl) {
            statusEl.textContent = 'Rejected';
            statusEl.className = 'request-status rejected';
          }
          item.querySelectorAll('button').forEach(b => b.style.display = 'none');
          
          const timeEl = item.querySelector('.request-time');
          if (timeEl) timeEl.textContent = '✕ Request denied';
        } else {
          btn.disabled = false;
          btn.textContent = '✕ Reject';
          alert('Failed to reject: ' + result.error);
        }
      } catch (e){
        btn.disabled = false;
        btn.textContent = '✕ Reject';
        alert('Error rejecting request');
      }
    });
  });
  
  // Initial update and set interval
  updateRequestTimes();
  var requestTimesInterval = setInterval(updateRequestTimes, 1000); // Update every second

  // Cleanup on View Transitions navigation
  document.addEventListener('astro:before-swap', function() {
    if (requestTimesInterval) {
      clearInterval(requestTimesInterval);
      requestTimesInterval = null;
    }
  }, { once: true });
</script>

<script>
  // Start Playlist button handler
  document.addEventListener('astro:page-load', () => {
    const startPlaylistBtn = document.getElementById('startPlaylistBtn');
    if (startPlaylistBtn) {
      startPlaylistBtn.addEventListener('click', async () => {
        const btn = startPlaylistBtn;
        const originalHTML = btn.innerHTML;

        btn.innerHTML = '<span class="action-icon">⏳</span><span class="action-label">Starting...</span>';
        btn.setAttribute('disabled', 'true');

        try {
          const response = await fetch('/api/playlist/global/', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'startAutoPlay' })
          });

          const result = await response.json();

          if (result.success) {
            btn.innerHTML = '<span class="action-icon">✅</span><span class="action-label">Started!</span>';
            setTimeout(() => {
              btn.innerHTML = originalHTML;
              btn.removeAttribute('disabled');
            }, 2000);
          } else {
            btn.innerHTML = '<span class="action-icon">❌</span><span class="action-label">Failed</span>';
            setTimeout(() => {
              btn.innerHTML = originalHTML;
              btn.removeAttribute('disabled');
            }, 2000);
          }
        } catch (error) {
          console.error('Failed to start playlist:', error);
          btn.innerHTML = '<span class="action-icon">❌</span><span class="action-label">Error</span>';
          setTimeout(() => {
            btn.innerHTML = originalHTML;
            btn.removeAttribute('disabled');
          }, 2000);
        }
      });
    }
  });
</script>

<script>
  function escapeHtml(s){if(typeof s!=='string')return '';return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,"&#39;");}

  // Helper: build headers with admin auth for playlist API calls
  async function getPlaylistAuthHeaders() {
    const headers = { 'Content-Type': 'application/json' };
    try {
      if (window.getAdminToken) {
        const token = await window.getAdminToken();
        if (token) headers['Authorization'] = 'Bearer ' + token;
      }
    } catch (_e) { /* intentional: proceed without auth if token fails */ }
    return headers;
  }

  // Playlist Monitor functionality
  document.addEventListener('astro:page-load', function() {
    const PLAYLIST_SERVER = 'https://playlist.freshwax.co.uk';

    // Elements
    const serverStatus = document.getElementById('playlistServerStatus');
    const trackCount = document.getElementById('playlistTrackCount');
    const refreshBtn = document.getElementById('refreshPlaylistStatus');
    const nowPlayingThumb = document.getElementById('nowPlayingThumb');
    const nowPlayingTitle = document.getElementById('nowPlayingTitle');
    const nowPlayingAdded = document.getElementById('nowPlayingAdded');
    const queueList = document.getElementById('queueList');
    const queueCount = document.getElementById('queueCount');
    const skipBtn = document.getElementById('playlistSkipBtn');
    const startBtn = document.getElementById('playlistStartBtn');
    const stopBtn = document.getElementById('playlistStopBtn');
    const tunnelBtn = document.getElementById('tunnelRestartBtn');

    // Check if playlist monitor elements exist
    if (!serverStatus) return;

    const tunnelStatus = document.getElementById('tunnelStatus');
    const mediamtxStatus = document.getElementById('mediamtxStatus');
    const icecastStatus = document.getElementById('icecastStatus');

    // Check a service by URL, return true if reachable
    async function checkService(url, timeout) {
      try {
        const ctrl = new AbortController();
        const timer = setTimeout(() => ctrl.abort(), timeout || 5000);
        const resp = await fetch(url, { signal: ctrl.signal, mode: 'no-cors' });
        clearTimeout(timer);
        return true;
      } catch (_e) {
        return false;
      }
    }

    // Check all infrastructure services
    async function checkAllServices() {
      // Playlist server — check via our API proxy
      serverStatus.textContent = 'Checking...';
      serverStatus.className = 'status-badge checking';
      try {
        const resp = await fetch('/api/admin/health-check/', {
          headers: { 'X-Admin-Key': window.ADMIN_KEY }
        });
        if (resp.ok) {
          const data = await resp.json();
          const ps = data.checks?.playlistServer;
          if (ps?.status === 'ok') {
            serverStatus.textContent = 'ONLINE';
            serverStatus.className = 'status-badge online';
            if (ps.fileCount) trackCount.textContent = `(${ps.fileCount} tracks)`;
          } else {
            serverStatus.textContent = 'OFFLINE';
            serverStatus.className = 'status-badge offline';
          }

          // Tunnel — if playlist server is reachable, tunnel is working
          if (tunnelStatus) {
            const tunnelOk = ps?.status === 'ok';
            tunnelStatus.textContent = tunnelOk ? 'ONLINE' : 'OFFLINE';
            tunnelStatus.className = 'status-badge ' + (tunnelOk ? 'online' : 'offline');
          }

          // MediaMTX
          if (mediamtxStatus) {
            const mtx = data.checks?.mediaServer;
            mediamtxStatus.textContent = mtx?.status === 'ok' ? 'ONLINE' : 'OFFLINE';
            mediamtxStatus.className = 'status-badge ' + (mtx?.status === 'ok' ? 'online' : 'offline');
          }

          // Icecast
          if (icecastStatus) {
            const ice = data.checks?.icecast;
            icecastStatus.textContent = ice?.status === 'ok' ? 'ONLINE' : 'OFFLINE';
            icecastStatus.className = 'status-badge ' + (ice?.status === 'ok' ? 'online' : 'offline');
          }
        } else {
          serverStatus.textContent = 'ERROR';
          serverStatus.className = 'status-badge offline';
        }
      } catch (_e) {
        serverStatus.textContent = 'OFFLINE';
        serverStatus.className = 'status-badge offline';
        if (tunnelStatus) { tunnelStatus.textContent = 'UNKNOWN'; tunnelStatus.className = 'status-badge checking'; }
        if (mediamtxStatus) { mediamtxStatus.textContent = 'UNKNOWN'; mediamtxStatus.className = 'status-badge checking'; }
        if (icecastStatus) { icecastStatus.textContent = 'UNKNOWN'; icecastStatus.className = 'status-badge checking'; }
      }
    }

    // Legacy alias
    function checkPlaylistServer() { checkAllServices(); }

    // Fetch playlist state
    async function fetchPlaylistState() {
      try {
        const response = await fetch('/api/playlist/global/');
        if (response.ok) {
          const result = await response.json();
          if (result.success && result.playlist) {
            updateNowPlaying(result.playlist);
            updateQueue(result.playlist);
          }
        }
      } catch (error) {
        console.error('Failed to fetch playlist state:', error);
      }
    }

    // Update now playing display
    function updateNowPlaying(playlist) {
      const queue = playlist.queue || [];
      const currentTrack = queue[0]; // First item in queue is "now playing"

      if (currentTrack && playlist.isPlaying) {
        nowPlayingTitle.textContent = currentTrack.title || currentTrack.url || 'Unknown Track';
        nowPlayingThumb.src = currentTrack.thumbnail || '/place-holder.webp';

        if (currentTrack.addedAt) {
          const added = new Date(currentTrack.addedAt);
          nowPlayingAdded.textContent = 'Added by ' + (currentTrack.addedByName || 'Unknown') + ' at ' + added.toLocaleTimeString();
        } else {
          nowPlayingAdded.textContent = currentTrack.addedByName ? 'Added by ' + currentTrack.addedByName : '';
        }
      } else {
        nowPlayingTitle.textContent = playlist.isPlaying ? 'Loading...' : 'Nothing playing';
        nowPlayingThumb.src = '/place-holder.webp';
        nowPlayingAdded.textContent = '';
      }
    }

    // Update queue display
    function updateQueue(playlist) {
      const queue = playlist.queue || [];
      // Skip first item (now playing), show rest as queue
      const upNext = queue.slice(1);
      queueCount.textContent = upNext.length + ' track' + (upNext.length !== 1 ? 's' : '') + ' up next';

      if (upNext.length === 0) {
        queueList.innerHTML = '<div class="queue-empty">No tracks queued - autoplay will pick random tracks</div>';
        return;
      }

      let html = '';
      upNext.forEach((track, index) => {
        const title = track.title || track.url || 'Unknown';
        const thumb = escapeHtml(track.thumbnail || '/place-holder.webp');
        const safeId = escapeHtml(track.id || '');
        const safeAddedBy = escapeHtml(track.addedBy || '');
        html += `
          <div class="queue-item" data-index="${index + 1}" data-id="${safeId}">
            <span class="queue-item-num">${index + 1}</span>
            <img class="queue-item-thumb" src="${thumb}" alt="${escapeHtml(title)}" width="48" height="48" loading="lazy">
            <div class="queue-item-info">
              <div class="queue-item-title">${escapeHtml(title)}</div>
              <div class="queue-item-added">${escapeHtml(track.addedByName || 'Unknown')}</div>
            </div>
            <button class="queue-item-remove" data-id="${safeId}" data-added-by="${safeAddedBy}" title="Remove from queue" aria-label="Remove from queue">×</button>
          </div>
        `;
      });
      queueList.innerHTML = html;

      // Add remove handlers
      queueList.querySelectorAll('.queue-item-remove').forEach(btn => {
        btn.addEventListener('click', function() {
          const trackId = this.dataset.id;
          const addedBy = this.dataset.addedBy;
          if (trackId) {
            removeFromQueue(trackId, addedBy);
          }
        });
      });
    }

    // Remove from queue (uses DELETE endpoint with admin override)
    async function removeFromQueue(itemId, addedBy) {
      try {
        const response = await fetch('/api/playlist/global/', {
          method: 'DELETE',
          headers: await getPlaylistAuthHeaders(),
          body: JSON.stringify({
            itemId: itemId,
            userId: addedBy || 'admin',
            isAdmin: true  // Admin flag for bypass
          })
        });
        const result = await response.json();
        if (result.success) {
          fetchPlaylistState();
        } else {
          alert('Failed to remove: ' + (result.error || 'Unknown error'));
        }
      } catch (error) {
        console.error('Failed to remove from queue:', error);
        alert('Failed to remove track from queue');
      }
    }

    // Skip track
    async function skipTrack() {
      skipBtn.disabled = true;
      skipBtn.querySelector('.btn-label').textContent = 'Skipping...';
      try {
        const response = await fetch('/api/playlist/global/', {
          method: 'PUT',
          headers: await getPlaylistAuthHeaders(),
          body: JSON.stringify({ action: 'next' })
        });
        if (response.ok) {
          fetchPlaylistState();
        }
      } catch (error) {
        console.error('Failed to skip track:', error);
      } finally {
        skipBtn.disabled = false;
        skipBtn.querySelector('.btn-label').textContent = 'Skip Track';
      }
    }

    // Start playlist
    async function startPlaylist() {
      startBtn.disabled = true;
      startBtn.querySelector('.btn-label').textContent = 'Starting...';
      try {
        const response = await fetch('/api/playlist/global/', {
          method: 'PUT',
          headers: await getPlaylistAuthHeaders(),
          body: JSON.stringify({ action: 'startAutoPlay' })
        });
        if (response.ok) {
          fetchPlaylistState();
        }
      } catch (error) {
        console.error('Failed to start playlist:', error);
      } finally {
        startBtn.disabled = false;
        startBtn.querySelector('.btn-label').textContent = 'Start Playlist';
      }
    }

    // Stop playlist
    async function stopPlaylist() {
      stopBtn.disabled = true;
      stopBtn.querySelector('.btn-label').textContent = 'Stopping...';
      try {
        const response = await fetch('/api/playlist/global/', {
          method: 'PUT',
          headers: await getPlaylistAuthHeaders(),
          body: JSON.stringify({ action: 'pause' })
        });
        if (response.ok) {
          fetchPlaylistState();
        }
      } catch (error) {
        console.error('Failed to stop playlist:', error);
      } finally {
        stopBtn.disabled = false;
        stopBtn.querySelector('.btn-label').textContent = 'Stop';
      }
    }

    // Tunnel restart instructions
    function showTunnelInstructions() {
      const msg = `To restart the Cloudflare tunnel:

1. Open PowerShell as Administrator
2. Navigate to: cd C:/cloudflared
3. Run: ./cloudflared.exe tunnel run playlist

Or run this single command:
C:/cloudflared/cloudflared.exe tunnel run playlist

The tunnel connects playlist.freshwax.co.uk to your local playlist server.`;

      alert(msg);
    }

    // Event listeners
    refreshBtn?.addEventListener('click', function() {
      checkPlaylistServer();
      fetchPlaylistState();
    });

    skipBtn?.addEventListener('click', skipTrack);
    startBtn?.addEventListener('click', startPlaylist);
    stopBtn?.addEventListener('click', stopPlaylist);
    tunnelBtn?.addEventListener('click', showTunnelInstructions);

    // Initial load
    checkPlaylistServer();
    fetchPlaylistState();

    // Auto-refresh every 30 seconds
    var playlistRefreshInterval = setInterval(function() {
      checkPlaylistServer();
      fetchPlaylistState();
    }, 30000);

    // Cleanup on View Transitions navigation
    document.addEventListener('astro:before-swap', function() {
      if (playlistRefreshInterval) {
        clearInterval(playlistRefreshInterval);
        playlistRefreshInterval = null;
      }
    }, { once: true });
  });
</script>
