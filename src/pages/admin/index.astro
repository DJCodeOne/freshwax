---
// src/pages/admin/index.astro
// Fresh Wax Admin Dashboard - Unified Design
// Central hub for all admin operations - Uses Firebase REST API

import { requireAdminAuth } from '../../lib/admin';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { queryCollection } from '../../lib/firebase-rest';
import { saQueryCollection } from '../../lib/firebase-service-account';
import { createLogger } from '../../lib/api-utils';
import '../../styles/admin/index.css';

const log = createLogger('admin-dashboard');

// Server-side admin auth check
const authResult = await requireAdminAuth(Astro.request, Astro.locals);
if (authResult) return Astro.redirect('/login');

const runtimeEnv = Astro.locals.runtime.env;

// Fetch all data using REST API with error handling
let ordersData: Record<string, unknown>[] = [];
let releasesData: Record<string, unknown>[] = [];
let artistsData: Record<string, unknown>[] = [];
let merchData: Record<string, unknown>[] = [];
let mixesData: Record<string, unknown>[] = [];
let livestreamsData: Record<string, unknown>[] = [];
let bypassRequestsData: Record<string, unknown>[] = [];
let payoutsData: Record<string, unknown>[] = [];
let disputesData: Record<string, unknown>[] = [];
let refundsData: Record<string, unknown>[] = [];
let ledgerData: Record<string, unknown>[] = [];
let blogPostsData: Record<string, unknown>[] = [];
let r2SubmissionsCount = 0;
let r2PendingFolders: string[] = [];

// Build service account key for salesLedger query
const projectId = runtimeEnv?.FIREBASE_PROJECT_ID || import.meta.env.FIREBASE_PROJECT_ID || 'freshwax-store';
const clientEmail = runtimeEnv?.FIREBASE_CLIENT_EMAIL || import.meta.env.FIREBASE_CLIENT_EMAIL;
const privateKey = runtimeEnv?.FIREBASE_PRIVATE_KEY || import.meta.env.FIREBASE_PRIVATE_KEY;

let serviceAccountKey = '';
if (clientEmail && privateKey) {
  serviceAccountKey = JSON.stringify({
    type: 'service_account',
    project_id: projectId,
    private_key: privateKey.replace(/\\n/g, '\n'),
    client_email: clientEmail
  });
}

// Helper: use service account for restricted collections, API key for public ones
const saQuery = (collection: string, opts: Record<string, unknown>) =>
  serviceAccountKey
    ? saQueryCollection(serviceAccountKey, projectId, collection, opts)
    : queryCollection(collection, opts);

try {
  const results = await Promise.allSettled([
    saQuery('orders', { limit: 50 }),
    queryCollection('releases', { limit: 500 }),
    saQuery('artists', { limit: 500 }),
    queryCollection('merch', { limit: 500 }),
    queryCollection('dj-mixes', { limit: 500 }),
    queryCollection('livestreams', { limit: 10 }),
    saQuery('bypassRequests', { limit: 20 }),
    saQuery('payouts', { limit: 200 }),
    saQuery('disputes', { limit: 50 }),
    saQuery('refunds', { limit: 50 }),
    saQuery('salesLedger', { limit: 500 }),
    saQuery('blog-posts', { limit: 100 })
  ]);

  ordersData = results[0].status === 'fulfilled' ? results[0].value : [];
  releasesData = results[1].status === 'fulfilled' ? results[1].value : [];
  artistsData = results[2].status === 'fulfilled' ? results[2].value : [];
  merchData = results[3].status === 'fulfilled' ? results[3].value : [];
  mixesData = results[4].status === 'fulfilled' ? results[4].value : [];
  livestreamsData = results[5].status === 'fulfilled' ? results[5].value : [];
  bypassRequestsData = results[6].status === 'fulfilled' ? results[6].value.filter((r: Record<string, unknown>) => r.status === 'pending') : [];
  payoutsData = results[7].status === 'fulfilled' ? results[7].value : [];
  disputesData = results[8].status === 'fulfilled' ? results[8].value : [];
  refundsData = results[9].status === 'fulfilled' ? results[9].value : [];
  ledgerData = results[10].status === 'fulfilled' ? results[10].value : [];
  blogPostsData = results[11].status === 'fulfilled' ? results[11].value : [];
} catch (error) {
  log.error('Error fetching data:', error);
}

// Fetch R2 pending submissions count using native R2 binding
try {
  const r2: R2Bucket = Astro.locals.runtime.env.R2;

  // Check submissions/ folder
  const submissionsResult = await r2.list({ prefix: 'submissions/', delimiter: '/' });
  for (const prefix of submissionsResult.delimitedPrefixes) {
    const folderName = prefix.replace(/^submissions\//, '').replace(/\/$/, '');
    if (!folderName.startsWith('test-')) {
      r2PendingFolders.push(`submissions/${folderName}`);
      r2SubmissionsCount++;
    }
  }

  // Also check root level for submission-like folders (Artist-timestamp pattern)
  const rootResult = await r2.list({ delimiter: '/' });
  const submissionPattern = /^[A-Za-z0-9_\-\s]+[-_]\d{13,}$/;
  for (const prefix of rootResult.delimitedPrefixes) {
    const folder = prefix.replace(/\/$/, '');
    // Skip known non-submission folders
    if (['submissions', 'releases', 'assets', 'thumbnails', 'audio', 'temp'].includes(folder)) continue;
    if (submissionPattern.test(folder)) {
      r2PendingFolders.push(folder);
      r2SubmissionsCount++;
    }
  }
} catch (error) {
  log.error('Error fetching R2 submissions:', error);
}

// Process orders - sort by createdAt desc
const orders = ordersData
  .map(order => ({
    ...order,
    createdAt: order.createdAt ? new Date(order.createdAt) : new Date()
  }))
  .sort((a, b) => b.createdAt.getTime() - a.createdAt.getTime());

// Calculate stats
const now = new Date();
const startOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);
const startOfToday = new Date(now.getFullYear(), now.getMonth(), now.getDate());

const todayOrders = orders.filter(o => o.createdAt >= startOfToday);
const monthOrders = orders.filter(o => o.createdAt >= startOfMonth);
const pendingOrders = orders.filter(o => o.status === 'pending');

const todayRevenue = todayOrders.reduce((sum, o) => sum + (o.totals?.total || o.total || 0), 0);
const monthRevenue = monthOrders.reduce((sum, o) => sum + (o.totals?.total || o.total || 0), 0);

// Filter out test orders and free downloads for financial calculations (from sorted orders)
const realOrders = orders.filter(o =>
  o.paymentMethod !== 'test_mode' &&
  o.paymentMethod !== 'free_download' &&
  (o.totals?.total > 0 || o.total > 0) &&
  (o.paymentStatus === 'completed' || o.orderStatus === 'completed' || o.status === 'completed')
);

// Partner stats (data already in array format from REST API)
const artists = artistsData;
const pendingPartners = artists.filter(a => a.approved === false);
const approvedPartners = artists.filter(a => a.approved === true);

// Release stats
const releases = releasesData;
const liveReleases = releases.filter(r => r.status === 'live');
const pendingReleases = releases.filter(r => r.status === 'pending');

// Merch stats
const merch = merchData;
const lowStockMerch = merch.filter(m => {
  // Use pre-computed flag from stock management system if available
  if (m.isLowStock === true) return true;
  // Fallback: check variantStock (primary) or variants (legacy) or top-level stock
  if (m.variantStock && typeof m.variantStock === 'object') {
    const total = Object.values(m.variantStock).reduce((sum: number, v: unknown) => {
      const stock = typeof v === 'number' ? v : ((v as Record<string, unknown>)?.stock as number || 0);
      return sum + stock;
    }, 0);
    return total <= 5 && total > 0;
  }
  if (m.variants && Array.isArray(m.variants) && m.variants.length > 0) {
    return m.variants.some((v: Record<string, unknown>) => ((v.stock as number) || 0) <= 5 && ((v.stock as number) || 0) > 0);
  }
  return ((m.totalStock as number) || (m.stock as number) || 0) <= 5 && ((m.totalStock as number) || (m.stock as number) || 0) > 0;
});
const outOfStockMerch = merch.filter(m => {
  // Use pre-computed flag from stock management system if available
  if (m.isOutOfStock === true) return true;
  if (m.isOutOfStock === false) return false;
  // Fallback: check variantStock (primary) or variants (legacy) or top-level stock
  if (m.variantStock && typeof m.variantStock === 'object') {
    return Object.values(m.variantStock).every((v: unknown) => {
      const stock = typeof v === 'number' ? v : ((v as Record<string, unknown>)?.stock as number || 0);
      return stock === 0;
    });
  }
  if (m.variants && Array.isArray(m.variants) && m.variants.length > 0) {
    return m.variants.every((v: Record<string, unknown>) => ((v.stock as number) || 0) === 0);
  }
  return ((m.totalStock as number) || (m.stock as number) || 0) === 0;
});

// Blog posts stats
const blogPosts = blogPostsData;
const publishedBlogPosts = blogPosts.filter(p => p.published);

// DJ Mixes stats
const mixes = mixesData;
const publishedMixes = mixes.filter(m => m.published);
const totalPlays = mixes.reduce((sum, m) => sum + (m.plays || 0), 0);

// Livestream stats - sort by startedAt desc
const livestreams = livestreamsData
  .map(ls => ({
    ...ls,
    startedAt: ls.startedAt ? new Date(ls.startedAt) : null,
    endedAt: ls.endedAt ? new Date(ls.endedAt) : null
  }))
  .sort((a, b) => (b.startedAt?.getTime() || 0) - (a.startedAt?.getTime() || 0));
const activeLivestream = livestreams.find(ls => ls.status === 'live');
const recentLivestreams = livestreams.slice(0, 5);

// Bypass requests - filter out expired ones (15 minutes)
const fifteenMinsAgo = new Date(Date.now() - 15 * 60 * 1000);
const bypassRequests = bypassRequestsData
  .filter(req => {
    // Filter out requests older than 15 minutes
    if (!req.createdAt) return true;
    const createdDate = new Date(req.createdAt);
    return createdDate > fifteenMinsAgo;
  });

// Recent orders (last 5 real orders - excludes test mode and free downloads)
const recentOrders = realOrders.slice(0, 5);

// Platform earnings calculations
const PLATFORM_FEE_RATE = 0.01; // 1% platform fee

// Calculate total payouts to artists
const totalArtistPayouts = payoutsData
  .filter(p => p.status === 'completed')
  .reduce((sum, p) => sum + (p.amount || 0), 0);

// Pending payouts - calculated from ledger (source of truth)
// Entries with artistPayoutStatus 'pending' or 'unpaid' are awaiting payout
const pendingLedgerEntries = ledgerData.filter(e =>
  e.artistPayoutStatus === 'pending' || e.artistPayoutStatus === 'unpaid'
);
const totalPendingPayouts = pendingLedgerEntries.reduce((sum, e) => sum + (e.artistPayout || 0), 0);
const totalPendingCount = pendingLedgerEntries.length;

// Calculate refunds issued
const totalRefunded = refundsData.reduce((sum, r) => sum + (r.amount || 0), 0);

// Calculate disputes impact
const openDisputes = disputesData.filter(d => d.status === 'warning_under_review' || d.status === 'warning_needs_response' || d.status === 'needs_response' || d.status === 'under_review');
const disputesUnderReview = openDisputes.reduce((sum, d) => sum + (d.amount || 0), 0);
const disputesLost = disputesData.filter(d => d.status === 'lost').reduce((sum, d) => sum + (d.amount || 0), 0);
const disputesWon = disputesData.filter(d => d.status === 'won').reduce((sum, d) => sum + (d.amount || 0), 0);

// Calculate financials from ledger (source of truth)
const ledgerGross = ledgerData.reduce((sum, e) => sum + (e.grossTotal || 0), 0);
const ledgerArtistPayout = ledgerData.reduce((sum, e) => sum + (e.artistPayout || 0), 0);

// Use ledger values if available, fallback to order calculations
const grossRevenue = ledgerGross > 0 ? ledgerGross : realOrders.reduce((sum, o) => sum + (o.totals?.total || o.total || 0), 0);

// Platform fees = gross - net (what platform keeps after artist payout)
const platformFeesEarned = ledgerGross > 0
  ? (ledgerGross - ledgerArtistPayout)
  : realOrders.reduce((sum, o) => sum + (o.totals?.freshWaxFee || 0), 0);

// Net to artists from ledger
const netToArtists = ledgerArtistPayout > 0
  ? ledgerArtistPayout
  : realOrders.reduce((sum, o) => {
      if (o.totals?.artistEarnings) return sum + o.totals.artistEarnings;
      const subtotal = o.totals?.subtotal || 0;
      const freshWaxFee = o.totals?.freshWaxFee || (subtotal * 0.01);
      const processingFee = o.totals?.paymentProcessingFee || o.totals?.stripeFee || ((subtotal * 0.014) + 0.20);
      return sum + (subtotal - freshWaxFee - processingFee);
    }, 0);

// Month-over-month calculations
const lastMonth = new Date(now.getFullYear(), now.getMonth() - 1, 1);
const endOfLastMonth = new Date(now.getFullYear(), now.getMonth(), 0);

// Calculate last month's payouts from ledger
const lastMonthPayouts = ledgerData
  .filter(e => {
    if (e.artistPayoutStatus !== 'paid') return false;
    const paidAt = e.artistPaidAt || e.createdAt;
    if (!paidAt) return false;
    const d = new Date(paidAt);
    return d >= lastMonth && d <= endOfLastMonth;
  })
  .reduce((sum, e) => sum + (e.artistPayout || 0), 0);

// Calculate this month's payouts from ledger (paid entries this month)
const thisMonthPayouts = ledgerData
  .filter(e => {
    if (e.artistPayoutStatus !== 'paid') return false;
    const paidAt = e.artistPaidAt || e.createdAt;
    if (!paidAt) return false;
    const d = new Date(paidAt);
    return d >= startOfMonth;
  })
  .reduce((sum, e) => sum + (e.artistPayout || 0), 0);

// Format helpers
const formatCurrency = (amount) => {
  return new Intl.NumberFormat('en-GB', { style: 'currency', currency: 'GBP' }).format(amount || 0);
};

const formatDate = (date) => {
  if (!date) return '-';
  return new Date(date).toLocaleDateString('en-GB', { 
    day: 'numeric', 
    month: 'short',
    hour: '2-digit',
    minute: '2-digit'
  });
};

const formatNumber = (num) => {
  return new Intl.NumberFormat('en-GB').format(num);
};

// Type aliases for use in Astro template expressions (generic syntax breaks the template parser)
type AnyRecord = Record<string, unknown>;

// Alerts
const alerts = [];
if (pendingPartners.length > 0) {
  alerts.push({ type: 'warning', icon: '👥', text: `${pendingPartners.length} partner${pendingPartners.length !== 1 ? 's' : ''} awaiting approval`, link: '/admin/artists/pending' });
}
if (pendingOrders.length > 0) {
  alerts.push({ type: 'info', icon: '📦', text: `${pendingOrders.length} order${pendingOrders.length !== 1 ? 's' : ''} need processing`, link: '/admin/orders' });
}
if (lowStockMerch.length > 0) {
  alerts.push({ type: 'warning', icon: '⚠️', text: `${lowStockMerch.length} product${lowStockMerch.length !== 1 ? 's' : ''} running low on stock`, link: '/admin/inventory' });
}
if (outOfStockMerch.length > 0) {
  alerts.push({ type: 'danger', icon: '🚫', text: `${outOfStockMerch.length} product${outOfStockMerch.length !== 1 ? 's' : ''} out of stock`, link: '/admin/inventory' });
}
if (openDisputes.length > 0) {
  alerts.push({ type: 'danger', icon: '⚠️', text: `${openDisputes.length} dispute${openDisputes.length !== 1 ? 's' : ''} need attention`, link: '/admin/payments' });
}
if (totalPendingPayouts > 0) {
  alerts.push({ type: 'warning', icon: '💳', text: `${formatCurrency(totalPendingPayouts)} in pending payouts (${totalPendingCount} payees)`, link: '/admin/payments' });
}

export const prerender = false;

// Prevent caching of admin dashboard for real-time data accuracy
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, max-age=0');
Astro.response.headers.set('Pragma', 'no-cache');
---

<AdminLayout title="Dashboard" activeNav="dashboard">
  <Fragment slot="breadcrumb">
    <div class="header-breadcrumb">
      <span>Admin Dashboard</span>
    </div>
  </Fragment>

  <Fragment slot="actions">
    <button class="btn btn-ghost" id="refreshDashboardBtn">
      ↻ Refresh
    </button>
  </Fragment>

  <!-- Alerts Section -->
  {alerts.length > 0 && (
    <div class="alerts-section mb-4">
      {alerts.map(alert => (
        <a href={alert.link} class={`alert-item alert-${alert.type}`}>
          <span class="alert-icon">{alert.icon}</span>
          <span class="alert-text">{alert.text}</span>
          <span class="alert-arrow">→</span>
        </a>
      ))}
    </div>
  )}

  <!-- Main Stats Grid -->
  <div class="stats-grid cols-6 mb-4">
    <div class="stat-card highlight">
      <div class="stat-label">Today's Revenue</div>
      <div class="stat-value">{formatCurrency(todayRevenue)}</div>
      <div class="stat-detail">{todayOrders.length} order{todayOrders.length !== 1 ? 's' : ''}</div>
    </div>
    
    <div class="stat-card success">
      <div class="stat-label">This Month</div>
      <div class="stat-value">{formatCurrency(monthRevenue)}</div>
      <div class="stat-detail">{monthOrders.length} orders</div>
    </div>
    
    <div class="stat-card">
      <div class="stat-label">Pending Orders</div>
      <div class="stat-value">{pendingOrders.length}</div>
      <div class="stat-detail">Need attention</div>
    </div>
    
    <div class="stat-card" title={pendingReleases.length > 0 ? `Pending: ${pendingReleases.map((r) => r.title).join(', ')}` : ''}>
      <div class="stat-label">Live Releases</div>
      <div class="stat-value">{liveReleases.length}</div>
      <div class="stat-detail">{pendingReleases.length} pending</div>
    </div>
    
    <div class="stat-card">
      <div class="stat-label">Partners</div>
      <div class="stat-value">{approvedPartners.length}</div>
      <div class="stat-detail">{pendingPartners.length} pending</div>
    </div>
    
    <div class="stat-card">
      <div class="stat-label">Mix Plays</div>
      <div class="stat-value">{formatNumber(totalPlays)}</div>
      <div class="stat-detail">{publishedMixes.length} mixes</div>
    </div>
  </div>

  <!-- Platform Earnings Section -->
  <div class="card mb-4 earnings-card">
    <div class="card-header">
      <h2>💰 Platform Earnings</h2>
      <a href="/admin/payments/" class="btn btn-ghost btn-sm">View Payments →</a>
    </div>
    <div class="card-body">
      <div class="earnings-grid">
        <div class="earning-stat primary">
          <div class="earning-icon">📊</div>
          <div class="earning-info">
            <span class="earning-label">Gross Revenue</span>
            <span class="earning-value">{formatCurrency(grossRevenue)}</span>
            <span class="earning-detail">{realOrders.length} order{realOrders.length !== 1 ? 's' : ''}</span>
          </div>
        </div>

        <div class="earning-stat success">
          <div class="earning-icon">🏦</div>
          <div class="earning-info">
            <span class="earning-label">FW Fees (1%)</span>
            <span class="earning-value">{formatCurrency(platformFeesEarned)}</span>
            <span class="earning-detail">Net after refunds</span>
          </div>
        </div>

        <div class="earning-stat info">
          <div class="earning-icon">🎤</div>
          <div class="earning-info">
            <span class="earning-label">Artist Earnings</span>
            <span class="earning-value">{formatCurrency(netToArtists)}</span>
            <span class="earning-detail">{realOrders.length} order{realOrders.length !== 1 ? 's' : ''}</span>
          </div>
        </div>

        <div class="earning-stat warning">
          <div class="earning-icon">⏳</div>
          <div class="earning-info">
            <span class="earning-label">Pending Payouts</span>
            <span class="earning-value">{formatCurrency(totalPendingPayouts)}</span>
            <span class="earning-detail">{totalPendingCount} awaiting payout</span>
          </div>
        </div>

        <div class="earning-stat danger">
          <div class="earning-icon">↩️</div>
          <div class="earning-info">
            <span class="earning-label">Total Refunded</span>
            <span class="earning-value">{formatCurrency(totalRefunded)}</span>
            <span class="earning-detail">{refundsData.length} refunds issued</span>
          </div>
        </div>

        <div class="earning-stat {openDisputes.length > 0 ? 'danger' : 'muted'}">
          <div class="earning-icon">⚖️</div>
          <div class="earning-info">
            <span class="earning-label">Disputes</span>
            <span class="earning-value">{formatCurrency(disputesUnderReview)}</span>
            <span class="earning-detail">
              {openDisputes.length} open • Won: {formatCurrency(disputesWon)} • Lost: {formatCurrency(disputesLost)}
            </span>
          </div>
        </div>
      </div>

      <!-- Month Comparison -->
      <div class="month-comparison">
        <div class="month-stat">
          <span class="month-label">This Month Payouts</span>
          <span class="month-value">{formatCurrency(thisMonthPayouts)}</span>
        </div>
        <div class="month-stat">
          <span class="month-label">Last Month Payouts</span>
          <span class="month-value">{formatCurrency(lastMonthPayouts)}</span>
        </div>
        <div class="month-stat">
          <span class="month-label">This Month Revenue</span>
          <span class="month-value">{formatCurrency(monthRevenue)}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="actions-grid mb-4">
    <a href="/admin/merch/upload/" class="action-card primary">
      <span class="card-icon">👕</span>
      <span class="card-title">Add Merch</span>
    </a>
    <a href="/admin/streaming/" class="action-card" style="position: relative;">
      <span class="card-icon">🔴</span>
      <span class="card-title">Live Stream</span>
      {activeLivestream && (
        <span class="card-badge live-pulse">LIVE</span>
      )}
    </a>
    <a href="/admin/orders/" class="action-card" style="position: relative;">
      <span class="card-icon">📋</span>
      <span class="card-title">Orders</span>
      {pendingOrders.length > 0 && (
        <span class="card-badge">{pendingOrders.length}</span>
      )}
    </a>
    <a href="/admin/artists/pending/" class="action-card" style="position: relative;">
      <span class="card-icon">✅</span>
      <span class="card-title">Approvals</span>
      {pendingPartners.length > 0 && (
        <span class="card-badge">{pendingPartners.length}</span>
      )}
    </a>
    <a href="/admin/analytics/" class="action-card">
      <span class="card-icon">📈</span>
      <span class="card-title">Analytics</span>
    </a>
    <a href="/admin/ledger/" class="action-card">
      <span class="card-icon">📒</span>
      <span class="card-title">Sales Ledger</span>
    </a>
  </div>

  <!-- Two Column Layout -->
  <div class="grid grid-2 gap-2">
    <!-- Recent Orders -->
    <div class="card">
      <div class="card-header">
        <h2>📋 Recent Orders</h2>
        <a href="/admin/orders/" class="btn btn-ghost btn-sm">View All →</a>
      </div>
      {recentOrders.length === 0 ? (
        <div class="card-body">
          <div class="empty-state" style="padding: 2rem;">
            <div class="empty-state-icon">📭</div>
            <div class="empty-state-title">No orders yet</div>
            <p class="empty-state-text">Orders will appear here as they come in.</p>
          </div>
        </div>
      ) : (
        <div class="table-wrapper">
          <table class="data-table" aria-label="Recent orders">
            <caption class="sr-only">Recent orders</caption>
            <thead>
              <tr>
                <th scope="col">Order</th>
                <th scope="col">Customer</th>
                <th scope="col">Purchased</th>
                <th scope="col">Total</th>
                <th scope="col">Date</th>
              </tr>
            </thead>
            <tbody>
              {recentOrders.map(order => {
                const customerName = order.customer?.firstName && order.customer?.lastName
                  ? `${order.customer.firstName} ${order.customer.lastName}`
                  : order.customer?.email?.split('@')[0] || '-';
                const items = order.items || [];
                const purchasedSummary = items.length > 0
                  ? items.map((i: AnyRecord) => String(i.title || i.name || '')).slice(0, 2).join(', ') + (items.length > 2 ? ` +${items.length - 2}` : '')
                  : '-';
                return (
                  <tr>
                    <td class="cell-mono">#{order.id?.slice(-6).toUpperCase()}</td>
