---
// src/pages/admin/releases/process.astro
// Process pending release submissions from R2 uploads bucket

import { requireAdminAuth } from '../../../lib/admin';
import AdminLayout from '../../../layouts/AdminLayout.astro';


// Server-side admin auth check
const authResult = await requireAdminAuth(Astro.request, Astro.locals);
if (authResult) return Astro.redirect('/login');

export const prerender = false;

// Use local API endpoint instead of external worker
const WORKER_URL = '/api';
const AUDIO_PROCESSOR_URL = import.meta.env.AUDIO_PROCESSOR_URL || 'http://localhost:8089';
const nonce = Astro.locals.nonce || '';
Astro.response.headers.set('Cache-Control', 'private, no-cache, no-store, must-revalidate');
---

<AdminLayout title="Process Submissions" activeNav="releases">
  <Fragment slot="actions">
    <button id="refreshBtn" class="btn btn-outline">Refresh</button>
    <a href="/admin/releases/manage/" class="btn btn-primary">View Releases</a>
  </Fragment>

  <!-- Status Card -->
  <div class="card mb-3">
    <div class="card-body">
      <div class="flex items-center gap-2">
        <span id="workerStatus" class="badge badge-pending">Checking...</span>
        <span id="workerUrl" class="text-muted" style="font-size: 0.85rem;">Local API</span>
        <span id="audioStatus" class="badge badge-pending" title="Local audio processor — WAV→MP3 conversion">Audio: checking…</span>
      </div>
    </div>
  </div>

  <!-- Submissions List -->
  <div class="card">
    <div class="card-header">
      <h2>Pending Submissions</h2>
      <span id="submissionCount" class="text-muted">Loading...</span>
    </div>
    <div class="card-body" id="submissionsContainer">
      <div class="loading-state">
        <div class="spinner"></div>
        <p>Loading submissions...</p>
      </div>
    </div>
  </div>

  <!-- Processing Log -->
  <div class="card mt-3" id="logCard" style="display: none;">
    <div class="card-header">
      <h2>Processing Log</h2>
      <button id="clearLogBtn" class="btn btn-ghost btn-sm">Clear</button>
    </div>
    <div class="card-body">
      <pre id="processingLog" style="background: #1f2937; color: #f9fafb; padding: 1rem; border-radius: 8px; max-height: 300px; overflow-y: auto; font-size: 0.85rem; margin: 0;"></pre>
    </div>
  </div>

  <Fragment slot="scripts">
    <script is:inline define:vars={{ WORKER_URL, AUDIO_PROCESSOR_URL }} nonce={nonce}>
      const workerStatus = document.getElementById('workerStatus');
      const submissionCount = document.getElementById('submissionCount');
      const submissionsContainer = document.getElementById('submissionsContainer');
      const logCard = document.getElementById('logCard');
      const processingLog = document.getElementById('processingLog');
      const refreshBtn = document.getElementById('refreshBtn');
      const clearLogBtn = document.getElementById('clearLogBtn');

      // Log helper
      function log(message) {
        const timestamp = new Date().toLocaleTimeString();
        processingLog.textContent += `[${timestamp}] ${message}\n`;
        processingLog.scrollTop = processingLog.scrollHeight;
        logCard.style.display = 'block';
      }

      // Check worker health (always online since using local API)
      async function checkWorkerHealth() {
        workerStatus.textContent = 'Online';
        workerStatus.className = 'badge badge-live';
        // Also probe the local audio processor and display its state
        const audioStatus = document.getElementById('audioStatus');
        const ready = await checkAudioProcessor();
        if (audioStatus) {
          if (ready) { audioStatus.textContent = 'Audio: ready'; audioStatus.className = 'badge badge-live'; }
          else if (location.hostname !== 'localhost' && location.hostname !== '127.0.0.1') {
            audioStatus.textContent = 'Audio: localhost only'; audioStatus.className = 'badge badge-pending';
          } else { audioStatus.textContent = 'Audio: offline (start scripts/audio-processor.cjs)'; audioStatus.className = 'badge badge-danger'; }
        }
      }

      // Audio processor (local Node service on :8089) — only reachable in local dev
      // (browsers block https→http://localhost as mixed content)
      async function checkAudioProcessor() {
        if (location.hostname !== 'localhost' && location.hostname !== '127.0.0.1') return false;
        try {
          const r = await fetch(`${AUDIO_PROCESSOR_URL}/health`, { method: 'GET', signal: AbortSignal.timeout(2000) });
          if (!r.ok) return false;
          const d = await r.json();
          return d.status === 'healthy' && d.r2Configured;
        } catch (_e) { return false; }
      }

      // Convert each WAV → MP3 via the local processor.
      // Returns the array of {trackIndex, mp3Url, previewUrl} for fix-track-urls.
      async function convertTracksToMp3(releaseId, r2FolderPath, trackList) {
        const fixes = [];
        for (const t of trackList) {
          if (!t.wavUrl) { log(`Track ${t.trackNumber}: no wavUrl, skipping`); continue; }
          let sourceKey;
          try {
            const u = new URL(t.wavUrl);
            sourceKey = decodeURIComponent(u.pathname.replace(/^\//, ''));
          } catch (_e) {
            log(`Track ${t.trackNumber}: bad wavUrl ${t.wavUrl}`); continue;
          }
          log(`Converting track ${t.trackNumber}: ${t.title}...`);
          try {
            const resp = await fetch(`${AUDIO_PROCESSOR_URL}/process-track`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                sourceKey,
                releaseFolder: r2FolderPath,
                trackNumber: t.trackNumber,
                trackTitle: t.title,
                originalWavUrl: t.wavUrl,
              }),
              signal: AbortSignal.timeout(600000), // 10 min per track ceiling
            });
            const result = await resp.json();
            if (result.success === false || result.error) {
              log(`Track ${t.trackNumber} failed: ${result.error || 'unknown'}`);
              continue;
            }
            const mp3Url = result.mp3Url;
            const wavUrl = result.wavUrl;
            const previewUrl = result.previewUrl || result.mp3Url;
            // Optional — falsy if ffprobe failed; fix-track-urls ignores empty.
            const duration = result.duration || '';
            if (!mp3Url) { log(`Track ${t.trackNumber}: processor returned no mp3Url`); continue; }
            log(`Track ${t.trackNumber} OK -> MP3 ${mp3Url}${duration ? ' (' + duration + ')' : ''}`);
            fixes.push({ trackIndex: t.trackIndex, mp3Url, wavUrl, previewUrl, duration });
          } catch (err) {
            log(`Track ${t.trackNumber} error: ${err instanceof Error ? err.message : String(err)}`);
          }
        }
        return fixes;
      }

      async function patchTrackUrls(releaseId, trackFixes) {
        const resp = await fetch('/api/admin/fix-track-urls/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ releaseId, trackFixes, adminKey: window.ADMIN_KEY }),
        });
        if (!resp.ok) {
          const errBody = await resp.text().catch(() => '');
          throw new Error(`fix-track-urls returned ${resp.status}: ${errBody.slice(0, 200)}`);
        }
        return resp.json();
      }

      // Load submissions
      async function loadSubmissions() {
        try {
          const response = await fetch('/api/list-submissions/');
          const data = await response.json();

          const submissions = data.submissions || [];
          submissionCount.textContent = `${submissions.length} pending`;

          if (submissions.length === 0) {
            submissionsContainer.innerHTML = `
              <div class="empty-state">
                <div class="empty-state-icon">📦</div>
                <div class="empty-state-title">No pending submissions</div>
                <p class="empty-state-text">Upload files to the freshwax-uploads R2 bucket to see them here.</p>
              </div>
            `;
            return;
          }

          submissionsContainer.innerHTML = `
            <div class="table-wrapper">
              <table class="data-table" aria-label="Pending submissions">
                <caption class="sr-only">Pending submissions</caption>
                <thead>
                  <tr>
                    <th scope="col">Submission ID</th>
                    <th scope="col" class="text-right">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  ${submissions.map(id => `
                    <tr data-id="${id}">
                      <td>
                        <div class="item-cell">
                          <div style="width: 48px; height: 48px; background: #e5e5e5; display: flex; align-items: center; justify-content: center; border-radius: 8px;">📁</div>
                          <div class="item-info">
                            <h4>${id}</h4>
                            <p class="cell-secondary">Pending processing</p>
                          </div>
                        </div>
                      </td>
                      <td class="text-right">
                        <button class="btn btn-primary btn-sm process-btn" data-id="${id}">
                          Process
                        </button>
                      </td>
                    </tr>
                  `).join('')}
                </tbody>
              </table>
            </div>
          `;

          // Attach click handlers
          document.querySelectorAll('.process-btn').forEach(btn => {
            btn.addEventListener('click', () => processSubmission(btn.dataset.id, btn));
          });

        } catch (error) {
          console.error('Failed to load submissions:', error);
          submissionsContainer.innerHTML = `
            <div class="empty-state" style="color: var(--accent-red);">
              <div class="empty-state-icon">⚠️</div>
              <div class="empty-state-title">Failed to load</div>
              <p class="empty-state-text">${error instanceof Error ? error.message : String(error)}</p>
            </div>
          `;
        }
      }

      // Process a submission
      async function processSubmission(submissionId, btn) {
        const row = btn.closest('tr');
        const originalText = btn.textContent;

        btn.disabled = true;
        btn.textContent = 'Processing...';
        btn.className = 'btn btn-outline btn-sm';

        log(`Starting processing: ${submissionId}`);

        try {
          const response = await fetch('/api/process-release/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ submissionId, adminKey: window.ADMIN_KEY })
          });

          const data = await response.json();

          if (data.success) {
            log(`SUCCESS: ${data.artist} - ${data.title}`);
            log(`Release ID: ${data.releaseId}`);
            log(`Tracks: ${data.tracks}`);
            log(`Cover: ${data.coverUrl}`);
            if (data.warning) {
              log(`WARNING: ${data.warning}`);
              showToast('Processed with warnings — check log', 'error');
            } else {
              showToast('Release processed — converting audio...');
            }

            // Audio conversion: only when running locally with the processor up
            try {
              if (data.trackList && data.r2FolderPath) {
                const audioReady = await checkAudioProcessor();
                if (audioReady) {
                  log(`Audio processor available. Converting ${data.trackList.length} tracks...`);
                  btn.textContent = 'Converting audio...';
                  const fixes = await convertTracksToMp3(data.releaseId, data.r2FolderPath, data.trackList);
                  if (fixes.length > 0) {
                    log(`Updating Firestore with ${fixes.length} converted track URL(s)...`);
                    await patchTrackUrls(data.releaseId, fixes);
                    log(`Firestore updated. Release is now in SEPARATE format (MP3 + WAV).`);
                    showToast('Release processed + audio converted!');
                  } else {
                    log('No tracks were converted (all failed or skipped).');
                    showToast('Processed but audio conversion failed — check log', 'error');
                  }
                } else {
                  log('Audio processor not running on localhost:8089.');
                  log('Release saved in WAV-only format. Start scripts/audio-processor.cjs and re-run, or convert later.');
                  showToast('Saved as WAV-only — audio processor not running', 'error');
                }
              }
            } catch (convErr) {
              const cmsg = convErr instanceof Error ? convErr.message : String(convErr);
              log(`Audio conversion error: ${cmsg}`);
              showToast('Audio conversion failed — release is in WAV-only state', 'error');
            }

            // Remove row with animation
            row.style.opacity = '0';
            row.style.transition = 'opacity 0.3s';
            setTimeout(() => {
              row.remove();
              updateCount();
            }, 300);

          } else {
            throw new Error(data.error || 'Processing failed');
          }

        } catch (error) {
          console.error('Processing failed:', error);
          const procErrMsg = error instanceof Error ? error.message : String(error);
          log(`ERROR: ${procErrMsg}`);
          showToast('Processing failed: ' + procErrMsg, 'error');

          btn.disabled = false;
          btn.textContent = 'Retry';
          btn.className = 'btn btn-danger btn-sm';
        }
      }

      // Update submission count
      function updateCount() {
        const rows = document.querySelectorAll('.process-btn').length;
        submissionCount.textContent = `${rows} pending`;

        if (rows === 0) {
          submissionsContainer.innerHTML = `
            <div class="empty-state">
              <div class="empty-state-icon">✅</div>
              <div class="empty-state-title">All done!</div>
              <p class="empty-state-text">All submissions have been processed.</p>
            </div>
          `;
        }
      }

      // Event listeners
      refreshBtn.addEventListener('click', () => {
        loadSubmissions();
        checkWorkerHealth();
      });

      clearLogBtn.addEventListener('click', () => {
        processingLog.textContent = '';
        logCard.style.display = 'none';
      });

      // Initial load
      checkWorkerHealth();
      loadSubmissions();
    </script>
  </Fragment>
</AdminLayout>

<style>
  .loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    gap: 1rem;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid #e5e5e5;
    border-top-color: #000;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
  }

  .empty-state-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .empty-state-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .empty-state-text {
    color: var(--text-secondary);
  }

  .mb-3 {
    margin-bottom: 1rem;
  }

  .mt-3 {
    margin-top: 1rem;
  }

  table {
    content-visibility: auto;
    contain-intrinsic-size: auto 500px;
  }
</style>
