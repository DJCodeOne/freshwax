---
// Admin Role Approvals
// Approve or deny Artist, Merch Seller, Vinyl Seller, and DJ Bypass requests
import '../../styles/global.css';
import { getAdminUids, requireAdminAuth } from '../../lib/admin';

// Server-side admin auth check
const authResult = await requireAdminAuth(Astro.request, Astro.locals);
if (authResult) return Astro.redirect('/login');

const adminUids = getAdminUids();
const nonce = Astro.locals.nonce || '';
const csrfToken = Astro.locals.csrfToken || '';
Astro.response.headers.set('Cache-Control', 'private, no-store, no-cache, must-revalidate, max-age=0');
---
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content={csrfToken} />
  <meta name="robots" content="noindex, nofollow" />
  <title>Role Approvals | Admin | Fresh Wax</title>
</head>
<body>
  <script is:inline src="/csrf-protect.js"></script>
  <div class="admin-page">
    <header class="admin-header">
      <a href="/admin/" class="back-link">← Back to Admin</a>
      <h1>Role Approvals</h1>
    </header>

    <div class="admin-content">
      <!-- Tabs -->
      <div class="tabs">
        <button class="tab active" data-tab="artist">
          Artist Requests
          <span class="badge" id="artistCount">0</span>
        </button>
        <button class="tab" data-tab="merch">
          Merch Seller Requests
          <span class="badge" id="merchCount">0</span>
        </button>
        <button class="tab" data-tab="vinyl">
          Vinyl Seller Requests
          <span class="badge" id="vinylCount">0</span>
        </button>
        <button class="tab" data-tab="dj">
          DJ Bypass Requests
          <span class="badge" id="djCount">0</span>
        </button>
      </div>

      <!-- Artist Requests Tab -->
      <div class="tab-content active" id="artistTab">
        <div class="requests-list" id="artistRequests">
          <div class="loading">Loading requests...</div>
        </div>
      </div>

      <!-- Merch Seller Requests Tab -->
      <div class="tab-content" id="merchTab">
        <div class="requests-list" id="merchRequests">
          <div class="loading">Loading requests...</div>
        </div>
      </div>

      <!-- Vinyl Seller Requests Tab -->
      <div class="tab-content" id="vinylTab">
        <div class="requests-list" id="vinylRequests">
          <div class="loading">Loading requests...</div>
        </div>
      </div>

      <!-- DJ Bypass Requests Tab -->
      <div class="tab-content" id="djTab">
        <div class="requests-list" id="djRequests">
          <div class="loading">Loading requests...</div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .admin-page {
      min-height: 100vh;
      background: #f5f5f5;
    }

    .admin-header {
      padding: 1.5rem 2rem;
      border-bottom: 1px solid #e5e5e5;
      background: #fff;
    }

    .back-link {
      color: #666;
      text-decoration: none;
      font-size: 0.875rem;
      display: inline-block;
      margin-bottom: 0.5rem;
    }

    .back-link:hover {
      color: #000;
    }

    .admin-header h1 {
      color: #000;
      margin: 0;
    }

    .admin-content {
      padding: 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .tabs {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid #e5e5e5;
      padding-bottom: 0.5rem;
      flex-wrap: wrap;
    }

    .tab {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.25rem;
      background: transparent;
      border: none;
      color: #666;
      cursor: pointer;
      border-radius: 6px;
      transition: all 0.2s;
      font-size: 0.9rem;
    }

    .tab:hover {
      color: #000;
      background: #f0f0f0;
    }

    .tab.active {
      color: #000;
      background: #000;
      color: #fff;
    }

    .tab .badge {
      background: #e5e5e5;
      color: #666;
      padding: 0.15rem 0.5rem;
      border-radius: 10px;
      font-size: 0.75rem;
    }

    .tab.active .badge {
      background: #fff;
      color: #000;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    .requests-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .loading {
      text-align: center;
      padding: 3rem;
      color: #666;
    }

    .empty-state {
      text-align: center;
      padding: 3rem;
      color: #666;
      background: #fff;
      border: 1px dashed #ddd;
      border-radius: 8px;
    }

    .request-card {
      background: #fff;
      border: 1px solid #e5e5e5;
      border-radius: 8px;
      padding: 1.5rem;
    }

    .request-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1rem;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .request-user {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .request-name {
      font-weight: 600;
      color: #000;
      font-size: 1.1rem;
    }

    .request-email {
      color: #666;
      font-size: 0.875rem;
    }

    .request-date {
      color: #999;
      font-size: 0.8rem;
    }

    .request-details {
      margin-bottom: 1rem;
      padding: 1rem;
      background: #f9f9f9;
      border-radius: 6px;
    }

    .detail-row {
      display: flex;
      margin-bottom: 0.5rem;
    }

    .detail-row:last-child {
      margin-bottom: 0;
    }

    .detail-label {
      width: 120px;
      color: #666;
      font-size: 0.875rem;
    }

    .detail-value {
      color: #000;
      font-size: 0.875rem;
      flex: 1;
    }

    .request-actions {
      display: flex;
      gap: 0.75rem;
    }

    .btn {
      padding: 0.625rem 1.25rem;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      border: none;
      font-size: 0.875rem;
    }

    .btn-approve {
      background: #000;
      color: #fff;
    }

    .btn-approve:hover {
      background: #333;
    }

    .btn-deny {
      background: transparent;
      color: #dc2626;
      border: 1px solid #dc2626;
    }

    .btn-deny:hover {
      background: rgba(220, 38, 38, 0.1);
    }

    .btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    @media (max-width: 600px) {
      .tabs { flex-direction: column; }
      .tab { width: 100%; justify-content: center; }
    }
  </style>

  <script is:inline nonce={nonce}>
    // Admin check uses Firestore admins collection
  </script>
  <script type="module">
    function escapeHtml(s){if(typeof s!=='string')return '';return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,"&#39;");}
    import { initializeApp, getApps } from 'https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js';
    import { getAuth, onAuthStateChanged } from 'https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js';

    const firebaseConfig = {
      apiKey: 'AIzaSyBiZGsWdvA9ESm3OsUpZ-VQpwqMjMpBY6g',
      authDomain: "freshwax-store.firebaseapp.com",
      projectId: "freshwax-store",
      storageBucket: "freshwax-store.firebasestorage.app",
      messagingSenderId: "675435782973",
      appId: "1:675435782973:web:e8459c2ec4a5f6d683db54"
    };
    const app = getApps().length ? getApps()[0] : initializeApp(firebaseConfig);
    const auth = getAuth(app);

    const tabs = document.querySelectorAll('.tab');
    const tabContents = document.querySelectorAll('.tab-content');

    // Event delegation for approve/deny buttons on all request containers
    ['artistRequests', 'merchRequests', 'vinylRequests', 'djRequests'].forEach(containerId => {
      document.getElementById(containerId)?.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-action]');
        if (!btn) return;
        const action = btn.dataset.action;
        const uid = btn.dataset.uid;
        const role = btn.dataset.role;
        if (action === 'approve') window.approveRequest(uid, role);
        else if (action === 'deny') window.denyRequest(uid, role);
      });
    });

    // Tab switching
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tabContents.forEach(c => c.classList.remove('active'));

        tab.classList.add('active');
        document.getElementById(`${tab.dataset.tab}Tab`).classList.add('active');
      });
    });

    onAuthStateChanged(auth, async (user) => {
      if (!user) {
        window.location.href = '/login/?redirect=/admin/role-approvals/';
        return;
      }

      // Check admin status via API
      const idToken = await user.getIdToken();
      const adminResp = await fetch('/api/admin/check-access/', {
        headers: { 'Authorization': `Bearer ${idToken}` }
      });
      const adminData = await adminResp.json();
      if (!adminData.success || !adminData.isAdmin) {
        window.location.href = '/';
        return;
      }

      // Load all requests
      await loadRequests();
    });

    async function loadRequests() {
      // Get pending role requests via API (replaces client-side Firestore collection query)
      const idToken = await auth.currentUser.getIdToken();
      const response = await fetch('/api/roles/manage/?action=getPendingRequests', {
        headers: { 'Authorization': `Bearer ${idToken}` }
      });
      const data = await response.json();

      const artistRequests = (data.requests?.artist || []).map(r => ({ uid: r.uid || r.userId, ...r, request: r }));
      const merchRequests = (data.requests?.merchSeller || []).map(r => ({ uid: r.uid || r.userId, ...r, request: r }));
      const vinylRequests = (data.requests?.vinylSeller || []).map(r => ({ uid: r.uid || r.userId, ...r, request: r }));
      const djRequests = (data.requests?.djBypass || []).map(r => ({ uid: r.uid || r.userId, ...r, request: r }));

      // Update counts
      document.getElementById('artistCount').textContent = artistRequests.length;
      document.getElementById('merchCount').textContent = merchRequests.length;
      document.getElementById('vinylCount').textContent = vinylRequests.length;
      document.getElementById('djCount').textContent = djRequests.length;

      // Render lists
      renderArtistRequests(artistRequests);
      renderMerchRequests(merchRequests);
      renderVinylRequests(vinylRequests);
      renderDJRequests(djRequests);
    }

    function renderArtistRequests(requests) {
      const container = document.getElementById('artistRequests');
      
      if (requests.length === 0) {
        container.innerHTML = '<div class="empty-state">No pending artist requests</div>';
        return;
      }

      container.innerHTML = requests.map(r => `
        <div class="request-card" data-uid="${escapeHtml(r.uid)}">
          <div class="request-header">
            <div class="request-user">
              <div class="request-name">${escapeHtml(r.displayName || 'Unknown')}</div>
              <div class="request-email">${escapeHtml(r.email)}</div>
              <div class="request-date">Requested: ${formatDate(r.request.requestedAt)}</div>
            </div>
          </div>
          <div class="request-details">
            <div class="detail-row">
              <span class="detail-label">Artist Name:</span>
              <span class="detail-value">${escapeHtml(r.request.artistName || '-')}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Bio:</span>
              <span class="detail-value">${escapeHtml(r.request.bio || '-')}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Links:</span>
              <span class="detail-value">${escapeHtml(r.request.links || '-')}</span>
            </div>
          </div>
          <div class="request-actions">
            <button class="btn btn-approve" data-action="approve" data-uid="${escapeHtml(r.uid)}" data-role="artist">Approve</button>
            <button class="btn btn-deny" data-action="deny" data-uid="${escapeHtml(r.uid)}" data-role="artist">Deny</button>
          </div>
        </div>
      `).join('');
    }

    function renderMerchRequests(requests) {
      const container = document.getElementById('merchRequests');
      
      if (requests.length === 0) {
        container.innerHTML = '<div class="empty-state">No pending merch seller requests</div>';
        return;
      }

      container.innerHTML = requests.map(r => `
        <div class="request-card" data-uid="${escapeHtml(r.uid)}">
          <div class="request-header">
            <div class="request-user">
              <div class="request-name">${escapeHtml(r.displayName || 'Unknown')}</div>
              <div class="request-email">${escapeHtml(r.email)}</div>
              <div class="request-date">Requested: ${formatDate(r.request.requestedAt)}</div>
            </div>
          </div>
          <div class="request-details">
            <div class="detail-row">
              <span class="detail-label">Business:</span>
              <span class="detail-value">${escapeHtml(r.request.businessName || '-')}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Description:</span>
              <span class="detail-value">${escapeHtml(r.request.description || '-')}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Website:</span>
              <span class="detail-value">${escapeHtml(r.request.website || '-')}</span>
            </div>
          </div>
          <div class="request-actions">
            <button class="btn btn-approve" data-action="approve" data-uid="${escapeHtml(r.uid)}" data-role="merchSeller">Approve</button>
            <button class="btn btn-deny" data-action="deny" data-uid="${escapeHtml(r.uid)}" data-role="merchSeller">Deny</button>
          </div>
        </div>
      `).join('');
    }

    function renderVinylRequests(requests) {
      const container = document.getElementById('vinylRequests');

      if (requests.length === 0) {
        container.innerHTML = '<div class="empty-state">No pending vinyl seller requests</div>';
        return;
      }

      container.innerHTML = requests.map(r => `
        <div class="request-card" data-uid="${escapeHtml(r.uid)}">
          <div class="request-header">
            <div class="request-user">
              <div class="request-name">${escapeHtml(r.displayName || 'Unknown')}</div>
              <div class="request-email">${escapeHtml(r.email)}</div>
              <div class="request-date">Requested: ${formatDate(r.request.requestedAt)}</div>
            </div>
          </div>
          <div class="request-details">
            <div class="detail-row">
              <span class="detail-label">Store Name:</span>
              <span class="detail-value">${escapeHtml(r.request.storeName || '-')}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Description:</span>
              <span class="detail-value">${escapeHtml(r.request.description || '-')}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Location:</span>
              <span class="detail-value">${escapeHtml(r.request.location || '-')}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Discogs:</span>
              <span class="detail-value">${r.request.discogsUrl ? `<a href="${escapeHtml(r.request.discogsUrl)}" target="_blank" rel="noopener noreferrer" style="color:#22c55e">${escapeHtml(r.request.discogsUrl)}</a>` : '-'}</span>
            </div>
          </div>
          <div class="request-actions">
            <button class="btn btn-approve" data-action="approve" data-uid="${escapeHtml(r.uid)}" data-role="vinylSeller">Approve</button>
            <button class="btn btn-deny" data-action="deny" data-uid="${escapeHtml(r.uid)}" data-role="vinylSeller">Deny</button>
          </div>
        </div>
      `).join('');
    }

    function renderDJRequests(requests) {
      const container = document.getElementById('djRequests');
      
      if (requests.length === 0) {
        container.innerHTML = '<div class="empty-state">No pending DJ bypass requests</div>';
        return;
      }

      container.innerHTML = requests.map(r => `
        <div class="request-card" data-uid="${escapeHtml(r.uid)}">
          <div class="request-header">
            <div class="request-user">
              <div class="request-name">${escapeHtml(r.displayName || 'Unknown')}</div>
              <div class="request-email">${escapeHtml(r.email)}</div>
              <div class="request-date">Requested: ${formatDate(r.request.requestedAt)}</div>
            </div>
          </div>
          <div class="request-details">
            <div class="detail-row">
              <span class="detail-label">Reason:</span>
              <span class="detail-value">${escapeHtml(r.request.reason || '-')}</span>
            </div>
          </div>
          <div class="request-actions">
            <button class="btn btn-approve" data-action="approve" data-uid="${escapeHtml(r.uid)}" data-role="djBypass">Approve</button>
            <button class="btn btn-deny" data-action="deny" data-uid="${escapeHtml(r.uid)}" data-role="djBypass">Deny</button>
          </div>
        </div>
      `).join('');
    }

    function formatDate(timestamp) {
      if (!timestamp) return '-';
      const date = timestamp.toDate ? timestamp.toDate() : new Date(timestamp);
      return date.toLocaleDateString('en-GB', { 
        day: 'numeric', 
        month: 'short', 
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });
    }

    // Global functions for button onclick
    window.approveRequest = async function(uid, roleType) {
      if (!confirm(`Approve this ${roleType === 'djBypass' ? 'DJ bypass' : roleType} request?`)) return;

      try {
        const idToken = await auth.currentUser.getIdToken();
        const response = await fetch('/api/roles/manage/', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${idToken}`
          },
          body: JSON.stringify({
            action: 'approveRole',
            uid,
            roleType
          })
        });
        const result = await response.json();
        if (!result.success) throw new Error(result.error || 'Approval failed');

        // Remove card from UI
        document.querySelector(`.request-card[data-uid="${uid}"]`)?.remove();

        // Update count
        await loadRequests();

        alert('Request approved!');
      } catch (error: unknown) {
        console.error('Error approving request:', error);
        alert('Error approving request: ' + (error instanceof Error ? error.message : String(error)));
      }
    };

    window.denyRequest = async function(uid, roleType) {
      const reason = prompt('Reason for denial (optional):');
      if (reason === null) return; // Cancelled

      try {
        const idToken = await auth.currentUser.getIdToken();
        const response = await fetch('/api/roles/manage/', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${idToken}`
          },
          body: JSON.stringify({
            action: 'denyRole',
            uid,
            roleType,
            reason
          })
        });
        const result = await response.json();
        if (!result.success) throw new Error(result.error || 'Denial failed');

        // Remove card from UI
        document.querySelector(`.request-card[data-uid="${uid}"]`)?.remove();

        // Update count
        await loadRequests();

        alert('Request denied');
      } catch (error: unknown) {
        console.error('Error denying request:', error);
        alert('Error denying request: ' + (error instanceof Error ? error.message : String(error)));
      }
    };
  </script>
</body>
</html>
