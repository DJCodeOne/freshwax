  function applyMode(mode) {
    hideChooser();
    if (mode === 'browser') {
      switchToBrowserMode();
    } else {
      // obs:obs, obs:butt, obs:relay
      switchToObsMode();
      var source = mode.split(':')[1] || 'obs';
      setTimeout(function() { setPreviewSource(source); }, 50);
    }
    try { localStorage.setItem('fw_lobby_mode', mode); } catch (e) { /* ignore */ }
  }

