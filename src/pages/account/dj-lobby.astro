  // Mobile Ready button
  document.getElementById('mobileReadyBtn')?.addEventListener('click', async () => {
    if (!currentUser) return;

    var btn = document.getElementById('mobileReadyBtn');
    var btnText = document.getElementById('mobileReadyBtnText');
    var statusText = document.getElementById('mobileStatusText');
    var goLiveBtn = document.getElementById('mobileGoLiveBtn');

    if (!btn || !btnText) return;

    // If already ready, ignore
    if (btn.classList.contains('mobile-is-ready')) return;

    btn.disabled = true;
    btnText.textContent = 'Booking slot...';

    try {
      // Auto-book slot if none booked and no one is live
      if (!mySlot && !currentStream) {
        var token = await currentUser.getIdToken();
        var now = new Date();
        now.setSeconds(0, 0);

        var bookResponse = await fetch('/api/livestream/slots/', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + token
          },
          body: JSON.stringify({
            action: 'book',
            djId: currentUser.uid,
            djName: (userInfo ? userInfo.name : null) || (currentUser.displayName) || 'DJ',
            djAvatar: (userInfo ? userInfo.avatar : null) || (currentUser.photoURL) || '/place-holder.webp',
            startTime: now.toISOString(),
            duration: 60,
            title: 'Live Session',
            genre: '',
            description: ''
          })
        });

        var bookResult = await bookResponse.json();
        if (!bookResult.success) {
          throw new Error(bookResult.error || 'Failed to book slot');
        }

        mySlot = bookResult.slot;
        currentStreamKey = mySlot.streamKey;
        scheduling.setMySlot(mySlot);
        scheduling.setCurrentStreamKey(currentStreamKey);
      }

      // Set presence ready
      var idToken = await currentUser.getIdToken();
      await fetch('/api/dj-lobby/presence/', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + idToken
        },
        body: JSON.stringify({
          action: 'heartbeat',
          userId: currentUser.uid,
          isReady: true
        })
      });

      // Sync desktop button state
      var desktopBtn = document.getElementById('setReadyBtn');
      var desktopBtnText = document.getElementById('readyBtnText');
      var desktopGoLive = document.getElementById('goLiveBtn');
      if (desktopBtn) {
        desktopBtn.classList.add('is-ready-state');
        desktopBtn.classList.remove('glow');
      }
      if (desktopBtnText) desktopBtnText.textContent = '\u2713 Ready';
      if (desktopGoLive) desktopGoLive.classList.remove('hidden');

      // Start camera preview so DJ can see themselves
      btnText.textContent = 'Starting camera...';
      var videoEl = document.getElementById('mobilePreviewVideo');
      var offlineState = document.getElementById('mobileOfflineState');
      await mobileBroadcast.startCamera(videoEl);

      // Show camera feed, hide offline state
      if (offlineState) offlineState.style.display = 'none';
      if (videoEl) videoEl.classList.add('active');

      // Update mobile UI
      btn.classList.add('mobile-is-ready');
      btnText.textContent = '\u2713 Ready';
      if (goLiveBtn) goLiveBtn.style.display = '';
      if (statusText) statusText.textContent = 'Camera preview active — tap GO LIVE when ready';

    } catch (e) {
      btnText.textContent = "I'm Ready";
      btn.disabled = false;
      if (statusText) statusText.textContent = (e instanceof Error ? e.message : 'Failed. Try again.');
    }
  });

  // Mobile Go Live button — camera already running from Ready step
  document.getElementById('mobileGoLiveBtn')?.addEventListener('click', async () => {
    if (!currentUser || !mySlot) return;

    var btn = document.getElementById('mobileGoLiveBtn');
    var btnText = document.getElementById('mobileGoLiveBtnText');
    var statusText = document.getElementById('mobileStatusText');
    var videoEl = document.getElementById('mobilePreviewVideo');
    var offlineState = document.getElementById('mobileOfflineState');
    var liveOverlay = document.getElementById('mobileLiveOverlay');
    var readyBtn = document.getElementById('mobileReadyBtn');
    var timerEl = document.getElementById('mobileLiveTimer');

    if (!btn || !btnText) return;

    btn.disabled = true;
    btnText.textContent = 'Connecting...';
    if (statusText) statusText.textContent = '';

    try {
      // Go live via WHIP (camera already started in Ready step)
      var token = await currentUser.getIdToken();
      await mobileBroadcast.goLive(
        token,
        mySlot.id,
        mySlot.streamKey || currentStreamKey,
        currentUser.uid,
        (userInfo ? userInfo.name : null) || currentUser.displayName || 'DJ',
        (userInfo ? userInfo.avatar : null) || currentUser.photoURL || '/place-holder.webp',
        timerEl
      );

      // Success - switch to live UI
      btn.style.display = 'none';
      if (readyBtn) readyBtn.style.display = 'none';
      if (liveOverlay) liveOverlay.style.display = '';

      // Swap header: hide Back to Live, show End Stream
      var headerBack = document.getElementById('headerBackToLive');
      var headerEnd = document.getElementById('headerEndStreamBtn');
      if (headerBack) headerBack.style.display = 'none';
      if (headerEnd) headerEnd.style.display = '';

      // Sync desktop buttons
      var desktopReadyBtn = document.getElementById('setReadyBtn');
      var desktopReadyText = document.getElementById('readyBtnText');
      var desktopGoLive = document.getElementById('goLiveBtn');
      if (desktopReadyBtn) {
        desktopReadyBtn.classList.remove('is-ready-state');
        desktopReadyBtn.classList.add('is-ready');
        desktopReadyBtn.style.background = '#dc2626';
      }
      if (desktopReadyText) desktopReadyText.textContent = '\uD83D\uDD34 LIVE';
      if (desktopGoLive) desktopGoLive.classList.add('hidden');

      // Reload stream status so desktop reflects live state
      if (typeof loadStreamStatus === 'function') await loadStreamStatus();
      if (typeof updateEndStreamButton === 'function') updateEndStreamButton(true, true);

    } catch (e) {
      btnText.textContent = 'GO LIVE';
      btn.disabled = false;
      if (statusText) statusText.textContent = (e instanceof Error ? e.message : 'Failed to go live.');
      // Reset video if camera started but WHIP failed
      if (offlineState) offlineState.style.display = '';
      if (videoEl) videoEl.classList.remove('active');
    }
  });

  // Header End Stream button (replaces Back to Live when live)
  document.getElementById('headerEndStreamBtn')?.addEventListener('click', async () => {
    if (!currentUser) return;
    if (!confirm('End your livestream?')) return;

    var btn = document.getElementById('headerEndStreamBtn');
    if (btn) { btn.textContent = 'Ending...'; btn.disabled = true; }

    try {
      var token = await currentUser.getIdToken();
      if (mobileBroadcast.getIsLive()) {
        // Active WHIP session — disconnect + end via API
        await mobileBroadcast.endStream(token);
      } else {
        // Orphaned stream — just call endStream API directly (no WHIP to disconnect)
        await fetch('/api/livestream/slots/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
          body: JSON.stringify({ action: 'endStream', djId: currentUser.uid })
        });
      }
    } catch (e) {
      // Best effort
    }

    resetMobileToOffline();
    if (typeof loadStreamStatus === 'function') await loadStreamStatus();
    if (typeof updateEndStreamButton === 'function') updateEndStreamButton(false, false);
    if (btn) { btn.textContent = 'End Stream'; btn.disabled = false; }
    var statusText = document.getElementById('mobileStatusText');
    if (statusText) statusText.textContent = 'Stream ended';
  });

  // Mobile mic/camera/flip controls
  document.getElementById('mobileMicBtn')?.addEventListener('click', () => {
    var muted = mobileBroadcast.toggleMic();
    var btn = document.getElementById('mobileMicBtn');
    if (btn) btn.classList.toggle('muted', muted);
    if (btn) btn.setAttribute('aria-label', muted ? 'Unmute microphone' : 'Mute microphone');
  });

  document.getElementById('mobileCameraBtn')?.addEventListener('click', () => {
    var off = mobileBroadcast.toggleCamera();
    var btn = document.getElementById('mobileCameraBtn');
    if (btn) btn.classList.toggle('muted', off);
    if (btn) btn.setAttribute('aria-label', off ? 'Enable camera' : 'Disable camera');
  });

  document.getElementById('mobileFlipBtn')?.addEventListener('click', () => {
    var videoEl = document.getElementById('mobilePreviewVideo');
    if (videoEl) {
      mobileBroadcast.flipCamera(videoEl).catch(function() {
        // Flip failed silently
      });
    }
  });

  function resetMobileToOffline() {
    var offlineState = document.getElementById('mobileOfflineState');
    var videoEl = document.getElementById('mobilePreviewVideo');
    var liveOverlay = document.getElementById('mobileLiveOverlay');
    var readyBtn = document.getElementById('mobileReadyBtn');
    var readyBtnText = document.getElementById('mobileReadyBtnText');
    var goLiveBtn = document.getElementById('mobileGoLiveBtn');

    if (offlineState) offlineState.style.display = '';
    if (videoEl) { videoEl.classList.remove('active'); videoEl.srcObject = null; }
    if (liveOverlay) liveOverlay.style.display = 'none';
    if (readyBtn) { readyBtn.style.display = ''; readyBtn.disabled = false; readyBtn.classList.remove('mobile-is-ready'); }
    if (readyBtnText) readyBtnText.textContent = "I'm Ready";
    if (goLiveBtn) goLiveBtn.style.display = 'none';

    // Restore header: show Back to Live, hide End Stream
    var headerBack = document.getElementById('headerBackToLive');
    var headerEnd = document.getElementById('headerEndStreamBtn');
    if (headerBack) headerBack.style.display = '';
    if (headerEnd) headerEnd.style.display = 'none';

    // Clear header remaining timer
    videoPlayer.setStreamEndTime(null);
    if (lobbyTimeRemainingInterval) { clearInterval(lobbyTimeRemainingInterval); lobbyTimeRemainingInterval = null; }
    var headerTimeRemaining = document.getElementById('headerTimeRemaining');
    if (headerTimeRemaining) headerTimeRemaining.classList.add('hidden');
    var timeRemaining = document.getElementById('timeRemaining');
    if (timeRemaining) timeRemaining.classList.add('hidden');

    // Reset desktop buttons
    var desktopBtn = document.getElementById('setReadyBtn');
    var desktopBtnText = document.getElementById('readyBtnText');
    if (desktopBtn) {
      desktopBtn.classList.remove('is-ready-state', 'is-ready');
      desktopBtn.style.background = '';
      desktopBtn.disabled = false;
      desktopBtn.classList.add('glow');
    }
    if (desktopBtnText) desktopBtnText.textContent = "I'm Ready!";
  }

  // pagehide cleanup for mobile broadcast
  window.addEventListener('pagehide', function() {
    mobileBroadcast.cleanup();
  });

  // Re-acquire wake lock on visibility change
  document.addEventListener('visibilitychange', function() {
    if (document.visibilityState === 'visible') {
      mobileBroadcast.reacquireWakeLock();
    }
  });
</script>

