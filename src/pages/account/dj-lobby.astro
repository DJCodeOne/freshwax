  function setStreamMode(mode) {
    currentStreamMode = mode;
    const directBtn = document.getElementById('directModeBtn');
    const relayBtn = document.getElementById('relayModeBtn');
    const directSection = document.getElementById('directStreamSection');
    const relaySection = document.getElementById('relayStreamSection');
