      obsOfflineState?.classList.add('hidden');
      obsVideoPreview?.classList.add('hidden');
      buttAudioPreview?.classList.add('hidden');
      // Disable OBS and BUTT tabs, activate Relay tab
      obsIndicator?.classList.add('disabled');
