    // =============== END SEPARATE PLAYER CONTROLS ===============

    // =============== STEREO AUDIO METERS ===============
    let obsAudioContext = null;
    // Note: obsAnalyserL, obsAnalyserR, liveAnalyserL, liveAnalyserR declared earlier for broadcast panel
    // Note: liveMeterAnimationId declared at top with other preview state
    let liveAudioContext = null;
    let obsMeterAnimationId = null;
    // Note: OBS/Live K-weighted analysers declared at top with other preview state

    function setupAudioMeter(videoElement, prefix) {
      try {
        const audioContext = new (window.AudioContext || window.webkitAudioContext)();
        const source = audioContext.createMediaElementSource(videoElement);
        const splitter = audioContext.createChannelSplitter(2);

        // Regular analysers for visualization (unfiltered)
        const analyserL = audioContext.createAnalyser();
        const analyserR = audioContext.createAnalyser();
        analyserL.fftSize = 256;
        analyserR.fftSize = 256;
        analyserL.smoothingTimeConstant = 0.5;
        analyserR.smoothingTimeConstant = 0.5;

        // K-weighted analysers for accurate LUFS (ITU-R BS.1770-4)
        const kWeightedAnalyserL = audioContext.createAnalyser();
        const kWeightedAnalyserR = audioContext.createAnalyser();
        kWeightedAnalyserL.fftSize = 2048;
        kWeightedAnalyserR.fftSize = 2048;
        kWeightedAnalyserL.smoothingTimeConstant = 0;
        kWeightedAnalyserR.smoothingTimeConstant = 0;

        // K-weighting Stage 1: High shelf filter (+4dB at high frequencies)
        const highShelfL = audioContext.createBiquadFilter();
        const highShelfR = audioContext.createBiquadFilter();
        highShelfL.type = 'highshelf';
        highShelfR.type = 'highshelf';
        highShelfL.frequency.value = 1681.97;
        highShelfR.frequency.value = 1681.97;
        highShelfL.gain.value = 4;
        highShelfR.gain.value = 4;

        // K-weighting Stage 2: High-pass filter
        const highPassL = audioContext.createBiquadFilter();
        const highPassR = audioContext.createBiquadFilter();
        highPassL.type = 'highpass';
        highPassR.type = 'highpass';
        highPassL.frequency.value = 38.14;
        highPassR.frequency.value = 38.14;
        highPassL.Q.value = 0.5;
        highPassR.Q.value = 0.5;

        // Upmix mono to stereo before splitting — if source is mono,
        // channelSplitter output 1 (right) would be silent. A gain node
        // with channelInterpretation 'speakers' copies mono to both L+R.
        const upmixNode = audioContext.createGain();
        upmixNode.channelCount = 2;
        upmixNode.channelCountMode = 'explicit';
        upmixNode.channelInterpretation = 'speakers';
        source.connect(upmixNode);
        upmixNode.connect(splitter);

        // Unfiltered path for LED visualization
        splitter.connect(analyserL, 0);
        splitter.connect(analyserR, 1);

        // K-weighted path for LUFS
        splitter.connect(highShelfL, 0);
        splitter.connect(highShelfR, 1);
        highShelfL.connect(highPassL);
        highShelfR.connect(highPassR);
        highPassL.connect(kWeightedAnalyserL);
        highPassR.connect(kWeightedAnalyserR);

        // Brick wall limiter to prevent clipping and protect ears
        const limiter = audioContext.createDynamicsCompressor();
        limiter.threshold.value = -1;   // Catch peaks near 0dB
        limiter.knee.value = 0;         // Hard knee for true limiting
        limiter.ratio.value = 20;       // High ratio = limiting behavior
        limiter.attack.value = 0.001;   // 1ms attack
        limiter.release.value = 0.1;    // 100ms release

        // Output to speakers through limiter
        source.connect(limiter);
        limiter.connect(audioContext.destination);

        // Store K-weighted analysers in global vars based on prefix
        if (prefix === 'OBS') {
          obsKWeightedAnalyserL = kWeightedAnalyserL;
          obsKWeightedAnalyserR = kWeightedAnalyserR;
        } else if (prefix === 'Live') {
          liveKWeightedAnalyserL = kWeightedAnalyserL;
          liveKWeightedAnalyserR = kWeightedAnalyserR;
        }

        console.debug(`[${prefix}] Audio meter with K-weighting and limiter initialized`);
        return { audioContext, analyserL, analyserR, kWeightedAnalyserL, kWeightedAnalyserR };
      } catch (e) {
        console.error(`[${prefix}] Audio meter setup error:`, e);
        return null;
      }
    }

    // Store previous levels for smoothing
    const meterLevels = new Map();

    function updateLedMeter(analyser, ledRowEl, isLeftChannel) {
      if (!analyser || !ledRowEl) return 0;

      const dataArray = new Uint8Array(analyser.frequencyBinCount);
      analyser.getByteFrequencyData(dataArray);

      // Calculate RMS level - reduced sensitivity
      let sum = 0;
      for (let i = 0; i < dataArray.length; i++) {
        sum += dataArray[i] * dataArray[i];
      }
      const rms = Math.sqrt(sum / dataArray.length);
      // Calibrated for -6dB peak to light ~6-8 of 12 LEDs (less sensitive)
      // Higher divisor = less sensitive. 220 means louder audio needed to light LEDs
      let level = Math.min(100, (rms / 220) * 100);

      // Get previous level for smoothing
      const meterId = ledRowEl.id;
      const prevLevel = meterLevels.get(meterId) || 0;

      // Smooth decay (fast attack, slower release)
      if (level > prevLevel) {
        // Fast attack
        level = level;
      } else {
        // Slower decay for smoother visuals
        level = prevLevel * 0.85 + level * 0.15;
      }

      // Store for next frame
      meterLevels.set(meterId, level);

      // Get all LEDs in the row
      const leds = ledRowEl.querySelectorAll('.led');
      const numLeds = leds.length;

      // Calculate how many LEDs should be lit (from center outward)
      // Level 0-100 maps to 0-12 LEDs
      const ledsToLight = Math.round((level / 100) * numLeds);

      // For left channel: LEDs go from right to left (index 11 to 0, where 11 is closest to center)
      // For right channel: LEDs go from left to right (index 0 to 11, where 0 is closest to center)
      leds.forEach((led, index) => {
        let shouldLight;
        if (isLeftChannel) {
          // Left channel: light from the end (closest to center) backwards
          shouldLight = index >= (numLeds - ledsToLight);
        } else {
          // Right channel: light from the start (closest to center) forwards
          shouldLight = index < ledsToLight;
        }

        if (shouldLight) {
          led.classList.add('lit');
        } else {
          led.classList.remove('lit');
        }
      });

      return level;
    }

    // Start preview LED meter animation (called when OBS or BUTT connects)
    // Exposed globally so it can be called from Icecast connection code
    window.startPreviewMeterAnimation = function() {
      if (!obsMeterAnimationId) {
        animateObsMeters();
        console.debug('[Audio] Preview LED meter animation started');
      }
    };

    // Force start preview meters (bypasses animation ID check for relay mode)
    window.forceStartPreviewMeters = function() {
      if (obsMeterAnimationId) {
        cancelAnimationFrame(obsMeterAnimationId);
        obsMeterAnimationId = null;
      }
      animateObsMeters();
      console.debug('[Audio] Preview LED meters force-started');
    };

    // Force start live meters (bypasses animation ID check for relay mode)
    window.forceStartLiveMeters = function() {
      if (liveMeterAnimationId) {
        cancelAnimationFrame(liveMeterAnimationId);
        liveMeterAnimationId = null;
      }
      animateLiveMeters();
      console.debug('[Audio] Live LED meters force-started');
    };

    function animateObsMeters() {
      // Use Icecast analysers when BUTT mode is active, otherwise OBS
      let analyserL, analyserR;
      if ((currentPreviewSource === 'butt' || currentPreviewSource === 'relay') && icecastAnalyserL && icecastAnalyserR) {
        analyserL = icecastAnalyserL;
        analyserR = icecastAnalyserR;
      } else if (obsAnalyserL && obsAnalyserR) {
        analyserL = obsAnalyserL;
        analyserR = obsAnalyserR;
      }

      if (analyserL && analyserR) {
        updateLedMeter(analyserL, document.getElementById('obsLeftLeds'), true);
        updateLedMeter(analyserR, document.getElementById('obsRightLeds'), false);
      }
      obsMeterAnimationId = requestAnimationFrame(animateObsMeters);
    }

    function animateLiveMeters() {
      // Right side LEDs show live output (what viewers hear)
      // Priority: liveAnalysers (from audioElement or hlsVideo) > icecastAnalysers (fallback)
      let analyserL, analyserR;
      if (liveAnalyserL && liveAnalyserR) {
        // Use live analysers from audioElement or HLS video
        analyserL = liveAnalyserL;
        analyserR = liveAnalyserR;
      } else if ((currentPreviewSource === 'butt' || currentPreviewSource === 'relay') && icecastAnalyserL && icecastAnalyserR) {
        // Fallback to icecast analysers for preview audio
        analyserL = icecastAnalyserL;
        analyserR = icecastAnalyserR;
      }

      if (analyserL && analyserR) {
        updateLedMeter(analyserL, document.getElementById('liveLeftLeds'), true);
        updateLedMeter(analyserR, document.getElementById('liveRightLeds'), false);
      }
      liveMeterAnimationId = requestAnimationFrame(animateLiveMeters);
    }

    // Wire up late-binding refs for module context
    _setupAudioMeterRef = setupAudioMeter;
    _animateLiveMetersRef = animateLiveMeters;

    // Setup meters when video plays
    const obsVid = document.getElementById('obsVideo');
    if (obsVid) {
      obsVid.addEventListener('play', () => {
        if (!obsAudioContext) {
          const result = setupAudioMeter(obsVid, 'OBS');
          if (result) {
            obsAudioContext = result.audioContext;
            obsAnalyserL = result.analyserL;
            obsAnalyserR = result.analyserR;
            console.debug('[Audio] OBS analysers initialized');
          }
        }
        if (obsAudioContext?.state === 'suspended') {
          obsAudioContext.resume();
        }
        if (!obsMeterAnimationId) animateObsMeters();
        // Also start broadcast meters if panel is visible
        const panel = document.getElementById('broadcastAudioPanel');
        if (panel && !panel.classList.contains('hidden') && !broadcastMeterAnimationId) {
          initBroadcastMeters();
        }
      });
      obsVid.addEventListener('pause', () => {
        if (obsMeterAnimationId) {
          cancelAnimationFrame(obsMeterAnimationId);
          obsMeterAnimationId = null;
