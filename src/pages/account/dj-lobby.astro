  document.getElementById('chooserObs')?.addEventListener('click', function() { applyMode('obs:obs'); });
  document.getElementById('chooserButt')?.addEventListener('click', function() { applyMode('obs:butt'); });
  document.getElementById('chooserRelay')?.addEventListener('click', function() { applyMode('obs:relay'); });

