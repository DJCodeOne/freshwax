  async function initLobby() {
    // Initialize extracted modules with shared context
    initModules();

    // DEBUG: Monitor audioPreview visibility changes
    const audioPreviewEl = document.getElementById('audioPreview');
    if (audioPreviewEl) {
      lobbyAudioPreviewObserver = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.attributeName === 'class') {
            const isHidden = audioPreviewEl.classList.contains('hidden');
            console.debug('[Stream DEBUG] audioPreview class changed! hidden=' + isHidden, new Error().stack?.split('\n').slice(0, 5));
          }
        });
      });
      lobbyAudioPreviewObserver.observe(audioPreviewEl, { attributes: true, attributeFilter: ['class'] });
      console.debug('[Stream DEBUG] MutationObserver attached to audioPreview');
    }

    // Initialize livestream chat immediately with playlist-global
    // This ensures chat is always active (live stream or playlist mode)
    // loadStreamStatus will upgrade to a live stream channel if one exists
    window.currentStreamId = 'playlist-global';
    await initLivestreamChat('playlist-global');

    // Show chat form for logged-in users immediately
    if (currentUser) {
      document.getElementById('loginPrompt')?.classList.add('hidden');
      document.getElementById('chatForm')?.classList.remove('hidden');
    }

    // Load initial data from API
    await loadAllSlots(); // Load all slots for consecutive slot detection
    await loadStreamStatus();

    // Detect orphaned live stream (DJ navigated away while live, stream still marked live in Firestore)
    if (currentStream && currentUser && currentStream.djId === currentUser.uid) {
      var headerBack = document.getElementById('headerBackToLive');
      var headerEnd = document.getElementById('headerEndStreamBtn');
      var statusText = document.getElementById('mobileStatusText');
