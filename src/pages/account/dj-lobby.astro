---
// src/pages/account/dj-lobby.astro
// DJ-only lobby with stream preview, private chat, streaming instructions, and takeover system
import '../../styles/dj-lobby.css';
import LiveChat from '../../components/live/LiveChat.astro';
export const prerender = false;

// Pusher config for client-side (PUBLIC_ prefixed vars are safe to expose)
const pusherConfig = {
  key: import.meta.env.PUBLIC_PUSHER_KEY || '',
  cluster: import.meta.env.PUBLIC_PUSHER_CLUSTER || 'eu'
};

// Firebase config for client-side
const firebaseConfig = {
  apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain: "freshwax-store.firebaseapp.com",
  projectId: "freshwax-store",
  storageBucket: "freshwax-store.firebasestorage.app",
  messagingSenderId: "675435782973",
  appId: "1:675435782973:web:e8459c2ec4a5f6d683db54"
};

// HLS URL for preview player - always use production stream URL
const hlsBaseUrl = 'https://stream.freshwax.co.uk';

const runtime = Astro.locals.runtime;
const nonce = Astro.locals.nonce || '';
const csrfToken = Astro.locals.csrfToken || '';
Astro.response.headers.set('Cache-Control', 'private, no-store, no-cache, must-revalidate, max-age=0');
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content={csrfToken} />
  <title>DJ Lobby - Fresh Wax</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://js.pusher.com" crossorigin />
  <link rel="preconnect" href="https://ws-eu.pusher.com" crossorigin />
  <link rel="preconnect" href="https://sockjs-eu.pusher.com" crossorigin />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link rel="preconnect" href="https://firestore.googleapis.com" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Configuration - must be set before scripts load -->
  <script define:vars={{ pusherConfig, hlsBaseUrl, firebaseConfig }} nonce={nonce}>
    window.PUSHER_CONFIG = pusherConfig;
    window.HLS_BASE_URL = hlsBaseUrl;
    window.FIREBASE_CONFIG = firebaseConfig;
  </script>
  <!-- Email verification check (loaded early so FreshWax object exists) -->
  <script is:inline src="/email-verify-check.js" nonce={nonce}></script>
</head>
<body class="dj-lobby-page">
  <script is:inline src="/csrf-protect.js"></script>
  <!-- Auth Gate -->
  <div id="authGate" class="auth-gate">
    <div class="auth-content">
      <div class="loading-dots wave">
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
      </div>
      <p>Checking DJ access</p>
    </div>
  </div>
  
  <!-- Access Denied -->
  <div id="accessDenied" class="access-denied hidden">
    <div class="denied-content">
      <div class="denied-icon">🔒</div>
      <h1>DJ Access Only</h1>
      <p>This area is restricted to approved DJs.</p>
      <a href="/live/" class="back-btn">Back to Live</a>
    </div>
  </div>
  
  <!-- Not Eligible - Needs mix with likes -->
  <div id="notEligible" class="not-eligible hidden">
    <div class="not-eligible-content">
      <div class="not-eligible-icon">🎧</div>
      <h1>ALMOST <span class="red">THERE</span></h1>
      <p id="eligibilityMessage">You need to build your reputation before accessing the DJ Lobby.</p>
      
      <!-- Two-column layout: Requirements on left, Access options on right -->
      <div class="eligibility-layout">
        <!-- Left column: Requirements -->
        <div class="eligibility-left">
          <div class="eligibility-requirements">
            <h2>To Access DJ Lobby, You Need:</h2>
            <div class="requirement-list">
              <div id="reqMixes" class="requirement">
                <span class="req-icon">❌</span>
                <span class="req-text">At least 1 DJ mix uploaded</span>
              </div>
              <div id="reqLikes" class="requirement">
                <span class="req-icon">❌</span>
                <span class="req-text">At least 10 likes on one of your mixes</span>
              </div>
            </div>

            <div id="progressInfo" class="progress-info">
              <p>Your best mix: <span id="bestMixLikes">0</span>/10 likes</p>
              <div class="progress-bar">
                <div id="likesProgress" class="progress-fill" style="width: 0%"></div>
              </div>
            </div>
          </div>

          <div class="eligibility-actions">
            <a href="/upload-mix/" class="action-btn primary">Upload a Mix →</a>
            <a href="/dj-mixes/" class="action-btn secondary">View DJ Mixes</a>
            <a href="/live/" class="action-btn secondary">Back to Live</a>
          </div>
        </div>

        <!-- Right column: Access options -->
        <div class="eligibility-right">
          <!-- Bypass Request Section -->
          <div id="bypassRequestSection" class="bypass-request-section">
            <!-- Request Form State -->
            <div id="bypassRequestForm" class="bypass-form-card">
              <div class="bypass-header">
                <span class="bypass-icon">⚡</span>
                <div>
                  <h4>Need access now?</h4>
                  <p>Request bypass access - an admin will review and approve.</p>
                </div>
              </div>
              <div class="bypass-form-inner">
                <textarea id="bypassReason" placeholder="Why do you need immediate access? (optional)" rows="2" maxlength="200" aria-label="Reason for bypass request"></textarea>
                <button id="submitBypassRequest" class="bypass-request-btn">
                  🎫 Request Bypass Access
                </button>
              </div>
            </div>

            <!-- Pending State -->
            <div id="bypassPending" class="bypass-status-card pending hidden">
              <div class="status-header">
                <span class="status-icon">⏳</span>
                <div>
                  <h4>Request Pending</h4>
                  <p>Your bypass request has been submitted. You'll get access once an admin approves it.</p>
                </div>
              </div>
              <button id="cancelBypassRequest" class="cancel-bypass-btn">Cancel Request</button>
            </div>

            <!-- Approved State -->
            <div id="bypassApproved" class="bypass-status-card approved hidden">
              <div class="status-header">
                <span class="status-icon">✅</span>
                <div>
                  <h4>Bypass Approved!</h4>
                  <p>Your request has been approved. Click below to enter the lobby.</p>
                </div>
              </div>
              <button id="continueWithBypass" class="continue-bypass-btn">Enter DJ Lobby →</button>
            </div>

            <!-- Denied State -->
            <div id="bypassDenied" class="bypass-status-card denied hidden">
              <div class="status-header">
                <span class="status-icon">❌</span>
                <div>
                  <h4>Request Denied</h4>
                  <p id="bypassDenialReason">Your request was not approved at this time.</p>
                </div>
              </div>
              <button id="resubmitBypassRequest" class="resubmit-bypass-btn">Submit New Request</button>
            </div>
          </div>

          <!-- Quick Access Key Section -->
          <div id="quickAccessSection" class="quick-access-section">
            <div class="quick-access-card">
              <div class="quick-access-header">
                <span class="quick-access-icon">🔑</span>
                <div>
                  <h4>Have an access code?</h4>
                  <p>Enter a quick access code to gain instant DJ lobby access.</p>
                </div>
              </div>
              <div class="quick-access-form">
                <input type="text" id="quickAccessCodeInput" placeholder="Enter access code" maxlength="10" autocomplete="off" aria-label="Quick access code" />
                <button id="redeemAccessCodeBtn" class="redeem-code-btn">
                  <span class="btn-text">Redeem Code</span>
                  <span class="btn-spinner hidden">⏳</span>
                </button>
              </div>
              <p id="quickAccessError" class="quick-access-error hidden"></p>
              <p id="quickAccessSuccess" class="quick-access-success hidden"></p>
            </div>
          </div>
        </div>
      </div>

      <div class="eligibility-why">
        <h4>Why this requirement?</h4>
        <p>This helps ensure our livestreams feature genuine DJs who play jungle and drum & bass music. Upload a quality mix, get your fans to show some love, and you'll be in the lobby in no time! 🔊</p>
      </div>
    </div>
  </div>
  
  <!-- Main Lobby -->
  <div id="mainLobby" class="lobby-container hidden">
    <header class="lobby-header">
      <div class="header-left">
        <div class="user-info">
          <div class="header-avatar-container">
            <img id="headerAvatar" src="/place-holder.webp" alt="Your DJ avatar" class="header-avatar" width="48" height="48" loading="lazy" decoding="async" />
            <div id="headerAvatarLetter" class="header-avatar-letter hidden">?</div>
          </div>
          <span id="headerName" class="header-name">Loading...</span>
        </div>
      </div>
      <div class="header-center">
        <h1>DJ <span class="red">LOBBY</span></h1>
        <p>Private space for Fresh Wax DJs</p>
      </div>
      <div class="header-right">
        <div id="headerTimeRemaining" class="header-time-remaining hidden">
          <span id="headerTimeLeft" class="header-time-value">--:--</span>
          <span class="header-time-label">remaining</span>
        </div>
        <a href="/live/" class="back-link" id="headerBackToLive">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
            <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
          </svg>
          Back to Live
        </a>
        <button id="headerEndStreamBtn" class="header-end-stream-btn" style="display:none">End Stream</button>
        <button id="signOutBtn" class="sign-out-btn">Sign Out</button>
      </div>
    </header>

    <!-- Broadcast Method Chooser -->
    <div id="broadcastChooser" class="broadcast-chooser hidden">
      <h2>How are you broadcasting?</h2>
      <div class="chooser-grid">
        <button id="chooserPhone" class="chooser-btn chooser-phone" type="button">
          <span class="chooser-icon">&#128241;</span>
          <span class="chooser-label">Phone</span>
          <span class="chooser-subtitle">Camera + mic from this device</span>
        </button>
        <button id="chooserObs" class="chooser-btn chooser-obs" type="button">
          <span class="chooser-icon">&#128421;</span>
          <span class="chooser-label">OBS</span>
          <span class="chooser-subtitle">Stream via OBS Studio</span>
        </button>
        <button id="chooserButt" class="chooser-btn chooser-butt" type="button">
          <span class="chooser-icon">&#127911;</span>
          <span class="chooser-label">BUTT</span>
          <span class="chooser-subtitle">Audio-only via BUTT</span>
        </button>
        <button id="chooserRelay" class="chooser-btn chooser-relay" type="button">
          <span class="chooser-icon">&#128225;</span>
          <span class="chooser-label">Relay</span>
          <span class="chooser-subtitle">External audio source</span>
        </button>
      </div>
    </div>

    <!-- Mobile Broadcast Layout (visible <=768px only) -->
    <div class="mobile-broadcast-layout" id="mobileBroadcastLayout">
      <!-- Video: offline placeholder + camera preview + live overlay -->
      <div class="mobile-video-container">
        <div id="mobileOfflineState" class="mobile-offline-state">
          <div class="mobile-offline-brand"><span class="fresh">FRESH</span><span class="wax">WAX</span></div>
          <p class="mobile-offline-text">Offline</p>
        </div>
        <video id="mobilePreviewVideo" class="mobile-preview-video" autoplay muted playsinline aria-hidden="true"></video>
        <div id="mobileLiveOverlay" class="mobile-live-overlay" style="display:none">
          <div class="mobile-live-top">
            <div class="mobile-live-badge">
              <span class="mobile-live-dot"></span>
              LIVE
            </div>
            <span id="mobileLiveTimer" class="mobile-live-timer">00:00</span>
          </div>
          <!-- Mobile broadcast controls hidden for now -->
          <div class="mobile-live-controls" style="display:none">
            <button id="mobileMicBtn" class="mobile-control-btn" aria-label="Toggle microphone">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 14c1.66 0 2.99-1.34 2.99-3L15 5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z"/></svg>
            </button>
            <button id="mobileCameraBtn" class="mobile-control-btn" aria-label="Toggle camera">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"/></svg>
            </button>
            <button id="mobileFlipBtn" class="mobile-control-btn" aria-label="Flip camera">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M9 12c0 1.66 1.34 3 3 3s3-1.34 3-3-1.34-3-3-3-3 1.34-3 3zm13-2V7c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2v-3l-2-2zm-2 6H4V7h16v9z"/></svg>
            </button>
          </div>
          <div id="mobileAudioMeter" class="mobile-audio-meter">
            <div class="mobile-meter-bar"></div>
            <div class="mobile-meter-bar"></div>
            <div class="mobile-meter-bar"></div>
            <div class="mobile-meter-bar"></div>
            <div class="mobile-meter-bar"></div>
          </div>
        </div>
      </div>

      <!-- Buttons: I'm Ready -> Go Live -> End Stream -->
      <div class="mobile-actions">
        <button id="mobileReadyBtn" class="mobile-ready-btn">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>
          <span id="mobileReadyBtnText">I'm Ready</span>
        </button>
        <button id="mobileGoLiveBtn" class="mobile-golive-btn" style="display:none">
          <span class="mobile-golive-dot"></span>
          <span id="mobileGoLiveBtnText">GO LIVE</span>
        </button>
        <p id="mobileStatusText" class="mobile-status-text"></p>
      </div>

      <!-- Chat container (chat DOM node moved here via JS) -->
      <div id="mobileChatContainer" class="mobile-chat-container"></div>

      <!-- Toggle to OBS/Advanced mode -->
      <div class="broadcast-mode-toggle">
        <button id="switchToObsMode" type="button">Switch to OBS / Advanced Mode</button>
      </div>
      <div class="change-method-link">
        <button id="changeMethodMobile" type="button">Change broadcast method</button>
      </div>
    </div>

    <div class="lobby-layout">
      <!-- Far Left Column: Stream Key -->
      <div class="key-column">
        <!-- Stream Control Card -->
        <div class="stream-control-card">
          <button id="setReadyBtn" class="go-live-btn glow">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
              <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
            </svg>
            <span id="readyBtnText">I'm Ready!</span>
          </button>
          <!-- GO LIVE button - shown after I'm Ready is pressed -->
          <button id="goLiveBtn" class="go-live-btn go-live-final hidden">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
              <circle cx="12" cy="12" r="8" fill="#dc2626"/>
              <circle cx="12" cy="12" r="4" fill="#fff"/>
            </svg>
            <span id="goLiveBtnText">GO LIVE!</span>
          </button>
          <div class="control-divider"></div>
          <button id="lobbyEndStreamBtn" class="lobby-end-stream-btn disabled" disabled>
            <span class="end-icon">⏹</span>
            <span class="end-text">End Stream</span>
          </button>
          <p id="endStreamStatus" class="end-stream-status">No active stream</p>
        </div>
        
        <!-- Takeover Section -->
        <div class="takeover-section" id="takeoverBox">
          <div class="section-header">
            <h3>🔄 Stream Takeover</h3>
          </div>
          
          <div id="takeoverRequest" class="takeover-content hidden">
            <p>Request to take over from <strong id="takeoverFromName">DJ</strong></p>
            <button id="requestTakeoverBtn" class="takeover-btn">Request Takeover</button>
            <p id="takeoverPending" class="takeover-pending hidden">⏳ Waiting for response... <span id="takeoverCountdown"></span></p>
            <p id="takeoverAttemptsLeft" class="takeover-attempts">3 requests remaining this session</p>
            <p id="takeoverLimitReached" class="takeover-limit hidden">⚠️ No requests remaining this session</p>
          </div>
          
          <div id="incomingTakeover" class="incoming-takeover hidden">
            <div class="incoming-badge">⚡ TAKEOVER REQUEST</div>
            <div class="incoming-dj">
              <img id="incomingDjAvatar" src="/place-holder.webp" alt="Incoming DJ avatar" width="48" height="48" loading="lazy" decoding="async" />
              <div>
                <strong id="incomingDjName">DJ Name</strong>
                <span>wants to take over</span>
              </div>
            </div>
            <div class="incoming-actions">
              <button id="acceptTakeoverBtn" class="accept-btn">✓ Accept</button>
              <button id="declineTakeoverBtn" class="decline-btn">✕ Decline</button>
            </div>
          </div>
          
          <div id="takeoverApproved" class="takeover-approved hidden">
            <div class="approved-badge">✓ APPROVED</div>
            <p>Copy these into OBS:</p>
            <div class="takeover-creds">
              <div class="cred-row">
                <label>Server</label>
                <div class="cred-value">
                  <code id="takeoverServerUrl">-</code>
                  <button class="copy-btn" data-copy="takeoverServerUrl">Copy</button>
                </div>
              </div>
              <div class="cred-row">
                <label>Key</label>
                <div class="cred-value">
                  <code id="takeoverStreamKey">-</code>
                  <button class="copy-btn" data-copy="takeoverStreamKey">Copy</button>
                </div>
              </div>
            </div>
          </div>
          
          <div id="noStreamTakeover" class="no-stream-msg">
            <p>No stream to takeover</p>
          </div>
        </div>

        <!-- Streaming Setup Link -->
        <div class="setup-link-section">
          <a href="/account/streaming-setup/" class="setup-link-btn">
            <span class="setup-text">Streaming Setup</span>
            <span class="setup-arrow">→</span>
          </a>
        </div>


        <!-- DJs Online Box -->
        <div class="djs-online-box">
          <div class="box-header">
            <h3>🎧 DJs in Lobby <span class="online-count-inline" id="onlineDjCount">0</span></h3>
            <button id="openDmBtn" class="dm-btn">DM</button>
          </div>
          <div id="djsList" class="djs-list">
            <p class="empty-state">No DJs online yet</p>
          </div>
        </div>
      </div>
      
      <!-- Middle Column: Preview Only -->
      <div class="main-column">
        <!-- Split Video Players -->
        <div class="preview-section">
          <div class="split-players three-col">
            <!-- Left: Your Preview (DJ's own test stream) -->
            <div class="player-panel obs-panel">
              <div class="panel-header">
                <span class="panel-title">Your Preview</span>
                <div class="connection-indicators">
                  <div class="indicator" id="serverIndicator" title="Server Connection">
                    <span class="indicator-dot disconnected" id="serverDot"></span>
                    <span class="indicator-label">Server</span>
                  </div>
                  <div class="indicator source-toggle active" id="obsIndicator" title="OBS Stream - Click to select">
                    <span class="indicator-dot disconnected" id="obsDot"></span>
                    <span class="indicator-label">OBS</span>
                  </div>
                  <div class="indicator source-toggle" id="buttIndicator" title="BUTT Audio Stream - Click to select">
                    <span class="indicator-dot disconnected" id="buttDot"></span>
                    <span class="indicator-label">BUTT</span>
                  </div>
                  <div class="indicator source-toggle" id="relayIndicator" title="Relay from external station - Click to select">
                    <span class="indicator-dot disconnected" id="relayDot"></span>
                    <span class="indicator-label">Relay</span>
                  </div>
                </div>
              </div>
              <div class="player-wrapper" id="obsPlayerWrapper">
                <div id="obsOfflineState" class="offline-state">
                  <div class="preview-branding"><span class="fresh">FRESH</span><span class="wax">WAX</span></div>
                </div>
                <div id="obsVideoPreview" class="video-preview hidden">
                  <video id="obsVideo" playsinline autoplay muted crossorigin="anonymous">
                  <track kind="captions" label="Captions unavailable for live content" />
                </video>
                </div>
                <!-- BUTT Audio-Only Placeholder -->
                <div id="buttAudioPreview" class="butt-audio-preview hidden">
                  <div class="audio-only-placeholder">
                    <video class="stream-bg-video" autoplay muted playsinline preload="none" data-sources="https://pub-5c0458d0721c4946884a203f2ca66ee0.r2.dev/videos/stream-bg.webm,https://pub-5c0458d0721c4946884a203f2ca66ee0.r2.dev/videos/stream-bg-2.webm" data-src-index="0">
                      <source src="https://pub-5c0458d0721c4946884a203f2ca66ee0.r2.dev/videos/stream-bg.webm" type="video/webm" />
                    </video>
                    <div class="audio-placeholder-branding">
                      <span class="brand-fresh">FRESH</span><span class="brand-wax">WAX</span>
                    </div>
                  </div>
                </div>
                <!-- Relay Preview Placeholder -->
                <div id="relayPreview" class="butt-audio-preview hidden">
                  <div class="audio-only-placeholder">
                    <video class="stream-bg-video" autoplay muted playsinline preload="none" data-sources="https://pub-5c0458d0721c4946884a203f2ca66ee0.r2.dev/videos/stream-bg.webm,https://pub-5c0458d0721c4946884a203f2ca66ee0.r2.dev/videos/stream-bg-2.webm" data-src-index="0">
                      <source src="https://pub-5c0458d0721c4946884a203f2ca66ee0.r2.dev/videos/stream-bg.webm" type="video/webm" />
                    </video>
                    <div class="audio-placeholder-branding">
                      <span class="brand-fresh">FRESH</span><span class="brand-wax">WAX</span>
                    </div>
                  </div>
                </div>
                <!-- Hidden audio element for Icecast/BUTT stream -->
                <audio id="icecastAudio" crossorigin="anonymous" preload="none" style="display:none;"></audio>
                <!-- Hidden audio element for Relay stream preview -->
                <audio id="relayAudio" crossorigin="anonymous" preload="none" style="display:none;"></audio>
              </div>
            </div>

            <!-- Center: Realtime Stats -->
            <div class="center-stats-panel">
              <div class="center-stat">
                <span class="center-stat-value" id="centerViewers">0</span>
                <span class="center-stat-label">Viewers</span>
              </div>
              <div class="center-stat">
                <span class="center-stat-value" id="centerBitrate">--</span>
                <span class="center-stat-label">Bitrate</span>
              </div>
              <div class="center-stat">
                <span class="center-stat-value" id="centerResolution">--</span>
                <span class="center-stat-label">Resolution</span>
              </div>
              <div class="center-stat">
                <span class="center-stat-value" id="centerFps">--</span>
                <span class="center-stat-label">FPS</span>
              </div>
