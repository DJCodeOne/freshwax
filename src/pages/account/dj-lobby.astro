    // Spawn Key button - Generate stream key without going live
    document.getElementById('spawnKeyBtn')?.addEventListener('click', async () => {
      if (!currentUser) return;

      const btn = document.getElementById('spawnKeyBtn');
      const streamKeyEl = document.getElementById('myStreamKey');
      const icecastPasswordEl = document.getElementById('icecastPassword');

      // If already have a key displayed, don't spawn again
