  async function loadStreamStatus(skipCache = false) {
    try {
      // Add cache buster to prevent stale cached responses
      // Use fresh=1 to bypass server-side cache when called from Pusher events
      const cacheBuster = Date.now();
      const freshParam = skipCache ? '&fresh=1' : '';
      const response = await fetch(`/api/livestream/status/?_t=${cacheBuster}${freshParam}`);
      const result = await response.json();
      
      const statusDot = document.querySelector('.status-dot');
      const statusText = document.getElementById('statusText');
      const offlineState = document.getElementById('offlineState');
      const videoPreview = document.getElementById('videoPreview');
      const audioPreview = document.getElementById('audioPreview');
      const timeRemaining = document.getElementById('timeRemaining');
      const takeoverRequest = document.getElementById('takeoverRequest');
      const noStreamTakeover = document.getElementById('noStreamTakeover');

      if (result.success && result.isLive && result.primaryStream) {
        console.debug('[Stream DEBUG] loadStreamStatus found LIVE stream:', result.primaryStream.djName);
        currentStream = result.primaryStream;

        // Set global stream ID for LiveChat component
        const streamId = currentStream.slotId || currentStream.id || currentStream.streamId;
        const previousStreamId = window.currentStreamId;
        window.currentStreamId = streamId;

        // Initialize livestream chat if not done, or switch from playlist-global to actual stream
        // Skip stream IDs that were previously rejected as not-live (stale D1/cache data)
        if (streamId && !staleStreamIds.has(streamId) && (!window.livestreamChatInitialized || previousStreamId !== streamId)) {
          // Cleanup previous channel first (e.g., playlist-global)
          if (livestreamChatChannel) {
            livestreamChatChannel.unbind_all();
            window.livestreamPusher?.unsubscribe(livestreamChatChannel.name);
            livestreamChatChannel = null;
          }
          window.livestreamChatInitialized = false;
          initLivestreamChat(streamId);
        } else if (staleStreamIds.has(streamId)) {
          console.debug('[LivestreamChat] Skipping stale stream ID:', streamId);
          // Keep using current channel (playlist-global)
          window.currentStreamId = previousStreamId;
        }

        statusDot?.classList.remove('offline');
        statusDot?.classList.add('live');
        document.querySelector('.live-panel')?.classList.add('streaming');
        if (statusText) statusText.textContent = `${currentStream.djName} is LIVE`;

        // Show relay indicators and set to connecting when stream goes live
        showRelayIndicators(true);
        updateYoutubeIndicator('connecting');
        updateTwitchIndicator('connecting');
        // Check relay health after a short delay (give relays time to start)
        setTimeout(checkRelayHealth, 5000);

        offlineState?.classList.add('hidden');
        timeRemaining?.classList.remove('hidden');

        // Check if this is a new DJ (for seamless transitions)
        const isNewDj = previousStreamDjId && previousStreamDjId !== currentStream.djId;
        const isSameDj = previousStreamDjId === currentStream.djId;

        // If new DJ started, trigger immediate fade in (seamless transition)
        if (isNewDj) {
          log('[Stream] New DJ detected, triggering seamless transition');
          triggerStreamFadeIn();
        }

        // Update previous DJ tracker
        previousStreamDjId = currentStream.djId;

        // Parse stream times
        if (currentStream.startedAt) {
          streamStartTime = new Date(currentStream.startedAt);
          videoPlayer.setStreamStartTime(streamStartTime);
        }

        // Determine if this DJ has a booked slot
        const hasBookedSlot = currentStream.endTime || currentStream.duration;

        let baseEndTime;
        if (currentStream.endTime) {
          baseEndTime = new Date(currentStream.endTime);
        } else if (currentStream.duration) {
          baseEndTime = new Date(streamStartTime.getTime() + currentStream.duration * 60000);
        } else {
          // Default to end of current hour if no scheduled end time
          const now = new Date();
          baseEndTime = new Date(now);
          baseEndTime.setMinutes(0, 0, 0);
          baseEndTime.setHours(baseEndTime.getHours() + 1);
        }

        // Calculate max stream end time (accounts for events, consecutive slots, subscription tier)
        // This determines how long the DJ can stream based on:
        // - Event bookings (2+ hours): Full duration, no mid-session breaks
        // - Consecutive slots: Extended to end of all consecutive slots
        // - Unbooked (Free tier): Current hour + next hour (max 2 hrs)
        // - Unbooked (Pro tier): Current hour + next 2 hours (max 3 hrs)
        streamEndTime = calculateMaxStreamEndTime(currentStream.djId, streamStartTime || new Date(), hasBookedSlot);

        // If calculateMaxStreamEndTime returned less than baseEndTime, use baseEndTime
        if (baseEndTime > streamEndTime) {
          streamEndTime = baseEndTime;
        }
        videoPlayer.setStreamEndTime(streamEndTime);

        const eventMode = isInEventMode();
        log(`[Stream] End time: ${streamEndTime.toLocaleTimeString()} | Event mode: ${eventMode} | Base: ${baseEndTime.toLocaleTimeString()}`);

        const currentDjName = document.getElementById('currentDjName');
        const currentStreamTitle = document.getElementById('currentStreamTitle');
        const currentDjAvatar = document.getElementById('currentDjAvatar');
        if (currentDjName) currentDjName.textContent = currentStream.djName || 'DJ';
        if (currentStreamTitle) currentStreamTitle.textContent = currentStream.title || 'Live Stream';
        if (currentStream.djAvatar && currentDjAvatar) {
          currentDjAvatar.src = currentStream.djAvatar;
        }

        // Check if this is an audio-only stream (BUTT/Icecast) or video (HLS/Red5)
        // Important: If hlsUrl exists, always treat as video stream (even for BUTT placeholder mode)
        // The placeholder mode generates an HLS video stream via FFmpeg
        // For relay mode, always show audio placeholder on both sides (no HLS video)
        const hasHlsUrl = !!currentStream.hlsUrl && !currentStream.isRelay;
        const isAudioStream = !hasHlsUrl && (
                             currentStream.isRelay ||
                             currentStream.streamType === 'audio' ||
                             currentStream.broadcastMode === 'butt' ||
                             currentStream.audioStreamUrl?.includes(':8000') ||
                             currentStream.audioStreamUrl);

        log('[Stream] Detection:', {
          streamType: currentStream.streamType,
          broadcastMode: currentStream.broadcastMode,
          hlsUrl: currentStream.hlsUrl,
          audioStreamUrl: currentStream.audioStreamUrl,
          hasHlsUrl,
          isAudioStream
        });

        if (hasHlsUrl) {
          // Video stream (HLS/Red5)
          videoPreview?.classList.remove('hidden');
          audioPreview?.classList.add('hidden');
          // Setup HLS video player (includes auto-play)
          setupHlsPlayer(currentStream);
        } else {
          // Audio-only stream (BUTT/Icecast/Relay)
          log('[Stream] Showing audio placeholder for audio-only stream');
          console.debug('[Stream DEBUG] Before: offlineState hidden?', offlineState?.classList.contains('hidden'), 'audioPreview hidden?', audioPreview?.classList.contains('hidden'));
          audioPreview?.classList.remove('hidden');
          videoPreview?.classList.add('hidden');
          offlineState?.classList.add('hidden'); // Ensure offline state is hidden
          // Remove any fade overlay classes (they cover content with z-index: 5)
          // For audio streams, just remove the classes directly without fade-in animation
          const playerWrapper = document.querySelector('.preview-player');
          if (playerWrapper) {
            playerWrapper.classList.remove('fading-out', 'faded-out', 'fading-in');
            console.debug('[Stream DEBUG] Removed fade classes from playerWrapper');
          }
          console.debug('[Stream DEBUG] After: offlineState hidden?', offlineState?.classList.contains('hidden'), 'audioPreview hidden?', audioPreview?.classList.contains('hidden'));
          // Debug: Check actual element dimensions and computed styles
          setTimeout(() => {
            const ap = document.getElementById('audioPreview');
            const pw = document.getElementById('previewPlayer');
            if (ap && pw) {
              const apRect = ap.getBoundingClientRect();
              const pwRect = pw.getBoundingClientRect();
              const apStyle = getComputedStyle(ap);
              const pwClasses = pw.className;
              console.debug('[Stream DEBUG] audioPreview dimensions:', { width: apRect.width, height: apRect.height, top: apRect.top, left: apRect.left });
              console.debug('[Stream DEBUG] previewPlayer dimensions:', { width: pwRect.width, height: pwRect.height });
              console.debug('[Stream DEBUG] previewPlayer classes:', pwClasses);
              console.debug('[Stream DEBUG] audioPreview computed style:', { display: apStyle.display, visibility: apStyle.visibility, opacity: apStyle.opacity, zIndex: apStyle.zIndex });
            }
          }, 200);
          cleanupHlsPlayer();

          // Populate lobby audio placeholder with DJ info
          const lobbyLiveDjName = document.getElementById('lobbyLiveDjName');
          const lobbyLiveShowTitle = document.getElementById('lobbyLiveShowTitle');
          const lobbyLiveBadgeText = document.getElementById('lobbyLiveBadgeText');
          const liveVinylAvatar = document.getElementById('liveVinylAvatar');
          const liveVinylAvatar2 = document.getElementById('liveVinylAvatar2');

          // For relay streams, show now playing track (stored in title) in red; otherwise show DJ name
          if (currentStream.isRelay && currentStream.title) {
            if (lobbyLiveDjName) lobbyLiveDjName.innerHTML = `<span style="color: #ef4444;">${escapeHtml(currentStream.title)}</span>`;
          } else {
            if (lobbyLiveDjName) lobbyLiveDjName.textContent = currentStream.djName || 'DJ';
          }

          // Update show title and badge for relay streams
          if (currentStream.isRelay && currentStream.relaySource?.stationName) {
            if (lobbyLiveShowTitle) lobbyLiveShowTitle.innerHTML = `Relayed from <span class="brand-fresh">${escapeHtml(currentStream.relaySource.stationName)}</span>`;
            if (lobbyLiveBadgeText) lobbyLiveBadgeText.textContent = 'RELAY';
          } else {
            if (lobbyLiveShowTitle) lobbyLiveShowTitle.innerHTML = 'Live on <span class="brand-fresh">Fresh</span> <span class="brand-wax">Wax</span>';
            if (lobbyLiveBadgeText) lobbyLiveBadgeText.textContent = 'AUDIO ONLY';
          }

          // Set vinyl label images - use placeholder for relay, DJ avatar for other streams
          const vinylImage = currentStream.isRelay ? '/place-holder.webp' : (currentStream.djAvatar || '/place-holder.webp');
          if (liveVinylAvatar) liveVinylAvatar.src = vinylImage;
          if (liveVinylAvatar2) liveVinylAvatar2.src = vinylImage;

          // Setup audio stream with auto-play
          const audioEl = document.getElementById('audioElement');
          const audioUrl = currentStream.audioStreamUrl || currentStream.streamUrl;
          console.debug('[Stream DEBUG] Audio setup - audioStreamUrl:', currentStream.audioStreamUrl, 'streamUrl:', currentStream.streamUrl, 'using:', audioUrl);
          if (audioEl && audioUrl) {
            log('[Audio] Setting up audio stream:', audioUrl);
            audioEl.src = audioUrl;
            audioEl.muted = false; // Ensure not muted
            audioEl.volume = 1;    // Ensure full volume
            audioEl.play().then(() => {
              console.debug('[Stream DEBUG] Audio play() succeeded, paused:', audioEl.paused, 'muted:', audioEl.muted, 'volume:', audioEl.volume);
              // Check state again after 2 seconds to catch anything that might mute/stop it
              setTimeout(() => {
                console.debug('[Stream DEBUG] Audio state after 2s - paused:', audioEl.paused, 'muted:', audioEl.muted, 'volume:', audioEl.volume, 'src:', audioEl.src);
              }, 2000);
            }).catch(e => {
              log('[Audio] Auto-play blocked, user interaction required:', e.message);
              console.debug('[Stream DEBUG] Audio play() failed:', e.message);
            });
          } else {
            console.debug('[Stream DEBUG] Audio NOT setup - audioEl:', !!audioEl, 'audioUrl:', audioUrl);
          }
        }

        // Handle takeover UI and End Stream button based on who is streaming
        if (currentStream.djId === currentUser?.uid) {
          takeoverRequest?.classList.add('hidden');
          noStreamTakeover?.classList.add('hidden');
          // Enable End Stream button for current streamer
          updateEndStreamButton(true, true);

          // DJ is viewing their own live stream - set streaming flag
          userIsStreaming = true;

          // Switch audio toggle to 'live' so DJ can monitor their output stream
          // This ensures they hear what viewers are hearing, not the preview
          // Directly unmute the live audio element since toggle variables may not be ready yet
          const liveAudioEl = document.getElementById('audioElement');
          if (liveAudioEl) {
            liveAudioEl.muted = false;
            console.debug('[Stream] Unmuted live audioElement for DJ monitoring');
          }
          // Also try to update the toggle UI when it's ready
          setTimeout(() => {
            if (typeof activeAudioSource !== 'undefined' && typeof updateAudioSourceUI === 'function') {
              activeAudioSource = 'live';
              updateAudioSourceUI();
              console.debug('[Stream] Switched audio toggle to LIVE for monitoring');
            }
          }, 500);

          // If this is the DJ's own relay stream and relay audio isn't playing, restart it
          // This handles the case where DJ logs out and back in while live
          if (currentStream.isRelay && currentStream.audioStreamUrl) {
            const relayAudio = document.getElementById('relayAudio');
            if (relayAudio && relayAudio.paused) {
              console.debug('[Stream] Restarting relay audio preview for own live stream');

              // Set selectedRelaySource from the current stream's relay info
              // This ensures the relay preview shows the correct station
              if (currentStream.relaySource) {
                selectedRelaySource = {
                  id: currentStream.relaySource.url?.split('/').pop() || 'unknown',
                  url: currentStream.relaySource.url || currentStream.audioStreamUrl,
                  name: currentStream.relaySource.stationName || 'External Source',
                  nowPlaying: currentStream.title || '',
                  listeners: 0
                };
                console.debug('[Stream] Set selectedRelaySource from live stream:', selectedRelaySource.name);
              }

              // Switch to relay mode - this handles all UI, tabs, and indicators
              setPreviewSource('relay');
              console.debug('[Stream] Switched to relay mode');

              relayAudio.src = currentStream.audioStreamUrl;
              relayAudio.play().then(() => {
                console.debug('[Stream] Relay audio restarted successfully');
                // Set up icecast analysers if not already done
                if (!icecastAudioContext) {
                  setupIcecastAnalysers(relayAudio);
                }
                // Mute relay audio since we're already live (use GainNode if available)
                if (icecastGainNode) {
                  icecastGainNode.gain.value = 0;
                } else {
                  relayAudio.volume = 0;
                }
                // Start LED meter animations now that analysers are set up
                console.debug('[Stream] Starting LED meters for relay reconnect');
                // Start left LED strip (preview meters)
                if (window.startPreviewMeterAnimation) {
                  window.startPreviewMeterAnimation();
                }
                // Start right LED strip (live meters)
                if (!liveMeterAnimationId && typeof animateLiveMeters === 'function') {
                  animateLiveMeters();
                }
                // Also restart broadcast meters with analysers now available
                if (!broadcastMeterAnimationId) {
                  initBroadcastMeters();
                }
              }).catch(e => {
                console.warn('[Stream] Could not restart relay audio:', e.message);
              });
            }
          }
        } else {
          takeoverRequest?.classList.remove('hidden');
          noStreamTakeover?.classList.add('hidden');
          const takeoverFromName = document.getElementById('takeoverFromName');
          if (takeoverFromName) takeoverFromName.textContent = currentStream.djName || 'current DJ';
          // Disable End Stream button - not your stream (unless admin)
          updateEndStreamButton(true, false);
        }

        // Hide Go Live setup section when someone is streaming (gives more space to video)
        document.getElementById('streamKeySection')?.classList.add('hidden');
        // Hide Multi Streaming section when live
        document.getElementById('multiStreamSection')?.classList.add('hidden');
        // Show Broadcast Audio Panel when live
        document.getElementById('broadcastAudioPanel')?.classList.remove('hidden');
        initBroadcastMeters();
        // Start live LED meters for right side (only if analysers are ready)
        // For relay mode, analysers are set up async so this may not start here
        // but will be started in the relay restart callback
        if (!liveMeterAnimationId && typeof animateLiveMeters === 'function') {
          // Check if we have analysers available
          const hasAnalysers = (icecastAnalyserL && icecastAnalyserR) || (liveAnalyserL && liveAnalyserR);
          if (hasAnalysers) {
            animateLiveMeters();
            console.debug('[Stream] Started live LED meters (analysers ready)');
          } else {
            console.debug('[Stream] Deferred live LED meters (waiting for analysers)');
          }
        }
        // Expand video player to use the extra space
        document.querySelector('.preview-section')?.classList.add('expanded');
        // Disable Go Live button when someone is streaming
        const goLiveBtn = document.getElementById('setReadyBtn');
        if (goLiveBtn) {
          goLiveBtn.disabled = true;
          goLiveBtn.classList.add('disabled');
        }

        // Check for relay chat
        updateRelayChatSection(currentStream);

        // Update stream info panel with live data
        updateStreamInfoPanel(true, currentStream);
      } else {
        console.debug('[Stream DEBUG] loadStreamStatus returned NO STREAM - hiding player');
        console.debug('[Stream DEBUG] API result:', result);
        currentStream = null;
        streamStartTime = null;
        streamEndTime = null;
        videoPlayer.setStreamStartTime(null);
        videoPlayer.setStreamEndTime(null);

        // Cleanup livestream chat when stream ends
        cleanupLivestreamChat();

        statusDot?.classList.add('offline');
        statusDot?.classList.remove('live');
        document.querySelector('.live-panel')?.classList.remove('streaming');
        if (statusText) statusText.textContent = 'No one streaming';

        // Hide relay indicators when stream ends
        showRelayIndicators(false);

        offlineState?.classList.remove('hidden');
        videoPreview?.classList.add('hidden');
        audioPreview?.classList.add('hidden');
        timeRemaining?.classList.add('hidden');
        takeoverRequest?.classList.add('hidden');
        noStreamTakeover?.classList.remove('hidden');

        // Cleanup HLS player when stream ends
        cleanupHlsPlayer();

        const offlineDjName = document.getElementById('currentDjName');
        const offlineStreamTitle = document.getElementById('currentStreamTitle');
        const offlineDjAvatar = document.getElementById('currentDjAvatar');
        if (offlineDjName) offlineDjName.textContent = '-';
        if (offlineStreamTitle) offlineStreamTitle.textContent = 'No stream';
        if (offlineDjAvatar) offlineDjAvatar.src = '/place-holder.webp';

        // Disable End Stream button - no active stream
        updateEndStreamButton(false, false);

        // Only reset UI if user has NOT clicked "I'm Ready"
        // Once userIsStreaming is true, keep stream key hidden and audio panel visible
        if (userIsStreaming) {
          // User clicked "I'm Ready" - keep stream key hidden, audio panel visible
          document.getElementById('streamKeySection')?.classList.add('hidden');
          document.getElementById('broadcastAudioPanel')?.classList.remove('hidden');
          // Keep BUTT preview visible if in BUTT mode
          if (currentPreviewSource === 'butt') {
            document.getElementById('buttAudioPreview')?.classList.remove('hidden');
            document.getElementById('obsOfflineState')?.classList.add('hidden');
          }
        } else {
          // User hasn't clicked "I'm Ready" yet - show stream key setup
          document.getElementById('streamKeySection')?.classList.remove('hidden');
          document.getElementById('multiStreamSection')?.classList.remove('hidden');
          // Audio panel is persistent - don't hide it
          document.querySelector('.preview-section')?.classList.remove('expanded');
          // Enable Go Live button when no one is streaming
          const goLiveBtn = document.getElementById('setReadyBtn');
          if (goLiveBtn) {
            goLiveBtn.disabled = false;
            goLiveBtn.classList.remove('disabled');
          }
