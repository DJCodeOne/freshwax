    }

    await checkAndCleanupChat();
    await loadMySlot();
    
    // Initialize Pusher-based real-time features (replaces Firebase onSnapshot)
    // This handles: presence, chat, takeover, DMs
    await initDjLobbyPusher(currentUser, userInfo);
    
    // Setup UI event listeners
    setupEventListeners();

    // Initialize OBS/BUTT source toggle
    initSourceToggle();

    // Initialize broadcast mode toggle (Placeholder vs Video)
    initBroadcastModeToggle();

    // Start Icecast connection status check
    startIcecastCheck();

    // Load saved Twitch settings
    loadTwitchSettings();

    // Polling for non-realtime data (reduced frequency to minimize Firebase reads)
    lobbyStreamStatusInterval = setInterval(loadStreamStatus, 60000); // 60s instead of 10s - saves ~84% reads
    lobbyTimeRemainingInterval = setInterval(updateTimeRemaining, 500); // Update every 500ms — 2x/sec is smooth enough for countdown
    lobbyStreamKeyInterval = setInterval(checkStreamKeyAvailability, 60000); // 60s instead of 30s
    lobbyAllSlotsInterval = setInterval(loadAllSlots, 60000); // Refresh slots every minute for consecutive slot detection
  }
  
  // Page cleanup - called when leaving
  function setupPageCleanup() {
    // Full page navigation cleanup
    window.addEventListener('beforeunload', async () => {
      try {
        await cleanupPusher();
      } catch (e) {
        console.error('Cleanup error:', e);
      }
    });

    // View Transitions navigation cleanup (beforeunload does NOT fire for these)
    document.addEventListener('astro:before-swap', async () => {
      try {
        clearInterval(lobbyStreamStatusInterval);
        clearInterval(lobbyTimeRemainingInterval);
        clearInterval(lobbyStreamKeyInterval);
        clearInterval(lobbyAllSlotsInterval);
        if (typeof lobbyViewersInterval !== 'undefined') clearInterval(lobbyViewersInterval);
        lobbyStreamStatusInterval = null;
        lobbyTimeRemainingInterval = null;
        lobbyStreamKeyInterval = null;
        lobbyAllSlotsInterval = null;
        lobbyViewersInterval = null;

        if (icecastCheckInterval) clearInterval(icecastCheckInterval);
        if (obsPreviewCheckInterval) clearInterval(obsPreviewCheckInterval);
        if (healthInterval) clearInterval(healthInterval);
        if (infoPanelDurationInterval) clearInterval(infoPanelDurationInterval);
        if (peakHoldTimer) clearInterval(peakHoldTimer);
        if (initCheckInterval) clearInterval(initCheckInterval);
        if (bypassPollInterval) clearInterval(bypassPollInterval);
        if (takeoverTimeout) clearInterval(takeoverTimeout);
        icecastCheckInterval = null;
        obsPreviewCheckInterval = null;
        healthInterval = null;
        infoPanelDurationInterval = null;
        peakHoldTimer = null;
        initCheckInterval = null;
        bypassPollInterval = null;
        takeoverTimeout = null;

        if (lobbyAudioPreviewObserver) {
          lobbyAudioPreviewObserver.disconnect();
          lobbyAudioPreviewObserver = null;
        }

        await cleanupPusher();
      } catch (e) {
        console.error('View Transition cleanup error:', e);
      }
    });
  }

