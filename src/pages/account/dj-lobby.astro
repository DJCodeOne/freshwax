          countdownEl.textContent = 'Key ready - copy to OBS';
          countdownEl.classList.add('slot-now');
        }

        console.debug('[DJ Lobby] Spawned key:', mySlot.id);

      } catch (error) {
        console.error('[DJ Lobby] Spawn key error:', error);
        streamKeyEl.innerHTML = '<span class="key-error">Failed - try again</span>';
