        alert('You already have a stream key!');
        return;
      }

      btn.disabled = true;
      btn.textContent = '...';
      streamKeyEl.innerHTML = '<span class="key-generating"><span class="spawn-dots"><span class="dot"></span><span class="dot"></span><span class="dot"></span></span> Spawning</span>';

      // Wait 3 seconds for animation effect
      await new Promise(resolve => setTimeout(resolve, 3000));

      try {
        const token = await currentUser.getIdToken();

        // First, check if user has any existing bookings (mySlot might not be loaded yet)
        let existingSlotId = mySlot?.id;

        if (!existingSlotId) {
          // Fetch user's current bookings to check
          const checkResponse = await fetch(`/api/livestream/slots/?djId=${currentUser.uid}`);
          const checkResult = await checkResponse.json();

          if (checkResult.success && checkResult.slots?.length > 0) {
            // User has existing bookings - find an active one (scheduled or in_lobby)
            const activeSlot = checkResult.slots.find(s => ['scheduled', 'in_lobby'].includes(s.status));
            if (activeSlot) {
              existingSlotId = activeSlot.id;
              mySlot = activeSlot;
              scheduling.setMySlot(activeSlot);
            }
          }
        }

        if (existingSlotId) {
          // Have existing slot - fetch its stream key
          const keyResponse = await fetch('/api/livestream/slots/', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
              action: 'getStreamKey',
              slotId: existingSlotId,
              djId: currentUser.uid
            })
          });

          const keyResult = await keyResponse.json();
          if (keyResult.success && keyResult.streamKey) {
            if (mySlot) mySlot.streamKey = keyResult.streamKey;
            currentStreamKey = keyResult.streamKey;
            scheduling.setMySlot(mySlot);
            scheduling.setCurrentStreamKey(keyResult.streamKey);
          } else {
            throw new Error(keyResult.error || 'Failed to get stream key');
          }
        } else {
          // No existing slot - book a new one
          const now = new Date();
          now.setSeconds(0, 0);

          const bookResponse = await fetch('/api/livestream/slots/', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
              action: 'book',
              djId: currentUser.uid,
              djName: userInfo?.name || currentUser.displayName || 'DJ',
              djAvatar: userInfo?.avatar || currentUser.photoURL || '/place-holder.webp',
              startTime: now.toISOString(),
              duration: 60,
              title: 'Live Session',
              genre: '',
              description: ''
            })
          });

          const bookResult = await bookResponse.json();

          if (!bookResult.success) {
            throw new Error(bookResult.error || 'Failed to spawn key');
          }

          // Update mySlot with the new booking
          mySlot = bookResult.slot;
          currentStreamKey = mySlot.streamKey;
          scheduling.setMySlot(mySlot);
          scheduling.setCurrentStreamKey(currentStreamKey);
        }

        // Update displays using currentStreamKey (always set correctly)
        streamKeyEl.classList.remove('key-loading', 'key-unavailable');
        streamKeyEl.classList.add('key-reveal');
        streamKeyEl.textContent = '';
        const keySpan = document.createElement('span');
        keySpan.className = 'key-text';
        keySpan.textContent = currentStreamKey;
        streamKeyEl.appendChild(keySpan);

        if (icecastPasswordEl) {
          icecastPasswordEl.textContent = currentStreamKey;
          icecastPasswordEl.classList.remove('stream-key-placeholder');
