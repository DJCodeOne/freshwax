  var chatMovedToBroadcast = false;
  var lobbyContainer = document.getElementById('mainLobby');

  function moveChatToBroadcast() {
    if (chatMovedToBroadcast) return;
    var chatSection = document.querySelector('.chat-section');
    var broadcastContainer = document.getElementById('mobileChatContainer');
    if (chatSection && broadcastContainer) {
      broadcastContainer.appendChild(chatSection);
      chatMovedToBroadcast = true;
      // Move modals to body so they render outside display:none .lobby-layout
      var gifModal = document.getElementById('gifModal');
      var dmModal = document.getElementById('dmModal');
      if (gifModal) document.body.appendChild(gifModal);
      if (dmModal) document.body.appendChild(dmModal);
    }
  }

  function moveChatToDesktop() {
    if (!chatMovedToBroadcast) return;
    var chatSection = document.querySelector('.chat-section');
    var rightColumn = document.querySelector('.right-column');
    if (chatSection && rightColumn) {
      rightColumn.insertBefore(chatSection, rightColumn.firstChild);
