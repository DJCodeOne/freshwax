  // =============== INITIALIZATION MODAL ===============
  let initCheckInterval = null;

  function showInitModal() {
    const modal = document.getElementById('initModal');
    if (!modal) return;

    // Check if in relay mode
    const isRelayMode = currentStreamMode === 'relay';

    // Reset modal state
    const progressFill = document.getElementById('initProgressFill');
    const progressText = document.getElementById('initProgressText');
    const backBtn = document.getElementById('initBackBtn');
    const goLiveBtn = document.getElementById('initGoLiveBtn');
    const modalHeader = modal.querySelector('.init-modal-header h2');
    const modalSubtitle = modal.querySelector('.init-subtitle');

    if (progressFill) progressFill.style.width = '0%';
    if (progressText) progressText.textContent = 'Starting up...';
    if (backBtn) backBtn.disabled = true;
    if (goLiveBtn) goLiveBtn.disabled = true;

    // Update modal title for relay mode
    if (isRelayMode) {
      if (modalHeader) modalHeader.textContent = 'Relay Mode';
      if (modalSubtitle) modalSubtitle.textContent = `Connecting to ${selectedRelaySource?.name || 'external station'}...`;
    } else {
      if (modalHeader) modalHeader.textContent = 'Initialising Stream';
      if (modalSubtitle) modalSubtitle.textContent = 'Checking your connections...';
    }

    // Reset check items
    ['initCheckObs', 'initCheckButt', 'initCheckLevels'].forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.classList.remove('connected', 'disconnected', 'error', 'checking');
      }
    });

    // Update labels for relay mode
    if (isRelayMode) {
      document.querySelector('#initCheckObs .init-check-label').textContent = 'Relay Source';
      document.getElementById('initObsStatus').textContent = 'Checking station...';
      document.querySelector('#initCheckButt .init-check-label').textContent = 'Audio Stream';
      document.getElementById('initButtStatus').textContent = 'Waiting...';
      document.querySelector('#initCheckLevels .init-check-label').textContent = 'Ready to Relay';
      document.getElementById('initLevelsStatus').textContent = 'Waiting...';
    } else {
      document.querySelector('#initCheckObs .init-check-label').textContent = 'OBS / Video Stream';
      document.getElementById('initObsStatus').textContent = 'Checking...';
      document.querySelector('#initCheckButt .init-check-label').textContent = 'BUTT / Audio Stream';
      document.getElementById('initButtStatus').textContent = 'Checking...';
      document.querySelector('#initCheckLevels .init-check-label').textContent = 'Audio Levels';
      document.getElementById('initLevelsStatus').textContent = 'Waiting...';
    }

    // Show modal
    modal.classList.remove('hidden');

    if (isRelayMode) {
      // For relay mode, check if the relay source is online
      startRelayChecks();
    } else {
      // Refresh Icecast status immediately for accurate BUTT detection, then start checks
      checkIcecastStatus().then(() => {
        // Start checking connections after Icecast status is updated
        setTimeout(() => startConnectionChecks(), 300);
      });
    }
  }

  async function startRelayChecks() {
    const progressFill = document.getElementById('initProgressFill');
    const progressText = document.getElementById('initProgressText');
    const backBtn = document.getElementById('initBackBtn');
    const goLiveBtn = document.getElementById('initGoLiveBtn');

    // Check 1: Verify relay source is selected
    if (progressFill) progressFill.style.width = '30%';
    if (progressText) progressText.textContent = 'Checking relay source...';

    const obsCheck = document.getElementById('initCheckObs');
    obsCheck?.classList.add('checking');

    await new Promise(r => setTimeout(r, 500));

    if (!selectedRelaySource) {
      obsCheck?.classList.remove('checking');
      obsCheck?.classList.add('error');
      document.getElementById('initObsStatus').textContent = 'No station selected';
      if (backBtn) backBtn.disabled = false;
      return;
    }

    // Check if relay source is online via server-side API (avoids CORS issues)
    let isRelayLive = false;
    try {
      const response = await fetch(`/api/relay-status/?station=${selectedRelaySource.id}`, {
        signal: AbortSignal.timeout(8000)
      });
      if (response.ok) {
        const result = await response.json();
        isRelayLive = result.isLive || false;
        console.debug('[Relay] Live check:', selectedRelaySource.name, isRelayLive ? 'LIVE' : 'offline');
      }
    } catch (err) {
      console.warn('[Relay] Live check failed:', err instanceof Error ? err.message : String(err));
      // If check fails, assume it might be live (let user try)
      isRelayLive = true;
    }

    obsCheck?.classList.remove('checking');
    if (isRelayLive) {
      obsCheck?.classList.add('connected');
      document.getElementById('initObsStatus').textContent = `${selectedRelaySource.name} is LIVE`;
    } else {
      obsCheck?.classList.add('disconnected');
      document.getElementById('initObsStatus').textContent = `${selectedRelaySource.name} appears offline`;
    }

    // Check 2: Audio stream availability
    if (progressFill) progressFill.style.width = '60%';
    if (progressText) progressText.textContent = 'Verifying audio stream...';

    const buttCheck = document.getElementById('initCheckButt');
    buttCheck?.classList.add('checking');
    await new Promise(r => setTimeout(r, 500));

    buttCheck?.classList.remove('checking');
    if (isRelayLive) {
      buttCheck?.classList.add('connected');
      document.getElementById('initButtStatus').textContent = 'Stream URL verified';
    } else {
      buttCheck?.classList.add('disconnected');
      document.getElementById('initButtStatus').textContent = 'Stream may not be available';
    }

    // Check 3: Ready status
    if (progressFill) progressFill.style.width = '100%';
    if (progressText) progressText.textContent = isRelayLive ? 'Ready to go live!' : 'Warning: Source may be offline';

    const levelsCheck = document.getElementById('initCheckLevels');
    levelsCheck?.classList.add('checking');
    await new Promise(r => setTimeout(r, 300));

    levelsCheck?.classList.remove('checking');
    if (isRelayLive) {
      levelsCheck?.classList.add('connected');
      document.getElementById('initLevelsStatus').textContent = 'All checks passed!';
    } else {
      levelsCheck?.classList.add('disconnected');
      document.getElementById('initLevelsStatus').textContent = 'You can still try to go live';
    }

    // Enable buttons
    if (backBtn) backBtn.disabled = false;
    if (goLiveBtn) goLiveBtn.disabled = false;
  }

  function hideInitModal() {
    const modal = document.getElementById('initModal');
    if (modal) modal.classList.add('hidden');
    if (initCheckInterval) {
      clearInterval(initCheckInterval);
      initCheckInterval = null;
    }
  }

  function startConnectionChecks() {
    const progressFill = document.getElementById('initProgressFill');
    const progressText = document.getElementById('initProgressText');
    let progress = 10;

    // Animate progress bar
    if (progressFill) progressFill.style.width = '10%';
    if (progressText) progressText.textContent = 'Checking OBS connection...';

    // Check OBS (video preview)
    const obsCheck = document.getElementById('initCheckObs');
    obsCheck?.classList.add('checking');

    setTimeout(() => {
      progress = 40;
      if (progressFill) progressFill.style.width = '40%';

      // Check if OBS video preview is loaded
      const obsVideo = document.getElementById('obsVideo');
      const obsPreview = document.getElementById('obsVideoPreview');
      // Check if video element has a valid source and is ready (readyState >= 2 means has current data)
      const isObsConnected = obsPreview && !obsPreview.classList.contains('hidden') && obsVideo &&
        (obsVideo.readyState >= 2 || !obsVideo.paused || (obsVideo.srcObject && obsVideo.srcObject.active));

      obsCheck?.classList.remove('checking');
      if (isObsConnected) {
        obsCheck?.classList.add('connected');
        document.getElementById('initObsStatus').textContent = 'Connected - Video stream detected';
      } else {
        obsCheck?.classList.add('disconnected');
        document.getElementById('initObsStatus').textContent = 'Not detected - Start OBS when ready';
      }

      // Check BUTT (audio)
      if (progressText) progressText.textContent = 'Checking BUTT connection...';
      const buttCheck = document.getElementById('initCheckButt');
      buttCheck?.classList.add('checking');

      setTimeout(() => {
        progress = 70;
        if (progressFill) progressFill.style.width = '70%';

        // Check if BUTT/Icecast is streaming (either actively connected or stream detected on server)
        const isButtConnected = icecastConnected || icecastStreamConnected || (currentPreviewSource === 'butt');

        buttCheck?.classList.remove('checking');
        if (isButtConnected) {
          buttCheck?.classList.add('connected');
          document.getElementById('initButtStatus').textContent = 'Connected - Audio stream detected';
        } else {
          buttCheck?.classList.add('disconnected');
          document.getElementById('initButtStatus').textContent = 'Not detected - Optional for video streams';
        }

        // Check audio levels
        if (progressText) progressText.textContent = 'Checking audio levels...';
        const levelsCheck = document.getElementById('initCheckLevels');
        levelsCheck?.classList.add('checking');

        setTimeout(() => {
          progress = 100;
          if (progressFill) progressFill.style.width = '100%';

          // Check if we have audio signal
          const hasAudioSignal = (obsAnalyserL || icecastAnalyserL) ? true : false;

          levelsCheck?.classList.remove('checking');
          if (hasAudioSignal) {
            levelsCheck?.classList.add('connected');
            document.getElementById('initLevelsStatus').textContent = 'Audio meters active - Check your levels';
          } else {
            levelsCheck?.classList.add('disconnected');
            document.getElementById('initLevelsStatus').textContent = 'No audio signal yet';
          }

          // Complete - enable buttons
          if (progressText) progressText.textContent = 'Ready to go!';
          const backBtn = document.getElementById('initBackBtn');
          const goLiveBtn = document.getElementById('initGoLiveBtn');
          if (backBtn) backBtn.disabled = false;
          if (goLiveBtn) goLiveBtn.disabled = false;

          // Update tip based on status
          updateInitTip(isObsConnected, isButtConnected);

          // Start live status updates
          startLiveStatusUpdates();

        }, 800);
      }, 800);
    }, 1000);
  }

  function startLiveStatusUpdates() {
    // Continuously update connection status while modal is open
    initCheckInterval = setInterval(() => {
      const modal = document.getElementById('initModal');
      if (!modal || modal.classList.contains('hidden')) {
        clearInterval(initCheckInterval);
        initCheckInterval = null;
        return;
      }

      // Update OBS status
      const obsVideo = document.getElementById('obsVideo');
      const obsPreview = document.getElementById('obsVideoPreview');
      const isObsConnected = obsPreview && !obsPreview.classList.contains('hidden') && obsVideo &&
        (obsVideo.readyState >= 2 || !obsVideo.paused || (obsVideo.srcObject && obsVideo.srcObject.active));
      const obsCheck = document.getElementById('initCheckObs');

      obsCheck?.classList.remove('connected', 'disconnected');
      if (isObsConnected) {
        obsCheck?.classList.add('connected');
        document.getElementById('initObsStatus').textContent = 'Connected - Video stream detected';
      } else {
        obsCheck?.classList.add('disconnected');
        document.getElementById('initObsStatus').textContent = 'Not detected - Start OBS when ready';
      }

      // Update BUTT status (check both active connection and server-detected stream)
      const isButtConnected = icecastConnected || icecastStreamConnected || (currentPreviewSource === 'butt');
      const buttCheck = document.getElementById('initCheckButt');

      buttCheck?.classList.remove('connected', 'disconnected');
      if (isButtConnected) {
        buttCheck?.classList.add('connected');
        document.getElementById('initButtStatus').textContent = 'Connected - Audio stream detected';
      } else {
        buttCheck?.classList.add('disconnected');
        document.getElementById('initButtStatus').textContent = 'Not detected - Optional for video streams';
      }

      // Update audio levels status
      const hasAudioSignal = (obsAnalyserL || icecastAnalyserL) ? true : false;
      const levelsCheck = document.getElementById('initCheckLevels');

      levelsCheck?.classList.remove('connected', 'disconnected');
      if (hasAudioSignal) {
        levelsCheck?.classList.add('connected');
        document.getElementById('initLevelsStatus').textContent = 'Audio meters active - Check your levels';
      } else {
        levelsCheck?.classList.add('disconnected');
        document.getElementById('initLevelsStatus').textContent = 'No audio signal yet';
      }

      updateInitTip(isObsConnected, isButtConnected);

    }, 2000);
  }

  function updateInitTip(obsConnected, buttConnected) {
    const tipsEl = document.getElementById('initTips');
    if (!tipsEl) return;

    let tipHtml = '';
    if (!obsConnected && !buttConnected) {
      tipHtml = `
        <div class="init-tip">
          <span class="tip-icon">💡</span>
          <span>Start OBS or BUTT to begin streaming</span>
        </div>
      `;
    } else if (obsConnected && !buttConnected) {
      tipHtml = `
        <div class="init-tip" style="background: rgba(34, 197, 94, 0.1); border-color: rgba(34, 197, 94, 0.3); color: #22c55e;">
          <span class="tip-icon">✓</span>
          <span>OBS connected! Check your audio levels before going live</span>
        </div>
      `;
    } else if (buttConnected) {
      tipHtml = `
        <div class="init-tip" style="background: rgba(34, 197, 94, 0.1); border-color: rgba(34, 197, 94, 0.3); color: #22c55e;">
          <span class="tip-icon">✓</span>
          <span>Audio stream connected! Ready when you are</span>
        </div>
      `;
    }
    tipsEl.innerHTML = tipHtml;
  }

