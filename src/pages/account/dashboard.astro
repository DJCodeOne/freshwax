---
// src/pages/account/dashboard.astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/dashboard.css';
import { FIREBASE_API_KEY } from '../../lib/constants';

export const prerender = false;
const firebaseConfig = {
  apiKey: FIREBASE_API_KEY,
  authDomain: "freshwax-store.firebaseapp.com",
  projectId: "freshwax-store",
  storageBucket: "freshwax-store.firebasestorage.app",
  messagingSenderId: "675435782973",
  appId: "1:675435782973:web:e8459c2ec4a5f6d683db54"
};
const nonce = Astro.locals.nonce || '';
Astro.response.headers.set('Cache-Control', 'private, no-store, no-cache, must-revalidate, max-age=0');
---

<Layout title="My Account" noindex={true}>
  <Header />
  
  <div class="dashboard-main">
    <!-- Loading Screen -->
    <div id="loadingScreen" class="loading-screen">
      <div class="spinner"></div>
      <p>Loading your account...</p>
    </div>

    <!-- Main Content (hidden until loaded) -->
    <div id="mainContent" class="hidden">
      
      <!-- Dashboard Header -->
      <div class="dashboard-header">
        <div class="dashboard-header-left">
          <div class="user-avatar" id="userAvatar">
            <span id="avatarInitial">C</span>
          </div>
          <div>
            <h1 id="welcomeName">Welcome back</h1>
            <p class="user-email" id="userEmail">Loading...</p>
          </div>
        </div>
        <div class="dashboard-header-right">
          <button type="button" id="goPlusHeaderBtn" class="pro-dashboard-btn" style="background: #374151; cursor: pointer;" title="Upgrade to Plus">
            <span class="pro-icon">👑</span>
            <span class="pro-text">Go Plus</span>
          </button>
          <a href="/artist/dashboard/" id="proDashboardBtn" class="pro-dashboard-btn disabled" title="Available for approved partners">
            <span class="pro-icon">⚡</span>
            <span class="pro-text">Pro Dashboard</span>
          </a>
          <button id="logoutBtn" class="logout-btn">Sign Out</button>
        </div>
      </div>

      <!-- Email Verification Banner (hidden by default) -->
      <div id="verifyBanner" class="verify-banner hidden">
        <div class="verify-banner-content">
          <span class="verify-banner-icon">⚠️</span>
          <span class="verify-banner-text">Please verify your email to unlock all features (purchasing, commenting, live chat).</span>
          <div class="verify-banner-actions">
            <a href="/verify-email/" class="verify-banner-btn verify-now">Verify Now</a>
            <button id="resendVerifyBtn" class="verify-banner-btn verify-resend">Resend Email</button>
          </div>
        </div>
        <button id="dismissVerifyBanner" class="verify-banner-dismiss" title="Dismiss" aria-label="Dismiss verification banner">&times;</button>
      </div>

      <!-- Tab Navigation -->
      <div class="tab-nav" role="tablist" aria-label="Dashboard sections">
        <button class="tab-btn active" data-tab="overview" role="tab" aria-selected="true" aria-controls="panel-overview" id="tab-overview">Overview</button>
        <button class="tab-btn" data-tab="orders" role="tab" aria-selected="false" aria-controls="panel-orders" id="tab-orders" tabindex="-1">Orders <span class="badge" id="ordersBadge" style="display: none;">0</span></button>
        <button class="tab-btn" data-tab="downloads" role="tab" aria-selected="false" aria-controls="panel-downloads" id="tab-downloads" tabindex="-1">Downloads</button>
        <button class="tab-btn" data-tab="credit" role="tab" aria-selected="false" aria-controls="panel-credit" id="tab-credit" tabindex="-1">Credit <span class="credit-badge" id="creditBadge" style="display: none;">£0</span></button>
        <button class="tab-btn" data-tab="wishlist" role="tab" aria-selected="false" aria-controls="panel-wishlist" id="tab-wishlist" tabindex="-1">Wishlist <span class="badge" id="wishlistBadge" style="display: none;">0</span></button>
        <button class="tab-btn" data-tab="following" role="tab" aria-selected="false" aria-controls="panel-following" id="tab-following" tabindex="-1">Following <span class="badge" id="followingBadge" style="display: none;">0</span></button>
        <button class="tab-btn" data-tab="mixes" role="tab" aria-selected="false" aria-controls="panel-mixes" id="tab-mixes" tabindex="-1">DJ Mixes</button>
        <button class="tab-btn" data-tab="profile" role="tab" aria-selected="false" aria-controls="panel-profile" id="tab-profile" tabindex="-1">Profile</button>
      </div>

      <!-- Tab Content -->
      <div class="tab-panels">
        
        <!-- Overview Tab -->
        <div class="tab-panel active" id="panel-overview" role="tabpanel" aria-labelledby="tab-overview" tabindex="0">
          <div class="stats-grid-full">
            <div class="stat-card">
              <div class="stat-value" id="statOrders">0</div>
              <div class="stat-label">Orders</div>
            </div>
            <div class="stat-card">
              <div class="stat-value" id="statVinyl">0</div>
              <div class="stat-label">Vinyl</div>
            </div>
            <div class="stat-card">
              <div class="stat-value" id="statDigitalEPs">0</div>
              <div class="stat-label">Digital</div>
            </div>
            <div class="stat-card">
              <div class="stat-value" id="statTracks">0</div>
              <div class="stat-label">Tracks</div>
            </div>
            <div class="stat-card">
              <div class="stat-value" id="statMerch">0</div>
              <div class="stat-label">Merch</div>
            </div>
            <div class="stat-card">
              <div class="stat-value" id="statSpent">£0</div>
              <div class="stat-label">Spent</div>
            </div>
          </div>

          <!-- Subscription Status Card -->
          <div class="subscription-card" id="subscriptionCard">
            <div class="subscription-header">
              <div class="subscription-tier" id="subscriptionTier">
                <span class="tier-badge free">Standard</span>
                <span class="tier-name">Account</span>
                <button class="tier-toggle-btn hidden" id="tierToggleBtn" title="Show Plus benefits" aria-label="Toggle details">▼</button>
              </div>
              <div class="subscription-status" id="subscriptionStatus"></div>
            </div>

            <div class="subscription-usage" id="subscriptionUsage">
              <div class="usage-item">
                <span class="usage-label">DJ Mix Uploads</span>
                <span class="usage-value"><span id="mixUploadsUsed">0</span> / <span id="mixUploadsLimit">1</span> this week</span>
              </div>
              <div class="usage-item">
                <span class="usage-label">Live Streaming</span>
                <span class="usage-value"><span id="streamTimeUsed">0</span> / <span id="streamTimeLimit">1</span> hours today</span>
              </div>
              <div class="usage-item plus-only hidden" id="playlistUsageItem">
                <span class="usage-label">Personal Playlist</span>
                <span class="usage-value"><span id="playlistTrackCount">0</span> / <span id="playlistTrackLimit">100</span> tracks</span>
              </div>
              <div class="usage-item plus-only hidden" id="skipUsageItem">
                <span class="usage-label">Daily Skips</span>
                <span class="usage-value"><span id="skipsUsed">0</span> / <span id="skipsLimit">3</span> used</span>
              </div>
            </div>

            <!-- Upgrade section removed - now in Go Plus modal -->
          </div>

          <div class="section">
            <div class="section-header">
              <h2>Recent Orders</h2>
              <button class="view-all-btn" data-tab="orders">View All →</button>
            </div>
            <div id="recentOrdersList" class="orders-list">
              <div class="empty-state">
                <p style="color: #fff; margin: 0 0 1.5rem 0;">No orders yet</p>
                <a href="/" style="display: inline-block; padding: 0.75rem 1.5rem; background: #dc2626; color: #fff; font-weight: 600; border-radius: 8px; text-decoration: none;">Start Shopping</a>
              </div>
            </div>
          </div>

          <div class="section">
            <div class="section-header">
              <h2>Recent Activity</h2>
            </div>
            <div id="activityFeed" class="activity-feed">
              <div class="empty-state">
                <p style="color: #a3a3a3; margin: 0;">Loading activity...</p>
              </div>
            </div>
            <button id="loadMoreActivity" class="view-all-btn" style="display:none;margin-top:0.75rem;">Load More</button>
          </div>
        </div>

        <!-- Orders Tab -->
        <div class="tab-panel" id="panel-orders" role="tabpanel" aria-labelledby="tab-orders" tabindex="-1">
          <h2>My Orders</h2>
          <div id="ordersContainer" class="orders-list">
            <div class="empty-state">
              <p>Loading orders...</p>
            </div>
          </div>
        </div>

        <!-- Downloads Tab -->
        <div class="tab-panel" id="panel-downloads" role="tabpanel" aria-labelledby="tab-downloads" tabindex="-1">
          <h2>My Downloads</h2>
          <div id="downloadsContainer" class="downloads-list">
            <div class="empty-state">
              <p>Loading downloads...</p>
            </div>
          </div>
        </div>

        <!-- Credit Tab -->
        <div class="tab-panel" id="panel-credit" role="tabpanel" aria-labelledby="tab-credit" tabindex="-1">
          <h2>Store Credit</h2>
          
          <!-- Balance Display -->
          <div class="credit-balance-card">
            <div class="balance-icon">💳</div>
            <div class="balance-info">
              <span class="balance-label">Available Balance</span>
              <span class="balance-amount" id="creditBalanceDisplay">£0.00</span>
            </div>
            <p class="balance-hint">Use your credit at checkout - it's automatically available!</p>
          </div>
          
          <!-- Redeem Gift Card -->
          <div class="redeem-section">
            <h3>Redeem Gift Card</h3>
            <p class="redeem-desc">Enter your gift card code to add credit to your account</p>
            
            <form id="dashboardRedeemForm" class="redeem-form">
              <div class="code-input-group">
                <input
                  type="text"
                  id="dashboardGiftCode"
                  placeholder="FWGC-XXXX-XXXX-XXXX"
                  maxlength="19"
                  autocomplete="off"
                  spellcheck="false"
                  aria-label="Gift card code"
                />
                <button type="submit" id="dashboardRedeemBtn" class="redeem-btn">
                  <span class="btn-text">Redeem</span>
                  <span class="btn-loading hidden">
                    <svg class="spinner" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" /></svg>
                  </span>
                </button>
              </div>
              <p id="dashboardRedeemError" class="redeem-error"></p>
              <p id="dashboardRedeemSuccess" class="redeem-success"></p>
            </form>
          </div>
          
          <!-- Transaction History -->
          <div class="transactions-section">
            <h3>Transaction History</h3>
            <div id="transactionsList" class="transactions-list">
              <div class="empty-state">
                <p style="color: #d1d5db;">No transactions yet</p>
              </div>
            </div>
          </div>
          
          <!-- Get More Credit -->
          <div class="get-credit-cta">
            <a href="/giftcards/" class="cta-link">
              <span class="cta-icon">🎁</span>
              <span>Learn more about Gift Cards →</span>
            </a>
          </div>
        </div>

        <!-- Wishlist Tab -->
        <div class="tab-panel" id="panel-wishlist" role="tabpanel" aria-labelledby="tab-wishlist" tabindex="-1">
          <div class="section-header-flex">
            <h2>My Wishlist</h2>
            <a href="/releases/" class="btn-secondary-sm">Browse Releases →</a>
          </div>
          <p class="wishlist-intro" style="color: #d1d5db; margin-bottom: 1.5rem; font-size: 0.875rem;">
            Releases you've saved for later. Click the bookmark icon on any release to add it here.
          </p>
          <div id="wishlistContainer" class="wishlist-grid">
            <div class="empty-state">
              <p style="color: #fff; margin: 0 0 1.5rem 0; font-size: 0.875rem;">Your wishlist is empty</p>
              <a href="/releases/" style="display: inline-block; padding: 0.7rem 1.4rem; background: #dc2626; color: #fff; font-weight: 600; font-size: 0.8rem; border-radius: 6px; text-decoration: none;">Browse Releases</a>
            </div>
          </div>
        </div>

        <!-- Following Tab -->
        <div class="tab-panel" id="panel-following" role="tabpanel" aria-labelledby="tab-following" tabindex="-1">
          <div class="section-header-flex">
            <h2>Artists I Follow</h2>
            <a href="/releases/" class="btn-secondary-sm">Discover Artists →</a>
          </div>
          <p class="following-intro" style="color: #d1d5db; margin-bottom: 1.5rem; font-size: 0.9375rem;">
            Stay updated with new releases from your favourite artists. Click the Follow button on any release to add artists here.
          </p>
          <div id="followingContainer" class="following-grid">
            <div class="empty-state">
              <p style="color: #fff; margin: 0 0 1.5rem 0;">You're not following any artists yet</p>
              <a href="/releases/" style="display: inline-block; padding: 0.75rem 1.5rem; background: #dc2626; color: #fff; font-weight: 600; border-radius: 8px; text-decoration: none;">Browse Releases</a>
            </div>
          </div>
        </div>

        <!-- DJ Mixes Tab -->
        <div class="tab-panel" id="panel-mixes" role="tabpanel" aria-labelledby="tab-mixes" tabindex="-1">
          <div class="section-header-flex">
            <h2>My DJ Mixes</h2>
            <a href="/upload-mix/" class="btn-primary-sm">+ Upload Mix</a>
          </div>
          <div class="mixes-stats" id="mixesStats">
            <div class="stat-mini"><span class="stat-value" id="statMixes">0</span><span class="stat-label">Mixes</span></div>
            <div class="stat-mini"><span class="stat-value" id="statMixPlays">0</span><span class="stat-label">Total Plays</span></div>
            <div class="stat-mini"><span class="stat-value" id="statMixLikes">0</span><span class="stat-label">Likes</span></div>
          </div>
          <div id="mixesContainer" class="mixes-list"><div class="empty-state"><p>Loading mixes...</p></div></div>
        </div>

        <!-- Profile Tab -->
        <div class="tab-panel" id="panel-profile" role="tabpanel" aria-labelledby="tab-profile" tabindex="-1">
          <h2>My Profile</h2>
          
          <!-- Avatar Upload Section -->
          <div class="avatar-upload-section">
            <div class="avatar-preview-large" id="avatarPreviewLarge">
              <span id="avatarInitialLarge">?</span>
              <img id="avatarImageLarge" src="" alt="Profile" class="hidden" width="80" height="80" loading="lazy" decoding="async" />
            </div>
            <div class="avatar-upload-controls">
              <h3>Profile Picture</h3>
              <p class="avatar-hint">This image will appear next to your comments, in chat, and across the site.</p>
              <div class="avatar-buttons">
                <label for="avatarUpload" class="btn-upload">
                  <span>📷 Upload Image</span>
                  <input type="file" id="avatarUpload" accept="image/jpeg,image/png,image/webp" style="display: none;" />
                </label>
                <button type="button" id="removeAvatarBtn" class="btn-remove hidden">Remove</button>
              </div>
              <p class="avatar-specs">JPG, PNG or WebP. Max 2MB. Round images work best.</p>
              <div id="avatarUploadStatus" class="avatar-status"></div>
            </div>
          </div>

          <!-- Plus Badge Selector - Only visible to Plus members -->
          <div class="plus-badge-section hidden" id="plusBadgeSection">
            <div class="badge-header" id="badgeHeader">
              <h3>Plus Badge <span class="plus-only-tag">Plus Only</span></h3>
              <span class="current-badge" id="currentBadgePreview">👑</span>
              <button type="button" class="badge-toggle-btn" id="badgeToggleBtn" aria-label="Toggle details">▼</button>
            </div>
            <div class="badge-content" id="badgeContent" style="display: none;">
              <p class="badge-hint">Choose your badge - displayed next to your name in chat and across the site.</p>
              <div class="badge-grid" id="badgeGrid">
                <button type="button" class="badge-option" data-badge="crown" title="Crown">👑</button>
                <button type="button" class="badge-option" data-badge="fire" title="Fire">🔥</button>
                <button type="button" class="badge-option" data-badge="headphones" title="Headphones">🎧</button>
                <button type="button" class="badge-option" data-badge="skull" title="Skull">💀</button>
                <button type="button" class="badge-option" data-badge="lion" title="Lion">🦁</button>
                <button type="button" class="badge-option" data-badge="leopard" title="Leopard">🐆</button>
                <button type="button" class="badge-option" data-badge="palm" title="Palm Tree">🌴</button>
                <button type="button" class="badge-option" data-badge="lightning" title="Lightning">⚡</button>
                <button type="button" class="badge-option" data-badge="vinyl" title="Vinyl">💿</button>
                <button type="button" class="badge-option" data-badge="speaker" title="Speaker">🔊</button>
                <button type="button" class="badge-option" data-badge="moon" title="Moon">🌙</button>
                <button type="button" class="badge-option" data-badge="star" title="Star">⭐</button>
                <button type="button" class="badge-option" data-badge="diamond" title="Diamond">💎</button>
                <button type="button" class="badge-option" data-badge="snake" title="Snake">🐍</button>
                <button type="button" class="badge-option" data-badge="bat" title="Bat">🦇</button>
                <button type="button" class="badge-option" data-badge="mic" title="Microphone">🎤</button>
                <button type="button" class="badge-option" data-badge="leaf" title="Leaf">🌿</button>
                <button type="button" class="badge-option" data-badge="gorilla" title="Gorilla">🦍</button>
                <button type="button" class="badge-option" data-badge="spider" title="Spider">🕷️</button>
                <button type="button" class="badge-option" data-badge="alien" title="Alien">👽</button>
              </div>
              <div class="badge-save-row">
                <button type="button" id="saveBadgeBtn" class="btn-save-badge" disabled>Save Badge</button>
                <span id="badgeSaveStatus" class="badge-save-status"></span>
              </div>
            </div>
          </div>

          <form id="profileForm" class="profile-form">
            <div class="form-row">
              <div class="form-group">
                <label for="firstName">First Name</label>
                <input type="text" id="firstName" name="firstName" maxlength="30" required aria-required="true" autocomplete="given-name">
              </div>
              <div class="form-group">
                <label for="lastName">Last Name</label>
                <input type="text" id="lastName" name="lastName" maxlength="30" required aria-required="true" autocomplete="family-name">
              </div>
            </div>
            <div class="form-group">
              <label for="displayName">Display Name</label>
              <input type="text" id="displayName" name="displayName" placeholder="How you appear on the site" maxlength="15" required aria-required="true" autocomplete="nickname">
              <p class="field-hint">This is how you'll be known across <span class="brand-fresh">Fresh</span> <span class="brand-wax">Wax</span> (max 15 characters)</p>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" readonly required aria-required="true" autocomplete="email">
              </div>
              <div class="form-group">
                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" maxlength="20" required aria-required="true" autocomplete="tel">
              </div>
            </div>
            
            <!-- Shipping Address Section -->
            <div class="address-section">
              <h3>Shipping Address</h3>
              <p class="address-hint">Save your address to speed up checkout</p>
              
              <!-- Postcode Lookup -->
              <div class="postcode-lookup">
                <div class="form-group" style="flex: 1; margin-bottom: 0;">
                  <label for="postcodeSearch">Find Address by Postcode</label>
                  <div style="display: flex; gap: 0.75rem;">
                    <input type="text" id="postcodeSearch" placeholder="E1 6AN" style="max-width: 140px; text-transform: uppercase;" required aria-required="true" aria-describedby="lookupError lookupSuccess" autocomplete="postal-code">
                    <button type="button" id="lookupBtn" class="lookup-btn">Verify</button>
                  </div>
                  <div id="lookupError" class="lookup-error"></div>
                  <div id="lookupSuccess" class="lookup-success"></div>
                </div>
              </div>
              
              <fieldset style="border: none; padding: 0; margin: 0;">
                <legend class="sr-only">Delivery Address</legend>
                <div class="form-group" style="margin-bottom: 0.5rem;">
                  <label for="address1">Address Line 1</label>
                  <input type="text" id="address1" name="address1" placeholder="Street address" maxlength="100" required aria-required="true" autocomplete="address-line1">
                </div>
                <div class="form-group">
                  <label for="address2">Address Line 2 (Optional)</label>
                  <input type="text" id="address2" name="address2" placeholder="Flat, unit, building, etc." maxlength="100" autocomplete="address-line2">
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="city">City</label>
                    <input type="text" id="city" name="city" maxlength="50" required aria-required="true" autocomplete="address-level2">
                  </div>
                  <div class="form-group">
                    <label for="county">County</label>
                    <input type="text" id="county" name="county" maxlength="50" required aria-required="true" autocomplete="address-level1">
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="postcode">Postcode</label>
                    <input type="text" id="postcode" name="postcode" style="text-transform: uppercase;" maxlength="10" required aria-required="true" autocomplete="postal-code">
                  </div>
                  <div class="form-group">
                    <label for="country">Country</label>
                    <select id="country" name="country" autocomplete="country-name">
                      <option value="United Kingdom" selected>United Kingdom</option>
                      <option value="Ireland">Ireland</option>
                      <option value="United States">United States</option>
                      <option value="Canada">Canada</option>
                      <option value="Australia">Australia</option>
                      <option value="New Zealand">New Zealand</option>
                      <option value="Germany">Germany</option>
                      <option value="France">France</option>
                      <option value="Netherlands">Netherlands</option>
                      <option value="Belgium">Belgium</option>
                      <option value="Spain">Spain</option>
                      <option value="Italy">Italy</option>
                      <option value="Portugal">Portugal</option>
                      <option value="Sweden">Sweden</option>
                      <option value="Norway">Norway</option>
                      <option value="Denmark">Denmark</option>
                      <option value="Finland">Finland</option>
                      <option value="Austria">Austria</option>
                      <option value="Switzerland">Switzerland</option>
                      <option value="Poland">Poland</option>
                      <option value="Czech Republic">Czech Republic</option>
                      <option value="Japan">Japan</option>
                      <option value="South Korea">South Korea</option>
                      <option value="Singapore">Singapore</option>
                      <option value="Hong Kong">Hong Kong</option>
                      <option value="Other">Other</option>
                    </select>
                  </div>
                </div>
              </fieldset>
            </div>
            
            <button type="submit" class="save-btn">Save Changes</button>
          </form>

          <!-- Selling & Payments Section (for vendors) -->
          <div class="selling-section hidden" id="sellingSection">
            <h3>Selling & Payments</h3>
            <p class="selling-hint">Manage how you receive payments for your sales on Fresh Wax.</p>
            <div class="selling-links">
              <a href="/account/payment-settings/" class="selling-link">
                <span class="selling-icon">&#128179;</span>
                <div class="selling-info">
                  <strong>Payment Settings</strong>
                  <span>Set up Stripe or PayPal to receive payouts</span>
                </div>
                <span class="selling-arrow">&rarr;</span>
              </a>
              <a href="/account/selling/" class="selling-link" id="vinylSellingLink" style="display:none;">
                <span class="selling-icon">&#128230;</span>
                <div class="selling-info">
                  <strong>Vinyl Selling</strong>
                  <span>Manage your vinyl crate listings</span>
                </div>
                <span class="selling-arrow">&rarr;</span>
              </a>
              <a href="/artist/dashboard/" class="selling-link" id="artistDashboardLink" style="display:none;">
                <span class="selling-icon">&#9889;</span>
