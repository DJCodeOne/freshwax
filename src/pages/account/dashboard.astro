  /* Plus Badge Selector */
  .plus-badge-section {
    background: linear-gradient(135deg, rgba(234, 179, 8, 0.1) 0%, rgba(161, 98, 7, 0.1) 100%);
    border: 1px solid rgba(234, 179, 8, 0.3);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .badge-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    user-select: none;
  }

  .badge-header h3 {
    margin: 0;
    font-size: 1rem;
    color: #eab308;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
  }

  .current-badge {
    font-size: 1.5rem;
    line-height: 1;
  }

  .badge-toggle-btn {
    background: none;
    border: none;
    color: #888;
    font-size: 0.875rem;
    cursor: pointer;
    padding: 0.25rem;
    transition: transform 0.2s ease;
  }

  .badge-toggle-btn.open {
    transform: rotate(180deg);
  }

  .badge-content {
    padding-top: 1rem;
    margin-top: 1rem;
    border-top: 1px solid rgba(234, 179, 8, 0.2);
  }

  .plus-badge-section h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1rem;
    color: #eab308;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .plus-only-tag {
    font-size: 0.65rem;
    background: linear-gradient(135deg, #eab308 0%, #a16207 100%);
    color: #000;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .badge-hint {
    margin: 0 0 1rem 0;
    color: #888;
    font-size: 0.8rem;
  }

  .badge-grid {
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .badge-option {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    background: rgba(30, 30, 30, 0.8);
    border: 2px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    padding: 0;
  }

  .badge-option:hover {
    background: rgba(50, 50, 50, 0.9);
    transform: scale(1.1);
    border-color: rgba(234, 179, 8, 0.5);
  }

  .badge-option.selected {
    background: rgba(234, 179, 8, 0.2);
    border-color: #eab308;
    transform: scale(1.05);
    box-shadow: 0 0 12px rgba(234, 179, 8, 0.4);
  }

  .badge-save-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .btn-save-badge {
    padding: 0.5rem 1.25rem;
    background: linear-gradient(135deg, #eab308 0%, #a16207 100%);
    border: none;
    border-radius: 6px;
    color: #000;
    font-weight: 600;
    font-size: 0.875rem;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .btn-save-badge:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(234, 179, 8, 0.3);
  }

  .btn-save-badge:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .badge-save-status {
    font-size: 0.8rem;
    color: #22c55e;
  }

  .badge-save-status.error {
    color: #ef4444;
  }

  @media (max-width: 768px) {
    .badge-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  @media (max-width: 480px) {
    .badge-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .badge-option {
      font-size: 1.2rem;
    }
