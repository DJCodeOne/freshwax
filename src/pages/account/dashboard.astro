  /* Release download buttons container */
  .release-dl-buttons {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  /* ZIP download button */
  .dl-btn.zip {
    background: linear-gradient(135deg, #f97316 0%, #c2410c 100%);
    border: 1px solid #fb923c;
    flex: 1;
    min-width: 120px;
    justify-content: center;
  }

  .dl-btn.zip:hover {
    background: linear-gradient(135deg, #fb923c 0%, #ea580c 100%);
    transform: translateY(-1px);
  }

  .dl-btn.zip.downloading {
    opacity: 0.7;
    pointer-events: none;
  }

  /* ZIP Progress Modal */
  .zip-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .zip-modal.hidden {
    display: none;
  }

  .zip-modal-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(4px);
  }

  .zip-modal-content {
    position: relative;
    background: #1a1a2e;
    border: 1px solid #374151;
    border-radius: 1rem;
    padding: 1.5rem;
    max-width: 400px;
    width: 100%;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }

  .zip-modal-title {
    color: #fff;
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
    text-align: center;
  }

  .zip-progress-bar {
    height: 8px;
    background: #374151;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  .zip-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #f97316 0%, #fb923c 100%);
    border-radius: 4px;
    transition: width 0.3s ease;
    width: 0%;
  }

  .zip-progress-fill.creating {
    animation: zipPulse 1.5s ease-in-out infinite;
    background: linear-gradient(90deg, #f97316 0%, #fbbf24 50%, #f97316 100%);
    background-size: 200% 100%;
  }

  @keyframes zipPulse {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .zip-progress-text {
    color: #d1d5db;
    font-size: 0.875rem;
    text-align: center;
    margin: 0 0 1rem 0;
  }

  .zip-file-list {
    max-height: 200px;
    overflow-y: auto;
    margin-bottom: 1rem;
  }

  .zip-file-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    color: #d1d5db;
    font-size: 0.875rem;
    border-bottom: 1px solid #374151;
  }

  .zip-file-item:last-child {
    border-bottom: none;
  }

  .zip-file-icon {
    flex-shrink: 0;
  }

  .zip-modal-close {
    width: 100%;
    padding: 0.75rem;
    background: #374151;
    color: #fff;
    border: none;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
  }

  .zip-modal-close:hover {
    background: #4b5563;
  }

  /* Download Status Modal */
  .dl-status-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .dl-status-modal.hidden {
    display: none;
  }

  .dl-status-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
  }

  .dl-status-content {
    position: relative;
    background: #1a1a2e;
    border: 1px solid #374151;
    border-radius: 1rem;
    padding: 2rem 1.5rem;
    max-width: 340px;
    width: 100%;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    text-align: center;
    animation: modalSlideIn-dashboard 0.2s ease-out;
