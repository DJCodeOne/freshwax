---
// src/pages/500.astro
// Custom 500 error page - apologetic, helpful, no technical details
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=300');
---

<Layout title="Something Went Wrong" description="Server error - something went wrong on Freshwax" noindex={true}>
  <Header />

  <div class="error-page" role="region" aria-labelledby="error-heading">
    <div class="error-container">
      <!-- Broken speaker icon -->
      <div class="error-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M11 5L6 9H2v6h4l5 4V5z" stroke-linecap="round" stroke-linejoin="round" />
          <line x1="23" y1="9" x2="17" y2="15" stroke-linecap="round" />
          <line x1="17" y1="9" x2="23" y2="15" stroke-linecap="round" />
        </svg>
      </div>

      <h1 id="error-heading">The Signal Dropped</h1>
      <p class="error-code" aria-label="Error 500">500</p>
      <p class="error-message">Sorry, something went wrong on our end.</p>
      <p class="error-sub">This isn't your fault. Our team has been notified and we're working to fix it. Please try again in a moment.</p>

      <div class="error-actions">
        <button type="button" class="cta-btn" id="retryBtn">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          Try Again
        </button>
        <a href="/" class="cta-btn secondary">Back to Home</a>
      </div>

      <nav class="error-links" aria-label="Helpful pages">
        <p>In the meantime, try visiting:</p>
        <ul class="link-grid" role="list">
          <li><a href="/releases/">New Releases</a></li>
          <li><a href="/weekly-chart/">Weekly Chart</a></li>
          <li><a href="/dj-mixes/">DJ Mixes</a></li>
          <li><a href="/merch/">Merchandise</a></li>
          <li><a href="/live/">Live Stream</a></li>
          <li><a href="/contact/">Contact Us</a></li>
        </ul>
      </nav>

      <div class="error-contact">
        <p>If this keeps happening, please let us know:</p>
        <a href="mailto:contact@freshwax.co.uk">contact@freshwax.co.uk</a>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  .error-page {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    background: linear-gradient(180deg, #0a0a0a 0%, #111 100%);
  }

  .error-container {
    text-align: center;
    max-width: 640px;
    width: 100%;
  }

  .error-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 1.5rem;
    color: #ef4444;
    opacity: 0.8;
  }

  .error-icon svg {
    width: 100%;
    height: 100%;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 0.5rem;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .error-code {
    font-size: 1rem;
    font-weight: 600;
    color: #ef4444;
    margin: 0 0 1.25rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .error-message {
    font-size: 1.25rem;
    color: #ccc;
    margin: 0 0 0.5rem;
    line-height: 1.4;
  }

  .error-sub {
    font-size: 0.95rem;
    color: #777;
    margin: 0 0 2rem;
    line-height: 1.5;
  }

  /* Action buttons */
  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    border-radius: 8px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    font-size: 0.95rem;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  .btn-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(239, 68, 68, 0.3);
  }

  .cta-btn.secondary {
    background: transparent;
    border: 1px solid #333;
    color: #ccc;
  }

  .cta-btn.secondary:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: #555;
    box-shadow: none;
  }

  /* Navigation links */
  .error-links {
    padding-top: 2rem;
    border-top: 1px solid #1e1e1e;
  }

  .error-links p {
    color: #666;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .link-grid {
    display: flex;
    gap: 0.5rem 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .link-grid a {
    color: #888;
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.25rem 0;
    transition: color 0.2s;
  }

  .link-grid a:hover {
    color: #ef4444;
  }

  /* Contact section */
  .error-contact {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #1e1e1e;
  }

  .error-contact p {
    color: #555;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
  }

  .error-contact > a {
    color: #ef4444;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .error-contact > a:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .error-page {
      padding: 2rem 1rem;
    }

    h1 {
      font-size: 2rem;
    }

    .error-message {
      font-size: 1.1rem;
    }

    .error-actions {
      flex-direction: column;
    }

    .cta-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  document.getElementById('retryBtn')?.addEventListener('click', () => window.location.reload());
</script>
