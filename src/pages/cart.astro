---
// src/pages/cart.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = false;
const nonce = Astro.locals.nonce || '';
Astro.response.headers.set('Cache-Control', 'private, no-store, no-cache, must-revalidate, max-age=0');
---

<Layout title="Record Bag" description="Review your Fresh Wax record bag. Add or remove vinyl, digital downloads, DJ mixes and merchandise before secure checkout." noindex={true}>
  <Header />

  <div class="cart-main">

    <!-- Page Header -->
    <div class="page-header-container">
      <div class="page-header-pattern"></div>
      <header class="cart-header">
        <h1>RECORD <span class="red">BAG</span></h1>
        <a href="/" class="back-btn">← Continue Shopping</a>
      </header>
    </div>
    
    <div id="cart-content" aria-live="polite">
      <div class="loading-state">
        <div class="loading-spinner"></div>
        <span>Loading your bag...</span>
      </div>
    </div>

  </div>

  <Footer />
</Layout>

<style>
  :global(html), :global(body) {
    background: #000 !important;
  }
  
  .cart-main {
    min-height: 100vh;
    padding: 2rem 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
    background: #000;
  }
  
  .page-header-container {
    background: linear-gradient(to bottom, #1f2937 0%, #374151 100%);
    border-radius: 1rem;
    padding: 2rem 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3);
    border: 2px solid rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
  }
  
  .page-header-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.1;
    pointer-events: none;
    background-image: linear-gradient(rgba(255, 255, 255, 0.3) 1px, transparent 1px), 
                      linear-gradient(90deg, rgba(255, 255, 255, 0.3) 1px, transparent 1px);
    background-size: 40px 40px;
  }
  
  .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }
  
  .cart-header h1 {
    margin: 0;
    font-family: 'Bebas Neue', 'Bebas Fallback', sans-serif;
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: #fff;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
  }
  
  .cart-header h1 .red {
    color: #dc2626;
  }
  
  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    background: rgba(0, 0, 0, 0.3);
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    backdrop-filter: blur(10px);
  }
  
  .back-btn:hover {
    background: #dc2626;
    border-color: #dc2626;
    transform: translateY(-2px);
  }
  
  .loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    padding: 4rem 2rem;
    background: linear-gradient(to bottom, #1f2937 0%, #111827 100%);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: #d1d5db;
    font-size: 1.125rem;
  }
  
  .loading-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(220, 38, 38, 0.2);
    border-top-color: #dc2626;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  
  @media (max-width: 768px) {
    .cart-main {
      padding: 1.5rem 1rem;
    }
    
    .page-header-container {
      padding: 1.5rem;
      border-radius: 0.75rem;
    }
  }
  
  @media (max-width: 600px) {
    .cart-main {
      padding: 1rem 0.75rem;
    }
    
    .page-header-container {
      padding: 1.25rem;
    }
    
    .cart-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    
    .back-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<style is:global>
  /* Cart Items Styling */
  #cart-content .empty-cart {
    text-align: center;
    padding: 4rem 2rem;
    background: #000;
    border: 2px solid rgba(255, 255, 255, 0.15);
    border-radius: 12px;
  }

  #cart-content .empty-cart h2 {
    font-family: 'Inter', sans-serif; font-weight: 700;
    font-size: 2rem;
    color: #dc2626;
    margin: 0 0 0.5rem 0;
  }

  #cart-content .empty-cart p {
    color: #d1d5db;
    margin: 0 0 1.5rem 0;
  }

  /* Mobile cart item adjustments — structured 2-row layout */
  @media (max-width: 600px) {
    /* Each cart item: stack into a grid for clean mobile layout */
    #cart-content article {
      display: grid !important;
      grid-template-columns: 56px 1fr auto !important;
      grid-template-rows: auto auto !important;
      gap: 0.5rem 0.75rem !important;
      padding: 0.875rem !important;
      margin-bottom: 0.625rem !important;
      align-items: start !important;
    }

    /* Image — row 1, col 1, spans both rows */
    #cart-content article > div:first-child {
      grid-row: 1 / 3 !important;
      grid-column: 1 !important;
      width: 56px !important;
      height: 56px !important;
      align-self: center !important;
    }

    #cart-content article img {
      width: 56px !important;
      height: 56px !important;
    }

    /* Title + badges — row 1, col 2, spans to col 3 */
    #cart-content article > div:nth-child(2) {
      grid-row: 1 !important;
      grid-column: 2 / 4 !important;
      min-width: 0 !important;
    }

    #cart-content h3 {
      font-size: 0.9375rem !important;
      line-height: 1.3 !important;
      white-space: normal !important;
      overflow: visible !important;
      text-overflow: unset !important;
    }

    /* Quantity controls — row 2, col 2 */
    #cart-content article > div:nth-child(3) {
      grid-row: 2 !important;
      grid-column: 2 !important;
      align-self: center !important;
    }

    /* Price — row 2, col 3 */
    #cart-content article > div:nth-child(4) {
      grid-row: 2 !important;
      grid-column: 3 !important;
      align-self: center !important;
      text-align: right !important;
      min-width: unset !important;
    }

    /* Remove button — absolute top-right corner */
    #cart-content article > button:last-child {
      position: absolute !important;
      top: 0.5rem !important;
      right: 0.5rem !important;
      width: 28px !important;
      height: 28px !important;
      font-size: 1rem !important;
      border-radius: 50% !important;
      z-index: 1 !important;
    }

    /* Article needs relative positioning for the remove button */
    #cart-content article {
      position: relative !important;
      padding-right: 2.5rem !important;
    }
  }

  @media (max-width: 400px) {
    #cart-content article {
      grid-template-columns: 48px 1fr auto !important;
      padding: 0.75rem !important;
      padding-right: 2.25rem !important;
      gap: 0.375rem 0.625rem !important;
    }

    #cart-content article > div:first-child {
      width: 48px !important;
      height: 48px !important;
    }

    #cart-content article img {
      width: 48px !important;
      height: 48px !important;
    }

    #cart-content h3 {
      font-size: 0.875rem !important;
    }

    /* Slightly smaller quantity buttons */
    #cart-content article > div:nth-child(3) button {
      width: 26px !important;
      height: 26px !important;
      font-size: 0.875rem !important;
    }

    #cart-content article > div:nth-child(4) > div:first-child {
      font-size: 0.9375rem !important;
    }
  }

  /* Touch-friendly cart controls */
  @media (hover: none) and (pointer: coarse) {
    #cart-content article > div:nth-child(3) button {
      min-height: 44px !important;
      min-width: 44px !important;
    }

    #cart-content a {
      min-height: 48px !important;
    }
  }
</style>

<script is:inline src="/cart-page.js?v=5" defer nonce={nonce}></script>