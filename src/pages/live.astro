<script is:inline nonce={nonce}>
  // Auto-hide header on live page
  // Uses is:inline to ensure it re-runs on every View Transition navigation
  // Uses AbortController to clean up event listeners on navigation away

  (function() {
    // Only activate on the live page
    if (!window.location.pathname.startsWith('/live')) {
      // Clean up if navigating away from live
      if (window._headerAutoHideAbort) {
        window._headerAutoHideAbort.abort();
        window._headerAutoHideAbort = null;
      }
      var h = document.getElementById('freshwax-header');
      if (h) h.classList.remove('header-auto-hide', 'header-visible');
      document.body.classList.remove('header-hidden');
      var hz = document.querySelector('.header-hover-zone');
      if (hz) hz.remove();
      return;
    }

    // Clean up any previous instance
    if (window._headerAutoHideAbort) {
      window._headerAutoHideAbort.abort();
      window._headerAutoHideAbort = null;
    }

    var header = document.getElementById('freshwax-header');
    if (!header) return;

    var abort = new AbortController();
    window._headerAutoHideAbort = abort;
    var sig = { signal: abort.signal };

    // Set real viewport height as CSS variable (handles mobile browser chrome)
    function setRealVH() {
      var vh = window.innerHeight;
      document.documentElement.style.setProperty('--real-vh', vh + 'px');
    }
    setRealVH();
    window.addEventListener('resize', setRealVH, sig);
    window.addEventListener('orientationchange', function() { setTimeout(setRealVH, 100); }, sig);

    // Create hover trigger zone at the very top of the page
    var hoverZone = document.querySelector('.header-hover-zone');
    if (!hoverZone) {
      hoverZone = document.createElement('div');
      hoverZone.className = 'header-hover-zone';
      document.body.appendChild(hoverZone);
    }

    // Add auto-hide class to header - body class MUST come first so CSS specificity works
    document.body.classList.add('header-hidden');
    header.classList.add('header-auto-hide');

    // Show header when hovering near the top
    hoverZone.addEventListener('mouseenter', function() {
      header.classList.add('header-visible');
    }, sig);

    // Keep header visible while mouse is over it
    header.addEventListener('mouseenter', function() {
      header.classList.add('header-visible');
    }, sig);

    // Hide header when mouse leaves both the trigger zone and header
    header.addEventListener('mouseleave', function(e) {
      var rect = hoverZone.getBoundingClientRect();
      if (e.clientY > rect.bottom) {
        header.classList.remove('header-visible');
      }
    }, sig);

    hoverZone.addEventListener('mouseleave', function(e) {
      var headerRect = header.getBoundingClientRect();
      if (e.clientY > headerRect.bottom || e.clientY < headerRect.top) {
        setTimeout(function() {
          if (!header.matches(':hover')) {
            header.classList.remove('header-visible');
          }
        }, 100);
      }
    }, sig);

    // Also show header when scrolled to very top
    var lastScrollY = window.scrollY;
    window.addEventListener('scroll', function() {
      if (window.scrollY === 0 && lastScrollY > 0) {
        header.classList.add('header-visible');
        setTimeout(function() {
          if (!header.matches(':hover') && !hoverZone.matches(':hover')) {
            header.classList.remove('header-visible');
          }
        }, 2000);
      }
      lastScrollY = window.scrollY;
    }, { passive: true, signal: abort.signal });
  })();

  // Clean up when navigating away via View Transitions
  document.addEventListener('astro:before-swap', function() {
    if (window._headerAutoHideAbort) {
      window._headerAutoHideAbort.abort();
      window._headerAutoHideAbort = null;
    }
    var h = document.getElementById('freshwax-header');
    if (h) h.classList.remove('header-auto-hide', 'header-visible');
    document.body.classList.remove('header-hidden');
    var hz = document.querySelector('.header-hover-zone');
    if (hz) hz.remove();
    // Note: module-scoped intervals (fullscreenStats, takeover, countdown, etc.)
    // are cleaned up in their own module script blocks above.
  });
</script>
