<script async is:inline src="https://cdn.jsdelivr.net/npm/hls.js@1.4.12/dist/hls.min.js" integrity="sha384-miJUhTuRucSoqFe3/VSB2sRghSMoev6wpPoEyj5fhF0PARehD+naPBsAkl5NqwPO" crossorigin="anonymous"></script>

<script is:inline type="module">
  import { initSpeedTest } from '/live/speed-test.js';
  import { initReactions } from '/live/reactions.js';
  import { initFullscreen, stopFullscreenStats } from '/live/fullscreen.js';
  import { initShare } from '/live/share.js';
  import { initShoutout } from '/live/shoutout.js';

  function escapeHtml(s){if(typeof s!=='string')return '';return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,"&#39;");}

  // Initialize extracted modules
  initSpeedTest();
  initReactions({ escapeHtml: escapeHtml });
  initFullscreen();
  initShare();
  initShoutout({ escapeHtml: escapeHtml });

  // Calendar and time picker state
  var calendarDate = new Date();
  var selectedDate = null;
  var selectedTime = null;
  var selectedDuration = 60;
  var bookingMode = 'schedule';

  function getBookedSlotsForDate(dateStr) {
    var slots = window.bookedSlots || [];
    return slots.filter(function(slot) {
      return slot.startTime.startsWith(dateStr) &&
        ['scheduled', 'live', 'in_lobby', 'queued'].indexOf(slot.status) !== -1;
    });
  }

  function isTimeSlotAvailable(dateStr, timeStr, duration) {
    var slotStart = new Date(dateStr + 'T' + timeStr + ':00');
    var slotEnd = new Date(slotStart.getTime() + duration * 60000);
    var daySlots = getBookedSlotsForDate(dateStr);
    for (var i = 0; i < daySlots.length; i++) {
      var bookedStart = new Date(daySlots[i].startTime);
      var bookedEnd = new Date(daySlots[i].endTime);
      if (slotStart < bookedEnd && slotEnd > bookedStart) {
        return false;
      }
    }
    return true;
  }

  function getEndTime(timeStr, duration) {
    var parts = timeStr.split(':');
    var hours = parseInt(parts[0]);
    var mins = parseInt(parts[1]);
    var totalMins = hours * 60 + mins + duration;
    var endHours = Math.floor(totalMins / 60) % 24;
    var endMins = totalMins % 60;
    return String(endHours).padStart(2, '0') + ':' + String(endMins).padStart(2, '0');
  }

  function renderCalendar() {
    var year = calendarDate.getFullYear();
    var month = calendarDate.getMonth();
    var today = new Date();
    today.setHours(0, 0, 0, 0);
    var maxDate = new Date();
    maxDate.setDate(maxDate.getDate() + 30);

    var monthYearEl = document.getElementById('calMonthYear');
    if (monthYearEl) monthYearEl.textContent = calendarDate.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });

    var firstDay = new Date(year, month, 1);
    var lastDay = new Date(year, month + 1, 0);
    var startDay = (firstDay.getDay() + 6) % 7;

    var daysContainer = document.getElementById('calDays');
    if (!daysContainer) return;
    daysContainer.innerHTML = '';

    var prevMonthLastDay = new Date(year, month, 0).getDate();
    for (var i = startDay - 1; i >= 0; i--) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'cal-day other-month disabled';
      btn.textContent = prevMonthLastDay - i;
      daysContainer.appendChild(btn);
    }

    for (var d = 1; d <= lastDay.getDate(); d++) {
      var btn2 = document.createElement('button');
      btn2.type = 'button';
      btn2.className = 'cal-day';
      btn2.textContent = d;
      var thisDate = new Date(year, month, d);
      thisDate.setHours(0, 0, 0, 0);
      if (thisDate < today || thisDate > maxDate) {
        btn2.classList.add('disabled');
      } else {
        (function(y, m, dy) {
          btn2.addEventListener('click', function() { selectDate(y, m, dy); });
        })(year, month, d);
      }
      if (thisDate.getTime() === today.getTime()) btn2.classList.add('today');
      if (selectedDate && thisDate.getFullYear() === selectedDate.getFullYear() && thisDate.getMonth() === selectedDate.getMonth() && thisDate.getDate() === selectedDate.getDate()) {
        btn2.classList.add('selected');
        btn2.style.background = '#dc2626';
        btn2.style.color = '#fff';
        btn2.style.fontWeight = '700';
        btn2.style.boxShadow = '0 2px 8px rgba(220, 38, 38, 0.4)';
      }
      daysContainer.appendChild(btn2);
    }

    var totalCells = daysContainer.children.length;
    var remaining = 42 - totalCells;
    for (var d2 = 1; d2 <= remaining && totalCells + d2 <= 42; d2++) {
      var btn3 = document.createElement('button');
      btn3.type = 'button';
      btn3.className = 'cal-day other-month disabled';
      btn3.textContent = d2;
      daysContainer.appendChild(btn3);
    }
  }

  function selectDate(year, month, day) {
    selectedDate = new Date(year, month, day);
    var dateInput = document.getElementById('bookingDate');
    if (dateInput) dateInput.value = year + '-' + String(month + 1).padStart(2, '0') + '-' + String(day).padStart(2, '0');
    renderCalendar();
    updateTimeFromDropdowns();
  }

  function updateTimeFromDropdowns() {
    var hourEl = document.getElementById('bookingHour');
    var minuteEl = document.getElementById('bookingMinute');
    var hour = hourEl && hourEl.value;
    var minute = minuteEl && minuteEl.value;

    if (hour && minute) {
      var timeStr = hour + ':' + minute;
      selectedTime = timeStr;
      var timeInput = document.getElementById('bookingTime');
      if (timeInput) timeInput.value = timeStr;

      var now = new Date();
      var dateStr = selectedDate
        ? selectedDate.getFullYear() + '-' + String(selectedDate.getMonth() + 1).padStart(2, '0') + '-' + String(selectedDate.getDate()).padStart(2, '0')
        : now.toISOString().split('T')[0];

      var isToday = dateStr === now.toISOString().split('T')[0];
      var isPast = isToday && (parseInt(hour) < now.getHours() || (parseInt(hour) === now.getHours() && parseInt(minute) <= now.getMinutes()));
      var isUnavailable = !isTimeSlotAvailable(dateStr, timeStr, selectedDuration);

      var infoEl = document.getElementById('selectedTimeInfo');
      if (infoEl && selectedDate) {
        if (isPast) {
          infoEl.textContent = 'This time has already passed';
          infoEl.className = 'selected-time-info error';
          infoEl.classList.remove('hidden');
        } else if (isUnavailable) {
          infoEl.textContent = 'This slot conflicts with another booking';
          infoEl.className = 'selected-time-info error';
          infoEl.classList.remove('hidden');
        } else {
          var endTime = getEndTime(timeStr, selectedDuration);
          var dateFormatted = selectedDate.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
          infoEl.textContent = dateFormatted + ': ' + timeStr + ' - ' + endTime;
          infoEl.className = 'selected-time-info';
          infoEl.classList.remove('hidden');
        }
      }
    } else {
      selectedTime = null;
      var ti = document.getElementById('bookingTime');
      if (ti) ti.value = '';
      var si = document.getElementById('selectedTimeInfo');
      if (si) si.classList.add('hidden');
    }
  }

  // Time dropdown change handlers
  var bookingHour = document.getElementById('bookingHour');
  var bookingMinute = document.getElementById('bookingMinute');
  if (bookingHour) bookingHour.addEventListener('change', updateTimeFromDropdowns);
  if (bookingMinute) bookingMinute.addEventListener('change', updateTimeFromDropdowns);

  // Duration change
  document.querySelectorAll('input[name="duration"]').forEach(function(radio) {
    radio.addEventListener('change', function(e) {
      selectedDuration = parseInt(e.target.value);
      updateTimeFromDropdowns();
    });
  });

  // Calendar navigation
  var calPrev = document.getElementById('calPrevMonth');
  if (calPrev) calPrev.addEventListener('click', function() { calendarDate.setMonth(calendarDate.getMonth() - 1); renderCalendar(); });
  var calNext = document.getElementById('calNextMonth');
  if (calNext) calNext.addEventListener('click', function() { calendarDate.setMonth(calendarDate.getMonth() + 1); renderCalendar(); });

  // Booking type toggle
  var bookingTypeSchedule = document.getElementById('bookingTypeSchedule');
  if (bookingTypeSchedule) bookingTypeSchedule.addEventListener('click', function() {
    bookingMode = 'schedule';
    document.getElementById('bookingTypeSchedule').classList.add('active');
    document.getElementById('bookingTypeQueue').classList.remove('active');
    document.getElementById('scheduledTimeSection').classList.remove('hidden');
    document.getElementById('queueSection').classList.add('hidden');
  });
  var bookingTypeQueue = document.getElementById('bookingTypeQueue');
  if (bookingTypeQueue) bookingTypeQueue.addEventListener('click', function() {
    bookingMode = 'queue';
    document.getElementById('bookingTypeQueue').classList.add('active');
    document.getElementById('bookingTypeSchedule').classList.remove('active');
    document.getElementById('scheduledTimeSection').classList.add('hidden');
    document.getElementById('queueSection').classList.remove('hidden');
  });

  // Close modals on overlay click
  document.querySelectorAll('.modal-overlay').forEach(function(overlay) {
    overlay.addEventListener('click', function() {
      var bm = document.getElementById('bookingModal'); if (bm) bm.classList.add('hidden');
      var gm = document.getElementById('goLiveNowModal'); if (gm) gm.classList.add('hidden');
      var sm = document.getElementById('shareModal'); if (sm) sm.classList.add('hidden');
    });
  });

  // Close modals on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var bm = document.getElementById('bookingModal');
      if (bm && !bm.classList.contains('hidden')) {
        bm.classList.add('hidden');
        var bookBtn = document.getElementById('bookSlotBtn');
        if (bookBtn) bookBtn.focus();
        return;
      }
      var gm = document.getElementById('goLiveNowModal');
      if (gm && !gm.classList.contains('hidden')) {
        gm.classList.add('hidden');
        var goLiveBtn = document.getElementById('goLiveNowBtn');
        if (goLiveBtn) goLiveBtn.focus();
        return;
      }
    }
  });

  // Go Live Now button
  var goLiveNowBtn = document.getElementById('goLiveNowBtn');
  if (goLiveNowBtn) goLiveNowBtn.addEventListener('click', async function() {
    var user = null;
    if (window.authReady) { user = await window.authReady; }
    else { user = window.firebaseAuth && window.firebaseAuth.currentUser; }
    if (!user) { window.location.href = '/login/?redirect=/account/dj-lobby/'; return; }
    window.location.href = '/account/dj-lobby/';
  });

  var closeGoLiveNow = document.getElementById('closeGoLiveNowModal');
  if (closeGoLiveNow) closeGoLiveNow.addEventListener('click', function() {
    var m = document.getElementById('goLiveNowModal'); if (m) m.classList.add('hidden');
  });

  var copyGoLiveKey = document.getElementById('copyGoLiveNowKey');
  if (copyGoLiveKey) copyGoLiveKey.addEventListener('click', function() {
    var keyEl = document.getElementById('goLiveNowStreamKey');
    var key = keyEl && keyEl.textContent;
    if (key && key !== '-') {
      navigator.clipboard.writeText(key);
      copyGoLiveKey.textContent = 'Copied!';
      setTimeout(function() { copyGoLiveKey.textContent = 'Copy'; }, 2000);
    }
  });

  // Character counters
  var bookingDesc = document.getElementById('bookingDescription');
  if (bookingDesc) bookingDesc.addEventListener('input', function(e) {
    var c = document.getElementById('bookingDescCount'); if (c) c.textContent = e.target.value.length;
  });
  var goLiveDesc = document.getElementById('goLiveNowDescription');
  if (goLiveDesc) goLiveDesc.addEventListener('input', function(e) {
    var c = document.getElementById('goLiveNowDescCount'); if (c) c.textContent = e.target.value.length;
  });

  // Cached auth for user info
  var cachedAuth = null;
  try {
    var cached = sessionStorage.getItem('fw_auth_cache');
    if (cached) {
      cachedAuth = JSON.parse(cached);
      if (cachedAuth.cachedAt && Date.now() - cachedAuth.cachedAt < 86400000) { /* valid */ }
      else { cachedAuth = null; sessionStorage.removeItem('fw_auth_cache'); }
    }
  } catch (e) { /* ignore */ }

  window.currentUserInfo = cachedAuth || { loggedIn: false, name: 'Anonymous', displayName: 'Anonymous', id: null };

  if (cachedAuth && cachedAuth.loggedIn) {
    setTimeout(function() {
      document.dispatchEvent(new CustomEvent('userAuthReady', {
        detail: { user: null, userInfo: window.currentUserInfo }
      }));
    }, 0);
  }

  // Setup booking buttons (View Transitions compatible)
  function setupBookingButtons() {
    var bookSlotBtn = document.getElementById('bookSlotBtn');
    if (bookSlotBtn && !bookSlotBtn._listenerAttached) {
      bookSlotBtn._listenerAttached = true;
      bookSlotBtn.addEventListener('click', function() {
        (async function() {
          var user = null;
          var cachedUid = null;
          try { cachedUid = localStorage.getItem('fw_uid'); } catch (e2) {}
          try {
            if (window.firebaseAuth && window.firebaseAuth.currentUser) { user = window.firebaseAuth.currentUser; }
            else if (window.authReady) { user = await window.authReady; }
            if (!user && cachedUid) {
              var auth = window.firebaseAuth;
              if (auth) {
                var mod = await import('https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js');
                user = await new Promise(function(resolve) {
                  var timeout = setTimeout(function() { resolve(auth.currentUser); }, 2000);
                  var unsub = mod.onAuthStateChanged(auth, function(u) { clearTimeout(timeout); unsub(); resolve(u); });
                });
              }
            }
          } catch (err) { console.error('[Live] Auth check error:', err); }
          if (!user) { window.location.href = '/login/?redirect=/live/'; return; }
          var displayName = user.displayName || (user.email && user.email.split('@')[0]) || 'DJ';
          window.openBookingSchedule(user.uid, displayName);
        })();
      });
    }

    var viewScheduleBtn = document.getElementById('viewScheduleBtn');
    if (viewScheduleBtn && !viewScheduleBtn._listenerAttached) {
      viewScheduleBtn._listenerAttached = true;
      viewScheduleBtn.addEventListener('click', function() { window.openPublicSchedule(); });
    }

    var viewFullScheduleBtn = document.getElementById('viewFullScheduleBtn');
    if (viewFullScheduleBtn && !viewFullScheduleBtn._listenerAttached) {
      viewFullScheduleBtn._listenerAttached = true;
      viewFullScheduleBtn.addEventListener('click', function() { window.openPublicSchedule(); });
    }

    var closeBookingModal = document.getElementById('closeBookingModal');
    if (closeBookingModal && !closeBookingModal._listenerAttached) {
      closeBookingModal._listenerAttached = true;
      closeBookingModal.addEventListener('click', function() {
        var m = document.getElementById('bookingModal'); if (m) m.classList.add('hidden');
      });
    }
  }

  setupBookingButtons();

  document.addEventListener('astro:page-load', function() {
    var b = document.getElementById('bookSlotBtn');
    var v = document.getElementById('viewScheduleBtn');
    var c = document.getElementById('closeBookingModal');
    if (b) b._listenerAttached = false;
    if (v) v._listenerAttached = false;
    if (c) c._listenerAttached = false;
    setupBookingButtons();
    setupMetersToggle();
  });

  // LED meters toggle
  function setupMetersToggle() {
    var toggleBtn = document.getElementById('toggleMetersBtn');
    var stereoMeters = document.getElementById('stereoMeters');
    if (!toggleBtn || !stereoMeters) return;

    var visibleIcon = toggleBtn.querySelector('.meters-visible-icon');
    var hiddenIcon = toggleBtn.querySelector('.meters-hidden-icon');

    var metersHidden = false;
    try { metersHidden = localStorage.getItem('fw_meters_hidden') === 'true'; } catch (e) {}
    if (metersHidden) {
      stereoMeters.classList.add('meters-hidden');
      toggleBtn.classList.add('meters-off');
      if (visibleIcon) visibleIcon.classList.add('hidden');
      if (hiddenIcon) hiddenIcon.classList.remove('hidden');
    }

    if (toggleBtn._metersListenerAttached) return;
    toggleBtn._metersListenerAttached = true;

    toggleBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      var isHidden = stereoMeters.classList.toggle('meters-hidden');
      toggleBtn.classList.toggle('meters-off', isHidden);
      if (visibleIcon) visibleIcon.classList.toggle('hidden', isHidden);
      if (hiddenIcon) hiddenIcon.classList.toggle('hidden', !isHidden);
      try { localStorage.setItem('fw_meters_hidden', isHidden ? 'true' : 'false'); } catch (e2) {}
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('astro:page-load', setupMetersToggle);
  } else {
    setupMetersToggle();
  }

  // Clean up fullscreen intervals on View Transition navigation
  document.addEventListener('astro:before-swap', function() {
    stopFullscreenStats();
  }, { once: true });
</script>

<script type="module" define:vars={{ firebaseConfig }} nonce={nonce}>
  import { initializeApp, getApps, getApp } from 'https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js';
  import { getAuth, onAuthStateChanged } from 'https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js';
  import { initPresence, waitForPusherAndSetup, startListenerHeartbeat, stopListenerHeartbeat, getOrCreateSessionId, resubscribePresence, getHeartbeatInterval } from '/live/presence.js';
  import { initMobile } from '/live/mobile.js';

  function escapeHtml(s){if(typeof s!=='string')return '';return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,"&#39;");}

  // Prevent duplicate app initialization
  const app = getApps().length ? getApp() : initializeApp(firebaseConfig);
  const auth = getAuth(app);
  
  let currentUser = null;
  let isLoggedIn = false;
  let userInfo = null;
  let currentWeekStart = getWeekStart(new Date());
  let allSlots = [];
  let myUpcomingSlot = null;
  let scheduleCache = null;
  let scheduleCacheTime = 0;
  const CACHE_DURATION = 900000; // 15 minute cache to reduce Firebase reads
  
  // Chat clear timer - clears chat 20 minutes after stream ends
  let wasLive = false;
  let chatClearTimer = null;
  const CHAT_CLEAR_DELAY = 20 * 60 * 1000; // 20 minutes in milliseconds

  // Playlist fallback timer - starts auto-play shortly after confirming no stream
  let playlistFallbackTimer = null;
  const PLAYLIST_FALLBACK_DELAY = 3 * 1000; // 3 seconds

  // Takeover fallback interval (promoted to module scope for cleanup)
  let takeoverFallbackInterval = null;
  
  function clearChatMessages() {
    const chatMessages = document.getElementById('chatMessages');
    const fsChatMessages = document.getElementById('fsChatMessages');
    if (chatMessages) {
      chatMessages.innerHTML = '<div class="chat-system-message">Chat cleared</div>';
    }
    if (fsChatMessages) {
      fsChatMessages.innerHTML = '<div class="chat-system-message">Chat cleared</div>';
    }
  }
  
  function scheduleChatClear() {
    // Cancel any existing timer
    if (chatClearTimer) {
      clearTimeout(chatClearTimer);
      chatClearTimer = null;
    }
    // Schedule chat clear in 20 minutes
    chatClearTimer = setTimeout(clearChatMessages, CHAT_CLEAR_DELAY);
  }
  
  function cancelChatClear() {
    if (chatClearTimer) {
      clearTimeout(chatClearTimer);
      chatClearTimer = null;
    }
  }

  // Playlist fallback: auto-play when no DJ is streaming
  async function startPlaylistFallback() {
    let playlistManager = window.playlistManager;

    // If playlist manager hasn't been loaded yet, trigger the lazy load
    // Uses the global function exposed by PlaylistModal.astro's Vite-processed script
    if (!playlistManager && typeof window.loadPlaylistModule === 'function') {
      await window.loadPlaylistModule({ silent: true });
      // Brief wait for initialization to set window.playlistManager
      await new Promise(resolve => setTimeout(resolve, 300));
      playlistManager = window.playlistManager;
    }

    if (!playlistManager) {
      return;
    }

    // Check if already playing
    if (playlistManager.isPlaying && playlistManager.queue?.length > 0) {
      await playlistManager.resume?.();
      return;
    }

    // Try to start auto-play from history
    const started = await playlistManager.startAutoPlay?.();
    if (started) {
      const offlineOverlay = document.getElementById('offlineOverlay');
      if (offlineOverlay) offlineOverlay.classList.add('hidden');
    }
  }

  function schedulePlaylistFallback() {
    // Cancel any existing timer
    cancelPlaylistFallback();
    // Schedule playlist fallback in 10 seconds
    playlistFallbackTimer = setTimeout(startPlaylistFallback, PLAYLIST_FALLBACK_DELAY);
  }

  function cancelPlaylistFallback() {
    if (playlistFallbackTimer) {
      clearTimeout(playlistFallbackTimer);
      playlistFallbackTimer = null;
    }
  }

  async function pausePlaylistForStream() {
    const playlistManager = window.playlistManager;
    if (playlistManager) {
      playlistManager.wasPausedForStream = playlistManager.isPlaying;
      // Completely stop and clear the playlist
      await playlistManager.pause?.();
      await playlistManager.clearQueue?.();
      // Hide the playlist player container
      const embedPlayer = document.getElementById('embedPlayer');
      if (embedPlayer) embedPlayer.classList.add('hidden');
      const playlistPlayer = document.getElementById('playlistPlayer');
      if (playlistPlayer) playlistPlayer.classList.add('hidden');
      // Don't show videoPlayer here - let live-stream.js decide which player to show
      // (audioPlayer for relay/audio streams, videoPlayer for HLS video streams)
    }
  }

  function getWeekStart(date) {
    const d = new Date(date);
    const day = d.getDay();
    const diff = d.getDate() - day + (day === 0 ? -6 : 1);
    d.setDate(diff);
    d.setHours(0, 0, 0, 0);
    return d;
  }
  
  function formatTime(dateStr) {
    const d = new Date(dateStr);
    return d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
  }
  
  function formatDate(dateStr) {
    const d = new Date(dateStr);
    return d.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
  }
  
  // Auth state - SINGLE CHECK, no repeated calls
  onAuthStateChanged(auth, async (user) => {
    currentUser = user;
    if (user) {
      await checkUserStatus(user.uid);
    }
    loadSchedule();
  });

  // Presence deps for module functions
  var presenceDeps = {
    escapeHtml: escapeHtml,
    getCurrentUser: function() { return currentUser; },
    getUserInfo: function() { return userInfo; },
    pausePlaylistForStream: pausePlaylistForStream,
    invalidateScheduleCache: function() { scheduleCache = null; },
    loadSchedule: loadSchedule
  };

  // Expose schedule refresh for live-stream.js Pusher events
