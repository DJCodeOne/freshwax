---
// src/pages/live.astro
// Live stream viewing page with schedule calendar, booking, and lobby system
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import LiveMiniPlayer from '../components/live/LiveMiniPlayer.astro';
import LiveChat from '../components/live/LiveChat.astro';
import LiveReactions from '../components/live/LiveReactions.astro';
import '../styles/live.css';
import ScheduleModal from '../components/ScheduleModal.astro';
import PlaylistModal from '../components/live/PlaylistModal.astro';
import { SITE_URL, FIREBASE_API_KEY } from '../lib/constants';
import { queryCollection } from '../lib/firebase-rest';

export const prerender = false;

// Firebase config for client-side scripts (with fallback)
const firebaseConfig = {
  apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY || FIREBASE_API_KEY,
  authDomain: "freshwax-store.firebaseapp.com",
  projectId: "freshwax-store",
  storageBucket: "freshwax-store.firebasestorage.app",
  messagingSenderId: "675435782973",
  appId: "1:675435782973:web:e8459c2ec4a5f6d683db54"
};

// Dynamic thumbnail URL for social sharing - shows current stream or DJ image when live
const ogImageUrl = `${SITE_URL}/api/livestream/thumbnail/`;
const nonce = Astro.locals.nonce || '';
Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=1800, stale-while-revalidate=3600');

// Fetch current or next upcoming livestream slot for MusicEvent structured data
let eventData: {
  startDate: string;
  endDate?: string;
  performer?: string;
  eventStatus?: 'EventScheduled' | 'EventRescheduled' | 'EventCancelled' | 'EventPostponed';
  eventAttendanceMode?: 'OnlineEventAttendanceMode';
} | undefined;

try {
  const now = new Date().toISOString();
  // Check for live slots first, then upcoming
  const liveSlots = await queryCollection('livestreamSlots', {
    filters: [{ field: 'status', op: 'EQUAL', value: 'live' }],
    limit: 1
  });
  const slot = liveSlots?.[0] || null;
  if (slot) {
    eventData = {
      startDate: slot.startTime || slot.bookedStart || now,
      endDate: slot.endTime || undefined,
      performer: slot.djName || slot.displayName || undefined,
      eventStatus: 'EventScheduled',
      eventAttendanceMode: 'OnlineEventAttendanceMode',
    };
  } else {
    // No live slot — check for next scheduled slot
    const upcomingSlots = await queryCollection('livestreamSlots', {
      filters: [
        { field: 'status', op: 'EQUAL', value: 'scheduled' },
        { field: 'bookedStart', op: 'GREATER_THAN_OR_EQUAL', value: now },
      ],
      orderBy: 'bookedStart',
      limit: 1,
    });
    const upcoming = upcomingSlots?.[0] || null;
    if (upcoming) {
      eventData = {
        startDate: upcoming.bookedStart || upcoming.startTime || now,
        endDate: upcoming.bookedEnd || upcoming.endTime || undefined,
        performer: upcoming.djName || upcoming.displayName || undefined,
        eventStatus: 'EventScheduled',
        eventAttendanceMode: 'OnlineEventAttendanceMode',
      };
    }
  }
} catch {
  // Non-critical — page renders fine without event structured data
}
---

<Layout
  title="Live DJ Streams - Jungle & DnB"
  description="Watch live DJ streams on Fresh Wax. Free jungle, drum & bass, and breakbeat sets from resident and guest DJs. Chat, react, and book your own slot."
  image={ogImageUrl}
  imageAlt="Fresh Wax Live Stream - Jungle and Drum & Bass DJs"
  type="video.other"
  hideShuffle={true}
  video={{
    duration: "PT0M",
    uploadDate: new Date().toISOString(),
    thumbnailUrl: ogImageUrl,
    contentUrl: `${SITE_URL}/live`,
    embedUrl: `${SITE_URL}/live/embed/`
  }}
  event={eventData}
>
  <link rel="preconnect" href="https://js.pusher.com" crossorigin slot="head" />
  <link rel="preconnect" href="https://ws-eu.pusher.com" crossorigin slot="head" />
  <link rel="preconnect" href="https://sockjs-eu.pusher.com" crossorigin slot="head" />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin slot="head" />
  <Header />
  
  <!-- Sticky Mini Player for Mobile -->
  <LiveMiniPlayer />

  <div id="fullscreenMode" class="fullscreen-mode hidden">
    <div class="fullscreen-header">
      <div class="fs-info">
        <div class="fs-live-badge is-loading" id="fsLiveBadge">
          <span class="fs-live-dot"></span>
          <span id="fsLiveStatus">LOADING...</span>
        </div>
        <p id="fsStreamTitle" class="text-2xl font-bold text-white">No Live Streams</p>
        <div class="fs-dj-info">
          <img id="fsDjAvatar" src="/place-holder.webp" alt="DJ avatar" width="40" height="40" loading="lazy" decoding="async" />
          <span id="fsDjName">-</span>
        </div>
      </div>
      <div class="fs-stats">
        <div class="fs-stat"><span>Views:</span><span id="fsViewers">0</span></div>
        <div class="fs-stat"><span>Reacts:</span><span id="fsLikes">0</span></div>
        <div class="fs-stat"><span>Time:</span><span id="fsDuration">0:00</span></div>
      </div>
      <button id="exitFullscreen" class="fs-exit-btn" aria-label="Exit fullscreen">Exit</button>
    </div>
    
    <!-- Fullscreen Controls Bar -->
    <div class="fs-controls-bar">
      <div class="fs-reactions">
        <button class="fs-reaction-btn reactions-disabled" data-emoji="❤️" title="Love" aria-label="React with love (join stream to react)" disabled>❤️</button>
        <button class="fs-reaction-btn reactions-disabled" data-emoji="🔥" title="Fire" aria-label="React with fire (join stream to react)" disabled>🔥</button>
        <button class="fs-reaction-btn reactions-disabled" data-emoji="💥" title="Explosion" aria-label="React with explosion (join stream to react)" disabled>💥</button>
        <button class="fs-reaction-btn reactions-disabled" data-emoji="⭐" title="Star" aria-label="React with star (join stream to react)" disabled>⭐</button>
        <button class="fs-reaction-btn reactions-disabled" data-emoji="🔊" title="Bass" aria-label="React with bass (join stream to react)" disabled>🔊</button>
        <button class="fs-reaction-btn reactions-disabled" data-emoji="👊" title="Fist" aria-label="React with fist bump (join stream to react)" disabled>👊</button>
        <button class="fs-reaction-btn reactions-disabled" data-emoji="👏" title="Clap" aria-label="React with clap (join stream to react)" disabled>👏</button>
        <button class="fs-reaction-btn reactions-disabled" data-emoji="🚀" title="Rocket" aria-label="React with rocket (join stream to react)" disabled>🚀</button>
        <button id="fsAnimToggleBtn" class="fs-reaction-btn fs-anim-toggle reactions-disabled" title="Turn off emoji animations" aria-label="Toggle emoji animations (join stream to react)" disabled>
          <svg class="anim-on-icon" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
          <svg class="anim-off-icon" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/></svg>
        </button>
      </div>
      <button id="fsShoutoutBtn" class="fs-shoutout-btn" title="Send a shoutout">
        <span>📣</span>
        <span>SHOUTOUT</span>
      </button>
      <div class="fs-volume">
        <svg class="fs-volume-icon" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/></svg>
        <input type="range" id="fsVolumeSlider" min="0" max="100" value="80" aria-label="Fullscreen volume" />
      </div>
    </div>
    
    <div class="fullscreen-content">
      <div class="fs-player" id="fsPlayer">
        <div class="fs-offline-overlay hidden" id="fsOfflineOverlay" style="display: none !important;">
          <div class="fs-offline-content">
            <div class="fs-offline-icon">OFFLINE</div>
            <p class="fs-offline-heading" role="status">No one is streaming right now</p>
            <p class="fs-offline-subtext" style="font-size: 0.875rem; color: #bbb; margin-top: 0.5rem;">The playlist will start in a moment</p>
          </div>
        </div>
        <div class="fs-video-container">
          <video id="fsVideo" class="fs-video hidden" controls playsinline>
            <track kind="captions" label="Captions unavailable for live content" default />
          </video>
        </div>
        <!-- Fullscreen Audio Placeholder (BUTT mode) -->
        <div id="fsAudioPlaceholder" class="fs-audio-placeholder hidden">
          <!-- Background video loop (fullscreen) -->
          <video class="stream-bg-video" autoplay muted playsinline preload="none" aria-hidden="true" data-sources="https://pub-5c0458d0721c4946884a203f2ca66ee0.r2.dev/videos/stream-bg.webm,https://pub-5c0458d0721c4946884a203f2ca66ee0.r2.dev/videos/stream-bg-2.webm" data-src-index="0">
            <source src="https://pub-5c0458d0721c4946884a203f2ca66ee0.r2.dev/videos/stream-bg.webm" type="video/webm" />
          </video>
          <!-- Branding top right -->
          <div class="fs-audio-placeholder-branding">
            <span class="brand-fresh">FRESH</span><span class="brand-wax">WAX</span>
          </div>
        </div>
      </div>
      <div class="fs-chat">
        <div class="fs-chat-header">
          <div class="fs-chat-tabs">
            <button class="fs-chat-tab active" data-chat="freshwax" aria-label="Fresh Wax chat">Fresh Wax</button>
            <button class="fs-chat-tab hidden" data-chat="twitch" id="fsTwitchChatTab" aria-label="Twitch chat">
              <svg class="twitch-icon" viewBox="0 0 24 24" fill="currentColor" width="12" height="12">
                <path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/>
              </svg>
              Twitch
            </button>
          </div>
        </div>
        <!-- Fresh Wax Chat Container -->
        <div id="fsFreshwaxChatContainer" class="fs-chat-container active">
          <div class="fs-chat-messages" id="fsChatMessages"></div>
          <div class="fs-chat-input">
            <input type="text" id="fsChatInput" placeholder="Message..." maxlength="500" aria-label="Chat message" />
            <button id="fsSendBtn">Send</button>
          </div>
        </div>
        <!-- Twitch Chat Container -->
        <div id="fsTwitchChatContainer" class="fs-chat-container hidden">
          <iframe id="fsTwitchChatFrame" class="fs-twitch-chat-frame" frameborder="0" scrolling="yes" allowfullscreen="true" title="Twitch chat"></iframe>
          <div class="fs-twitch-placeholder" id="fsTwitchPlaceholder">
            <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32">
              <path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/>
            </svg>
            <p>Twitch chat will appear when the DJ is streaming on Twitch</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Mobile Tab Navigation -->
  <nav class="mobile-tabs" id="mobileTabs" role="tablist" aria-label="Live stream tabs">
    <button class="mobile-tab active" data-tab="player" role="tab" aria-selected="true" aria-controls="tabpanel-player" id="tab-player">
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
      <span>Player</span>
    </button>
    <button class="mobile-tab" data-tab="chat" role="tab" aria-selected="false" aria-controls="tabpanel-chat" id="tab-chat" tabindex="-1">
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><path d="M21 6h-2v9H6v2c0 .55.45 1 1 1h11l4 4V7c0-.55-.45-1-1-1zm-4 6V3c0-.55-.45-1-1-1H3c-.55 0-1 .45-1 1v14l4-4h10c.55 0 1-.45 1-1z"/></svg>
      <span>Chat</span>
    </button>
    <button class="mobile-tab" data-tab="schedule" role="tab" aria-selected="false" aria-controls="tabpanel-schedule" id="tab-schedule" tabindex="-1">
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z"/></svg>
      <span>Schedule</span>
    </button>
  </nav>
  
  <div class="live-main">
    <div class="live-layout">
      <aside class="schedule-column" id="tabpanel-schedule" role="tabpanel" aria-labelledby="tab-schedule" tabindex="-1">
        <div class="schedule-header">
          <h1>LIVE <span class="red">STREAM</span></h1>
          <p>Watch live DJ sets</p>
          <div id="djButtons" class="schedule-buttons">
            <button id="goLiveNowBtn" class="go-live-now-btn">
              <span class="btn-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="3"/>
                  <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
              </span>
              <span class="btn-content">
                <span class="btn-label">Go Live</span>
                <span class="btn-sublabel">Start streaming now</span>
              </span>
            </button>
            <button id="bookSlotBtn" class="book-btn">
              <span class="btn-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                  <path d="M9 16l2 2 4-4"/>
                </svg>
              </span>
              <span class="btn-content">
                <span class="btn-label">Book Slot</span>
                <span class="btn-sublabel">Reserve your time</span>
              </span>
            </button>
          </div>
        </div>
        
        <div class="sidebar-card">
          <h2>⏭️ UP NEXT</h2>
          <div id="queueListCard" class="queue-list-card">
            <span class="empty-message">No upcoming DJs</span>
          </div>
        </div>
        
        <div class="sidebar-card schedule-card">
          <div class="schedule-header">
            <h2>TODAY'S LINEUP</h2>
            <button id="viewFullScheduleBtn" class="view-full-btn">
              View Full Schedule
            </button>
          </div>
          <div id="scheduleList" class="schedule-list">
            <p class="empty-message">No shows today</p>
          </div>
        </div>
      </aside>
      
      <div class="player-column" id="tabpanel-player" role="tabpanel" aria-labelledby="tab-player" tabindex="0">
        <div class="stream-info-bar" id="streamInfoBar">
          <div class="stream-info-left">
            <a href="/account/dj-lobby/" id="djLobbyBtn" class="dj-lobby-btn" title="Open DJ Lobby">
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true">
                <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
              </svg>
              <span>DJ Lobby</span>
            </a>
            <button id="playlistBtn" class="playlist-btn hidden">
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                <path d="M3 6h10v2H3V6zm0 4h10v2H3v-2zm0 4h7v2H3v-2zm13-4v8l6-4-6-4z"/>
              </svg>
              <span>Playlist</span>
            </button>
          </div>
          <div class="stream-info-right">
            <div class="stream-stats">
              <div class="stat"><span class="stat-icon">Views</span><span id="viewerCount">0</span></div>
              <button class="stat like-stat" id="likeStatBtn" title="React to this stream">
                <span class="stat-icon">Reacts</span><span id="likeCount">0</span>
              </button>
              <div class="stat"><span class="stat-icon">Time</span><span id="streamDuration">0:00</span></div>
            </div>
            <div class="live-badge is-loading" id="liveBadge">
              <span class="live-dot"></span>
              <span id="liveStatusText">LOADING...</span>
              <span id="onAirText" class="on-air-text hidden">On Air</span>
            </div>
          </div>
        </div>
        
        <div class="player-container" id="playerContainer">
          <!-- Duration Timer (top-right corner) -->
          <div class="np-duration-box player-timer" id="bottomDurationBox" style="display: none;">
            <span class="np-duration-label" id="bottomDurationLabel">LEFT</span>
            <span class="np-duration" id="bottomDuration">--:--</span>
          </div>
          <!-- Relay Source Attribution -->
          <div class="relay-attribution" id="relayAttribution">Relayed From The Underground Lair</div>

          <!-- Offline Overlay - shown by default, hidden when stream is active -->
          <div id="offlineOverlay" class="offline-overlay is-loading">
            <div class="offline-overlay-content">
              <div class="offline-icon-large" id="offlineIconText">LOADING...</div>
              <p class="offline-text" id="offlineMainText">Checking for active streams</p>
              <p class="offline-subtext" id="offlineSubText">Please wait...</p>
            </div>
          </div>
          
          <div id="countdownOverlay" class="countdown-overlay hidden">
            <div class="countdown-content">
              <h2>NEXT DJ STARTING SOON</h2>
              <div class="countdown-dj">
                <img id="countdownDjAvatar" src="/place-holder.webp" alt="Next DJ avatar" class="countdown-avatar" width="48" height="48" loading="lazy" decoding="async" />
                <span id="countdownDjName">-</span>
              </div>
              <div class="countdown-timer">
                <span class="countdown-label">Going live in</span>
                <span id="countdownTime" class="countdown-value">0:60</span>
              </div>
              <div class="countdown-bar">
                <div id="countdownProgress" class="countdown-progress"></div>
              </div>
            </div>
          </div>

          <!-- Initializing Overlay - shown while stream connects, hidden after audio plays or 10s -->
          <div id="initializingOverlay" class="initializing-overlay">
            <div class="initializing-content">
              <div class="initializing-spinner"></div>
              <h2 class="initializing-title">CONNECTING</h2>
              <p class="initializing-text">Initializing audio stream...</p>
              <p class="initializing-subtext">This may take a few seconds. Please be patient while we link up to the servers.</p>
              <div class="initializing-bars">
                <div class="init-bar"></div>
                <div class="init-bar"></div>
                <div class="init-bar"></div>
                <div class="init-bar"></div>
                <div class="init-bar"></div>
              </div>
            </div>
          </div>
          <!-- Inline fallback script to ensure overlays always hide -->
          <script>
            (function() {
              var initOverlay = document.getElementById('initializingOverlay');
              var offlineOverlay = document.getElementById('offlineOverlay');

              // Fade both overlays after 5 seconds
              setTimeout(function() {
                if (initOverlay && !initOverlay.classList.contains('hidden')) {
                  initOverlay.classList.add('fade-out');
                }
                if (offlineOverlay && offlineOverlay.classList.contains('is-loading')) {
                  offlineOverlay.style.opacity = '0';
                  offlineOverlay.style.transition = 'opacity 0.5s ease-out';
                }
              }, 5000);

              // Force hide both overlays after 10 seconds
              setTimeout(function() {
                if (initOverlay) {
                  initOverlay.classList.add('hidden');
                  initOverlay.style.display = 'none';
                }
                if (offlineOverlay && offlineOverlay.classList.contains('is-loading')) {
                  offlineOverlay.classList.add('hidden');
                  offlineOverlay.style.display = 'none';
                }
              }, 10000);
            })();
          </script>

          <div id="audioPlayer" class="audio-player hidden">
            <div class="audio-only-placeholder">
              <!-- Background video loop -->
              <video class="stream-bg-video" autoplay muted playsinline preload="none" aria-hidden="true" data-sources="https://pub-5c0458d0721c4946884a203f2ca66ee0.r2.dev/videos/stream-bg.webm,https://pub-5c0458d0721c4946884a203f2ca66ee0.r2.dev/videos/stream-bg-2.webm" data-src-index="0">
                <source src="https://pub-5c0458d0721c4946884a203f2ca66ee0.r2.dev/videos/stream-bg.webm" type="video/webm" />
              </video>
              <!-- Branding top right -->
              <div class="audio-placeholder-branding">
                <span class="brand-fresh">FRESH</span><span class="brand-wax">WAX</span>
              </div>
            </div>
            <audio id="audioElement" crossorigin="anonymous" preload="auto" aria-label="Live stream audio"></audio>
          </div>

          <!-- Video Player (for both live stream and playlist) -->
