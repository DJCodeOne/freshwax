---
// src/pages/404.astro
// Custom 404 error page - music-themed, accessible, lightweight
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=1800');
Astro.response.status = 404;
---

<Layout title="Page Not Found" description="Page not found - the page you're looking for doesn't exist on Fresh Wax" noindex={true}>
  <Header />

  <div class="error-page" role="region" aria-labelledby="error-heading">
    <div class="error-container">
      <!-- Vinyl record icon -->
      <div class="error-icon" aria-hidden="true">
        <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="60" cy="60" r="56" stroke="#333" stroke-width="2" />
          <circle cx="60" cy="60" r="48" stroke="#222" stroke-width="1" />
          <circle cx="60" cy="60" r="40" stroke="#222" stroke-width="1" />
          <circle cx="60" cy="60" r="32" stroke="#222" stroke-width="1" />
          <circle cx="60" cy="60" r="18" stroke="#333" stroke-width="2" />
          <circle cx="60" cy="60" r="6" fill="#ef4444" />
          <!-- Scratch mark -->
          <line x1="30" y1="30" x2="90" y2="90" stroke="#ef4444" stroke-width="1.5" stroke-dasharray="4 8" opacity="0.6" />
        </svg>
      </div>

      <h1 id="error-heading">Track Not Found</h1>
      <p class="error-code" aria-label="Error 404">404</p>
      <p class="error-message">This page seems to have slipped out of the crate.</p>
      <p class="error-sub">The page you were looking for doesn't exist, may have been moved, or the URL might be misspelt.</p>

      <!-- Search box -->
      <div class="error-search">
        <form action="/releases/" method="get" role="search" aria-label="Search the store">
          <div class="search-wrapper">
            <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              name="q"
              placeholder="Search releases, artists, merch..."
              class="search-input"
              autocomplete="off"
              aria-label="Search releases, artists, and merchandise"
            />
            <button type="submit" class="search-btn">Search</button>
          </div>
        </form>
      </div>

      <div class="error-actions">
        <a href="/" class="cta-btn">Back to Home</a>
        <a href="/releases/" class="cta-btn secondary">Browse Releases</a>
      </div>

      <nav class="error-links" aria-label="Popular pages">
        <p>Popular pages you might be looking for:</p>
        <ul class="link-grid" role="list">
          <li><a href="/releases/">New Releases</a></li>
          <li><a href="/weekly-chart/">Weekly Chart</a></li>
          <li><a href="/dj-mixes/">DJ Mixes</a></li>
          <li><a href="/merch/">Merchandise</a></li>
          <li><a href="/live/">Live Stream</a></li>
          <li><a href="/giftcards/">Gift Cards</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/contact/">Contact Us</a></li>
        </ul>
      </nav>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  .error-page {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    background: linear-gradient(180deg, #0a0a0a 0%, #111 100%);
  }

  .error-container {
    text-align: center;
    max-width: 640px;
    width: 100%;
  }

  .error-icon {
    width: 100px;
    height: 100px;
    margin: 0 auto 1.5rem;
    opacity: 0.7;
    animation: spin 8s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .error-icon {
      animation: none;
    }
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 0.5rem;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .error-code {
    font-size: 1rem;
    font-weight: 600;
    color: #ef4444;
    margin: 0 0 1.25rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .error-message {
    font-size: 1.25rem;
    color: #ccc;
    margin: 0 0 0.5rem;
    line-height: 1.4;
  }

  .error-sub {
    font-size: 0.95rem;
    color: #777;
    margin: 0 0 2rem;
    line-height: 1.5;
  }

  /* Search box */
  .error-search {
    margin-bottom: 2rem;
  }

  .search-wrapper {
    display: flex;
    align-items: center;
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .search-wrapper:focus-within {
    border-color: #ef4444;
  }

  .search-icon {
    width: 20px;
    height: 20px;
    margin-left: 1rem;
    color: #999;
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 0.875rem 0.75rem;
    color: #fff;
    font-size: 0.95rem;
  }

  .search-input:focus:not(:focus-visible) {
    outline: none;
  }

  .search-input:focus-visible {
    outline: 2px solid #60a5fa;
    outline-offset: 2px;
  }

  .search-input::placeholder {
    color: #555;
  }

  .search-btn {
    background: #ef4444;
    color: #fff;
    border: none;
    padding: 0.875rem 1.25rem;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.2s;
    flex-shrink: 0;
  }

  .search-btn:hover {
    background: #dc2626;
  }

  /* Action buttons */
  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .cta-btn {
    display: inline-block;
    padding: 0.875rem 2rem;
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    border-radius: 8px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    font-size: 0.95rem;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(239, 68, 68, 0.3);
  }

  .cta-btn.secondary {
    background: transparent;
    border: 1px solid #333;
    color: #ccc;
  }

  .cta-btn.secondary:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: #555;
    box-shadow: none;
  }

  /* Navigation links */
  .error-links {
    padding-top: 2rem;
    border-top: 1px solid #1e1e1e;
  }

  .error-links p {
    color: #999;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .link-grid {
    display: flex;
    gap: 0.5rem 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .link-grid a {
    color: #888;
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.25rem 0;
    transition: color 0.2s;
  }

  .link-grid a:hover {
    color: #ef4444;
  }

  @media (max-width: 480px) {
    .error-page {
      padding: 2rem 1rem;
    }

    h1 {
      font-size: 2rem;
    }

    .error-message {
      font-size: 1.1rem;
    }

    .error-actions {
      flex-direction: column;
    }

    .cta-btn {
      width: 100%;
      text-align: center;
    }

    .search-btn {
      padding: 0.875rem 1rem;
    }
  }
</style>
