---
// Artist Releases - Pro Dashboard
// View, edit, and manage releases
import ProDashboardLayout from '../../../layouts/ProDashboardLayout.astro';
Astro.response.headers.set('Cache-Control', 'private, no-cache, no-store, must-revalidate');
---
<ProDashboardLayout title="My Releases" activeSection="/pro/releases">
  <div class="releases-page">
    <div class="page-header">
      <div class="header-content">
        <p class="subtitle">Manage your music releases on Fresh Wax</p>
      </div>
      <a href="/pro/releases/new/" class="btn btn-primary">
        <span>+</span> New Release
      </a>
    </div>

    <!-- Filters -->
    <div class="filters-bar">
      <div class="filter-tabs">
        <button class="filter-tab active" data-status="all">All</button>
        <button class="filter-tab" data-status="live">Live</button>
        <button class="filter-tab" data-status="pending">Pending</button>
        <button class="filter-tab" data-status="draft">Drafts</button>
      </div>
      <div class="search-box">
        <input type="text" id="searchInput" placeholder="Search releases..." aria-label="Search releases">
      </div>
    </div>

    <!-- Releases List -->
    <div id="releasesList" class="releases-list">
      <div class="loading">Loading releases...</div>
    </div>

    <!-- Empty State -->
    <div id="emptyState" class="empty-state" style="display: none;">
      <div class="empty-icon">📀</div>
      <h3>No releases yet</h3>
      <p>Upload your first release to start selling on Fresh Wax</p>
      <a href="/pro/releases/new/" class="btn btn-primary">Upload Release</a>
    </div>
  </div>

  <style>
    .releases-page {
      max-width: 1200px;
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.5rem;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .header-content .subtitle {
      color: var(--text-secondary, #a3a3a3);
      margin: 0;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.25rem;
      border-radius: 8px;
      font-weight: 600;
      text-decoration: none;
      transition: background-color 0.2s, color 0.2s, box-shadow 0.2s, transform 0.2s;
      border: none;
      cursor: pointer;
    }

    .btn-primary {
      background: var(--accent, #22c55e);
      color: #000;
    }

    .btn-primary:hover {
      background: var(--accent-hover, #16a34a);
    }

    .filters-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    .filter-tabs {
      display: flex;
      gap: 0.5rem;
    }

    .filter-tab {
      padding: 0.5rem 1rem;
      background: var(--bg-secondary, #141414);
      border: 1px solid var(--border-color, #262626);
      border-radius: 6px;
      color: var(--text-secondary, #a3a3a3);
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }

    .filter-tab:hover {
      color: var(--text-primary, #fff);
      border-color: var(--text-secondary, #a3a3a3);
    }

    .filter-tab.active {
      background: var(--accent, #22c55e);
      color: #000;
      border-color: var(--accent, #22c55e);
    }

    .search-box input {
      padding: 0.5rem 1rem;
      background: var(--bg-secondary, #141414);
      border: 1px solid var(--border-color, #262626);
      border-radius: 6px;
      color: var(--text-primary, #fff);
      width: 250px;
    }

    .search-box input:focus {
      outline: none;
      border-color: var(--accent, #22c55e);
    }

    .search-box input:focus-visible {
      outline: 2px solid #60a5fa;
      outline-offset: 2px;
    }

    .releases-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .loading {
      text-align: center;
      padding: 3rem;
      color: var(--text-secondary, #a3a3a3);
    }

    .release-card {
      display: grid;
      grid-template-columns: 80px 1fr auto;
      gap: 1rem;
      padding: 1rem;
      background: var(--bg-secondary, #141414);
      border: 1px solid var(--border-color, #262626);
      border-radius: 8px;
      align-items: center;
      transition: border-color 0.2s;
    }

    .release-card:hover {
      border-color: var(--accent, #22c55e);
    }

    .release-artwork {
      width: 80px;
      height: 80px;
      border-radius: 6px;
      object-fit: cover;
      background: var(--bg-tertiary, #1a1a1a);
    }

    .release-info {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .release-title {
      font-weight: 600;
      color: var(--text-primary, #fff);
    }

    .release-meta {
      font-size: 0.85rem;
      color: var(--text-secondary, #a3a3a3);
    }

    .release-stats {
      display: flex;
      gap: 1rem;
      font-size: 0.8rem;
      color: var(--text-muted, #666);
      margin-top: 0.25rem;
    }

    .release-status {
      display: inline-block;
      padding: 0.2rem 0.6rem;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
    }

    .status-live {
      background: rgba(34, 197, 94, 0.2);
      color: #22c55e;
    }

    .status-pending {
      background: rgba(251, 191, 36, 0.2);
      color: #fbbf24;
    }

    .status-draft {
      background: rgba(156, 163, 175, 0.2);
      color: #d1d5db;
    }

    .status-rejected {
      background: rgba(239, 68, 68, 0.2);
      color: #ef4444;
    }

    .release-actions {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    .release-card.has-shipping {
      grid-template-columns: 80px 1fr auto;
      grid-template-rows: auto auto;
    }

    .shipping-edit {
      grid-column: 1 / -1;
      display: none;
      padding: 1rem;
      margin-top: 0.75rem;
      background: var(--bg-tertiary, #1a1a1a);
      border: 1px solid var(--border-color, #262626);
      border-radius: 6px;
    }

    .shipping-edit.open {
      display: block;
    }

    .shipping-edit h4 {
      margin: 0 0 0.5rem;
      font-size: 0.9rem;
      color: var(--text-primary, #fff);
    }

    .shipping-edit .hint {
      font-size: 0.78rem;
      color: var(--text-muted, #666);
      margin-bottom: 0.75rem;
      line-height: 1.4;
    }

    .shipping-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .shipping-row label {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      font-size: 0.8rem;
      color: var(--text-secondary, #a3a3a3);
    }

    .shipping-row input {
      padding: 0.5rem 0.65rem;
      background: var(--bg-secondary, #141414);
      border: 1px solid var(--border-color, #262626);
      border-radius: 4px;
      color: var(--text-primary, #fff);
      font-size: 0.9rem;
    }

    .shipping-row input:focus {
      outline: none;
      border-color: var(--accent, #22c55e);
    }

    .shipping-actions {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    .shipping-actions .status {
      font-size: 0.8rem;
      color: var(--text-muted, #666);
      margin-left: auto;
    }

    .shipping-actions .status.ok {
      color: #22c55e;
    }

    .shipping-actions .status.err {
      color: #ef4444;
    }

    @media (max-width: 640px) {
      .shipping-row {
        grid-template-columns: 1fr;
      }
    }

    .parts-edit {
      grid-column: 1 / -1;
      display: none;
      padding: 1rem;
      margin-top: 0.75rem;
      background: var(--bg-tertiary, #1a1a1a);
      border: 1px solid var(--border-color, #262626);
      border-radius: 6px;
    }

    .parts-edit.open {
      display: block;
    }

    .parts-edit h4 {
      margin: 0 0 0.5rem;
      font-size: 0.9rem;
      color: var(--text-primary, #fff);
    }

    .parts-edit .hint {
      font-size: 0.78rem;
      color: var(--text-muted, #666);
      margin-bottom: 0.75rem;
      line-height: 1.4;
    }

    .part-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto auto auto;
      gap: 0.75rem;
      align-items: end;
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--border-color, #262626);
    }

    .part-row:last-of-type {
      border-bottom: none;
      margin-bottom: 0.5rem;
    }

    .part-row .part-name {
      font-weight: 600;
      color: var(--text-primary, #fff);
      font-size: 0.9rem;
    }

    .part-row label {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      font-size: 0.75rem;
      color: var(--text-secondary, #a3a3a3);
    }

    .part-row input[type="number"] {
      padding: 0.4rem 0.55rem;
      background: var(--bg-secondary, #141414);
      border: 1px solid var(--border-color, #262626);
      border-radius: 4px;
      color: var(--text-primary, #fff);
      font-size: 0.9rem;
      width: 80px;
    }

    .part-row input[type="number"]:focus {
      outline: none;
      border-color: var(--accent, #22c55e);
    }

    .part-row .pressed-toggle {
      flex-direction: row;
      align-items: center;
      gap: 0.4rem;
      color: var(--text-primary, #fff);
      font-size: 0.85rem;
      padding-bottom: 0.4rem;
    }

    @media (max-width: 640px) {
      .part-row {
        grid-template-columns: 1fr 1fr;
      }
      .part-row .part-name {
        grid-column: 1 / -1;
      }
      .part-row .pressed-toggle {
        grid-column: 1 / -1;
      }
    }

    .action-btn {
      padding: 0.5rem 0.75rem;
      background: var(--bg-tertiary, #1a1a1a);
      border: 1px solid var(--border-color, #262626);
      border-radius: 6px;
      color: var(--text-secondary, #a3a3a3);
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s;
      text-decoration: none;
      font-size: 0.85rem;
    }

    .action-btn:hover {
      color: var(--text-primary, #fff);
      border-color: var(--text-secondary, #a3a3a3);
    }

    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      background: var(--bg-secondary, #141414);
      border: 1px dashed var(--border-color, #262626);
      border-radius: 8px;
    }

    .empty-icon {
      font-size: 3rem;
      margin-bottom: 1rem;
    }

    .empty-state h3 {
      color: var(--text-primary, #fff);
      margin-bottom: 0.5rem;
    }

    .empty-state p {
      color: var(--text-secondary, #a3a3a3);
      margin-bottom: 1.5rem;
    }

    @media (max-width: 640px) {
      .release-card {
        grid-template-columns: 60px 1fr;
      }

      .release-actions {
        grid-column: 1 / -1;
        justify-content: flex-end;
      }

      .release-artwork {
        width: 60px;
        height: 60px;
      }
    }
  </style>

  <script type="module">
    function escapeHtml(s){if(typeof s!=='string')return '';return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,"&#39;");}
    import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js';
    import { getAuth, onAuthStateChanged } from 'https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js';

    const firebaseConfig = window.FIREBASE_CONFIG || {};
    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);

    const releasesList = document.getElementById('releasesList');
    const emptyState = document.getElementById('emptyState');
    const filterTabs = document.querySelectorAll('.filter-tab');
    const searchInput = document.getElementById('searchInput');

    let allReleases = [];
    let currentFilter = 'all';

    onAuthStateChanged(auth, async (user) => {
      if (!user) return;
      await loadReleases(user);
    });

    async function loadReleases(user) {
      try {
        const idToken = await user.getIdToken();
        const response = await fetch('/api/pro/dashboard-data/?type=releases', {
          headers: { 'Authorization': `Bearer ${idToken}` }
        });
        if (!response.ok) throw new Error('Load releases failed: ' + response.status);
        const data = await response.json();

        if (!data.success) throw new Error(data.error || 'Failed to load releases');

        allReleases = data.releases || [];
        renderReleases();
      } catch (error) {
        console.error('Error loading releases:', error);
        releasesList.innerHTML = '<div class="loading">Error loading releases</div>';
      }
    }

    function renderReleases() {
      const searchTerm = searchInput.value.toLowerCase();
      
      let filtered = allReleases.filter(release => {
        // Status filter
        if (currentFilter !== 'all') {
          if (currentFilter === 'live' && release.status !== 'approved' && release.status !== 'live') return false;
          if (currentFilter === 'pending' && release.status !== 'pending') return false;
          if (currentFilter === 'draft' && release.status !== 'draft') return false;
        }

        // Search filter
        if (searchTerm) {
          const title = (release.title || '').toLowerCase();
          const artist = (release.artistName || '').toLowerCase();
          if (!title.includes(searchTerm) && !artist.includes(searchTerm)) return false;
        }

        return true;
      });

      if (filtered.length === 0) {
        releasesList.style.display = 'none';
        emptyState.style.display = 'block';
        return;
      }

      emptyState.style.display = 'none';
      releasesList.style.display = 'flex';

      releasesList.innerHTML = filtered.map(release => {
        const statusClass = release.status === 'approved' || release.status === 'live' ? 'status-live' :
                           release.status === 'pending' ? 'status-pending' :
                           release.status === 'rejected' ? 'status-rejected' : 'status-draft';
        const statusText = release.status === 'approved' ? 'live' : release.status || 'draft';
        const isVinyl = release.vinylRelease === true;
        const ukVal = release.vinylShippingUK != null ? release.vinylShippingUK : '';
        const euVal = release.vinylShippingEU != null ? release.vinylShippingEU : '';
        const intlVal = release.vinylShippingIntl != null ? release.vinylShippingIntl : '';
        const shippingEditor = isVinyl ? `
          <div class="shipping-edit" data-shipping-for="${release.id}">
            <h4>Vinyl shipping rates</h4>
            <p class="hint">Leave a field blank to use your account default (set on <a href="/artist/account/#vinyl-shipping-section">your account page</a>). Enter 0 for free shipping.</p>
            <div class="shipping-row">
              <label>UK (£)<input type="number" step="0.01" min="0" max="999" data-region="UK" value="${ukVal}"></label>
              <label>EU (£)<input type="number" step="0.01" min="0" max="999" data-region="EU" value="${euVal}"></label>
              <label>International (£)<input type="number" step="0.01" min="0" max="999" data-region="Intl" value="${intlVal}"></label>
            </div>
            <div class="shipping-actions">
              <button class="action-btn" data-action="save-shipping">Save shipping</button>
              <span class="status"></span>
            </div>
          </div>
        ` : '';
        const parts = Array.isArray(release.vinylParts) ? release.vinylParts : [];
        const hasParts = parts.length > 0;
        const partsEditor = hasParts ? `
          <div class="parts-edit" data-parts-for="${release.id}">
            <h4>Vinyl parts</h4>
            <p class="hint">Edit stock + price for each pressed part. Toggle "Pressed" off until that part is finished — buyers will see "Coming soon" instead of being able to buy it.</p>
            ${parts.map((p, idx) => {
              const partId = 'part-' + (idx + 1);
              const priceVal = p.price != null ? p.price : '';
              const stockVal = p.stock != null ? p.stock : '';
              return `
                <div class="part-row" data-part-id="${partId}">
                  <span class="part-name">${escapeHtml(p.name || ('Part ' + (idx + 1)))}</span>
                  <label>Price (£)<input type="number" step="0.01" min="0" max="999" data-field="price" value="${priceVal}"></label>
                  <label>Stock<input type="number" step="1" min="0" max="99999" data-field="stock" value="${stockVal}"></label>
                  <label class="pressed-toggle"><input type="checkbox" data-field="pressed"${p.pressed ? ' checked' : ''}> Pressed</label>
                </div>
              `;
            }).join('')}
            <div class="shipping-actions">
              <button class="action-btn" data-action="save-parts">Save parts</button>
              <span class="status"></span>
            </div>
          </div>
        ` : '';
        return `
          <div class="release-card${isVinyl ? ' has-shipping' : ''}" data-id="${release.id}">
            <img src="${escapeHtml(release.artwork || '/place-holder.webp')}" alt="${escapeHtml(release.title)}" class="release-artwork" width="100" height="100" loading="lazy">
            <div class="release-info">
              <div class="release-title">${escapeHtml(release.title || 'Untitled')}</div>
              <div class="release-meta">${escapeHtml(release.artistName || 'Unknown Artist')} • ${release.trackCount || 0} tracks</div>
              <div class="release-stats">
                <span>💰 ${release.salesCount || 0} sales</span>
                <span>▶️ ${release.plays || 0} plays</span>
              </div>
            </div>
            <div class="release-actions">
              <span class="release-status ${statusClass}">${statusText}</span>
              ${hasParts ? `<button class="action-btn" data-action="toggle-parts">Parts</button>` : ''}
              ${isVinyl ? `<button class="action-btn" data-action="toggle-shipping">Shipping</button>` : ''}
              <a href="/item/${release.id}/" class="action-btn" target="_blank" rel="noopener noreferrer">View</a>
            </div>
            ${partsEditor}
            ${shippingEditor}
          </div>
        `;
      }).join('');

      attachShippingHandlers();
      attachPartsHandlers();
    }

    function attachShippingHandlers() {
      releasesList.querySelectorAll('[data-action="toggle-shipping"]').forEach(btn => {
        btn.addEventListener('click', () => {
          const card = btn.closest('.release-card');
          const edit = card?.querySelector('.shipping-edit');
          if (edit) edit.classList.toggle('open');
        });
      });
      releasesList.querySelectorAll('[data-action="save-shipping"]').forEach(btn => {
        btn.addEventListener('click', async () => {
          const editor = btn.closest('.shipping-edit');
          const card = btn.closest('.release-card');
          if (!editor || !card) return;
          const releaseId = card.dataset.id;
          const status = editor.querySelector('.status');
          const inputs = editor.querySelectorAll('input[data-region]');
          const payload = { releaseId };
          let invalid = false;
          inputs.forEach(input => {
            const region = input.dataset.region;
            const raw = input.value.trim();
            const key = region === 'UK' ? 'vinylShippingUK' : region === 'EU' ? 'vinylShippingEU' : 'vinylShippingIntl';
            if (raw === '') {
              payload[key] = null;
            } else {
              const num = parseFloat(raw);
              if (!Number.isFinite(num) || num < 0 || num > 999) { invalid = true; return; }
              payload[key] = num;
            }
          });
          if (invalid) {
            status.textContent = 'Invalid amount';
            status.className = 'status err';
            return;
          }
          btn.disabled = true;
          status.textContent = 'Saving...';
          status.className = 'status';
          try {
            const user = auth.currentUser;
            if (!user) throw new Error('Not signed in');
            const idToken = await user.getIdToken();
            const r = await fetch('/api/pro/update-release-shipping/', {
              method: 'POST',
              headers: { 'Authorization': `Bearer ${idToken}`, 'Content-Type': 'application/json' },
              body: JSON.stringify(payload)
            });
            const data = await r.json();
            if (!r.ok || !data.success) throw new Error(data.error || 'Save failed');
            status.textContent = 'Saved';
            status.className = 'status ok';
            // Update local cache so re-renders show the new values
            const local = allReleases.find(rel => rel.id === releaseId);
            if (local && data.shipping) {
              local.vinylShippingUK = data.shipping.vinylShippingUK;
              local.vinylShippingEU = data.shipping.vinylShippingEU;
              local.vinylShippingIntl = data.shipping.vinylShippingIntl;
            }
          } catch (e) {
            status.textContent = e instanceof Error ? e.message : 'Save failed';
            status.className = 'status err';
          } finally {
            btn.disabled = false;
          }
        });
      });
    }

    function attachPartsHandlers() {
      releasesList.querySelectorAll('[data-action="toggle-parts"]').forEach(btn => {
        btn.addEventListener('click', () => {
          const card = btn.closest('.release-card');
          const edit = card?.querySelector('.parts-edit');
          if (edit) edit.classList.toggle('open');
        });
      });
      releasesList.querySelectorAll('[data-action="save-parts"]').forEach(btn => {
        btn.addEventListener('click', async () => {
          const editor = btn.closest('.parts-edit');
          const card = btn.closest('.release-card');
          if (!editor || !card) return;
          const releaseId = card.dataset.id;
          const status = editor.querySelector('.status');
          const rows = editor.querySelectorAll('.part-row');
          const partUpdates = [];
          let invalid = false;
          rows.forEach(row => {
            const partId = row.dataset.partId;
            const priceRaw = row.querySelector('input[data-field="price"]').value.trim();
            const stockRaw = row.querySelector('input[data-field="stock"]').value.trim();
            const pressed = row.querySelector('input[data-field="pressed"]').checked;
            const upd = { partId };
            if (priceRaw !== '') {
              const num = parseFloat(priceRaw);
              if (!Number.isFinite(num) || num < 0 || num > 999) { invalid = true; return; }
              upd.price = num;
            }
            if (stockRaw !== '') {
              const num = parseInt(stockRaw, 10);
              if (!Number.isFinite(num) || num < 0 || num > 99999) { invalid = true; return; }
              upd.stock = num;
            }
            upd.pressed = pressed;
            partUpdates.push(upd);
          });
          if (invalid) {
            status.textContent = 'Invalid value';
            status.className = 'status err';
            return;
          }
          btn.disabled = true;
          status.textContent = 'Saving...';
          status.className = 'status';
          try {
            const user = auth.currentUser;
            if (!user) throw new Error('Not signed in');
            const idToken = await user.getIdToken();
            const r = await fetch('/api/pro/update-release-vinyl-parts/', {
              method: 'POST',
              headers: { 'Authorization': `Bearer ${idToken}`, 'Content-Type': 'application/json' },
              body: JSON.stringify({ releaseId, parts: partUpdates })
            });
            const data = await r.json();
            if (!r.ok || !data.success) throw new Error(data.error || 'Save failed');
            status.textContent = 'Saved';
            status.className = 'status ok';
            const local = allReleases.find(rel => rel.id === releaseId);
            if (local && Array.isArray(data.parts)) {
              data.parts.forEach((p, i) => {
                if (!local.vinylParts || !local.vinylParts[i]) return;
                local.vinylParts[i].price = p.price;
                local.vinylParts[i].stock = p.stock;
                local.vinylParts[i].pressed = p.pressed;
              });
            }
          } catch (e) {
            status.textContent = e instanceof Error ? e.message : 'Save failed';
            status.className = 'status err';
          } finally {
            btn.disabled = false;
          }
        });
      });
    }

    // Filter tabs
    filterTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        filterTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        currentFilter = tab.dataset.status;
        renderReleases();
      });
    });

    // Search
    searchInput.addEventListener('input', () => {
      renderReleases();
    });
  </script>
</ProDashboardLayout>
