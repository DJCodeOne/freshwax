---
// src/pages/checkout.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/checkout.css';

export const prerender = false;
const nonce = Astro.locals.nonce || '';
Astro.response.headers.set('Cache-Control', 'private, no-store, no-cache, must-revalidate, max-age=0');
---

<Layout title="Checkout" description="Secure checkout for Fresh Wax vinyl records, digital downloads, DJ mixes and merchandise. Pay with Stripe or PayPal." noindex={true}>
  <Fragment slot="head">
    <link rel="dns-prefetch" href="https://js.stripe.com" />
    <link rel="dns-prefetch" href="https://www.paypal.com" />
    <link rel="preconnect" href="https://js.stripe.com" crossorigin />
    <link rel="preconnect" href="https://www.paypal.com" crossorigin />
  </Fragment>
  <Header />

  <div class="checkout-main">

    <!-- Page Header -->
    <div class="page-header-container">
      <div class="page-header-pattern"></div>
      <header class="checkout-header">
        <h1>CHECK<span class="red">OUT</span></h1>
        <a href="/cart/" class="back-btn">← Back to Bag</a>
      </header>
    </div>

    <!-- PayPal SDK loaded dynamically when needed -->

    <div id="error-message" class="error-message" role="alert" aria-live="assertive"></div>

    <div id="checkout-content">
      <div class="loading-state">
        <div class="loading-spinner"></div>
        <span>Loading your cart...</span>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  import { init } from '../lib/checkout-client';
  document.addEventListener('astro:page-load', init);
</script>

<script is:inline src="/email-verify-check.js" defer nonce={nonce}></script>
