---
// src/pages/releases.astro
// OPTIMIZED: Uses D1 first with Firebase REST API fallback
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ReleasePlate from '../components/ReleasePlate.astro';
import { getLiveReleases } from '../lib/firebase-rest';
import { createLogger } from '../lib/api-utils';

const log = createLogger('releases-page');

// Fetch all live releases — D1 primary, Firebase fallback
// KV-cached for 10 minutes so DB is only hit infrequently
const db = (Astro.locals as App.Locals).runtime?.env?.DB;
let allReleases: Record<string, unknown>[] = [];
try {
  allReleases = await getLiveReleases(undefined, db);
} catch (e: unknown) {
  log.error('Failed to fetch releases:', e);
}

// Group releases by label locally
const releasesByLabel: Record<string, Record<string, unknown>[]> = {};
for (const release of allReleases) {
  const label = release.labelName || release.recordLabel || release.copyrightHolder || 'Unknown Label';
  if (!releasesByLabel[label]) {
    releasesByLabel[label] = [];
  }
  releasesByLabel[label].push(release);
}

// Sort each label's releases by catalog/label code
for (const label of Object.keys(releasesByLabel)) {
  releasesByLabel[label].sort((a, b) => {
    const codeA = a.catalogNumber || a.labelCode || '';
    const codeB = b.catalogNumber || b.labelCode || '';
    return codeA.localeCompare(codeB);
  });
}

// Sort labels alphabetically
const sortedLabels = Object.keys(releasesByLabel).sort((a, b) => {
  if (a === 'Unknown Label') return 1;
  if (b === 'Unknown Label') return -1;
  return a.localeCompare(b);
});

const totalReleases = Object.values(releasesByLabel).reduce((sum, releases) => sum + releases.length, 0);

Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=300, stale-while-revalidate=600');

// Preload the first visible release cover image for faster LCP
const firstLabel = sortedLabels[0];
const firstCoverArt = firstLabel ? releasesByLabel[firstLabel]?.[0]?.coverArtUrl : null;

// Build ItemList structured data for SEO (all releases flattened)
let itemPosition = 0;
const releaseItemList = {
  name: 'All Releases - Jungle & DnB Music',
  items: sortedLabels.flatMap(label =>
    releasesByLabel[label].map(r => ({
      name: `${r.releaseName || 'Untitled'} - ${r.artistName || 'Unknown Artist'}`,
      url: `/item/${r.id}/`,
      image: r.coverArtUrl || undefined,
      position: ++itemPosition,
    }))
  )
};
---

<Layout title="All Releases - Jungle & DnB Music" description="Browse all jungle and drum & bass releases on Fresh Wax. Shop vinyl, digital downloads, and discover new and classic tracks from underground labels." itemList={releaseItemList}>
  {firstCoverArt && <link rel="preload" href={firstCoverArt} as="image" slot="head" />}
  <Header />
  
  <!-- Background Image -->
  <div class="bg-image-overlay"></div>

  <div class="flex min-h-screen" style="background: transparent;">
    
    <!-- Left Sidebar Navigation (hidden - replaced by dropdown in header) -->
    <aside aria-label="Filter by label" class="w-80 bg-gradient-to-b from-gray-800 to-gray-900 border-r-2 border-white sticky top-[73px] h-[calc(100vh-73px)] overflow-y-auto flex-shrink-0 hidden shadow-2xl">
      <div class="p-6">
        <!-- Header -->
        <div class="mb-6 pt-6 pb-6 border-t-2 border-b-2 border-red-600">
          <div class="text-2xl font-black text-white mb-2 tracking-tight uppercase drop-shadow-lg font-heading">
            Labels
          </div>
          <p class="text-sm text-gray-300">
            {sortedLabels.length} label{sortedLabels.length !== 1 ? 's' : ''} • {totalReleases} release{totalReleases !== 1 ? 's' : ''}
          </p>
        </div>
        
        <!-- Labels Navigation -->
        <nav aria-label="Release labels" class="space-y-1">
          {sortedLabels.map((label) => (
            <a 
              href={`#label-${label.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
              class="label-nav-link flex items-center justify-between p-3 rounded-lg hover:bg-white/10 transition-[background-color,border-color] group border-2 border-transparent hover:border-white"
              data-label-id={`label-${label.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
            >
              <div class="flex-1 min-w-0">
                <div class="text-sm font-bold text-white truncate group-hover:text-white transition-colors">
                  {label}
                </div>
                <div class="text-xs text-gray-300 mt-0.5">
                  {releasesByLabel[label].length} release{releasesByLabel[label].length !== 1 ? 's' : ''}
                </div>
              </div>
              <svg class="w-4 h-4 text-gray-300 group-hover:text-white transition-colors flex-shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          ))}
        </nav>
      </div>
    </aside>

    <!-- Main Content Area - FIXED WIDTH -->
    <div class="flex-1 min-w-0 px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
      <div class="max-w-6xl mx-auto w-full" aria-live="polite">
        <!-- Page Header -->
        <header class="mb-12">
          <div class="releases-header">
            <div class="releases-title-row">
              <div class="releases-header-line"></div>
              <h1 class="releases-title">All Releases</h1>
              <div class="releases-header-line"></div>
            </div>
            <p class="releases-subtitle releases-subtitle-desktop">
              Explore the library organised by label
            </p>
            <p class="releases-subtitle releases-subtitle-mobile">
              Explore the library
            </p>
            <p class="releases-count">
              {totalReleases} releases
            </p>
            <div class="releases-divider"></div>
          </div>
          <!-- Label Selector — below hero -->
          <div class="label-dropdown-wrap">
            <div class="label-dropdown-container">
              <select id="label-select" class="label-dropdown" aria-label="Select a label to jump to">
                <option value="">Jump to label...</option>
                {sortedLabels.map((label) => (
                  <option value={`label-${label.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>{label} ({releasesByLabel[label].length})</option>
                ))}
              </select>
              <svg class="label-dropdown-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </div>
        </header>

        {totalReleases === 0 ? (
          <div class="text-center py-20 bg-gradient-to-b from-gray-800 to-gray-900 rounded-2xl shadow-lg border-2 border-white">
            <div class="text-6xl mb-4">🎵</div>
            <h2 class="text-2xl font-bold text-white mb-2">No Releases Yet</h2>
            <p class="text-gray-300 mb-6">New releases coming soon!</p>
          </div>
        ) : (
          <div class="space-y-16">
            {sortedLabels.map((label, labelIdx) => (
              <section
                id={`label-${label.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
                class="label-section scroll-mt-24"
              >
                <!-- Label Header -->
                <div class="mb-6">
                  <div class="label-header">
                    <div class="label-title-row">
                      <div class="label-header-line"></div>
                      <h2 class="label-title">{label}</h2>
                      <div class="label-header-line"></div>
                    </div>
                    <p class="label-count">
                      {releasesByLabel[label].length} release{releasesByLabel[label].length !== 1 ? 's' : ''}
                    </p>
                    <div class="label-divider" aria-hidden="true">
                      <div class="label-divider-line"></div>
                      <div class="label-divider-diamond"></div>
                      <div class="label-divider-line"></div>
                    </div>
                  </div>

                  {/* Buy All Discography Button */}
                  {releasesByLabel[label].length > 1 && (
                    <div class="flex justify-center mt-3">
                      <button
                        class="buy-discography-btn flex items-center gap-2 px-5 py-3 bg-gradient-to-r from-green-600 to-green-700 hover:from-green-500 hover:to-green-600 text-white font-bold rounded-lg shadow-lg transition-colors text-sm"
                        data-label={label}
                        data-releases={JSON.stringify(releasesByLabel[label].map(r => ({
                          id: r.id,
                          title: r.releaseName || 'Untitled',
                          artist: r.artistName || 'Unknown Artist',
                          price: r.pricing?.digital || r.pricePerSale || 0,
                          artwork: r.coverArtUrl || '/place-holder.webp'
                        })))}
                        data-total-price={releasesByLabel[label].reduce((sum, r) => sum + (r.pricing?.digital || r.pricePerSale || 0), 0).toFixed(2)}
                      >
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                        </svg>
                        <span>Buy All ({releasesByLabel[label].length}) - £{releasesByLabel[label].reduce((sum, r) => sum + (r.pricing?.digital || r.pricePerSale || 0), 0).toFixed(2)}</span>
                      </button>
                    </div>
                  )}
                </div>

                <!-- Releases Grid -->
                <div class="space-y-6 w-full">
                  {releasesByLabel[label].map((release, rIdx) => (
                    <div
                      id={release.id}
                      class="release-item scroll-mt-24 w-full"
                    >
                      <ReleasePlate {...release} priority={label === sortedLabels[0] && rIdx === 0} />
                    </div>
                  ))}
                </div>
              </section>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>

  <Footer />

  <script>
    // Smooth scroll behavior for label links
    document.querySelectorAll('.label-nav-link').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = link.getAttribute('href').substring(1);
        const targetElement = document.getElementById(targetId);

        if (targetElement) {
          // Immediately highlight clicked link
          document.querySelectorAll('.label-nav-link').forEach(l => {
            l.classList.remove('bg-gradient-to-r', 'from-orange-700', 'to-orange-800', 'border-white', 'shadow-lg');
          });
          link.classList.add('bg-gradient-to-r', 'from-orange-700', 'to-orange-800', 'border-white', 'shadow-lg');

          targetElement.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });

    // Highlight active label in sidebar as user scrolls
    const observerOptions = {
      root: null,
      rootMargin: '-10% 0px -85% 0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          document.querySelectorAll('.label-nav-link').forEach(link => {
            link.classList.remove('bg-gradient-to-r', 'from-orange-700', 'to-orange-800', 'border-white', 'shadow-lg');
          });
          
          const activeLink = document.querySelector(`[data-label-id="${entry.target.id}"]`);
          if (activeLink) {
            activeLink.classList.add('bg-gradient-to-r', 'from-orange-700', 'to-orange-800', 'border-white', 'shadow-lg');
            
            activeLink.scrollIntoView({ 
              behavior: 'smooth',
              block: 'nearest'
            });
          }
        }
      });
    }, observerOptions);

    document.querySelectorAll('.label-section').forEach(section => {
      observer.observe(section);
    });

    // Cleanup observer on page navigation (Astro View Transitions)
    document.addEventListener('astro:before-swap', () => {
      observer.disconnect();
    }, { once: true });

    // Mobile label dropdown — use event delegation for View Transitions compatibility
    function initLabelDropdown() {
      var labelSelect = document.getElementById('label-select');
      if (labelSelect && !labelSelect.dataset.initialized) {
        labelSelect.dataset.initialized = 'true';
        labelSelect.addEventListener('change', function() {
          var val = this.value;
          if (!val) return;
          var el = document.getElementById(val);
          if (el) {
            // Close any open mobile menus/keyboards first
            this.blur();
            // Small delay to let keyboard dismiss on mobile before scrolling
            setTimeout(function() {
              el.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 150);
            labelSelect.value = '';
          }
        });
      }
    }
    initLabelDropdown();
    document.addEventListener('astro:page-load', initLabelDropdown);

    // Buy All Discography functionality — uses global FreshWaxCart from freshwax-cart.js

    document.querySelectorAll('.buy-discography-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();

        if (!window.FreshWaxCart || !FreshWaxCart.isLoggedIn()) {
          window.location.href = '/login/?redirect=' + encodeURIComponent(window.location.pathname);
          return;
        }

        const label = btn.getAttribute('data-label');
        var releasesData = [];
        try {
          releasesData = JSON.parse(btn.getAttribute('data-releases') || '[]');
        } catch (e) {
          showToast('Failed to load releases data', 'error');
          btn.disabled = false;
          return;
        }
        const totalPrice = parseFloat(btn.getAttribute('data-total-price') || '0');

        if (releasesData.length === 0) {
          showToast('No releases found for this label', 'error');
          return;
        }

        // Disable button during operation
        btn.disabled = true;
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg><span>Adding...</span>';

        const cart = FreshWaxCart.get();
        let items = cart.items || [];
        let addedCount = 0;
        let skippedCount = 0;

        for (const release of releasesData) {
          // Check if already in cart
          const existingIndex = items.findIndex(item =>
            item.id === release.id && (item.type === 'digital' || item.type === 'vinyl')
          );

          if (existingIndex !== -1) {
            skippedCount++;
            continue;
          }

          // Remove any single tracks from this release
          items = items.filter(item => !(item.id === release.id && item.type === 'track'));

          // Add the digital release
          items.push({
            id: release.id,
            releaseId: release.id,
            type: 'digital',
            format: 'digital',
            name: release.artist + ' - ' + release.title,
            title: release.title,
            artist: release.artist,
            price: release.price,
            image: release.artwork,
            artwork: release.artwork,
            quantity: 1,
            fromDiscography: true,
            label: label
          });

          addedCount++;
        }

        FreshWaxCart.save({items: items});
        FreshWaxCart.updateBadge();

        // Show success state
        btn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Added!</span>';
        btn.classList.remove('from-green-600', 'to-green-700');
        btn.classList.add('from-green-500', 'to-green-600');

        let message = `Added ${addedCount} release${addedCount !== 1 ? 's' : ''} from ${label} to cart!`;
        if (skippedCount > 0) {
          message += ` (${skippedCount} already in cart)`;
        }
        showToast(message);

        setTimeout(() => {
          btn.disabled = false;
          btn.innerHTML = originalHTML;
          btn.classList.remove('from-green-500', 'to-green-600');
          btn.classList.add('from-green-600', 'to-green-700');
        }, 800);
      });
    });
  </script>

  <style>
    .bg-image-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: #000;
      background-image: url('/freshwax-bg-releases.webp');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      opacity: 0;
      z-index: -1;
      pointer-events: none;
      filter: blur(3px) brightness(0.4);
      transform: scale(1.05);
      animation: bgFadeIn045 2s ease-out 0.3s forwards;
    }

    @media (min-width: 640px) {
      .bg-image-overlay {
        background-size: cover;
      }
    }

    /* Releases Header - column layout with title-row for line centering */
    .releases-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.35rem;
      padding: 1.75rem 1.5rem;
      background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.25) 50%, transparent 80%);
      margin-bottom: 0.5rem;
    }

    .releases-title-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      width: 100%;
    }

    .releases-header-line {
      flex: 1;
      height: 2px;
      background: linear-gradient(90deg, transparent, #dc2626, transparent);
      display: none;
    }

    .releases-title {
      font-family: 'Bebas Neue', 'Bebas Fallback', sans-serif;
      font-size: 2.5rem;
      font-weight: 400;
      color: #ffffff;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin: 0;
      line-height: 1;
      white-space: nowrap;
      text-shadow:
        0 0 20px rgba(0, 0, 0, 0.95),
        0 0 40px rgba(0, 0, 0, 0.8),
        0 2px 4px rgba(0, 0, 0, 0.9),
        0 0 60px rgba(220, 38, 38, 0.3);
    }

    /* Mobile: show short subtitle, hide long one */
    .releases-subtitle-desktop { display: none; }
    .releases-subtitle-mobile { display: block; color: rgba(255, 255, 255, 0.75); font-size: 0.8rem; margin: 0; font-weight: 400; letter-spacing: 0.05em; text-shadow: 0 0 8px rgba(0, 0, 0, 0.9), 0 1px 2px rgba(0, 0, 0, 0.8); }

    .releases-count {
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.85rem;
      margin: 0;
      font-weight: 400;
      letter-spacing: 0.05em;
      text-shadow: 0 0 8px rgba(0, 0, 0, 0.9), 0 1px 2px rgba(0, 0, 0, 0.8);
    }

    .releases-divider {
      height: 2px;
      width: 100%;
      background: linear-gradient(90deg, transparent, #dc2626, transparent);
      margin-top: 0.75rem;
    }

    @media (min-width: 640px) {
      .releases-header {
        gap: 0.35rem;
        padding: 2.5rem 3rem;
      }
      .releases-title-row {
        gap: 2rem;
      }
      .releases-header-line {
        display: block;
      }
      .releases-title {
        font-size: 4.5rem;
      }
      /* Desktop: show full subtitle, hide short one */
      .releases-subtitle-desktop { display: block; color: rgba(255, 255, 255, 0.75); font-size: 0.9rem; margin: 0; font-weight: 400; letter-spacing: 0.05em; text-shadow: 0 0 8px rgba(0, 0, 0, 0.9), 0 1px 2px rgba(0, 0, 0, 0.8); }
      .releases-subtitle-mobile { display: none; }
    }

    @media (min-width: 768px) {
      .releases-header {
        padding: 3rem 3rem;
      }
      .releases-title-row {
        gap: 2.5rem;
      }
      .releases-title {
        font-size: 6rem;
      }
    }

    /* Label Headers - column layout with title-row for line centering */
    .label-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.25rem;
      padding: 1.5rem 1.25rem;
      background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.2) 50%, transparent 80%);
    }

    .label-title-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.25rem;
      width: 100%;
    }

    .label-header-line {
      flex: 1;
      height: 2px;
      background: linear-gradient(90deg, transparent, rgba(220, 38, 38, 0.5), transparent);
      display: none;
    }

    .label-title {
      font-family: 'Bebas Neue', 'Bebas Fallback', sans-serif;
      font-size: 1.75rem;
      font-weight: 400;
      color: #ffffff;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin: 0;
      line-height: 1;
      text-shadow:
        0 0 16px rgba(0, 0, 0, 0.95),
        0 0 32px rgba(0, 0, 0, 0.8),
        0 2px 4px rgba(0, 0, 0, 0.9);
    }

    .label-count {
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.75rem;
      margin: 0;
      font-weight: 400;
      letter-spacing: 0.05em;
      text-shadow: 0 0 8px rgba(0, 0, 0, 0.9), 0 1px 2px rgba(0, 0, 0, 0.8);
    }

    @media (min-width: 640px) {
      .label-header {
        gap: 0.25rem;
        padding: 2rem 2rem;
      }
      .label-title-row {
        gap: 1.5rem;
      }
      .label-header-line {
        display: block;
      }
      .label-title {
        font-size: 2rem;
      }
    }

    @media (min-width: 768px) {
      .label-header {
        padding: 2.25rem 2.5rem;
      }
      .label-title-row {
        gap: 2rem;
      }
      .label-title {
        font-size: 2.5rem;
      }
    }

    /* Label Dropdown — sits below hero */
    .label-dropdown-wrap {
      display: block;
      margin-top: 1rem;
      text-align: center;
    }

    .label-dropdown-container {
      position: relative;
      max-width: 280px;
      margin: 0 auto;
    }

    .label-dropdown {
      width: 100%;
      appearance: none;
      -webkit-appearance: none;
      background: linear-gradient(135deg, rgba(0, 0, 0, 0.7), rgba(30, 30, 30, 0.9));
      border: 1px solid rgba(220, 38, 38, 0.4);
      border-radius: 0.75rem;
      color: #ffffff;
      font-family: 'Inter', sans-serif;
      font-size: 0.875rem;
      font-weight: 600;
      padding: 0.875rem 3rem 0.875rem 1.25rem;
      cursor: pointer;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .label-dropdown:focus:not(:focus-visible) {
      outline: none;
    }

    .label-dropdown:focus {
      border-color: #dc2626;
      box-shadow: 0 0 0 2px rgba(220, 38, 38, 0.3);
    }

    .label-dropdown:focus-visible {
      outline: 2px solid #60a5fa;
      outline-offset: 2px;
    }

    .label-dropdown option {
      background: #1a1a1a;
      color: #ffffff;
      padding: 0.5rem 1rem;
    }

    .label-dropdown-arrow {
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
      width: 1.25rem;
      height: 1.25rem;
      color: #dc2626;
      pointer-events: none;
    }

    @media (min-width: 1024px) {
      .label-dropdown-container {
        max-width: 350px;
      }
    }

    /* Label Divider — red lines + diamond */
    .label-divider {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.5rem 0 0 0;
      width: 100%;
    }

    .label-divider-line {
      flex: 1;
      height: 2px;
      background: linear-gradient(90deg, transparent, #dc2626, transparent);
      border-radius: 1px;
    }

    .label-divider-diamond {
      width: 8px;
      height: 8px;
      background: #dc2626;
      transform: rotate(45deg);
