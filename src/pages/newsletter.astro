---
// src/pages/newsletter.astro
// Public newsletter signup page

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=1800, stale-while-revalidate=3600');
---

<Layout title="Newsletter - New Releases & Offers" description="Subscribe to the Fresh Wax newsletter for new jungle and drum & bass releases, exclusive vinyl offers, and store updates.">
  <Header />

  <div class="min-h-screen bg-black pt-24 pb-16">
    <div class="max-w-2xl mx-auto px-4">

      <!-- Header -->
      <div class="text-center mb-12">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-br from-red-600 to-red-800 rounded-2xl mb-6">
          <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-white mb-4">Stay Fresh</h1>
        <p class="text-xl text-gray-300">
          Subscribe to our newsletter for the latest jungle & drum and bass releases, exclusive offers, and store updates.
        </p>
      </div>

      <!-- Confirmation Status Banner -->
      <div id="confirm-banner" class="hidden mb-6 p-4 rounded-lg text-center font-semibold"></div>

      <!-- Signup Form -->
      <div class="bg-gradient-to-br from-gray-900 to-gray-800 border border-gray-700 rounded-2xl p-8 md:p-10">
        <form id="newsletter-signup-form" class="space-y-6">
          <div>
            <label for="signup-name" class="block text-sm font-semibold text-gray-300 mb-2">Name (optional)</label>
            <input
              type="text"
              id="signup-name"
              placeholder="Your name"
              class="w-full px-4 py-3 bg-gray-800 border border-gray-600 text-white placeholder-gray-500 focus:outline-none focus:border-red-500 transition-colors rounded-lg"
            />
          </div>
          <div>
            <label for="signup-email" class="block text-sm font-semibold text-gray-300 mb-2">Email address *</label>
            <input
              type="email"
              id="signup-email"
              placeholder="your@email.com"
              required
              aria-required="true"
              class="w-full px-4 py-3 bg-gray-800 border border-gray-600 text-white placeholder-gray-500 focus:outline-none focus:border-red-500 transition-colors rounded-lg"
            />
          </div>
          <div>
            <label class="flex items-start gap-3 cursor-pointer">
              <input
                type="checkbox"
                id="signup-consent"
                required
                aria-required="true"
                class="mt-1 w-4 h-4 accent-red-600"
              />
              <span class="text-sm text-gray-300">
                I agree to receive marketing emails from Fresh Wax. You can unsubscribe at any time. <a href="/privacy/" class="text-red-500 hover:text-red-400 underline">Privacy Policy</a>
              </span>
            </label>
          </div>
          <button
            type="submit"
            id="signup-btn"
            class="w-full px-6 py-4 bg-red-600 text-white font-bold text-lg hover:bg-red-700 transition-colors rounded-lg"
          >
            Subscribe to Newsletter
          </button>
        </form>
        <p id="signup-message" class="mt-4 text-center hidden"></p>
      </div>

      <!-- What you'll get -->
      <div class="mt-12 grid md:grid-cols-3 gap-6">
        <div class="text-center p-6">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-gray-800 rounded-xl mb-4">
            <span class="text-2xl">🎵</span>
          </div>
          <h3 class="text-white font-bold mb-2">New Releases</h3>
          <p class="text-gray-300 text-sm">Be the first to hear about fresh jungle and D&B drops</p>
        </div>
        <div class="text-center p-6">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-gray-800 rounded-xl mb-4">
            <span class="text-2xl">🎁</span>
          </div>
          <h3 class="text-white font-bold mb-2">Exclusive Offers</h3>
          <p class="text-gray-300 text-sm">Subscriber-only discounts and early access</p>
        </div>
        <div class="text-center p-6">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-gray-800 rounded-xl mb-4">
            <span class="text-2xl">📻</span>
          </div>
          <h3 class="text-white font-bold mb-2">Live Events</h3>
          <p class="text-gray-300 text-sm">Updates on streams, shows, and community events</p>
        </div>
      </div>

    </div>
  </div>

  <Footer />
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    // Show confirmation status from redirect
    const params = new URLSearchParams(window.location.search);
    const banner = document.getElementById('confirm-banner');
    if (banner) {
      if (params.get('confirmed') === 'success') {
        banner.textContent = 'Your subscription is confirmed! Welcome to Fresh Wax.';
        banner.className = 'mb-6 p-4 rounded-lg text-center font-semibold bg-green-900/50 border border-green-700 text-green-400';
      } else if (params.get('confirmed') === 'already') {
        banner.textContent = 'You are already subscribed!';
        banner.className = 'mb-6 p-4 rounded-lg text-center font-semibold bg-blue-900/50 border border-blue-700 text-blue-400';
      } else if (params.get('error')) {
        banner.textContent = 'Something went wrong confirming your subscription. Please try subscribing again.';
        banner.className = 'mb-6 p-4 rounded-lg text-center font-semibold bg-red-900/50 border border-red-700 text-red-400';
      }
    }

    const form = document.getElementById('newsletter-signup-form');
    const nameInput = document.getElementById('signup-name') as HTMLInputElement;
    const emailInput = document.getElementById('signup-email') as HTMLInputElement;
    const consentInput = document.getElementById('signup-consent') as HTMLInputElement;
    const btn = document.getElementById('signup-btn') as HTMLButtonElement;
    const message = document.getElementById('signup-message') as HTMLParagraphElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Prevent double-submit
      if (btn.disabled) return;

      const email = emailInput?.value?.trim();
      const name = nameInput?.value?.trim();
      if (!email) return;

      if (!consentInput?.checked) {
        message.textContent = 'Please agree to receive marketing emails.';
        message.className = 'mt-4 text-center text-red-500';
        message.classList.remove('hidden');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Subscribing...';
      message.classList.add('hidden');

      try {
        const response = await fetch('/api/newsletter/subscribe/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, name, source: 'newsletter-page', consent: true })
        });

        if (!response.ok) throw new Error('Subscribe failed: ' + response.status);
        const data = await response.json();

        if (data.success) {
          message.textContent = data.message || 'Please check your email to confirm your subscription.';
          message.className = 'mt-4 text-center text-green-500 font-semibold';
          message.classList.remove('hidden');
          form.reset();
        } else {
          message.textContent = data.error || 'Failed to subscribe. Please try again.';
          message.className = 'mt-4 text-center text-red-500';
          message.classList.remove('hidden');
        }
      } catch (err) {
        message.textContent = 'Something went wrong. Please try again.';
        message.className = 'mt-4 text-center text-red-500';
        message.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Subscribe to Newsletter';
      }
    });
  });
</script>
